    private void GeneratePassword()
    {
        const string lower   = "abcdefghijklmnopqrstuvwxyz";
        const string upper   = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        const string digits  = "0123456789";
        const string special = "!@#$%^&*_+-=";
        var rng = new Random();
        var chars = new char[14];
        chars[0] = lower[rng.Next(lower.Length)];
        chars[1] = upper[rng.Next(upper.Length)];
        chars[2] = digits[rng.Next(digits.Length)];
        chars[3] = special[rng.Next(special.Length)];
        var all = lower + upper + digits + special;
        for (int i = 4; i < 14; i++) chars[i] = all[rng.Next(all.Length)];
        var pwd = new string(chars.OrderBy(_ => rng.Next()).ToArray());
        _password  = pwd;
        _password2 = pwd;
    }

