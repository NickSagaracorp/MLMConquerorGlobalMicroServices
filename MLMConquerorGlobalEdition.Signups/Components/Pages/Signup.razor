@page "/signup"
@page "/signup/{SponsorSlug}"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS

<!-- ── HEADER ─────────────────────────────────────────────────────────────── -->
<header class="enroll-header py-3">
    <div class="container d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-2">
            <span class="fw-bold fs-4 text-primary">MLM Conqueror</span>
        </div>
        <div class="d-flex align-items-center gap-1 text-muted small fw-semibold">
            <span>Secure Enrollment</span>
            <i class="ri-lock-2-line text-warning fs-5"></i>
        </div>
    </div>
    <div class="text-center mt-3">
        <h1 class="fw-bold text-primary mb-1">MLM Conqueror Enrollment</h1>
        <p class="text-muted mb-0">
            Your Sponsor is
            <span class="fw-semibold text-dark">@(_sponsor?.DisplayName ?? SponsorSlug ?? "—")</span>
        </p>
    </div>
</header>

<!-- ── MAIN ───────────────────────────────────────────────────────────────── -->
<div class="container">
    <div class="main-content d-flex flex-column p-0">
        <div class="m-auto m-1230">

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger mt-4 mb-0">@_error</div>
        }

        @if (_success)
        {
            <!-- SUCCESS -->
            <section class="section-card mt-enroll mb-5">
                <div class="section-body text-center py-5">
                    <i class="ri-checkbox-circle-line text-success" style="font-size:4rem"></i>
                    <h3 class="mt-3 mb-2">Welcome, @_completedEmail!</h3>
                    <p class="text-muted mb-4">Your account is active. You can now log in to your BizCenter.</p>
                    <a href="/login" class="btn btn-primary px-5">Go to BizCenter</a>
                </div>
            </section>
        }
        else
        {
            <!-- ── ENROLLMENT ────────────────────────────────────────────── -->
            <section class="section-card mt-enroll mb-5" id="enrollment">
                <div class="section-head">
                    <div class="section-icon"><i class="ri-award-line"></i></div>
                    <div>
                        <h4 class="mb-0">Enrollment</h4>
                        <p class="text-muted mb-0">You are enrolling as a Lifestyle Ambassador.</p>
                    </div>
                </div>
                <div class="section-body">
                    <label class="plan-card is-checked">
                        <input type="checkbox" class="plan-card__radio" checked disabled />
                        <div class="plan-card__body">
                            <div class="plan-card__title">
                                <div class="d-flex align-items-center gap-2">
                                    <h5 class="mb-0">@(_enrollmentProduct?.Name ?? "Lifestyle Ambassador")</h5>
                                    <span class="plan-selected-chip"><i class="ri-check-fill"></i> Included</span>
                                </div>
                                <small class="text-muted d-block">One-time enrollment</small>
                            </div>
                            <div class="row g-3 align-items-center mt-1">
                                <div class="col-lg-9">
                                    <p class="text-muted mb-0 small">
                                        @if (!string.IsNullOrEmpty(_enrollmentProduct?.Description))
                                        {
                                            @_enrollmentProduct.Description
                                        }
                                        else
                                        {
                                            @:You are enrolling as a Lifestyle Ambassador. This allows you to promote memberships,
                                            @:earn commissions from sales, and access the Biz Center with training, tools, and reports.
                                            @:Renewal applies annually.
                                        }
                                    </p>
                                </div>
                            </div>
                            <div class="row g-3 mt-4">
                                <div class="col-12">
                                    <span class="price-chip">@((_enrollmentProduct?.Price ?? 99m).ToString("C"))</span>
                                </div>
                            </div>
                        </div>
                    </label>
                </div>
            </section>

            <!-- ── SELECT YOUR MEMBERSHIP ────────────────────────────────── -->
            <section class="section-card mb-5" id="membership">
                <div class="section-head">
                    <div class="section-icon"><i class="ri-vip-crown-line"></i></div>
                    <div>
                        <h4 class="mb-0">Select your membership</h4>
                        <p class="text-muted mb-0">Choose the plan to access all benefits.</p>
                    </div>
                </div>
                <div class="section-body">
                    @if (_membershipProducts.Count == 0)
                    {
                        <div class="text-muted small py-2">Loading membership options…</div>
                    }
                    @foreach (var p in _membershipProducts)
                    {
                        <label class="plan-card mb-3 @(_selectedMembershipProductId == p.Id ? "is-checked" : "")"
                               @onclick="() => _selectedMembershipProductId = p.Id">
                            <input type="radio" class="plan-card__radio"
                                   name="membershipProduct"
                                   checked="@(_selectedMembershipProductId == p.Id)"
                                   @onchange="() => _selectedMembershipProductId = p.Id" />
                            <div class="plan-card__body">
                                <div class="plan-card__title">
                                    <div class="d-flex align-items-center gap-2">
                                        <h5 class="mb-0">@p.Name</h5>
                                        <span class="plan-selected-chip"><i class="ri-check-fill"></i> Selected</span>
                                    </div>
                                    <small class="text-muted d-block">@p.Price.ToString("C") / month</small>
                                </div>

                                <div class="row g-3 align-items-center mt-1">
                                    <div class="col-lg-9">
                                        @if (!string.IsNullOrEmpty(p.Description))
                                        {
                                            <p class="text-muted mb-0 small">@p.Description</p>
                                        }
                                        else
                                        {
                                            <p class="text-muted mb-0 small">
                                                Access exclusive travel benefits, loyalty points, and member-only deals worldwide.
                                            </p>
                                        }
                                    </div>
                                    <div class="col-lg-3 text-lg-end">
                                        <img src="@GetProductImageUrl(p.Id)"
                                             class="img-fluid rounded-3 shadow-sm"
                                             alt="@p.Name"
                                             onerror="this.style.display='none'" />
                                    </div>
                                </div>

                                <div class="row g-3 mt-4">
                                    <div class="col-12">
                                        <span class="price-chip">@p.Price.ToString("C")</span>
                                    </div>
                                </div>
                            </div>
                        </label>
                    }
                </div>
            </section>

            <!-- ── PERSONAL / BUSINESS INFO ──────────────────────────────── -->
            <section class="section-card mb-5">
                <div class="section-head">
                    <div class="section-icon"><i class="ri-user-3-line"></i></div>
                    <div>
                        <h4 class="mb-0">Personal / Business Info</h4>
                        <p class="text-muted mb-0">Tell us a bit about yourself. These details stay private.</p>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="First Name"
                                       value="@_firstName" @oninput="e => _firstName = e.Value?.ToString() ?? string.Empty" />
                                <label>First Name *</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Last Name"
                                       value="@_lastName" @oninput="e => _lastName = e.Value?.ToString() ?? string.Empty" />
                                <label>Last Name *</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="date" class="form-control" @bind="_dateOfBirth"
                                       max="@_maxDob" />
                                <label>Date of Birth *</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="SSN" @bind="_ssn" />
                                <label>SSN</label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div>
                            <p class="mb-0 fw-semibold">Enrolling as a business?</p>
                            <small class="text-muted">Toggle to add company details.</small>
                        </div>
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input" type="checkbox" @bind="_showBusiness" />
                            <label class="form-check-label">Yes</label>
                        </div>
                    </div>

                    @if (_showBusiness)
                    {
                        <div class="row g-3 mt-2">
                            <div class="col-md-8">
                                <div class="form-floating">
                                    <input type="text" class="form-control" placeholder="Business Name" @bind="_businessName" />
                                    <label>Business Name</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input type="text" class="form-control" placeholder="EIN" @bind="_ein" />
                                    <label>EIN</label>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- ── CONTACT INFO ───────────────────────────────────────────── -->
            <section class="section-card mb-5" id="contact-info">
                <div class="section-head">
                    <div class="section-icon"><i class="ri-contacts-book-2-line"></i></div>
                    <div>
                        <h4 class="mb-0">Contact Info</h4>
                        <p class="text-muted mb-0">How can we reach you? Use a valid email and phone.</p>
                    </div>
                </div>
                <div class="section-body">
                    <div class="row g-3">
                        <!-- WhatsApp -->
                        <div class="col-md-6">
                            <label class="form-label text-secondary">WhatsApp</label>
                            <div class="input-group country-line">
                                <select class="form-select country-code" @bind="_waCountryCode">
                                    @foreach (var c in _countryCodes)
                                    {
                                        <option value="@c.Code">@c.Flag @c.Code</option>
                                    }
                                </select>
                                <input type="tel" class="form-control" placeholder="9XXXXXXXX" @bind="_whatsApp" />
                            </div>
                        </div>
                        <!-- Cell Phone -->
                        <div class="col-md-6">
                            <label class="form-label text-secondary">Cell Phone</label>
                            <div class="input-group country-line">
                                <select class="form-select country-code" @bind="_cellCountryCode">
                                    @foreach (var c in _countryCodes)
                                    {
                                        <option value="@c.Code">@c.Flag @c.Code</option>
                                    }
                                </select>
                                <input type="tel" class="form-control" placeholder="9XXXXXXXX" @bind="_cellPhone" />
                            </div>
                        </div>
                        <!-- Email -->
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="email" class="form-control @(_emailMismatch ? "is-invalid" : "")"
                                       placeholder="name@example.com"
                                       value="@_email"
                                       @oninput="OnEmailInput" />
                                <label>Email *</label>
                                <div class="invalid-feedback">Please enter a valid email.</div>
                            </div>
                        </div>
                        <!-- Confirm Email -->
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="email" class="form-control @(_emailMismatch ? "is-invalid" : "")"
                                       placeholder="Repeat email"
                                       value="@_email2"
                                       @oninput="OnEmail2Input" />
                                <label>Verify Email *</label>
                                <div class="invalid-feedback">Emails do not match.</div>
                            </div>
                        </div>
                        <!-- Address -->
                        <div class="col-md-8">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Address line" @bind="_address" />
                                <label>Address</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="City" @bind="_city" />
                                <label>City</label>
                            </div>
                        </div>
                        <!-- Country -->
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select class="form-select"
                                        value="@_country"
                                        @onchange="e => { _country = e.Value?.ToString() ?? string.Empty; _province = string.Empty; }">
                                    <option value="">— Select —</option>
                                    @foreach (var ct in _countryList)
                                    {
                                        <option value="@ct.Code">@ct.Name</option>
                                    }
                                </select>
                                <label>Country</label>
                            </div>
                        </div>
                        <!-- Postal Code -->
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Postal Code" @bind="_postalCode" />
                                <label>Postal Code</label>
                            </div>
                        </div>
                        <!-- Province / State -->
                        <div class="col-md-3">
                            <div class="form-floating">
                                <select class="form-select" @bind="_province">
                                    <option value="">— Select —</option>
                                    @foreach (var p in GetProvinces(_country))
                                    {
                                        <option value="@p">@p</option>
                                    }
                                </select>
                                <label>Province / State</label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <!-- Billing same? -->
                    <div class="row g-3 align-items-center">
                        <div class="col-lg-6">
                            <p class="mb-0 fw-semibold">Is your billing address the same as this Contact Info?</p>
                        </div>
                        <div class="col-lg-6">
                            <div class="d-flex align-items-center gap-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="billingSame"
                                           checked="@_billingSame" @onchange="() => _billingSame = true" />
                                    <label class="form-check-label">Yes</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="billingSame"
                                           checked="@(!_billingSame)" @onchange="() => _billingSame = false" />
                                    <label class="form-check-label">No</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!_billingSame)
                    {
                        <div class="row g-3 mt-2">
                            <div class="col-12 d-flex justify-content-end">
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CopyContactToBilling">
                                    Copy from contact
                                </button>
                            </div>
                            <div class="col-md-8">
                                <div class="form-floating">
                                    <input type="text" class="form-control" placeholder="Billing Address" @bind="_billAddress" />
                                    <label>Billing Address</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-floating">
                                    <input type="text" class="form-control" placeholder="City" @bind="_billCity" />
                                    <label>City</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select class="form-select" @bind="_billCountry">
                                        <option value="">— Select —</option>
                                        @foreach (var ct in _countryList)
                                        {
                                            <option value="@ct.Code">@ct.Name</option>
                                        }
                                    </select>
                                    <label>Country</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <input type="text" class="form-control" placeholder="Postal Code" @bind="_billPostal" />
                                    <label>Postal Code</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-floating">
                                    <select class="form-select" @bind="_billProvince">
                                        <option value="">— Select —</option>
                                        @foreach (var p in GetProvinces(_billCountry))
                                        {
                                            <option value="@p">@p</option>
                                        }
                                    </select>
                                    <label>Province / State</label>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- ── WEBSITE NAME & PASSWORD ────────────────────────────────── -->
            <section class="section-card mb-5" id="website-pass">
                <div class="section-head">
                    <div class="section-icon"><i class="ri-lock-2-line"></i></div>
                    <div>
                        <h4 class="mb-0">Website Name and Password</h4>
                        <p class="text-muted mb-0">
                            Choose the name that comes after <strong>www.mlmconqueror.com/</strong> and set a secure password.
                        </p>
                    </div>
                </div>
                <div class="section-body">
                    <div class="mb-2">
                        <small class="text-muted">
                            Your Website Name can use letters or numbers only (no spaces). Example: <code>johndoe</code>, <code>myshop23</code>.
                        </small>
                    </div>
                    <div class="row g-3 align-items-start">
                        <div class="col-12">
                            <label class="form-label text-secondary">Website URL</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">www.mlmconqueror.com/</span>
                                <input type="text" class="form-control" placeholder="yourname" maxlength="30" autocomplete="off"
                                       value="@_siteHandle" @oninput="OnHandleInput" />
                            </div>
                            <div class="d-flex gap-3 mt-2 align-items-center">
                                <small class="text-muted">Only letters and numbers. Lowercased automatically.</small>
                                <small class="fw-semibold @_slugStatusClass">@_slugStatusMsg</small>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-secondary">Password</label>
                            <div class="input-group">
                                <input type="@(_showPwd ? "text" : "password")" class="form-control"
                                       placeholder="Create a password"
                                       value="@_password"
                                       @oninput="OnPasswordInput" />
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => _showPwd = !_showPwd">
                                    <i class="@(_showPwd ? "ri-eye-off-line" : "ri-eye-line")"></i>
                                </button>
                            </div>
                            <div class="mt-2">
                                <div class="progress" style="height:8px">
                                    <div class="progress-bar @PwdStrengthClass" role="progressbar"
                                         style="width:@(PwdStrengthPct)%"></div>
                                </div>
                                <small class="text-muted">Strength: @PwdStrengthLabel</small>
                            </div>
                            <ul class="mt-2 mb-0 small text-muted" style="line-height:1.3">
                                <li>Min. 8 characters</li>
                                <li>Use upper &amp; lower case</li>
                                <li>Add numbers and a symbol</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary">Confirm Password</label>
                            <div class="input-group">
                                <input type="@(_showPwd2 ? "text" : "password")"
                                       class="form-control @(PasswordMismatch ? "is-invalid" : "")"
                                       placeholder="Repeat password"
                                       value="@_password2"
                                       @oninput="OnPassword2Input" />
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => _showPwd2 = !_showPwd2">
                                    <i class="@(_showPwd2 ? "ri-eye-off-line" : "ri-eye-line")"></i>
                                </button>
                                <div class="invalid-feedback">Passwords do not match.</div>
                            </div>
                            <div class="d-flex gap-2 mt-3">
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="GeneratePassword">
                                    Generate strong password
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CopyPassword">
                                    @_copyBtnText
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- ── PAYMENT INFO ───────────────────────────────────────────── -->
            <section class="section-card mb-5" id="payment-info">
                <div class="section-head">
                    <div class="section-icon"><i class="ri-bank-card-line"></i></div>
                    <div>
                        <h4 class="mb-0">Payment Info</h4>
                        <p class="text-muted mb-0">Choose a payment method and complete your enrollment.</p>
                    </div>
                </div>
                <div class="section-body">

                    <!-- Coupon -->
                    <div class="row g-3 align-items-end mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-secondary" for="couponCode">Coupon Code</label>
                            <input type="text" class="form-control" id="couponCode" placeholder="Enter coupon" @bind="_couponCode" />
                        </div>
                        <div class="col-md-3">
                            <button type="button" class="btn btn-outline-secondary w-100" @onclick="ApplyCoupon">Apply</button>
                        </div>
                        <div class="col-md-3">
                            <div class="small @_couponMsgClass">@_couponMsg</div>
                        </div>
                    </div>

                    <!-- Tabs -->
                    <ul class="nav nav-pills pay-tabs mb-3" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(_paymentTab == "card" ? "active" : "")" type="button"
                                    @onclick='() => _paymentTab = "card"'>
                                <i class="ri-bank-card-2-line me-1"></i> Credit Card
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(_paymentTab == "token" ? "active" : "")" type="button"
                                    @onclick='() => _paymentTab = "token"'>
                                <i class="ri-key-line me-1"></i> Token
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(_paymentTab == "crypto" ? "active" : "")" type="button"
                                    @onclick='() => _paymentTab = "crypto"'>
                                <i class="ri-bit-coin-line me-1"></i> Crypto
                            </button>
                        </li>
                    </ul>

                    <!-- Credit Card -->
                    @if (_paymentTab == "card")
                    {
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" class="form-control" placeholder="First Name" @bind="_ccFirst" />
                                    <label>First Name</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" class="form-control" placeholder="Last Name" @bind="_ccLast" />
                                    <label>Last Name</label>
                                </div>
                            </div>
                            <div class="col-lg-8">
                                <label class="form-label text-secondary">Card Number</label>
                                <div class="input-group">
                                    <input type="@(_showCcNum ? "text" : "password")" class="form-control"
                                           inputmode="numeric" placeholder="1234 5678 9012 3456"
                                           value="@_ccNumber" @oninput="e => _ccNumber = e.Value?.ToString() ?? string.Empty" />
                                    <span class="input-group-text bg-light" id="ccBrand">@DetectCardBrand()</span>
                                    <button class="btn btn-outline-secondary" type="button" @onclick="() => _showCcNum = !_showCcNum">
                                        <i class="@(_showCcNum ? "ri-eye-off-line" : "ri-eye-line")"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <label class="form-label text-secondary">CCV / CVV</label>
                                <div class="input-group">
                                    <input type="@(_showCcv ? "text" : "password")" class="form-control"
                                           inputmode="numeric" placeholder="123" @bind="_ccCvv" />
                                    <button class="btn btn-outline-secondary" type="button" @onclick="() => _showCcv = !_showCcv">
                                        <i class="@(_showCcv ? "ri-eye-off-line" : "ri-eye-line")"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-secondary">Expiration</label>
                                <div class="row g-2">
                                    <div class="col-6">
                                        <select class="form-select" @bind="_ccExpMonth">
                                            <option value="0">Month</option>
                                            @for (int m = 1; m <= 12; m++)
                                            {
                                                var mo = m;
                                                <option value="@mo">@mo.ToString("D2")</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <select class="form-select" @bind="_ccExpYear">
