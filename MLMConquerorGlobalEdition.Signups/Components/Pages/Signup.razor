    private async Task HandleJoinNow()
    {
        _error = string.Empty;

        if (string.IsNullOrWhiteSpace(_firstName) || string.IsNullOrWhiteSpace(_lastName))
            { _error = "First and last name are required."; return; }
        if (string.IsNullOrWhiteSpace(_email))
            { _error = "Email is required."; return; }
        if (!_email.Equals(_email2, StringComparison.OrdinalIgnoreCase))
            { _error = "Email addresses do not match."; return; }
        if (string.IsNullOrEmpty(_selectedMembershipProductId))
            { _error = "Please select a membership plan."; return; }
        if (_dateOfBirth == default || _dateOfBirth > DateTime.Today.AddYears(-18))
            { _error = "You must be at least 18 years old."; return; }
        if (string.IsNullOrWhiteSpace(_password))
            { _error = "Password is required."; return; }
        if (_password != _password2)
            { _error = "Passwords do not match."; return; }

        _busy = true;
        try
        {
            var api   = HttpFactory.CreateClient("SignupsInternal");
            var phone = string.IsNullOrWhiteSpace(_cellPhone)
                ? null
                : $"{_cellCountryCode}{_cellPhone}";

            // Step 1: Create ambassador account
            var r1 = await api.PostAsJsonAsync("api/v1/signups/ambassador", new
            {
                SponsorMemberId   = _sponsor?.MemberId ?? SponsorSlug,
                FirstName         = _firstName,
                LastName          = _lastName,
                DateOfBirth       = _dateOfBirth,
                Email             = _email,
                Password          = _password,
                ConfirmPassword   = _password2,
                Phone             = phone,
                Country           = _country,
                ReplicateSiteSlug = _siteHandle,
                MembershipLevelId = _defaultLevelId
            });
            var b1 = await r1.Content.ReadFromJsonAsync<ApiWrapper<SignupResponseModel>>();
            if (b1?.Success != true || b1.Data is null)
            {
                _error = b1?.Message ?? b1?.Errors?.FirstOrDefault() ?? "Signup failed. Please check your details.";
                return;
            }
            _signupId = b1.Data.SignupId;

            // Step 2: Select membership product
            if (!string.IsNullOrEmpty(_selectedMembershipProductId))
            {
                var productIds = new List<string> { _selectedMembershipProductId };
                if (_enrollmentProduct != null) productIds.Insert(0, _enrollmentProduct.Id);
                var r2 = await api.PostAsJsonAsync(
                    $"api/v1/signups/{_signupId}/select-products",
                    new { ProductIds = productIds });
                var b2 = await r2.Content.ReadFromJsonAsync<ApiWrapper<bool>>();
                if (b2?.Success != true)
                {
                    _error = b2?.Message ?? "Product selection failed.";
                    return;
                }
            }

            // Step 3: Complete with payment
            object payment = _paymentTab switch
            {
                "card" => new
                {
                    PaymentMethod = "CreditCard",
                    CreditCard = new
                    {
                        GatewayToken = "manual",
                        Last4        = _ccNumber.Replace(" ", "").Length >= 4
                                       ? _ccNumber.Replace(" ", "")[^4..]
                                       : string.Empty,
                        First6       = _ccNumber.Replace(" ", "").Length >= 6
                                       ? _ccNumber.Replace(" ", "")[..6]
                                       : string.Empty,
                        CardBrand    = DetectCardBrand(),
                        ExpiryMonth  = _ccExpMonth,
                        ExpiryYear   = _ccExpYear,
                        Gateway      = "Stripe"
                    }
                },
                "token"  => new { PaymentMethod = "Token",  TokenCode = _payToken },
                "crypto" => new { PaymentMethod = "Crypto", CryptoCurrency = "BTC" },
                _        => (object)new { PaymentMethod = "CreditCard" }
            };

            var r3 = await api.PostAsJsonAsync($"api/v1/signups/{_signupId}/complete", payment);
            var b3 = await r3.Content.ReadFromJsonAsync<ApiWrapper<SignupResponseModel>>();

            if (b3?.Success == true && b3.Data is not null)
            {
                _completedEmail = b3.Data.Email;
                _success = true;
            }
            else
            {
                _error = b3?.Message ?? b3?.Errors?.FirstOrDefault() ?? "Could not complete enrollment.";
            }
        }
        catch (Exception ex) { _error = $"Connection error: {ex.Message}"; }
        finally { _busy = false; }
    }

    // ── Local models ──────────────────────────────────────────────────────────
    private record ApiWrapper<T>(bool Success, T? Data, string? Message, List<string>? Errors);
    private record SponsorModel(string MemberId, string DisplayName, string FullName, string? ReplicateSiteSlug);
    private record MembershipLevelModel(int Id, string Name, string? Description, decimal Price, decimal RenewalPrice, bool IsFree);
    private record ProductModel(string Id, string Name, string? Description, decimal Price, string? Sku, bool CorporateFee, bool JoinPageMembership);
    private record SignupResponseModel(string SignupId, string MemberId, string Email, string MemberType,
        DateTime EnrollDate, string? AccessToken, string? RefreshToken, DateTime? TokenExpiry);
}
