# ============================================================
# MLMConquerorGlobalEdition — Environment Variables Reference
# Copy this file to .env (NEVER commit .env to source control)
# Set these as environment variables in production via AWS
# Secrets Manager, Azure Key Vault, or Docker Secrets.
# ============================================================

# ── SQL Server (Production) ──────────────────────────────────
# Format: Server=HOST,PORT;Database=DB;User Id=USER;Password=PASS;...
ADMINAPI__CONNECTIONSTRINGS__DEFAULTCONNECTION=
ADMINAPI__CONNECTIONSTRINGS__REDIS=
BIZCENTER__CONNECTIONSTRINGS__DEFAULTCONNECTION=
BIZCENTER__CONNECTIONSTRINGS__HANGFIRE=
BIZCENTER__CONNECTIONSTRINGS__REDIS=
SIGNUPAPI__CONNECTIONSTRINGS__DEFAULTCONNECTION=
SIGNUPAPI__CONNECTIONSTRINGS__HANGFIRE=

# ── JWT RSA Keys (RS256 asymmetric signing) ──────────────────
# Generate key pair:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in jwt_private.pem -out jwt_private_pkcs8.pem
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
#   base64 -w 0 jwt_private_pkcs8.pem   → paste into PRIVATE_KEY vars below
#   base64 -w 0 jwt_public.pem          → paste into PUBLIC_KEY vars below
#
# PRIVATE KEY (used by AdminAPI + SignupAPI to sign tokens):
ADMINAPI__JWT__PRIVATEKEYBASE64=
SIGNUPAPI__JWT__PRIVATEKEYBASE64=
#
# PUBLIC KEY (used by ALL APIs to validate tokens):
ADMINAPI__JWT__PUBLICKEYBASE64=
BIZCENTER__JWT__PUBLICKEYBASE64=
SIGNUPAPI__JWT__PUBLICKEYBASE64=

# ── Root Ambassador Seed (only for initial deployment) ──────
SIGNUPAPI__ROOTAMBASSADOR__EMAIL=
SIGNUPAPI__ROOTAMBASSADOR__PASSWORD=

# ── Firebase ─────────────────────────────────────────────────
BIZCENTER__FIREBASE__PROJECTID=
BIZCENTER__FIREBASE__CREDENTIALSFILEPATH=

# ── CORS Origins (comma-separated production domains) ────────
# Example: https://app.mlmconqueror.com,https://admin.mlmconqueror.com
ADMINAPI__CORS__ALLOWEDORIGINS__0=
BIZCENTER__CORS__ALLOWEDORIGINS__0=
SIGNUPAPI__CORS__ALLOWEDORIGINS__0=

# ── Allowed Hosts (production hostnames only) ────────────────
# Example: app.mlmconqueror.com;admin.mlmconqueror.com
ADMINAPI__ALLOWEDHOSTS=
BIZCENTER__ALLOWEDHOSTS=
SIGNUPAPI__ALLOWEDHOSTS=
