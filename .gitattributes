# Normalize line endings to LF on commit, checkout as-is on Windows
* text=auto eol=lf

# Force binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.nupkg binary
