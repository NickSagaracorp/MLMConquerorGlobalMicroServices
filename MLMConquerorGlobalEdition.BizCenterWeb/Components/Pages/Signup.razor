@page "/signup"
@page "/signup/{SponsorSlug}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout MLMConquerorGlobalEdition.SharedComponents.Components.Layout.BlankLayout
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Localization.IStringLocalizer<MLMConquerorGlobalEdition.SharedComponents.Resources.SharedResources> L

<PageTitle>@L["PageTitle.Signup"]</PageTitle>

@{
    var api = HttpFactory.CreateClient("SignupsApi");
}

<div class="signup-wrapper">
    <div class="signup-card">

        <div class="signup-logo">
            <h2>@L["Signup.BrandTitle"]</h2>
            <p class="text-muted">@L["Signup.BrandSubtitle"]</p>
        </div>

        <!-- Progress bar -->
        <div class="progress-steps mb-4">
            <div class="step @(Step >= 1 ? "active" : "") @(Step > 1 ? "done" : "")">
                <span class="step-dot">@(Step > 1 ? "✓" : "1")</span>
                <span class="step-label">@L["Signup.StepPersonal"]</span>
            </div>
            <div class="step-line"></div>
            <div class="step @(Step >= 2 ? "active" : "") @(Step > 2 ? "done" : "")">
                <span class="step-dot">@(Step > 2 ? "✓" : "2")</span>
                <span class="step-label">@L["Signup.StepProducts"]</span>
            </div>
            <div class="step-line"></div>
            <div class="step @(Step >= 3 ? "active" : "")">
                <span class="step-dot">3</span>
                <span class="step-label">@L["Signup.StepPayment"]</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        <!-- ── STEP 1 ─────────────────────────────────────────────────────── -->
        @if (Step == 1)
        {
            @if (_sponsor is not null)
            {
                <div class="sponsor-banner mb-3">
                    <span class="badge bg-success me-2">@L["Signup.SponsorBadge"]</span>
                    <strong>@_sponsor.DisplayName</strong>
                </div>
            }

            <div class="row g-2 mb-2">
                <div class="col-6">
                    <label class="form-label">@L["Signup.FirstName"] *</label>
                    <input class="form-control" @bind="_form.FirstName" />
                </div>
                <div class="col-6">
                    <label class="form-label">@L["Signup.LastName"] *</label>
                    <input class="form-control" @bind="_form.LastName" />
                </div>
            </div>
            <div class="mb-2">
                <label class="form-label">@L["Signup.Email"] *</label>
                <input class="form-control" type="email" @bind="_form.Email" />
            </div>
            <div class="row g-2 mb-2">
                <div class="col-6">
                    <label class="form-label">@L["Signup.Password"] *</label>
                    <input class="form-control" type="password" @bind="_form.Password" />
                </div>
                <div class="col-6">
                    <label class="form-label">@L["Signup.ConfirmPassword"] *</label>
                    <input class="form-control" type="password" @bind="_form.ConfirmPassword" />
                </div>
            </div>
            <div class="row g-2 mb-2">
                <div class="col-6">
                    <label class="form-label">@L["Signup.DateOfBirth"] *</label>
                    <input class="form-control" type="date" @bind="_form.DateOfBirth" />
                </div>
                <div class="col-6">
                    <label class="form-label">@L["Signup.Country"] *</label>
                    <input class="form-control" @bind="_form.Country" placeholder="US" />
                </div>
            </div>
            <div class="mb-2">
                <label class="form-label">@L["Signup.Phone"]</label>
                <input class="form-control" @bind="_form.Phone" placeholder="+1 555 000 0000" />
            </div>
            <div class="mb-2">
                <label class="form-label">@L["Signup.ReplicateSlug"]</label>
                <input class="form-control" @bind="_form.ReplicateSiteSlug" placeholder="@L["Signup.ReplicateSlugPlaceholder"]" />
            </div>
            <div class="mb-3">
                <label class="form-label">@L["Signup.MembershipLevel"] *</label>
                @if (_levels.Count == 0)
                {
                    <div class="text-muted small">@L["Signup.LoadingLevels"]</div>
                }
                else
                {
                    <select class="form-select" @bind="_form.MembershipLevelId">
                        <option value="0">@L["Signup.SelectLevel"]</option>
                        @foreach (var lvl in _levels)
                        {
                            <option value="@lvl.Id">@lvl.Name — $@lvl.Price.ToString("N2")</option>
                        }
                    </select>
                }
            </div>
            <button class="btn btn-primary w-100" disabled="@_busy" @onclick="HandleStep1">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                @L["Signup.Continue"]
            </button>
        }

        <!-- ── STEP 2 ─────────────────────────────────────────────────────── -->
        @if (Step == 2)
        {
            <p class="text-muted small mb-3">@L["Signup.ProductsIntro"]</p>

            @if (_products.Count == 0)
            {
                <div class="alert alert-info">@L["Signup.NoProducts"]</div>
            }
            else
            {
                @foreach (var p in _products)
                {
                    <div class="product-card @(_selectedProductIds.Contains(p.Id) ? "selected" : "")"
                         @onclick="() => ToggleProduct(p.Id)">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@p.Name</strong>
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <div class="text-muted small">@p.Description</div>
                                }
                            </div>
                            <span class="badge bg-primary">$@p.Price.ToString("N2")</span>
                        </div>
                    </div>
                }
            }

            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-outline-secondary flex-fill" @onclick="() => Step = 1">@L["Signup.Back"]</button>
                <button class="btn btn-primary flex-fill" disabled="@_busy" @onclick="HandleStep2">
                    @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    @L["Signup.Continue"]
                </button>
            </div>
        }

        <!-- ── STEP 3 ─────────────────────────────────────────────────────── -->
        @if (Step == 3)
        {
            <div class="mb-3">
                <label class="form-label">@L["Signup.PaymentMethod"] *</label>
                <select class="form-select" @bind="_paymentMethod">
                    <option value="CreditCard">@L["Signup.PaymentCreditCard"]</option>
                    <option value="Crypto">@L["Signup.PaymentCrypto"]</option>
                    <option value="Token">@L["Signup.PaymentToken"]</option>
                    <option value="DiscountCode">@L["Signup.PaymentDiscount"]</option>
                </select>
            </div>

            @if (_paymentMethod == "CreditCard")
            {
                <div class="mb-2">
                    <label class="form-label">@L["Signup.GatewayToken"] *</label>
                    <input class="form-control" @bind="_cc.GatewayToken" placeholder="tok_..." />
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-4">
                        <label class="form-label">@L["Signup.First6"]</label>
                        <input class="form-control" @bind="_cc.First6" placeholder="411111" maxlength="6" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">@L["Signup.Last4"] *</label>
                        <input class="form-control" @bind="_cc.Last4" placeholder="1111" maxlength="4" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">@L["Signup.CardBrand"]</label>
                        <input class="form-control" @bind="_cc.CardBrand" placeholder="Visa" />
                    </div>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-4">
                        <label class="form-label">@L["Signup.ExpMonth"]</label>
                        <input class="form-control" type="number" @bind="_cc.ExpiryMonth" placeholder="12" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">@L["Signup.ExpYear"]</label>
                        <input class="form-control" type="number" @bind="_cc.ExpiryYear" placeholder="2028" />
                    </div>
                    <div class="col-4">
                        <label class="form-label">@L["Signup.Gateway"]</label>
                        <input class="form-control" @bind="_cc.Gateway" placeholder="Stripe" />
                    </div>
                </div>
            }

            @if (_paymentMethod == "Crypto")
            {
                <div class="mb-2">
                    <label class="form-label">@L["Signup.Cryptocurrency"]</label>
                    <input class="form-control" @bind="_cryptoCurrency" placeholder="BTC, ETH…" />
                </div>
                <div class="mb-2">
                    <label class="form-label">@L["Signup.TransactionId"] *</label>
                    <input class="form-control" @bind="_cryptoTxId" placeholder="0xabc..." />
                </div>
            }

            @if (_paymentMethod == "Token")
            {
                <div class="mb-2">
                    <label class="form-label">@L["Signup.TokenCode"] *</label>
                    <input class="form-control" @bind="_tokenCode" placeholder="TOKEN-XXXX-XXXX" />
                </div>
            }

            @if (_paymentMethod == "DiscountCode")
            {
                <div class="mb-2">
                    <label class="form-label">@L["Signup.DiscountCode"] *</label>
                    <input class="form-control" @bind="_discountCode" placeholder="PROMO2026" />
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-outline-secondary flex-fill" @onclick="() => Step = 2">@L["Signup.Back"]</button>
                <button class="btn btn-success flex-fill" disabled="@_busy" @onclick="HandleStep3">
                    @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    @L["Signup.CompleteSignup"]
                </button>
            </div>
        }

        <!-- ── SUCCESS ───────────────────────────────────────────────────── -->
        @if (Step == 4)
        {
            <div class="text-center py-4">
                <div class="display-4 mb-3">🎉</div>
                <h4>@string.Format(L["Signup.Welcome"], _completedEmail)</h4>
                <p class="text-muted">@((MarkupString)L["Signup.AccountActive"].Value)</p>
            </div>
        }

        @if (Step < 4)
        {
            <div class="mt-3 text-center">
                <a href="/login" class="text-muted small">@L["Signup.AlreadyHaveAccount"]</a>
            </div>
        }

    </div>
</div>

<style>
    .signup-wrapper { display:flex; justify-content:center; align-items:flex-start; min-height:100vh; background:#f0f2f5; padding:2rem 1rem; }
    .signup-card { background:white; padding:2rem; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,.08); width:100%; max-width:560px; }
    .signup-logo { text-align:center; margin-bottom:1.5rem; }
    .progress-steps { display:flex; align-items:center; justify-content:center; }
    .step { display:flex; flex-direction:column; align-items:center; gap:4px; }
    .step-dot { width:32px; height:32px; border-radius:50%; background:#dee2e6; color:#6c757d; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:600; }
    .step.active .step-dot { background:#0d6efd; color:white; }
    .step.done   .step-dot { background:#198754; color:white; }
    .step-label { font-size:11px; color:#6c757d; }
    .step.active .step-label { color:#0d6efd; font-weight:600; }
    .step-line { flex:1; height:2px; background:#dee2e6; margin:0 8px 20px; }
    .sponsor-banner { background:#d1e7dd; border-radius:8px; padding:.5rem .75rem; font-size:.9rem; }
    .product-card { border:2px solid #dee2e6; border-radius:8px; padding:.75rem 1rem; margin-bottom:.5rem; cursor:pointer; transition:border-color .15s, background .15s; }
    .product-card:hover   { border-color:#0d6efd; background:#f8f9ff; }
    .product-card.selected { border-color:#0d6efd; background:#e7efff; }
</style>

@code {
    [Parameter] public string? SponsorSlug { get; set; }

    private int    Step   = 1;
    private bool   _busy;
    private string _error = string.Empty;

    private SignupFormModel          _form   = new();
    private List<MembershipLevelModel> _levels   = new();
    private SponsorModel?            _sponsor;
    private string?                  _signupId;

    private List<ProductModel>   _products          = new();
    private HashSet<string>      _selectedProductIds = new();

    private string         _paymentMethod  = "CreditCard";
    private CreditCardModel _cc            = new();
    private string?        _cryptoCurrency;
    private string?        _cryptoTxId;
    private string?        _tokenCode;
    private string?        _discountCode;
    private string?        _completedEmail;

    protected override async Task OnInitializedAsync()
    {
        var api = HttpFactory.CreateClient("SignupsApi");

        if (!string.IsNullOrWhiteSpace(SponsorSlug))
        {
            _form.SponsorMemberId = SponsorSlug;
            try
            {
                var sponsorResp = await api.PostAsJsonAsync(
                    "api/v1/signups/validate-sponsor",
                    new { SponsorMemberId = SponsorSlug });

                if (sponsorResp.IsSuccessStatusCode)
                {
                    var body = await sponsorResp.Content.ReadFromJsonAsync<ApiWrapper<SponsorModel>>();
                    if (body?.Success == true && body.Data is not null)
                        _sponsor = body.Data;
                }
            }
            catch { /* sponsor resolve is best-effort */ }
        }

        try
        {
            var levelsResp = await api.GetFromJsonAsync<ApiWrapper<List<MembershipLevelModel>>>(
                "api/v1/signups/membership-levels");
            if (levelsResp?.Success == true && levelsResp.Data is not null)
                _levels = levelsResp.Data;
        }
        catch { /* handled via empty list in UI */ }
    }

    private async Task HandleStep1()
    {
        _error = string.Empty;
        if (string.IsNullOrWhiteSpace(_form.FirstName) || string.IsNullOrWhiteSpace(_form.LastName))
            { _error = L["Signup.ErrorNameRequired"]; return; }
        if (string.IsNullOrWhiteSpace(_form.Email))
            { _error = L["Signup.ErrorEmailRequired"]; return; }
        if (string.IsNullOrWhiteSpace(_form.Password) || _form.Password != _form.ConfirmPassword)
            { _error = L["Signup.ErrorPasswordMismatch"]; return; }
        if (_form.MembershipLevelId == 0)
            { _error = L["Signup.ErrorLevelRequired"]; return; }
        if (_form.DateOfBirth == default || _form.DateOfBirth > DateTime.UtcNow.AddYears(-18))
            { _error = L["Signup.ErrorAge18"]; return; }

        _busy = true;
        try
        {
            var api  = HttpFactory.CreateClient("SignupsApi");
            var resp = await api.PostAsJsonAsync("api/v1/signups/ambassador", new
            {
                SponsorMemberId    = _sponsor?.MemberId ?? _form.SponsorMemberId,
                _form.FirstName,
                _form.LastName,
                _form.DateOfBirth,
                _form.Email,
                _form.Password,
                _form.ConfirmPassword,
                _form.Phone,
                _form.Country,
                _form.ReplicateSiteSlug,
                _form.MembershipLevelId
            });

            var body = await resp.Content.ReadFromJsonAsync<ApiWrapper<SignupResponseModel>>();

            if (body?.Success == true && body.Data is not null)
            {
                _signupId = body.Data.SignupId;

                var productsResp = await api.GetFromJsonAsync<ApiWrapper<List<ProductModel>>>(
                    "api/v1/signups/products");
                if (productsResp?.Success == true && productsResp.Data is not null)
                    _products = productsResp.Data;

                Step = 2;
            }
            else
            {
                _error = body?.Message ?? body?.Errors?.FirstOrDefault() ?? L["Signup.ErrorGeneric"];
            }
        }
        catch (Exception ex)
        {
            _error = string.Format(L["Signup.ErrorServerUnreachable"], ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task HandleStep2()
    {
        if (_products.Count > 0 && _selectedProductIds.Count == 0)
            { _error = L["Signup.ErrorProductRequired"]; return; }

        _error = string.Empty;
        _busy  = true;
        try
        {
            if (_selectedProductIds.Count > 0)
            {
                var api  = HttpFactory.CreateClient("SignupsApi");
                var resp = await api.PostAsJsonAsync(
                    $"api/v1/signups/{_signupId}/select-products",
                    new { ProductIds = _selectedProductIds.ToList() });

                var body = await resp.Content.ReadFromJsonAsync<ApiWrapper<bool>>();
                if (body?.Success != true)
                {
                    _error = body?.Message ?? body?.Errors?.FirstOrDefault() ?? L["Signup.ErrorProductsSave"];
                    return;
                }
            }

            Step = 3;
        }
        catch (Exception ex)
        {
            _error = string.Format(L["Signup.ErrorServerUnreachable"], ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task HandleStep3()
    {
        _error = string.Empty;
        _busy  = true;
        try
        {
            var api  = HttpFactory.CreateClient("SignupsApi");
            var resp = await api.PostAsJsonAsync($"api/v1/signups/{_signupId}/complete", new
            {
                PaymentMethod       = _paymentMethod,
                CreditCard          = _paymentMethod == "CreditCard"   ? _cc            : null,
                CryptoCurrency      = _paymentMethod == "Crypto"       ? _cryptoCurrency : null,
                CryptoTransactionId = _paymentMethod == "Crypto"       ? _cryptoTxId    : null,
                TokenCode           = _paymentMethod == "Token"        ? _tokenCode     : null,
                DiscountCode        = _paymentMethod == "DiscountCode" ? _discountCode  : null,
            });

            var body = await resp.Content.ReadFromJsonAsync<ApiWrapper<SignupResponseModel>>();

            if (body?.Success == true && body.Data is not null)
            {
                _completedEmail = body.Data.Email;
                Step = 4;
            }
            else
            {
                _error = body?.Message ?? body?.Errors?.FirstOrDefault() ?? L["Signup.ErrorComplete"];
            }
        }
        catch (Exception ex)
        {
            _error = string.Format(L["Signup.ErrorServerUnreachable"], ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private void ToggleProduct(string id)
    {
        if (!_selectedProductIds.Add(id))
            _selectedProductIds.Remove(id);
    }

    // ── Local models ─────────────────────────────────────────────────────────

    private class SignupFormModel
    {
        public string?   SponsorMemberId   { get; set; }
        public string    FirstName         { get; set; } = string.Empty;
        public string    LastName          { get; set; } = string.Empty;
        public string    Email             { get; set; } = string.Empty;
        public string    Password          { get; set; } = string.Empty;
        public string    ConfirmPassword   { get; set; } = string.Empty;
        public string?   Phone             { get; set; }
        public string    Country           { get; set; } = "US";
        public DateTime  DateOfBirth       { get; set; } = DateTime.Today.AddYears(-25);
        public string?   ReplicateSiteSlug { get; set; }
        public int       MembershipLevelId { get; set; }
    }

    private class CreditCardModel
    {
        public string  GatewayToken { get; set; } = string.Empty;
        public string  Last4        { get; set; } = string.Empty;
        public string  First6       { get; set; } = string.Empty;
        public string  CardBrand    { get; set; } = string.Empty;
        public int     ExpiryMonth  { get; set; }
        public int     ExpiryYear   { get; set; }
        public string  Gateway      { get; set; } = string.Empty;
        public string? CardToken    { get; set; }
    }

    private record ApiWrapper<T>(bool Success, T? Data, string? Message, List<string>? Errors);
    private record SponsorModel(string MemberId, string DisplayName, string FullName, string? ReplicateSiteSlug);
    private record MembershipLevelModel(int Id, string Name, string? Description, decimal Price, decimal RenewalPrice, bool IsFree);
    private record ProductModel(string Id, string Name, string? Description, decimal Price, string? Sku);
    private record SignupResponseModel(string SignupId, string MemberId, string Email, string MemberType, DateTime EnrollDate,
        string? AccessToken, string? RefreshToken, DateTime? TokenExpiry);
}
