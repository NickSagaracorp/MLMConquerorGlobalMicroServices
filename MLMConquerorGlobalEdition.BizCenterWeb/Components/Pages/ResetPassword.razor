@page "/reset-password"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout MLMConquerorGlobalEdition.SharedComponents.Components.Layout.BlankLayout
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Localization.IStringLocalizer<MLMConquerorGlobalEdition.SharedComponents.Resources.SharedResources> L

@* Reuses the same two-column layout as Login.razor.
   Calls SignupAPI POST /api/v1/auth/reset-password via the AuthApi named HttpClient.
   Reads `email` and `token` from the query string. Performs client-side strength
   validation; the backend remains authoritative. *@

<PageTitle>@L["PageTitle.ResetPassword"]</PageTitle>

<div class="container">
    <div class="main-content d-flex flex-column p-0">
        <div class="m-auto m-1230">
            <div class="row align-items-center">
                <div class="col-lg-6 d-none d-lg-block">
                    <img src="assets/images/poster-login.webp" class="rounded-3" alt="@L["Login.PosterAlt"]">
                </div>
                <div class="col-lg-6">
                    <div class="mw-480 ms-lg-auto">
                        <div class="d-inline-block mb-4">
                            <img src="assets/images/logo.svg" class="rounded-3 for-light-logo" alt="@L["Login.LogoAlt"]">
                            <img src="assets/images/logo.svg" class="rounded-3 for-dark-logo" alt="@L["Login.LogoAlt"]">
                        </div>
                        <h3 class="fs-28 mb-2">@L["ResetPassword.Title"]</h3>
                        <p class="fw-medium fs-16 mb-4">@L["ResetPassword.Subtitle"]</p>

                        @if (_invalidLink)
                        {
                            <div class="alert alert-danger mb-3">
                                @L["ResetPassword.InvalidLink"]
                            </div>
                            <a href="/forgot-password" class="btn btn-outline-primary fw-medium py-2 px-3 w-100">
                                <div class="d-flex align-items-center justify-content-center py-1">
                                    <i class="material-symbols-outlined fs-20 me-2">refresh</i>
                                    <span>@L["ResetPassword.RequestNew"]</span>
                                </div>
                            </a>
                        }
                        else if (_done)
                        {
                            <div class="alert alert-success mb-3">
                                @L["ResetPassword.SuccessMessage"]
                            </div>
                            <a href="/login" class="btn btn-primary fw-medium py-2 px-3 w-100">
                                <div class="d-flex align-items-center justify-content-center py-1">
                                    <i class="material-symbols-outlined text-white fs-20 me-2">login</i>
                                    <span>@L["ResetPassword.GoToLogin"]</span>
                                </div>
                            </a>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <div class="alert alert-danger mb-3">@_error</div>
                            }

                            <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true">
                                <div class="form-group mb-3">
                                    <label class="label text-secondary">@L["ResetPassword.EmailLabel"]</label>
                                    <input type="email" class="form-control h-55"
                                           value="@Email"
                                           readonly
                                           autocomplete="email" />
                                </div>
                                <div class="form-group mb-4">
                                    <label class="label text-secondary">@L["ResetPassword.NewPasswordLabel"]</label>
                                    <input type="password" class="form-control h-55"
                                           placeholder="@L["ResetPassword.NewPasswordPlaceholder"]"
                                           autocomplete="new-password"
                                           required
                                           minlength="8"
                                           @bind="_newPassword" />
                                    <small class="text-secondary fs-12">@L["ResetPassword.PasswordHint"]</small>
                                </div>
                                <div class="form-group mb-4">
                                    <label class="label text-secondary">@L["ResetPassword.ConfirmPasswordLabel"]</label>
                                    <input type="password" class="form-control h-55"
                                           placeholder="@L["ResetPassword.ConfirmPasswordPlaceholder"]"
                                           autocomplete="new-password"
                                           required
                                           minlength="8"
                                           @bind="_confirmPassword" />
                                </div>
                                <div class="form-group mb-4">
                                    <button type="submit" class="btn btn-primary fw-medium py-2 px-3 w-100" disabled="@_busy">
                                        <div class="d-flex align-items-center justify-content-center py-1">
                                            @if (_busy)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                            }
                                            else
                                            {
                                                <i class="material-symbols-outlined text-white fs-20 me-2">lock_reset</i>
                                            }
                                            <span>@L["ResetPassword.SubmitButton"]</span>
                                        </div>
                                    </button>
                                </div>
                                <div class="form-group">
                                    <p>
                                        <a href="/login" class="fw-medium text-primary text-decoration-none">
                                            @L["ResetPassword.BackToLogin"]
                                        </a>
                                    </p>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _busy;
    private bool _done;
    private bool _invalidLink;
    private string _error = string.Empty;

    protected override void OnInitialized()
    {
        _invalidLink = string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token);
    }

    private async Task HandleSubmit()
    {
        _error = string.Empty;

        if (_invalidLink)
        {
            return;
        }

        // Client-side validation: required, min 8, ≥1 uppercase, ≥1 digit, match.
        if (string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmPassword))
        {
            _error = L["ResetPassword.ErrorRequired"];
            return;
        }

        if (_newPassword.Length < 8
            || !System.Linq.Enumerable.Any(_newPassword, char.IsUpper)
            || !System.Linq.Enumerable.Any(_newPassword, char.IsDigit))
        {
            _error = L["ResetPassword.ErrorWeak"];
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _error = L["ResetPassword.ErrorMismatch"];
            return;
        }

        _busy = true;
        try
        {
            var client = HttpFactory.CreateClient("AuthApi");
            var response = await client.PostAsJsonAsync(
                "api/v1/auth/reset-password",
                new
                {
                    Email = Email,
                    Token = Token,
                    NewPassword = _newPassword
                });

            if (response.IsSuccessStatusCode)
            {
                _done = true;
            }
            else
            {
                // Surface backend message if available.
                try
                {
                    var problem = await response.Content
                        .ReadFromJsonAsync<MLMConquerorGlobalEdition.SharedKernel.ApiResponse<bool>>();

                    var firstError = problem?.Errors is null
                        ? null
                        : System.Linq.Enumerable.FirstOrDefault(problem.Errors);

                    _error = !string.IsNullOrWhiteSpace(problem?.UserFriendlyMessage)
                        ? problem!.UserFriendlyMessage!
                        : !string.IsNullOrWhiteSpace(problem?.Message)
                            ? problem!.Message!
                            : !string.IsNullOrWhiteSpace(firstError)
                                ? firstError!
                                : L["ResetPassword.ErrorGeneric"];
                }
                catch
                {
                    _error = L["ResetPassword.ErrorGeneric"];
                }
            }
        }
        catch
        {
            _error = L["ResetPassword.ServerError"];
        }
        finally
        {
            _busy = false;
        }
    }
}
