@page "/Error"
@using System.Diagnostics
@inject Microsoft.Extensions.Localization.IStringLocalizer<MLMConquerorGlobalEdition.SharedComponents.Resources.SharedResources> L

<PageTitle>@L["PageTitle.Error"]</PageTitle>

<h1 class="text-danger">@L["Error.Title"]</h1>
<h2 class="text-danger">@L["Error.Subtitle"]</h2>

@if (ShowRequestId)
{
    <p>
        <strong>@L["Error.RequestIdLabel"]</strong> <code>@RequestId</code>
    </p>
}

<h3>@L["Error.DevModeHeader"]</h3>
<p>
    @((MarkupString)L["Error.DevModeIntro"].Value)
</p>
<p>
    @((MarkupString)L["Error.DevModeWarning"].Value)
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
