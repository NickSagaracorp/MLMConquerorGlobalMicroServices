@page "/forgot-password"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout MLMConquerorGlobalEdition.SharedComponents.Components.Layout.BlankLayout
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Localization.IStringLocalizer<MLMConquerorGlobalEdition.SharedComponents.Resources.SharedResources> L

@* Reuses the same two-column layout as Login.razor.
   Calls SignupAPI POST /api/v1/auth/forgot-password via the AuthApi named HttpClient.
   Backend always returns 200 (anti-enumeration), so we always show the same success message. *@

<PageTitle>@L["PageTitle.ForgotPassword"]</PageTitle>

<div class="container">
    <div class="main-content d-flex flex-column p-0">
        <div class="m-auto m-1230">
            <div class="row align-items-center">
                <div class="col-lg-6 d-none d-lg-block">
                    <img src="assets/images/poster-login.webp" class="rounded-3" alt="@L["Login.PosterAlt"]">
                </div>
                <div class="col-lg-6">
                    <div class="mw-480 ms-lg-auto">
                        <div class="d-inline-block mb-4">
                            <img src="assets/images/logo.svg" class="rounded-3 for-light-logo" alt="@L["Login.LogoAlt"]">
                            <img src="assets/images/logo.svg" class="rounded-3 for-dark-logo" alt="@L["Login.LogoAlt"]">
                        </div>
                        <h3 class="fs-28 mb-2">@L["ForgotPassword.Title"]</h3>
                        <p class="fw-medium fs-16 mb-4">@L["ForgotPassword.Subtitle"]</p>

                        @if (_sent)
                        {
                            <div class="alert alert-success mb-3">
                                @L["ForgotPassword.SuccessMessage"]
                            </div>
                            <a href="/login" class="btn btn-outline-primary fw-medium py-2 px-3 w-100">
                                <div class="d-flex align-items-center justify-content-center py-1">
                                    <i class="material-symbols-outlined fs-20 me-2">arrow_back</i>
                                    <span>@L["ForgotPassword.BackToLogin"]</span>
                                </div>
                            </a>
                        }
                        else
                        {
                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <div class="alert alert-danger mb-3">@_error</div>
                            }

                            <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true">
                                <div class="form-group mb-4">
                                    <label class="label text-secondary">@L["ForgotPassword.EmailLabel"]</label>
                                    <input name="Email" type="email" class="form-control h-55"
                                           placeholder="@L["ForgotPassword.EmailPlaceholder"]"
                                           autocomplete="email"
                                           required
                                           @bind="_email" />
                                </div>
                                <div class="form-group mb-4">
                                    <button type="submit" class="btn btn-primary fw-medium py-2 px-3 w-100" disabled="@_busy">
                                        <div class="d-flex align-items-center justify-content-center py-1">
                                            @if (_busy)
                                            {
                                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                            }
                                            else
                                            {
                                                <i class="material-symbols-outlined text-white fs-20 me-2">mail</i>
                                            }
                                            <span>@L["ForgotPassword.SendButton"]</span>
                                        </div>
                                    </button>
                                </div>
                                <div class="form-group">
                                    <p>
                                        <a href="/login" class="fw-medium text-primary text-decoration-none">
                                            @L["ForgotPassword.BackToLogin"]
                                        </a>
                                    </p>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _email = string.Empty;
    private bool _busy;
    private bool _sent;
    private string _error = string.Empty;

    private async Task HandleSubmit()
    {
        _error = string.Empty;

        if (string.IsNullOrWhiteSpace(_email))
        {
            _error = L["ForgotPassword.ErrorEmailRequired"];
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(
                _email,
                @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            _error = L["ForgotPassword.ErrorEmailInvalid"];
            return;
        }

        _busy = true;
        try
        {
            var client = HttpFactory.CreateClient("AuthApi");
            // Anti-enumeration: backend always returns 200, even if email isn't registered.
            var response = await client.PostAsJsonAsync(
                "api/v1/auth/forgot-password",
                new { Email = _email });

            if (response.IsSuccessStatusCode)
            {
                _sent = true;
            }
            else
            {
                _error = L["ForgotPassword.ServerError"];
            }
        }
        catch
        {
            _error = L["ForgotPassword.ServerError"];
        }
        finally
        {
            _busy = false;
        }
    }
}
