@inject HttpClient Http
@inject IViewContextService ViewContext
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

@using MLMConquerorGlobalEdition.SharedComponents.Constants

<BreadcrumbNav Items="@_breadcrumb" />

<!-- Filter bar -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-12 col-sm-auto">
                <label class="form-label small mb-1">@L["Tickets.FilterStatus"]</label>
                <select class="form-select form-select-sm" style="min-width:140px;"
                        @bind="_statusFilter" @bind:after="ApplyFiltersAsync">
                    <option value="">@L["Tickets.AllStatuses"]</option>
                    <option value="Open">@L["Tickets.StatusOpen"]</option>
                    <option value="InProgress">@L["Tickets.StatusInProgress"]</option>
                    <option value="Escalated">@L["Tickets.StatusEscalated"]</option>
                    <option value="Resolved">@L["Tickets.StatusResolved"]</option>
                    <option value="Closed">@L["Tickets.StatusClosed"]</option>
                </select>
            </div>
            <div class="col-12 col-sm-auto">
                <label class="form-label small mb-1">@L["Tickets.FilterPriority"]</label>
                <select class="form-select form-select-sm" style="min-width:130px;"
                        @bind="_priorityFilter" @bind:after="ApplyFiltersAsync">
                    <option value="">@L["Tickets.AllPriorities"]</option>
                    <option value="Low">@L["Tickets.PriorityLow"]</option>
                    <option value="Normal">@L["Tickets.PriorityNormal"]</option>
                    <option value="High">@L["Tickets.PriorityHigh"]</option>
                    <option value="Urgent">@L["Tickets.PriorityUrgent"]</option>
                </select>
            </div>
            <div class="col-12 col-sm-auto ms-sm-auto">
                <button class="btn btn-primary btn-sm" @onclick="@(() => { _showCreateModal = true; _pendingShow = true; })">
                    <i class="ri-add-line me-1"></i>@L["Tickets.CreateNew"]
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header py-3">
        <h6 class="card-title mb-0 fw-semibold">
            @(ViewContext.HasPermission(Permissions.Ticket.ViewAll) ? L["Tickets.HeaderAll"] : L["Tickets.HeaderMine"])
        </h6>
    </div>
    <div class="card-body p-0">
        <LoadingSpinner IsLoading="@_isLoading" />
        @if (!_isLoading)
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th>@L["Tickets.ColTicketNumber"]</th>
                            <th>@L["Tickets.ColSubject"]</th>
                            <th>@L["Tickets.ColCategory"]</th>
                            <th>@L["Tickets.ColPriority"]</th>
                            <th>@L["Tickets.ColStatus"]</th>
                            <th>@L["Tickets.ColCreated"]</th>
                            <th>@L["Tickets.ColActions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_items.Any())
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">@L["Tickets.NoData"]</td></tr>
                        }
                        @foreach (var t in _items)
                        {
                            <tr>
                                <td><span class="fw-medium">@t.TicketNumber</span></td>
                                <td>@t.Subject</td>
                                <td>@t.Category</td>
                                <td><StatusBadge Status="@t.Priority" /></td>
                                <td><StatusBadge Status="@t.Status" /></td>
                                <td>@t.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <button class="btn btn-xs btn-outline-primary"
                                                @onclick="@(() => Nav.NavigateTo($"/tickets/{t.TicketId}"))">
                                            <i class="ri-eye-line me-1"></i>@L["Tickets.ActionView"]
                                        </button>
                                        <AdminOnlyWrapper Permission="@Permissions.Ticket.Assign">
                                            <button class="btn btn-xs btn-outline-secondary">
                                                <i class="ri-user-add-line me-1"></i>@L["Tickets.ActionAssign"]
                                            </button>
                                        </AdminOnlyWrapper>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_total > _pageSize)
            {
                var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                <div class="d-flex justify-content-center py-3">
                    <nav aria-label="@L["Tickets.PaginationAria"]">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page - 1)">&#x2039;</button>
                            </li>
                            @for (var pg = 1; pg <= totalPages; pg++)
                            {
                                var p = pg;
                                <li class="page-item @(p == _page ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(p)">@p</button>
                                </li>
                            }
                            <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page + 1)">&#x203A;</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@if (_showCreateModal)
{
    <CreateTicketModal @ref="_createModal"
                       MemberProfileId="@MemberProfileId"
                       OnTicketCreated="@HandleTicketCreatedAsync" />
}

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool   _isLoading     = true;
    private int    _page = 1, _pageSize = 10, _total;
    private bool   _showCreateModal;
    private bool   _pendingShow;
    private string _statusFilter   = string.Empty;
    private string _priorityFilter = string.Empty;

    private List<TicketListItem> _items = new();
    private CreateTicketModal?   _createModal;

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new(L["Tickets.BreadcrumbHome"].Value,    "/dashboard"),
        new(L["Tickets.BreadcrumbTickets"].Value)
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await LoadPageAsync(1);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingShow && _createModal is not null)
        {
            _pendingShow = false;
            _createModal.Show();
        }
    }

    private async Task ApplyFiltersAsync() => await LoadPageAsync(1);

    private async Task ChangePage(int page) => await LoadPageAsync(page);

    private async Task LoadPageAsync(int page)
    {
        _page = page;
        _isLoading = true;
        StateHasChanged();
        try
        {
            var isAdmin = ViewContext.HasPermission(Permissions.Ticket.ViewAll);
            var baseUrl = isAdmin ? "api/v1/admin/tickets" : "api/v1/bizcenter/tickets";
            var query   = $"?page={page}&pageSize={_pageSize}";
            if (!string.IsNullOrEmpty(_statusFilter))   query += $"&status={_statusFilter}";
            if (!string.IsNullOrEmpty(_priorityFilter)) query += $"&priority={_priorityFilter}";

            var response = await Http.GetFromJsonAsync<ApiResponse<PagedData<TicketListItem>>>(baseUrl + query);
            if (response?.Success == true && response.Data is not null)
            {
                _items = response.Data.Items;
                _total = response.Data.TotalCount;
            }
        }
        catch { /* silently degrade */ }
        finally { _isLoading = false; }
    }

    private async Task HandleTicketCreatedAsync()
    {
        _showCreateModal = false;
        await LoadPageAsync(1);
    }

    private class ApiResponse<T> { public bool Success { get; set; } public T? Data { get; set; } }
    private class PagedData<T>   { public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    private record TicketListItem(
        string   TicketId,
        string   TicketNumber,
        string   Subject,
        string   Category,
        string   Priority,
        string   Status,
        DateTime CreatedAt);
}
