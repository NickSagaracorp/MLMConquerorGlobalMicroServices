@inject HttpClient Http
@inject IViewContextService ViewContext
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

@using MLMConquerorGlobalEdition.SharedComponents.Constants

<BreadcrumbNav Items="@_breadcrumb" />

<LoadingSpinner IsLoading="@_isLoading" />

@if (!_isLoading && _ticket is not null)
{
    <div class="row g-3">

        <!-- ── Left column: ticket info + comments ─────────────────────── -->
        <div class="col-12 col-lg-8">

            <!-- Ticket header card -->
            <div class="card mb-3">
                <div class="card-header d-flex align-items-center justify-content-between py-3">
                    <h6 class="card-title mb-0 fw-semibold">
                        #@_ticket.TicketNumber — @_ticket.Subject
                    </h6>
                    <div class="d-flex gap-2 align-items-center">
                        @if (_ticket.EscalationLevel > 0)
                        {
                            <StatusBadge Status="@EscalationLabel(_ticket.EscalationLevel)" />
                        }
                        <StatusBadge Status="@_ticket.Status" />
                    </div>
                </div>
                <div class="card-body">
                    <p class="mb-3">@_ticket.Description</p>
                    <div class="row g-2 text-muted small">
                        <div class="col-6">
                            @L["TicketDetail.LabelCategory"]: <strong class="text-body">@_ticket.Category</strong>
                        </div>
                        <div class="col-6">
                            @L["TicketDetail.LabelPriority"]: <strong class="text-body">@_ticket.Priority</strong>
                        </div>
                        <div class="col-6">
                            @L["TicketDetail.LabelAssignedTo"]: <strong class="text-body">@(_ticket.AssignedTo ?? L["TicketDetail.Unassigned"].Value)</strong>
                        </div>
                        <div class="col-6">
                            @L["TicketDetail.LabelCreated"]: <strong class="text-body">@_ticket.CreatedAt.ToString("MMM dd, yyyy HH:mm")</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments thread -->
            <div class="card">
                <div class="card-header py-3">
                    <h6 class="card-title mb-0 fw-semibold">
                        @string.Format(L["TicketDetail.CommentsHeader"], _comments.Count)
                    </h6>
                </div>
                <div class="card-body p-0">
                    @if (_comments.Count == 0)
                    {
                        <div class="text-center py-4 text-muted small">@L["TicketDetail.NoComments"]</div>
                    }
                    else
                    {
                        @foreach (var c in _comments)
                        {
                            <div class="border-bottom p-3 @(c.IsStaff ? "bg-light" : "")">
                                <div class="d-flex justify-content-between align-items-center small text-muted mb-1">
                                    <div>
                                        <strong class="text-body">@c.Author</strong>
                                        @if (c.IsStaff)
                                        {
                                            <span class="badge bg-secondary ms-2">@L["TicketDetail.StaffBadge"]</span>
                                        }
                                    </div>
                                    <span>@c.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                                </div>
                                <p class="mb-0 small">@c.Content</p>
                            </div>
                        }
                    }
                </div>
                <!-- Add comment footer -->
                <div class="card-footer">
                    <textarea class="form-control mb-2"
                              rows="3"
                              placeholder="@L["TicketDetail.CommentPlaceholder"]"
                              @bind="_newComment"></textarea>
                    <button class="btn btn-primary btn-sm"
                            @onclick="AddCommentAsync"
                            disabled="@_savingComment">
                        @if (_savingComment)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @L["TicketDetail.PostComment"]
                    </button>
                </div>
            </div>
        </div>

        <!-- ── Right column: actions sidebar ──────────────────────────── -->
        <div class="col-12 col-lg-4">
            <div class="card">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">@L["TicketDetail.ActionsHeader"]</h6>
                    <div class="d-grid gap-2">

                        <!-- Assign -->
                        <AdminOnlyWrapper Permission="@Permissions.Ticket.Assign">
                            @if (_showAssignForm)
                            {
                                <div class="border rounded p-2 mb-1">
                                    <label class="form-label small mb-1">@L["TicketDetail.AssignLabel"]</label>
                                    <input class="form-control form-control-sm mb-2"
                                           placeholder="@L["TicketDetail.AssignPlaceholder"]"
                                           @bind="_assignTarget" />
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-primary flex-grow-1"
                                                @onclick="AssignTicketAsync"
                                                disabled="@_busyAssign">
                                            @if (_busyAssign)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1"></span>
                                            }
                                            @L["TicketDetail.AssignConfirm"]
                                        </button>
                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="@(() => _showAssignForm = false)">
                                            @L["TicketDetail.AssignCancel"]
                                        </button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary btn-sm"
                                        @onclick="@(() => _showAssignForm = true)">
                                    <i class="ri-user-add-line me-1"></i>@L["TicketDetail.AssignAgent"]
                                </button>
                            }
                        </AdminOnlyWrapper>

                        <!-- Resolve -->
                        <AdminOnlyWrapper Permission="@Permissions.Ticket.Resolve">
                            <button class="btn btn-success btn-sm"
                                    @onclick="@(() => _showResolveModal = true)">
                                <i class="ri-check-double-line me-1"></i>@L["TicketDetail.ResolveTicket"]
                            </button>
                        </AdminOnlyWrapper>

                        <!-- Merge -->
                        <AdminOnlyWrapper Permission="@Permissions.Ticket.Merge">
                            <button class="btn btn-outline-secondary btn-sm">
                                <i class="ri-git-merge-line me-1"></i>@L["TicketDetail.MergeTicket"]
                            </button>
                        </AdminOnlyWrapper>

                        <!-- Escalate dropdown -->
                        <AdminOnlyWrapper Permission="@Permissions.Ticket.EscalateToL2">
                            <div class="dropdown">
                                <button class="btn btn-outline-warning btn-sm dropdown-toggle w-100"
                                        type="button"
                                        data-bs-toggle="dropdown"
                                        aria-expanded="false">
                                    <i class="ri-arrow-up-line me-1"></i>@L["TicketDetail.Escalate"]
                                </button>
                                <ul class="dropdown-menu w-100">
                                    @if (ViewContext.HasPermission(Permissions.Ticket.EscalateToL2))
                                    {
                                        <li>
                                            <button class="dropdown-item"
                                                    @onclick="@(() => EscalateAsync(2))">
                                                @L["TicketDetail.EscalateLevel2"]
                                            </button>
                                        </li>
                                    }
                                    @if (ViewContext.HasPermission(Permissions.Ticket.EscalateToL3))
                                    {
                                        <li>
                                            <button class="dropdown-item"
                                                    @onclick="@(() => EscalateAsync(3))">
                                                @L["TicketDetail.EscalateLevel3"]
                                            </button>
                                        </li>
                                    }
                                    @if (ViewContext.HasPermission(Permissions.Ticket.EscalateToIT))
                                    {
                                        <li>
                                            <button class="dropdown-item text-danger"
                                                    @onclick="@(() => EscalateAsync(4))">
                                                @L["TicketDetail.EscalateIT"]
                                            </button>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </AdminOnlyWrapper>

                    </div>
                </div>
            </div>
        </div>

    </div>
}

<!-- Resolve confirm modal -->
@if (_showResolveModal)
{
    <ConfirmModal IsVisible="true"
                  Title="@L["TicketDetail.ResolveModalTitle"]"
                  Message="@L["TicketDetail.ResolveModalMessage"]"
                  ConfirmLabel="@L["TicketDetail.ResolveModalConfirm"]"
                  ConfirmColor="success"
                  IsBusy="@_busyResolve"
                  OnConfirm="ResolveTicketAsync"
                  OnCancel="@(() => _showResolveModal = false)" />
}

@code {
    [Parameter, EditorRequired] public string TicketId        { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool   _isLoading     = true;
    private bool   _savingComment;
    private bool   _showResolveModal;
    private bool   _busyResolve;
    private bool   _showAssignForm;
    private bool   _busyAssign;
    private string _newComment    = string.Empty;
    private string _assignTarget  = string.Empty;

    private TicketDetail? _ticket;
    private List<TicketCommentItem> _comments = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new(L["TicketDetail.BreadcrumbHome"].Value,    "/dashboard"),
        new(L["TicketDetail.BreadcrumbTickets"].Value, "/tickets"),
        new($"#{_ticket?.TicketNumber ?? TicketId}")
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(TicketId)) return;
        _isLoading = true;
        StateHasChanged();
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<TicketDetailWithComments>>(
                $"api/v1/bizcenter/tickets/{TicketId}");
            if (response?.Success == true && response.Data is not null)
            {
                _ticket   = response.Data.Ticket;
                _comments = response.Data.Comments;
            }
        }
        catch { /* silently degrade */ }
        finally { _isLoading = false; }
    }

    private async Task AddCommentAsync()
    {
        if (string.IsNullOrWhiteSpace(_newComment)) return;
        _savingComment = true;
        try
        {
            await Http.PostAsJsonAsync($"api/v1/bizcenter/tickets/{TicketId}/comments",
                new { Content = _newComment });
            _newComment = string.Empty;
            await OnParametersSetAsync();
        }
        catch { /* silently degrade */ }
        finally { _savingComment = false; }
    }

    private async Task EscalateAsync(int level)
    {
        try { await Http.PostAsJsonAsync($"api/v1/admin/tickets/{TicketId}/assign", new { EscalationLevel = level }); }
        catch { /* silently degrade */ }
    }

    private async Task ResolveTicketAsync()
    {
        _busyResolve = true;
        try
        {
            await Http.PostAsJsonAsync($"api/v1/admin/tickets/{TicketId}/resolve", new { });
            _showResolveModal = false;
            await OnParametersSetAsync();
        }
        catch { /* silently degrade */ }
        finally { _busyResolve = false; }
    }

    private async Task AssignTicketAsync()
    {
        if (string.IsNullOrWhiteSpace(_assignTarget)) return;
        _busyAssign = true;
        try
        {
            await Http.PostAsJsonAsync($"api/v1/admin/tickets/{TicketId}/assign", new { AssignedTo = _assignTarget });
            _assignTarget   = string.Empty;
            _showAssignForm = false;
            await OnParametersSetAsync();
        }
        catch { /* silently degrade */ }
        finally { _busyAssign = false; }
    }

    private string EscalationLabel(int level) => level switch
    {
        1 => L["TicketDetail.EscalationLevel1"],
        2 => L["TicketDetail.EscalationLevel2"],
        3 => L["TicketDetail.EscalationLevel3"],
        4 => L["TicketDetail.EscalationIT"],
        _ => string.Format(L["TicketDetail.EscalationOther"], level)
    };

    // ── Local data models ─────────────────────────────────────────────────────
    private class ApiResponse<T> { public bool Success { get; set; } public T? Data { get; set; } }

    private class TicketDetailWithComments
    {
        public TicketDetail?              Ticket   { get; set; }
        public List<TicketCommentItem>    Comments { get; set; } = new();
    }

    private record TicketDetail(
        string   TicketId,
        string   TicketNumber,
        string   Subject,
        string   Description,
        string   Category,
        string   Priority,
        string   Status,
        DateTime CreatedAt,
        string?  AssignedTo,
        int      EscalationLevel);

    private record TicketCommentItem(
        string   Author,
        string   Content,
        DateTime CreatedAt,
        bool     IsStaff);
}
