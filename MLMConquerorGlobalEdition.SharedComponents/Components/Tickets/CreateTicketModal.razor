@inject HttpClient Http
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

@if (_visible)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog"
         style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="ri-customer-service-2-line me-2"></i>@L["TicketCreate.Title"]
                    </h5>
                    <button type="button" class="btn-close" @onclick="Hide" aria-label="@L["TicketCreate.CloseAria"]"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@_form" OnValidSubmit="SubmitAsync">
                        <DataAnnotationsValidator />

                        <!-- Subject -->
                        <div class="mb-3">
                            <label class="form-label">
                                @L["TicketCreate.SubjectLabel"] <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control"
                                       @bind-Value="_form.Subject"
                                       placeholder="@L["TicketCreate.SubjectPlaceholder"]" />
                            <ValidationMessage For="@(() => _form.Subject)" />
                        </div>

                        <div class="row g-3 mb-3">
                            <!-- Category -->
                            <div class="col-12 col-sm-6">
                                <label class="form-label">@L["TicketCreate.CategoryLabel"]</label>
                                <InputSelect class="form-select" @bind-Value="_form.Category">
                                    <option value="">@L["TicketCreate.CategorySelect"]</option>
                                    <option value="Billing">@L["TicketCreate.CategoryBilling"]</option>
                                    <option value="Technical">@L["TicketCreate.CategoryTechnical"]</option>
                                    <option value="Commission">@L["TicketCreate.CategoryCommission"]</option>
                                    <option value="Membership">@L["TicketCreate.CategoryMembership"]</option>
                                    <option value="Account">@L["TicketCreate.CategoryAccount"]</option>
                                    <option value="Other">@L["TicketCreate.CategoryOther"]</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _form.Category)" />
                            </div>

                            <!-- Priority -->
                            <div class="col-12 col-sm-6">
                                <label class="form-label">@L["TicketCreate.PriorityLabel"]</label>
                                <InputSelect class="form-select" @bind-Value="_form.Priority">
                                    <option value="Low">@L["TicketCreate.PriorityLow"]</option>
                                    <option value="Normal">@L["TicketCreate.PriorityNormal"]</option>
                                    <option value="High">@L["TicketCreate.PriorityHigh"]</option>
                                    <option value="Urgent">@L["TicketCreate.PriorityUrgent"]</option>
                                </InputSelect>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label class="form-label">
                                @L["TicketCreate.DescriptionLabel"] <span class="text-danger">*</span>
                            </label>
                            <InputTextArea class="form-control"
                                           rows="5"
                                           @bind-Value="_form.Description"
                                           placeholder="@L["TicketCreate.DescriptionPlaceholder"]" />
                            <ValidationMessage For="@(() => _form.Description)" />
                        </div>

                        <!-- File attachment (UI only — upload logic wired in later iteration) -->
                        <div class="mb-3">
                            <label class="form-label">@L["TicketCreate.AttachmentLabel"] <span class="text-muted small">@L["TicketCreate.AttachmentOptional"]</span></label>
                            <input type="file" class="form-control" accept="image/*,.pdf,.doc,.docx,.txt" />
                            <div class="form-text">@L["TicketCreate.AttachmentHelp"]</div>
                        </div>

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <ApiErrorAlert ErrorMessage="@_errorMessage" />
                        }

                        <!-- Footer buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary" @onclick="Hide"
                                    disabled="@_isBusy">
                                @L["TicketCreate.Cancel"]
                            </button>
                            <button type="submit" class="btn btn-primary" disabled="@_isBusy">
                                @if (_isBusy)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                @L["TicketCreate.Submit"]
                            </button>
                        </div>

                    </EditForm>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string        MemberProfileId   { get; set; } = string.Empty;
    [Parameter]                 public EventCallback OnTicketCreated   { get; set; }

    private bool   _visible;
    private bool   _isBusy;
    private string _errorMessage = string.Empty;

    private TicketForm _form = new();

    // ── Public API ────────────────────────────────────────────────────────────
    public void Show()
    {
        _form         = new TicketForm();
        _errorMessage = string.Empty;
        _visible      = true;
        StateHasChanged();
    }

    public void Hide()
    {
        _visible = false;
        StateHasChanged();
    }

    // ── Submit ────────────────────────────────────────────────────────────────
    private async Task SubmitAsync()
    {
        _isBusy       = true;
        _errorMessage = string.Empty;

        try
        {
            var response = await Http.PostAsJsonAsync("api/v1/bizcenter/tickets", new
            {
                Subject     = _form.Subject,
                Category    = _form.Category,
                Priority    = _form.Priority,
                Description = _form.Description
            });

            if (response.IsSuccessStatusCode)
            {
                Hide();
                await OnTicketCreated.InvokeAsync();
            }
            else
            {
                _errorMessage = L["TicketCreate.ErrorGeneric"];
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    // ── Local form model ──────────────────────────────────────────────────────
    public class TicketForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Subject is required.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200, ErrorMessage = "Subject cannot exceed 200 characters.")]
        public string Subject     { get; set; } = string.Empty;

        public string Category    { get; set; } = string.Empty;

        public string Priority    { get; set; } = "Normal";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Description is required.")]
        public string Description { get; set; } = string.Empty;
    }
}
