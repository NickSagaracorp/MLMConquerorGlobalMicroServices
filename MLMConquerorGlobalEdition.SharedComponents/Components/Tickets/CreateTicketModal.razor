@inject NavigationManager Nav

@if (_visible)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog"
         style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="ri-customer-service-2-line me-2"></i>Create New Ticket
                    </h5>
                    <button type="button" class="btn-close" @onclick="Hide"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@_form" OnValidSubmit="SubmitAsync">
                        <DataAnnotationsValidator />

                        <!-- Subject -->
                        <div class="mb-3">
                            <label class="form-label">
                                Subject <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control"
                                       @bind-Value="_form.Subject"
                                       placeholder="Briefly describe your issue (max 200 chars)" />
                            <ValidationMessage For="@(() => _form.Subject)" />
                        </div>

                        <div class="row g-3 mb-3">
                            <!-- Category -->
                            <div class="col-12 col-sm-6">
                                <label class="form-label">Category</label>
                                <InputSelect class="form-select" @bind-Value="_form.Category">
                                    <option value="">Select a category…</option>
                                    <option value="Billing">Billing</option>
                                    <option value="Technical">Technical</option>
                                    <option value="Commission">Commission</option>
                                    <option value="Membership">Membership</option>
                                    <option value="Account">Account</option>
                                    <option value="Other">Other</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _form.Category)" />
                            </div>

                            <!-- Priority -->
                            <div class="col-12 col-sm-6">
                                <label class="form-label">Priority</label>
                                <InputSelect class="form-select" @bind-Value="_form.Priority">
                                    <option value="Low">Low</option>
                                    <option value="Normal">Normal</option>
                                    <option value="High">High</option>
                                    <option value="Urgent">Urgent</option>
                                </InputSelect>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label class="form-label">
                                Description <span class="text-danger">*</span>
                            </label>
                            <InputTextArea class="form-control"
                                           rows="5"
                                           @bind-Value="_form.Description"
                                           placeholder="Provide full details about your issue…" />
                            <ValidationMessage For="@(() => _form.Description)" />
                        </div>

                        <!-- File attachment (UI only — upload logic wired in later iteration) -->
                        <div class="mb-3">
                            <label class="form-label">Attachment <span class="text-muted small">(optional)</span></label>
                            <input type="file" class="form-control" accept="image/*,.pdf,.doc,.docx,.txt" />
                            <div class="form-text">Supported: images, PDF, Word, TXT. Max 10 MB.</div>
                        </div>

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <ApiErrorAlert ErrorMessage="@_errorMessage" />
                        }

                        <!-- Footer buttons -->
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary" @onclick="Hide"
                                    disabled="@_isBusy">
                                Cancel
                            </button>
                            <button type="submit" class="btn btn-primary" disabled="@_isBusy">
                                @if (_isBusy)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Submit Ticket
                            </button>
                        </div>

                    </EditForm>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string        MemberProfileId   { get; set; } = string.Empty;
    [Parameter]                 public EventCallback OnTicketCreated   { get; set; }

    private bool   _visible;
    private bool   _isBusy;
    private string _errorMessage = string.Empty;

    private TicketForm _form = new();

    // ── Public API ────────────────────────────────────────────────────────────
    public void Show()
    {
        _form         = new TicketForm();
        _errorMessage = string.Empty;
        _visible      = true;
        StateHasChanged();
    }

    public void Hide()
    {
        _visible = false;
        StateHasChanged();
    }

    // ── Submit ────────────────────────────────────────────────────────────────
    private async Task SubmitAsync()
    {
        _isBusy       = true;
        _errorMessage = string.Empty;

        try
        {
            // TODO: POST /api/v1/bizcenter/tickets
            //       Body: { subject, category, priority, description, memberId }
            await Task.Delay(300);

            Hide();
            await OnTicketCreated.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    // ── Local form model ──────────────────────────────────────────────────────
    public class TicketForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Subject is required.")]
        [System.ComponentModel.DataAnnotations.MaxLength(200, ErrorMessage = "Subject cannot exceed 200 characters.")]
        public string Subject     { get; set; } = string.Empty;

        public string Category    { get; set; } = string.Empty;

        public string Priority    { get; set; } = "Normal";

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Description is required.")]
        public string Description { get; set; } = string.Empty;
    }
}
