<div class="text-center py-5">
    <div class="mb-3">
        <i class="@Icon fs-1 text-muted opacity-50"></i>
    </div>
    <h6 class="fw-semibold mb-1">@Title</h6>
    <p class="text-muted small mb-3">@Message</p>
    @if (!string.IsNullOrEmpty(ActionLabel))
    {
        <button class="btn btn-primary btn-sm" @onclick="OnAction">
            @ActionLabel
        </button>
    }
</div>

@code {
    [Parameter] public string Icon          { get; set; } = "ri-inbox-line";
    [Parameter] public string Title         { get; set; } = "No data found";
    [Parameter] public string Message       { get; set; } = "There is nothing to display here yet.";
    [Parameter] public string? ActionLabel  { get; set; }
    [Parameter] public EventCallback OnAction { get; set; }
}
