<div class="card status-box h-100" role="region" aria-label="@Title: @Value">
    <div class="card-body d-flex align-items-center gap-3">
        <div class="status-box-icon rounded-circle d-flex align-items-center justify-content-center bg-@Color bg-opacity-10"
             style="width:52px;height:52px;min-width:52px;"
             aria-hidden="true">
            <i class="@Icon fs-4 text-@Color"></i>
        </div>
        <div class="flex-grow-1">
            <div class="text-muted small mb-1" id="@_titleId">@Title</div>
            <div class="fs-4 fw-bold" aria-labelledby="@_titleId">@Value</div>
            @if (!string.IsNullOrEmpty(Trend))
            {
                <div class="small @(TrendUp ? "text-success" : "text-danger")"
                     aria-label="@(TrendUp ? "Tendencia positiva" : "Tendencia negativa"): @Trend">
                    <i class="@(TrendUp ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line")" aria-hidden="true"></i>
                    @Trend
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title   { get; set; } = string.Empty;
    [Parameter] public string Value   { get; set; } = string.Empty;
    [Parameter] public string Icon    { get; set; } = "ri-bar-chart-line";
    [Parameter] public string Color   { get; set; } = "primary";
    [Parameter] public string? Trend  { get; set; }
    [Parameter] public bool   TrendUp { get; set; } = true;

    private readonly string _titleId = $"stat-title-{Guid.NewGuid():N}";
}
