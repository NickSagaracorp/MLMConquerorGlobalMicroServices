@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    <button type="button" class="btn-close" @onclick="Cancel"></button>
                </div>
                <div class="modal-body">
                    <p>@Message</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="Cancel" disabled="@IsBusy">Cancel</button>
                    <button class="btn btn-@ConfirmColor" @onclick="Confirm" disabled="@IsBusy">
                        @if (IsBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        @ConfirmLabel
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible        { get; set; }
    [Parameter] public string Title          { get; set; } = "Confirm";
    [Parameter] public string Message        { get; set; } = "Are you sure?";
    [Parameter] public string ConfirmLabel   { get; set; } = "Confirm";
    [Parameter] public string ConfirmColor   { get; set; } = "danger";
    [Parameter] public bool IsBusy           { get; set; }
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel  { get; set; }

    private async Task Confirm() => await OnConfirm.InvokeAsync();
    private async Task Cancel()  => await OnCancel.InvokeAsync();
}
