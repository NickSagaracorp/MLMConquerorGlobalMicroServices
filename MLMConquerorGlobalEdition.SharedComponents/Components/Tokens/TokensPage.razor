@inject IViewContextService ViewContext
@inject HttpClient Http

@using MLMConquerorGlobalEdition.SharedComponents.Constants

<BreadcrumbNav Items="@_breadcrumb" />

<div class="row g-3 mb-4">
    <div class="col-12 col-md-8">
        <div class="card">
            <div class="card-header py-3">
                <h6 class="card-title mb-0 fw-semibold">Token Transactions</h6>
            </div>
            <div class="card-body p-0">
                <LoadingSpinner IsLoading="@_isLoading" />
                @if (!_isLoading)
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Token Type</th>
                                    <th>Type</th>
                                    <th>Token Code</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!_items.Any())
                                {
                                    <tr><td colspan="6" class="text-center text-muted py-4">No data available.</td></tr>
                                }
                                @foreach (var t in _items)
                                {
                                    <tr>
                                        <td>@t.TokenTypeName</td>
                                        <td><StatusBadge Status="@t.TransactionType" /></td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(t.TokenCode))
                                            {
                                                <span class="font-monospace fw-bold @(t.IsUsed ? "text-muted text-decoration-line-through" : "text-primary")">
                                                    @t.TokenCode
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="fw-semibold @(t.Amount > 0 ? "text-success" : "text-danger")">
                                                @(t.Amount > 0 ? "+" : "")@t.Amount
                                            </span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(t.TokenCode))
                                            {
                                                @if (t.IsUsed)
                                                {
                                                    <span class="badge bg-secondary">Used</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success">Available</span>
                                                }
                                            }
                                        </td>
                                        <td><span class="small text-muted">@t.OccurredAt.ToString("MMM dd, yyyy")</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (_total > _pageSize)
                    {
                        var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                        <div class="d-flex justify-content-center py-3">
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(_page - 1)">&#x2039;</button>
                                    </li>
                                    @for (var pg = 1; pg <= totalPages; pg++)
                                    {
                                        var p = pg;
                                        <li class="page-item @(p == _page ? "active" : "")">
                                            <button class="page-link" @onclick="() => ChangePage(p)">@p</button>
                                        </li>
                                    }
                                    <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(_page + 1)">&#x203A;</button>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <TokenBalanceWidget MemberProfileId="@MemberProfileId" />

        <div class="card mt-3">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Quick Actions</h6>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => _showDistributeModal = true">
                        <i class="ri-share-line me-1"></i>Distribute Token
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _showPurchaseModal = true">
                        <i class="ri-shopping-cart-line me-1"></i>Purchase Tokens
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool _isLoading = true;
    private int  _page = 1, _pageSize = 20, _total;
    private bool _showDistributeModal;
    private bool _showPurchaseModal;
    private List<TokenTransactionDto> _items = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new("Dashboard", "/dashboard"),
        new("Tokens")
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await LoadPageAsync(1);
    }

    private async Task ChangePage(int page) => await LoadPageAsync(page);

    private async Task LoadPageAsync(int page)
    {
        _page = page; _isLoading = true; StateHasChanged();
        // TODO: GET /api/v1/bizcenter/tokens?memberId={MemberProfileId}&page={page}&pageSize={_pageSize}
        await Task.Delay(50);
        _isLoading = false;
    }

    public record TokenTransactionDto(
        string    TokenTypeName,
        string    TransactionType,
        string?   TokenCode,
        bool      IsUsed,
        int       Amount,
        DateTime  OccurredAt,
        string?   Notes);
}
