@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

<BreadcrumbNav Items="@_breadcrumb" />

<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6">
        <StatCard Title="@L["DualResidual.LeftLeg"].Value" Value="@_leftPoints.ToString("N0")" Icon="ri-arrow-left-circle-line" Color="primary" />
    </div>
    <div class="col-12 col-sm-6">
        <StatCard Title="@L["DualResidual.RightLeg"].Value" Value="@_rightPoints.ToString("N0")" Icon="ri-arrow-right-circle-line" Color="info" />
    </div>
</div>

<div class="card">
    <div class="card-header py-3">
        <h6 class="card-title mb-0 fw-semibold">@L["DualResidual.HistoryTitle"]</h6>
    </div>
    <div class="card-body p-0">
        <LoadingSpinner IsLoading="@_isLoading" />
        @if (!_isLoading)
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th>@L["Reports.Period"]</th>
                            <th>@L["DualResidual.WeakLeg"]</th>
                            <th>@L["Common.Amount"]</th>
                            <th>@L["Reports.PaymentDate"]</th>
                            <th>@L["Common.Status"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_items.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">@L["Common.NoDataAvailable"]</td></tr>
                        }
                        @foreach (var dr in _items)
                        {
                            <tr>
                                <td>@dr.Period</td>
                                <td>@dr.WeakLegPoints.ToString("N0")</td>
                                <td><span class="fw-semibold">@dr.Amount.ToString("C")</span></td>
                                <td>@(dr.PaymentDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                <td><StatusBadge Status="@dr.Status" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_total > _pageSize)
            {
                var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                <div class="d-flex justify-content-center py-3">
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page - 1)">&#x2039;</button>
                            </li>
                            @for (var pg = 1; pg <= totalPages; pg++)
                            {
                                var p = pg;
                                <li class="page-item @(p == _page ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(p)">@p</button>
                                </li>
                            }
                            <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page + 1)">&#x203A;</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool    _isLoading   = true;
    private int     _page = 1, _pageSize = 20, _total;
    private decimal _leftPoints;
    private decimal _rightPoints;
    private List<DualResidualDto> _items = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new(L["UserProfile.Breadcrumb.Dashboard"].Value, "/dashboard"),
        new(L["Sidebar.Commissions"].Value, "/commissions"),
        new(L["DualResidual.Breadcrumb"].Value)
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await LoadPageAsync(1);
    }

    private async Task ChangePage(int page) => await LoadPageAsync(page);

    private async Task LoadPageAsync(int page)
    {
        _page = page; _isLoading = true; StateHasChanged();
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<DualResidualReportData>>(
                $"api/v1/bizcenter/commissions/dual-residual?page={page}&pageSize={_pageSize}");
            if (response?.Success == true && response.Data is not null)
            {
                _items       = response.Data.Items;
                _total       = response.Data.TotalCount;
                _leftPoints  = response.Data.LeftLegPoints;
                _rightPoints = response.Data.RightLegPoints;
            }
        }
        catch { /* silently degrade */ }
        finally { _isLoading = false; }
    }

    private class ApiResponse<T>  { public bool Success { get; set; } public T? Data { get; set; } }
    private class DualResidualReportData
    {
        public decimal            LeftLegPoints  { get; set; }
        public decimal            RightLegPoints { get; set; }
        public List<DualResidualDto> Items       { get; set; } = new();
        public int                TotalCount     { get; set; }
    }

    public record DualResidualDto(
        string    Period,
        decimal   WeakLegPoints,
        decimal   Amount,
        DateTime? PaymentDate,
        string    Status);
}
