@inject IViewContextService ViewContext
@inject HttpClient Http

@using MLMConquerorGlobalEdition.SharedComponents.Constants

<div class="card">
    <div class="card-header py-3">
        <h6 class="card-title mb-0 fw-semibold">Commission Earnings</h6>
    </div>
    <div class="card-body p-0">
        <LoadingSpinner IsLoading="@_isLoading" />
        @if (!_isLoading)
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Period</th>
                            <th>Payment Date</th>
                            <th>Status</th>
                            @if (ViewContext.HasPermission(Permissions.Commission.Delete) || ViewContext.HasPermission(Permissions.Commission.ForcePay))
                            {
                                <th class="text-end">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_items.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">No data available.</td></tr>
                        }
                        @foreach (var e in _items)
                        {
                            <tr>
                                <td>@e.CommissionType</td>
                                <td><span class="fw-semibold">@e.Amount.ToString("C")</span></td>
                                <td>@e.PeriodDate.ToString("MMM yyyy")</td>
                                <td>@(e.PaymentDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                <td><StatusBadge Status="@e.Status" /></td>
                                @if (ViewContext.HasPermission(Permissions.Commission.Delete) || ViewContext.HasPermission(Permissions.Commission.ForcePay))
                                {
                                    <td class="text-end">
                                        @if (e.Status == "Pending")
                                        {
                                            <AdminOnlyWrapper Permission="@Permissions.Commission.ForcePay">
                                                <button class="btn btn-xs btn-outline-success me-1"
                                                        @onclick="() => ForcePay(e.Id)"
                                                        title="Force Pay">
                                                    <i class="ri-money-dollar-circle-line"></i>
                                                </button>
                                            </AdminOnlyWrapper>
                                            <AdminOnlyWrapper Permission="@Permissions.Commission.Delete">
                                                <button class="btn btn-xs btn-outline-danger"
                                                        @onclick="() => ConfirmDelete(e.Id)"
                                                        title="Delete">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            </AdminOnlyWrapper>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_total > _pageSize)
            {
                var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                <div class="d-flex justify-content-center py-3">
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page - 1)">&#x2039;</button>
                            </li>
                            @for (var pg = 1; pg <= totalPages; pg++)
                            {
                                var p = pg;
                                <li class="page-item @(p == _page ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(p)">@p</button>
                                </li>
                            }
                            <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page + 1)">&#x203A;</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@if (_showDeleteConfirm)
{
    <ConfirmModal IsVisible="true"
                  Title="Delete Commission"
                  Message="Are you sure you want to delete this unpaid commission? This action cannot be undone."
                  ConfirmLabel="Delete"
                  ConfirmColor="danger"
                  IsBusy="@_actionBusy"
                  OnConfirm="ExecuteDeleteAsync"
                  OnCancel="@(() => { _showDeleteConfirm = false; _targetId = null; })" />
}

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool    _isLoading        = true;
    private int     _page             = 1;
    private int     _pageSize         = 20;
    private int     _total;
    private bool    _showDeleteConfirm;
    private bool    _actionBusy;
    private string? _targetId;

    private List<CommissionEarningDto> _items = new();

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await LoadPageAsync(1);
    }

    private async Task ChangePage(int page) => await LoadPageAsync(page);

    private async Task LoadPageAsync(int page)
    {
        _page      = page;
        _isLoading = true;
        StateHasChanged();

        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<PagedData<CommissionEarningDto>>>(
                $"api/v1/bizcenter/commissions?page={page}&pageSize={_pageSize}");

            if (response?.Success == true && response.Data is not null)
            {
                _items = response.Data.Items;
                _total = response.Data.TotalCount;
            }
        }
        catch { /* silently degrade */ }
        finally { _isLoading = false; }
    }

    private void ConfirmDelete(string id)
    {
        _targetId          = id;
        _showDeleteConfirm = true;
    }

    private async Task ExecuteDeleteAsync()
    {
        _actionBusy = true;
        await Http.DeleteAsync($"api/v1/admin/commissions/{_targetId}");
        _showDeleteConfirm = false;
        _actionBusy        = false;
        _targetId          = null;
        await LoadPageAsync(_page);
    }

    private async Task ForcePay(string id)
    {
        await Http.PostAsJsonAsync("api/v1/admin/commissions/pay", new { CommissionId = id });
        await LoadPageAsync(_page);
    }

    private class ApiResponse<T> { public bool Success { get; set; } public T? Data { get; set; } }
    private class PagedData<T>   { public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    public record CommissionEarningDto(
        string    Id,
        string    CommissionType,
        decimal   Amount,
        DateTime  PeriodDate,
        DateTime? PaymentDate,
        string    Status);
}
