@inject HttpClient Http
@using System.Net.Http.Json

<style>
    .row-click {
        cursor: pointer;
    }
</style>

@if (ShowBreadcrumb)
{
    <BreadcrumbNav Items="@_breadcrumb" />
}

<!-- Current Progress Stat Cards -->
<div class="row justify-content-center">
    <div class="col-xxl-12 col-lg-12">
        <div class="card bg-white border-0 rounded-3 mb-4">
            <div class="card-body p-4" style="padding-bottom: 0 !important;">
                <div class="mb-3 mb-lg-4">
                    <h3 class="mb-0">Current Progress: @DateTime.UtcNow.ToString("MMMM")</h3>
                </div>
                <div class="row">
                    <div class="col-xxl-4 col-xl-4 col-sm-4">
                        <div class="card rounded-3 mb-4 stats-box style-three" style="background-color: #EDE9FE; border: 1px solid #C4B5FD;">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <i class="material-symbols-outlined fs-40" style="color: #4338CA;">functions</i>
                                    </div>
                                    <div class="flex-grow-1 ms-2">
                                        <span>Total Points</span>
                                        @if (_statsLoading) { <span class="placeholder col-6 d-block mt-1"></span> }
                                        else { <h3 class="fs-20 mt-1 mb-0">@_totalPoints.ToString("N0")</h3> }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xxl-4 col-xl-4 col-sm-4">
                        <div class="card bg-danger bg-opacity-10 border-danger border-opacity-10 rounded-3 mb-4 stats-box style-three">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <i class="material-symbols-outlined fs-40 text-danger">done_all</i>
                                    </div>
                                    <div class="flex-grow-1 ms-2">
                                        <span>Total Eligible Points</span>
                                        @if (_statsLoading) { <span class="placeholder col-6 d-block mt-1"></span> }
                                        else { <h3 class="fs-20 mt-1 mb-0">@_eligiblePoints.ToString("N0")</h3> }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-xxl-4 col-xl-4 col-sm-4">
                        <div class="card bg-success bg-opacity-10 border-success border-opacity-10 rounded-3 mb-4 stats-box style-three">
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center">
                                    <div class="flex-shrink-0">
                                        <i class="material-symbols-outlined fs-40 text-success">stacks</i>
                                    </div>
                                    <div class="flex-grow-1 ms-2">
                                        <span>Progress</span>
                                        @if (_statsLoading) { <span class="placeholder col-6 d-block mt-1"></span> }
                                        else { <h3 class="fs-20 mt-1 mb-0">@_progressPercent%</h3> }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Ambassador Breakdown Table -->
<div class="card bg-white border-0 rounded-3 mb-4">
    <div class="card-body p-0">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 p-4">
            <form class="position-relative table-src-form me-0">
                <input type="text" class="form-control" placeholder="Search here"
                       value="@_ambassadorSearch"
                       @oninput="OnAmbassadorSearchInput" />
                <i class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y">search</i>
            </form>
        </div>

        <LoadingSpinner IsLoading="@_ambassadorLoading" />
        @if (!_ambassadorLoading)
        {
            <div class="default-table-area style-two default-table-width">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">Ambassador</th>
                                <th scope="col">Total Points</th>
                                <th scope="col">Eligible Points</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var amb in AmbassadorPaged)
                            {
                                var pct = amb.TotalPoints > 0
                                    ? (int)Math.Min(100, Math.Round(amb.EligiblePoints / (double)amb.TotalPoints * 100))
                                    : 0;
                                var ambLocal = amb;
                                <tr class="row-click" @onclick="() => OpenBranchModalAsync(ambLocal)">
                                    <td class="text-primary fw-medium" style="cursor:pointer;">@amb.AmbassadorName</td>
                                    <td class="text-body">@amb.TotalPoints.ToString("N0")</td>
                                    <td>
                                        <div style="position:relative;width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:conic-gradient(#605DFF @(pct)%, #ECEEF2 @(pct)%);">
                                            <div style="position:absolute;width:80%;height:80%;background-color:#ffffff;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                                <p class="text-body fw-semibold mb-0" style="font-size:12px;">@amb.EligiblePoints</p>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!AmbassadorFiltered.Any())
                            {
                                <tr><td colspan="3" class="text-center text-muted py-4">No data available.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (AmbassadorFiltered.Any())
                {
                    <div class="p-4 pt-lg-4">
                        <div class="d-flex justify-content-center justify-content-sm-between align-items-center text-center flex-wrap gap-2 showing-wrap">
                            <span class="fs-12 fw-medium">Showing @AmbassadorPaged.Count() of @AmbassadorFiltered.Count Results</span>
                            @if (AmbassadorFiltered.Count > _ambassadorPageSize)
                            {
                                var totalAmbPages = (int)Math.Ceiling((double)AmbassadorFiltered.Count / _ambassadorPageSize);
                                <nav aria-label="Ambassador pagination">
                                    <ul class="pagination mb-0 justify-content-center">
                                        <li class="page-item @(_ambassadorPage <= 1 ? "disabled" : "")">
                                            <button type="button" class="page-link icon" @onclick="() => GoToAmbassadorPage(_ambassadorPage - 1)" aria-label="Previous">
                                                <i class="material-symbols-outlined">keyboard_arrow_left</i>
                                            </button>
                                        </li>
                                        @for (var pg = 1; pg <= totalAmbPages; pg++)
                                        {
                                            var p = pg;
                                            <li class="page-item @(p == _ambassadorPage ? "active" : "")">
                                                <button type="button" class="page-link" @onclick="() => GoToAmbassadorPage(p)">@p</button>
                                            </li>
                                        }
                                        <li class="page-item @(_ambassadorPage >= totalAmbPages ? "disabled" : "")">
                                            <button type="button" class="page-link icon" @onclick="() => GoToAmbassadorPage(_ambassadorPage + 1)" aria-label="Next">
                                                <i class="material-symbols-outlined">keyboard_arrow_right</i>
                                            </button>
                                        </li>
                                    </ul>
                                </nav>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- History Table -->
<div class="card bg-white border-0 rounded-3 mb-4">
    <div class="card-body p-0">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 p-4">
            <div class="mb-3 mb-lg-4 w-100">
                <h3 class="mb-0">History</h3>
            </div>
            <form class="position-relative table-src-form me-0">
                <input type="text" class="form-control" placeholder="Search here"
                       value="@_search"
                       @oninput="OnSearchInput" />
                <i class="material-symbols-outlined position-absolute top-50 start-0 translate-middle-y">search</i>
            </form>
            <div class="d-flex gap-2">
                <input class="form-control" style="max-width:140px"
                       type="date"
                       value="@(_from?.ToString("yyyy-MM-dd"))"
                       @onchange="OnFromChange" />
                <input class="form-control" style="max-width:140px"
                       type="date"
                       value="@(_to?.ToString("yyyy-MM-dd"))"
                       @onchange="OnToChange" />
            </div>
        </div>

        <LoadingSpinner IsLoading="@_isLoading" />
        @if (!_isLoading)
        {
            <div class="default-table-area style-two default-table-width">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th scope="col">Earned Date</th>
                                <th scope="col">Amount</th>
                                <th scope="col">Eligible Points</th>
                                <th scope="col">Paid</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Filtered)
                            {
                                var statusBadgeClass = item.Status?.ToLower() switch
                                {
                                    "paid"    => "badge bg-success bg-opacity-10 text-success p-2 fs-12 fw-normal",
                                    "pending" => "badge bg-warning bg-opacity-10 text-warning p-2 fs-12 fw-normal",
                                    _         => "badge bg-secondary bg-opacity-10 text-secondary p-2 fs-12 fw-normal"
                                };
                                <tr>
                                    <td class="text-body">@item.EarnedDate.ToString("MM/dd/yyyy")</td>
                                    <td class="text-body">@item.Amount.ToString("C")</td>
                                    <td class="text-body">@item.EligiblePoints.ToString("N0")</td>
                                    <td><span class="@statusBadgeClass">@item.Status</span></td>
                                </tr>
                            }
                            @if (!Filtered.Any())
                            {
                                <tr><td colspan="4" class="text-center text-muted py-4">No car bonus data available.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="p-4 pt-lg-4">
                    <div class="d-flex justify-content-center justify-content-sm-between align-items-center text-center flex-wrap gap-2 showing-wrap">
                        <span class="fs-12 fw-medium">Showing @Filtered.Count() of @_total Results</span>
                        @if (_total > _pageSize)
                        {
                            var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                            <nav aria-label="Car Bonus pagination">
                                <ul class="pagination mb-0 justify-content-center">
                                    <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                        <button type="button" class="page-link icon" @onclick="() => LoadPageAsync(_page - 1)" aria-label="Previous">
                                            <i class="material-symbols-outlined">keyboard_arrow_left</i>
                                        </button>
                                    </li>
                                    @for (var pg = 1; pg <= totalPages; pg++)
                                    {
                                        var p = pg;
                                        <li class="page-item @(p == _page ? "active" : "")">
                                            <button type="button" class="page-link" @onclick="() => LoadPageAsync(p)">@p</button>
                                        </li>
                                    }
                                    <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                        <button type="button" class="page-link icon" @onclick="() => LoadPageAsync(_page + 1)" aria-label="Next">
                                            <i class="material-symbols-outlined">keyboard_arrow_right</i>
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Branch Detail Modal -->
@if (_branchModalVisible)
{
    <div class="modal-backdrop fade show"></div>
}
<div class="modal fade @(_branchModalVisible ? "show" : "")" id="branchModal" tabindex="-1" aria-hidden="@(!_branchModalVisible)"
     style="display: @(_branchModalVisible ? "block" : "none");"
     role="dialog">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <div>
                    <div class="text-primary fw-semibold small d-flex align-items-center">
                        <i class="ri-share-forward-line me-1"></i> Enrollment Team • Branch
                    </div>
                    <h5 class="modal-title mt-1">@_branchModalTitle</h5>
                    <div class="text-secondary small">Total Points: @_branchModalTotalPoints</div>
                </div>
                <button type="button" class="btn-close" aria-label="Close" @onclick="CloseBranchModal"></button>
            </div>

            <div class="modal-body pt-2">
                @if (_branchLoading)
                {
                    <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
                }
                else if (!_branchDetail.Members.Any())
                {
                    <p class="text-muted text-center py-4">No members found in this branch.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Order No</th>
                                    <th>Full Name</th>
                                    <th>Membership Level</th>
                                    <th>Expiration Date</th>
                                    <th class="text-end">Points</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in _branchDetail.Members)
                                {
                                    <tr>
                                        <td class="text-muted fs-13">@m.OrderNo</td>
                                        <td class="fw-medium">@m.FullName</td>
                                        <td>@m.MembershipLevel</td>
                                        <td class="text-muted fs-13">@(m.ExpirationDate.HasValue ? m.ExpirationDate.Value.ToString("MM/dd/yyyy") : "—")</td>
                                        <td class="text-end fw-semibold text-primary">@m.Points</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" @onclick="CloseBranchModal">Close</button>
                <button type="button" class="btn btn-primary">Export list</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;
    [Parameter] public string ApiBaseUrl     { get; set; } = "api/v1/bizcenter/commissions";
    [Parameter] public string TeamApiBaseUrl { get; set; } = "api/v1/bizcenter/team";
    [Parameter] public bool   ShowBreadcrumb { get; set; } = true;

    // History table state
    private bool    _isLoading  = true;
    private int     _page = 1, _pageSize = 20, _total;
    private string    _search = string.Empty;
    private DateTime? _from;
    private DateTime? _to;
    private List<EarningItem> _items = new();

    // Stat cards state
    private bool    _statsLoading     = true;
    private decimal _totalPoints;
    private decimal _eligiblePoints;
    private int     _progressPercent;

    // Ambassador breakdown state (client-side paging)
    private bool    _ambassadorLoading = true;
    private string  _ambassadorSearch  = string.Empty;
    private int     _ambassadorPage    = 1;
    private int     _ambassadorPageSize = 10;
    private List<AmbassadorBreakdownItem> _ambassadorItems = new();

    // Branch modal state
    private bool             _branchModalVisible;
    private bool             _branchLoading;
    private string           _branchModalTitle       = string.Empty;
    private string           _branchModalTotalPoints = "0";
    private BranchDetailDto  _branchDetail           = new();

    private List<EarningItem> Filtered =>
        _items.Where(x => string.IsNullOrWhiteSpace(_search)
                       || x.CommissionTypeName.Contains(_search, StringComparison.OrdinalIgnoreCase))
              .ToList();

    private List<AmbassadorBreakdownItem> AmbassadorFiltered =>
        _ambassadorItems.Where(x => string.IsNullOrWhiteSpace(_ambassadorSearch)
                                 || x.AmbassadorName.Contains(_ambassadorSearch, StringComparison.OrdinalIgnoreCase))
                        .ToList();

    private IEnumerable<AmbassadorBreakdownItem> AmbassadorPaged =>
        AmbassadorFiltered
            .Skip((_ambassadorPage - 1) * _ambassadorPageSize)
            .Take(_ambassadorPageSize);

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new("Dashboard", "/dashboard"),
        new("Commissions", "/commissions"),
        new("Car Bonus")
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await Task.WhenAll(LoadStatsAsync(), LoadAmbassadorBreakdownAsync(), LoadPageAsync(1));
    }

    // ── History table input handlers ──────────────────────────────────────────

    private void OnSearchInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        _page   = 1;
    }

    private async Task OnFromChange(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        _from = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : (DateTime?)null;
        await LoadPageAsync(1);
    }

    private async Task OnToChange(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        _to = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : (DateTime?)null;
        await LoadPageAsync(1);
    }

    // ── Ambassador breakdown handlers ─────────────────────────────────────────

    private void OnAmbassadorSearchInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        _ambassadorSearch = e.Value?.ToString() ?? string.Empty;
        _ambassadorPage   = 1;
    }

    private void GoToAmbassadorPage(int page)
    {
        var total     = AmbassadorFiltered.Count;
        var totalPg   = (int)Math.Ceiling((double)total / _ambassadorPageSize);
        if (page < 1 || (totalPg > 0 && page > totalPg)) return;
        _ambassadorPage = page;
    }

    // ── Branch modal handlers ─────────────────────────────────────────────────

    private async Task OpenBranchModalAsync(AmbassadorBreakdownItem amb)
    {
        _branchModalTitle       = amb.AmbassadorName;
        _branchModalTotalPoints = amb.TotalPoints.ToString("N0");
        _branchDetail           = new BranchDetailDto();
        _branchModalVisible     = true;
        _branchLoading          = true;
        StateHasChanged();

        try
        {
            var url  = $"{ApiBaseUrl}/car-bonus/ambassadors/{amb.MemberId}/branch";
            var resp = await Http.GetFromJsonAsync<ApiWrapper<BranchDetailDto>>(url);
            if (resp?.Success == true && resp.Data is not null)
            {
                _branchDetail = resp.Data;
            }
        }
        catch
        {
            // Silently degrade — endpoint may not exist yet; leave empty list.
            _branchDetail = new BranchDetailDto();
        }
        finally
        {
            _branchLoading = false;
            StateHasChanged();
        }
    }

    private void CloseBranchModal()
    {
        _branchModalVisible = false;
    }

    // ── Loaders ───────────────────────────────────────────────────────────────

    private async Task LoadStatsAsync()
    {
        _statsLoading = true;
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<CarBonusStats>>(
                $"{ApiBaseUrl}/car-bonus/stats");
            if (resp?.Success == true && resp.Data is not null)
            {
                _totalPoints     = resp.Data.TotalPoints;
                _eligiblePoints  = resp.Data.EligiblePoints;
                _progressPercent = resp.Data.ProgressPercent;
            }
        }
        catch { /* silently degrade */ }
        finally { _statsLoading = false; }
    }

    private async Task LoadAmbassadorBreakdownAsync()
    {
        _ambassadorLoading = true;
        StateHasChanged();
        try
        {
            var url  = $"{ApiBaseUrl}/car-bonus/ambassadors";
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<AmbassadorBreakdownItem>>>(url);
            if (resp?.Success == true && resp.Data is not null)
                _ambassadorItems = resp.Data;
        }
        catch { /* silently degrade */ }
        finally { _ambassadorLoading = false; }
    }

    private async Task LoadPageAsync(int page)
    {
        _page = page; _isLoading = true; StateHasChanged();
        try
        {
            var url = $"{ApiBaseUrl}/car-bonus?page={page}&pageSize={_pageSize}";
            if (_from.HasValue) url += $"&from={_from.Value:yyyy-MM-dd}";
            if (_to.HasValue)   url += $"&to={_to.Value:yyyy-MM-dd}";
            var resp = await Http.GetFromJsonAsync<ApiWrapper<PagedData<EarningItem>>>(url);
            if (resp?.Success == true && resp.Data is not null)
            {
                _items = resp.Data.Items;
                _total = resp.Data.TotalCount;
            }
        }
        catch { /* silently degrade */ }
        finally { _isLoading = false; }
    }

    // ── Private DTOs ──────────────────────────────────────────────────────────

    private class ApiWrapper<T> { public bool Success { get; set; } public T? Data { get; set; } }
    private class PagedData<T>  { public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    private class CarBonusStats
    {
        public decimal TotalPoints     { get; set; }
        public decimal EligiblePoints  { get; set; }
        public int     ProgressPercent { get; set; }
    }

    private class AmbassadorBreakdownItem
    {
        public string  MemberId        { get; set; } = string.Empty;
        public string  AmbassadorName  { get; set; } = string.Empty;
        public decimal TotalPoints     { get; set; }
        public int     EligiblePoints  { get; set; }
    }

    private class BranchDetailDto
    {
        public List<BranchMemberDto> Members { get; set; } = new();
    }

    private class BranchMemberDto
    {
        public string    OrderNo         { get; set; } = string.Empty;
        public string    FullName        { get; set; } = string.Empty;
        public string    MembershipLevel { get; set; } = string.Empty;
        public DateTime? ExpirationDate  { get; set; }
        public int       Points          { get; set; }
    }

    private class EarningItem
    {
        public string   CommissionTypeName { get; set; } = string.Empty;
        public decimal  Amount             { get; set; }
        public string   Status             { get; set; } = string.Empty;
        public DateTime EarnedDate         { get; set; }
        public DateTime PaymentDate        { get; set; }
        public int      EligiblePoints     { get; set; }
    }
}
