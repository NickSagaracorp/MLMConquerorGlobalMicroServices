@inject HttpClient Http
@inject IJSRuntime  JS

<BreadcrumbNav Items="@_breadcrumb" />

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <h3 class="mb-0">Marketing</h3>
</div>

<LoadingSpinner IsLoading="@_isLoading" />

@if (!_isLoading)
{
    @if (_error is not null)
    {
        <ApiErrorAlert ErrorMessage="@_error" />
    }
    else if (!_grouped.Any())
    {
        <EmptyState Icon="ri-file-list-3-line"
                    Title="No documents available"
                    Message="There are no marketing documents available at this time." />
    }
    else
    {
        var activeGroup = _grouped.FirstOrDefault(g => g.Key == _activeType) ?? _grouped.First();

        <!-- Document type tab bar -->
        <div class="d-flex justify-content-center flex-wrap gap-2 mb-4" role="tablist" aria-label="Marketing document types">
            @foreach (var group in _grouped)
            {
                var isActive = group.Key == _activeType;
                <button type="button"
                        class="btn @(isActive ? "btn-primary" : "btn-outline-primary") py-2 px-3 fw-medium"
                        @onclick="() => _activeType = group.Key"
                        role="tab"
                        aria-selected="@isActive.ToString().ToLowerInvariant()">
                    @group.Key
                </button>
            }
        </div>

        <!-- Active document type table -->
        <div class="row justify-content-center">
            <div class="col-lg-12 col-md-12">
                <div class="card border-0 rounded-3 mb-4 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 border-bottom pb-3 mb-3">
                            <h4 class="fs-18 mb-0 fw-semibold">@activeGroup.Key</h4>
                            <span class="text-muted small">@activeGroup.Count() file@(activeGroup.Count() == 1 ? "" : "s")</span>
                        </div>

                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th scope="col" class="text-secondary">File</th>
                                        <th scope="col" class="text-secondary text-end" style="width:120px;">Download</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var doc in activeGroup.OrderBy(d => d.LanguageName))
                                    {
                                        <tr @key="doc.Id">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="ri-file-3-line fs-18 text-primary me-2"></i>
                                                    <div>
                                                        <div class="fw-medium">@doc.LanguageName</div>
                                                        <small class="text-muted">@doc.OriginalFileName · @FormatFileSize(doc.FileSizeBytes)</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"
                                                        disabled="@(_downloadingId == doc.Id)"
                                                        @onclick="() => DownloadAsync(doc.Id)"
                                                        aria-label="@($"Download {doc.DocumentTypeName} in {doc.LanguageName}")">
                                                    @if (_downloadingId == doc.Id)
                                                    {
                                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                    }
                                                    else
                                                    {
                                                        <i class="ri-download-2-line"></i>
                                                    }
                                                    <span class="d-none d-sm-inline">Download</span>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_downloadError))
        {
            <div class="alert alert-danger alert-dismissible mt-3">
                @_downloadError
                <button type="button" class="btn-close" @onclick="() => _downloadError = null" aria-label="Close"></button>
            </div>
        }
    }
}

@code {
    private bool    _isLoading = true;
    private string? _error;
    private string? _downloadError;
    private int?    _downloadingId;
    private string  _activeType = string.Empty;

    private List<MarketingDocumentSummaryDto> _items = new();
    private List<IGrouping<string, MarketingDocumentSummaryDto>> _grouped = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new("Dashboard", "/dashboard"),
        new("Marketing")
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error     = null;
        StateHasChanged();

        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<MarketingDocumentSummaryDto>>>(
                "api/v1/bizcenter/marketing-documents");

            if (resp?.Success == true && resp.Data is not null)
            {
                _items   = resp.Data;
                _grouped = _items
                    .GroupBy(d => d.DocumentTypeName)
                    .OrderBy(g => g.Key)
                    .ToList();

                if (_grouped.Any() && string.IsNullOrEmpty(_activeType))
                    _activeType = _grouped.First().Key;
            }
            else
            {
                _error = "Failed to load marketing documents.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DownloadAsync(int id)
    {
        _downloadError = null;
        _downloadingId = id;
        StateHasChanged();

        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<string>>(
                $"api/v1/bizcenter/marketing-documents/{id}/download");

            if (resp?.Success == true && !string.IsNullOrWhiteSpace(resp.Data))
            {
                await JS.InvokeVoidAsync("open", resp.Data, "_blank");
            }
            else
            {
                _downloadError = "Could not generate download link. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _downloadError = ex.Message;
        }
        finally
        {
            _downloadingId = null;
            StateHasChanged();
        }
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1_024)     return $"{bytes / 1_024.0:F0} KB";
        return $"{bytes} B";
    }

    // ── DTOs (deserialization only) ───────────────────────────────
    private record MarketingDocumentSummaryDto(
        int    Id,
        string Title,
        string DocumentTypeName,
        string LanguageCode,
        string LanguageName,
        string OriginalFileName,
        long   FileSizeBytes,
        string ContentType);

    private record ApiResp<T>(bool Success, T? Data, string? ErrorCode);
}
