@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

@using Microsoft.Extensions.Localization
@using MLMConquerorGlobalEdition.SharedComponents.Resources
@using MLMConquerorGlobalEdition.SharedComponents.Components.Placement

<div class="modal fade show d-block"
     role="dialog"
     aria-modal="true"
     aria-labelledby="wizard-title"
     style="background:rgba(0,0,0,0.5)"
     @onkeydown="HandleKeyDown">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-0" id="wizard-title">
                        <i class="ri-user-add-line me-2 text-primary" aria-hidden="true"></i>
                        @(Placement.IsAlreadyPlaced ? L["Placement.WizardTitleMove"] : L["Placement.WizardTitlePlace"])
                    </h5>
                    <div class="text-muted small mt-1">
                        @Placement.FullName — @Placement.MemberCode
                    </div>
                </div>
                <button type="button"
                        class="btn-close"
                        aria-label="@L["Placement.WizardCloseAria"]"
                        @onclick="Cancel"
                        disabled="@_isBusy"></button>
            </div>

            <!-- Stepper -->
            <div class="modal-body border-bottom pb-3">
                <nav class="placement-stepper" aria-label="@L["Placement.WizardStepperAria"]">
                    @foreach (var (step, i) in _steps.Select((s, i) => (s, i)))
                    {
                        <div class="placement-step @StepClass(i)"
                             aria-current="@(i == _currentStep ? "step" : null)">
                            <div class="placement-step-dot">
                                @if (i < _currentStep)
                                {
                                    <i class="ri-check-line" aria-hidden="true"></i>
                                }
                                else
                                {
                                    <span>@(i + 1)</span>
                                }
                            </div>
                            <div class="placement-step-label">@step</div>
                        </div>
                    }
                </nav>
            </div>

            <!-- Step content -->
            <div class="modal-body" style="min-height:240px">

                @if (_error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-2 mb-3"
                         role="alert">
                        <i class="ri-error-warning-line fs-5 flex-shrink-0" aria-hidden="true"></i>
                        <div>@_error</div>
                    </div>
                }

                @* ── Step 0: Confirm member ────────────────────────────────────── *@
                @if (_currentStep == 0)
                {
                    <div>
                        <h6 class="fw-semibold mb-3">@L["Placement.Step0Heading"]</h6>
                        <div class="card border-0 bg-light p-3">
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(Placement.PhotoUrl))
                                {
                                    <img src="@Placement.PhotoUrl"
                                         alt="@string.Format(L["Placement.PhotoAlt"], Placement.FullName)"
                                         class="rounded-circle"
                                         style="width:56px;height:56px;object-fit:cover"
                                         loading="lazy" />
                                }
                                else
                                {
                                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:56px;height:56px"
                                         aria-hidden="true">
                                        <i class="ri-user-line text-primary fs-4"></i>
                                    </div>
                                }
                                <div>
                                    <div class="fw-semibold fs-6">@Placement.FullName</div>
                                    <div class="text-muted small">@Placement.MemberCode</div>
                                    <div class="text-muted small">
                                        @L["Placement.Recruited"] @Placement.EnrolledAt.ToString("dd MMM yyyy")
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (!Placement.IsWindowExpired)
                        {
                            <div class="alert alert-info d-flex gap-2 mt-3 mb-0 small"
                                 role="note">
                                <i class="ri-information-line flex-shrink-0" aria-hidden="true"></i>
                                <div>
                                    @string.Format(L["Placement.WindowInfo"], Placement.DaysRemainingInWindow, 2 - Placement.PlacementOpportunitiesUsed)
                                </div>
                            </div>
                        }
                    </div>
                }

                @* ── Step 1: Select node ──────────────────────────────────────── *@
                @if (_currentStep == 1)
                {
                    <div>
                        <h6 class="fw-semibold mb-1">@L["Placement.Step1Heading"]</h6>
                        <p class="text-muted small mb-3">
                            @L["Placement.Step1Help"]
                        </p>

                        @if (_isLoadingNodes)
                        {
                            <div class="text-center py-4" role="status" aria-label="@L["Placement.LoadingTreeAria"]">
                                <div class="spinner-border text-primary" aria-hidden="true"></div>
                                <div class="text-muted small mt-2">@L["Placement.LoadingTreeMsg"]</div>
                            </div>
                        }
                        else if (_availableNodes == null || !_availableNodes.Nodes.Any())
                        {
                            <EmptyState Icon="ri-node-tree"
                                        Title="@L["Placement.NoNodesTitle"]"
                                        Message="@L["Placement.NoNodesMessage"]" />
                        }
                        else
                        {
                            <div class="mb-3 d-flex align-items-center gap-2">
                                <i class="ri-user-star-line text-primary" aria-hidden="true"></i>
                                <span class="small">
                                    @L["Placement.SponsorLabel2"] <strong>@_availableNodes.SponsorFullName</strong>
                                </span>
                            </div>

                            <PlacementNodeSelector Nodes="@_availableNodes.Nodes"
                                                   SelectedParentId="@_selectedParentId"
                                                   SelectedSide="@_selectedSide"
                                                   OnSelect="@OnNodeSelected" />
                        }
                    </div>
                }

                @* ── Step 2: Confirm ──────────────────────────────────────────── *@
                @if (_currentStep == 2)
                {
                    <div>
                        <h6 class="fw-semibold mb-3">@L["Placement.Step2Heading"]</h6>

                        <dl class="row small">
                            <dt class="col-5 text-muted fw-normal">@L["Placement.MemberLabel"]</dt>
                            <dd class="col-7 fw-semibold">@Placement.FullName</dd>

                            <dt class="col-5 text-muted fw-normal">@L["Placement.TargetNodeLabel"]</dt>
                            <dd class="col-7 fw-semibold">@_selectedParentName</dd>

                            <dt class="col-5 text-muted fw-normal">@L["Placement.LegLabel"]</dt>
                            <dd class="col-7">
                                <span class="badge bg-@(_selectedSide == "Left" ? "primary" : "info")">
                                    @(_selectedSide == "Left" ? L["Placement.LeftLeg"] : L["Placement.RightLeg"])
                                </span>
                            </dd>

                            <dt class="col-5 text-muted fw-normal">@L["Placement.OpportunitiesAfterLabel"]</dt>
                            <dd class="col-7">
                                @(2 - Placement.PlacementOpportunitiesUsed - 1) @L["Placement.RemainingSuffix"]
                            </dd>
                        </dl>

                        @if (2 - Placement.PlacementOpportunitiesUsed - 1 == 0)
                        {
                            <div class="alert alert-warning d-flex gap-2 small mb-0"
                                 role="alert">
                                <i class="ri-alert-line flex-shrink-0" aria-hidden="true"></i>
                                <div>
                                    <strong>@L["Placement.LastOpportunityTitle"]</strong>
                                    @L["Placement.LastOpportunityBody"]
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Footer -->
            <div class="modal-footer justify-content-between">
                <button class="btn btn-ghost btn-sm text-muted"
                        @onclick="Cancel"
                        disabled="@_isBusy"
                        type="button"
                        aria-label="@L["Placement.WizardCancelAria"]">
                    <i class="ri-close-line me-1" aria-hidden="true"></i>
                    @L["Placement.WizardCancel"]
                </button>

                <div class="d-flex gap-2">
                    @if (_currentStep > 0)
                    {
                        <button class="btn btn-outline-secondary btn-sm"
                                @onclick="PrevStep"
                                disabled="@_isBusy"
                                type="button">
                            <i class="ri-arrow-left-line me-1" aria-hidden="true"></i>
                            @L["Placement.WizardPrev"]
                        </button>
                    }

                    @if (_currentStep < _steps.Length - 1)
                    {
                        <button class="btn btn-primary btn-sm"
                                @onclick="NextStep"
                                disabled="@(!CanProceed || _isBusy)"
                                type="button">
                            @L["Placement.WizardNext"]
                            <i class="ri-arrow-right-line ms-1" aria-hidden="true"></i>
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-success btn-sm"
                                @onclick="ConfirmPlacement"
                                disabled="@_isBusy"
                                type="button"
                                aria-label="@L["Placement.WizardConfirmAria"]">
                            @if (_isBusy)
                            {
                                <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
                                <span class="visually-hidden">@L["Placement.Processing"]</span>
                            }
                            <i class="ri-check-line me-1" aria-hidden="true"></i>
                            @L["Placement.WizardConfirm"]
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public PlacementPage.PendingPlacementDto Placement { get; set; } = default!;

    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public EventCallback OnCancel  { get; set; }

    private string[] _steps => new[]
    {
        L["Placement.StepMember"].Value,
        L["Placement.StepSelectNode"].Value,
        L["Placement.StepConfirm"].Value
    };
    private int    _currentStep      = 0;
    private bool   _isBusy;
    private bool   _isLoadingNodes;
    private string? _error;

    private AvailableNodesResponse? _availableNodes;
    private string? _selectedParentId;
    private string? _selectedSide;
    private string? _selectedParentName;

    private bool CanProceed => _currentStep switch
    {
        0 => true,
        1 => !string.IsNullOrEmpty(_selectedParentId) && !string.IsNullOrEmpty(_selectedSide),
        _ => true
    };

    private string StepClass(int index) =>
        index < _currentStep ? "done"
        : index == _currentStep ? "active"
        : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (Placement.IsAlreadyPlaced)
        {
            // Pre-select current position (it will be overridden by user selection)
            _selectedParentId = Placement.CurrentParentMemberId;
            _selectedSide     = Placement.CurrentTreeSide;
        }
    }

    private async Task NextStep()
    {
        _error = null;

        if (_currentStep == 0)
        {
            // Load available nodes when entering step 1
            await LoadAvailableNodesAsync();
        }

        if (_currentStep == 1 && string.IsNullOrEmpty(_selectedParentId))
        {
            _error = L["Placement.SelectNodeBeforeContinue"];
            return;
        }

        _currentStep++;
    }

    private void PrevStep()
    {
        _error = null;
        if (_currentStep > 0) _currentStep--;
    }

    private async Task LoadAvailableNodesAsync()
    {
        _isLoadingNodes = true;
        _error          = null;
        StateHasChanged();

        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResponseWrapper<AvailableNodesResponse>>(
                $"api/v1/bizcenter/placement/available-nodes/{Placement.MemberId}");
            _availableNodes = resp?.Data;
        }
        catch (Exception ex)
        {
            _error = $"{L["Placement.LoadTreeError"]} {ex.Message}";
        }
        finally
        {
            _isLoadingNodes = false;
        }
    }

    private void OnNodeSelected((string ParentId, string Side, string ParentName) selection)
    {
        _selectedParentId   = selection.ParentId;
        _selectedSide       = selection.Side;
        _selectedParentName = selection.ParentName;
    }

    private async Task ConfirmPlacement()
    {
        _isBusy = true;
        _error  = null;

        try
        {
            var payload = new
            {
                MemberToPlaceId      = Placement.MemberId,
                TargetParentMemberId = _selectedParentId,
                Side                 = _selectedSide
            };

            var resp = await Http.PostAsJsonAsync("api/v1/bizcenter/placement", payload);

            if (resp.IsSuccessStatusCode)
            {
                await OnSuccess.InvokeAsync();
            }
            else
            {
                var err = await resp.Content.ReadFromJsonAsync<ApiResponseWrapper<object>>();
                _error = err?.Message ?? L["Placement.SaveError"];
                _currentStep = 2; // Stay on confirm step
            }
        }
        catch (Exception ex)
        {
            _error = $"{L["Placement.UnexpectedErrorPrefix"]} {ex.Message}";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && !_isBusy)
            await Cancel();
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();

    private class ApiResponseWrapper<T>
    {
        public bool    Success { get; set; }
        public T?      Data    { get; set; }
        public string? Message { get; set; }
    }

    public class AvailableNodesResponse
    {
        public string SponsorMemberId { get; set; } = string.Empty;
        public string SponsorFullName { get; set; } = string.Empty;
        public List<PlacementTreeNodeDto> Nodes { get; set; } = new();
    }

    public class PlacementTreeNodeDto
    {
        public string  MemberId        { get; set; } = string.Empty;
        public string  FullName        { get; set; } = string.Empty;
        public string  MemberCode      { get; set; } = string.Empty;
        public string? PhotoUrl        { get; set; }
        public string? LeftChildId     { get; set; }
        public string? LeftChildName   { get; set; }
        public string? RightChildId    { get; set; }
        public string? RightChildName  { get; set; }
        public bool    IsLeftAvailable  { get; set; }
        public bool    IsRightAvailable { get; set; }
        public string? ParentMemberId  { get; set; }
        public int     Depth           { get; set; }
    }
}
