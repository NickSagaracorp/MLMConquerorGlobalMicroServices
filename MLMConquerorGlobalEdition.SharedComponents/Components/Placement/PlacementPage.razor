@inject HttpClient Http
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

@using Microsoft.Extensions.Localization
@using MLMConquerorGlobalEdition.SharedComponents.Resources
@using MLMConquerorGlobalEdition.SharedComponents.Constants

<BreadcrumbNav Items="@_breadcrumb" />

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h4 class="mb-0 fw-semibold">@L["Placement.Title"]</h4>
        <p class="text-muted small mb-0 mt-1">
            @L["Placement.Subtitle"]
        </p>
    </div>
    <a class="btn btn-outline-secondary btn-sm" href="@HistoryRoute">
        <i class="ri-history-line me-1" aria-hidden="true"></i>
        @L["Placement.ViewHistory"]
    </a>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <StatCard Title="@L["Placement.StatPending"]"
                  Value="@_pendingCount.ToString()"
                  Icon="ri-user-add-line"
                  Color="warning" />
    </div>
    <div class="col-6 col-md-3">
        <StatCard Title="@L["Placement.StatPlaced"]"
                  Value="@_placedCount.ToString()"
                  Icon="ri-checkbox-circle-line"
                  Color="success" />
    </div>
    <div class="col-6 col-md-3">
        <StatCard Title="@L["Placement.StatAutoPlaced"]"
                  Value="@_autoPlacedCount.ToString()"
                  Icon="ri-robot-line"
                  Color="info" />
    </div>
    <div class="col-6 col-md-3">
        <StatCard Title="@L["Placement.StatExpired"]"
                  Value="@_expiredCount.ToString()"
                  Icon="ri-time-line"
                  Color="danger" />
    </div>
</div>

<!-- Main content -->
@if (_isLoading)
{
    <!-- Skeleton loader -->
    <div role="status" aria-label="@L["Placement.LoadingPlacements"]">
        @for (int i = 0; i < 3; i++)
        {
            <div class="placement-card mb-3 skeleton-card" aria-hidden="true">
                <div class="d-flex gap-3 align-items-center">
                    <div class="rounded-circle bg-secondary bg-opacity-10"
                         style="width:48px;height:48px;min-width:48px"></div>
                    <div class="flex-grow-1">
                        <div class="bg-secondary bg-opacity-10 rounded mb-2"
                             style="height:16px;width:60%"></div>
                        <div class="bg-secondary bg-opacity-10 rounded"
                             style="height:12px;width:40%"></div>
                    </div>
                </div>
            </div>
        }
        <span class="visually-hidden">@L["Placement.LoadingShort"]</span>
    </div>
}
else if (_error != null)
{
    <ApiErrorAlert Message="@_error" OnRetry="LoadAsync" />
}
else if (!_placements.Any())
{
    <EmptyState Icon="ri-group-line"
                Title="@L["Placement.NoneTitle"]"
                Message="@L["Placement.NoneMessage"]"
                ActionLabel="@L["Placement.ViewHistory"]"
                ActionIcon="ri-history-line"
                OnAction="@(() => Nav.NavigateTo(HistoryRoute))" />
}
else
{
    <!-- Filter tabs -->
    <ul class="nav nav-pills mb-3" role="tablist" aria-label="@L["Placement.FilterAria"]">
        @foreach (var tab in _tabs)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link @(tab == _activeTab ? "active" : "")"
                        role="tab"
                        aria-selected="@(tab == _activeTab ? "true" : "false")"
                        @onclick="() => _activeTab = tab"
                        type="button">
                    @TabLabel(tab)
                    <span class="badge bg-@(tab == _activeTab ? "white text-primary" : "secondary") ms-1">
                        @GetTabCount(tab)
                    </span>
                </button>
            </li>
        }
    </ul>

    <!-- Placement cards -->
    <div class="d-flex flex-column gap-3"
         role="list"
         aria-label="@L["Placement.ListAria"]">
        @foreach (var p in FilteredPlacements)
        {
            <div role="listitem">
                <PlacementCard Placement="@p"
                               OnPlace="@(() => OpenWizard(p))"
                               OnMove="@(() => OpenWizard(p))"
                               OnRemove="@(() => ConfirmRemove(p))" />
            </div>
        }
    </div>
}

<!-- Placement Wizard -->
@if (_wizardPlacement != null)
{
    <PlacementWizard Placement="@_wizardPlacement"
                     OnSuccess="@OnWizardSuccess"
                     OnCancel="@(() => _wizardPlacement = null)" />
}

<!-- Confirm Remove Modal -->
<ConfirmModal IsVisible="@(_removeTarget != null)"
              Title="@L["Placement.RemoveTitle"]"
              ConfirmLabel="@L["Placement.RemoveConfirmLabel"]"
              CancelLabel="@L["Common.Cancel"]"
              ConfirmColor="danger"
              IsBusy="@_isRemoving"
              OnConfirm="ExecuteRemove"
              OnCancel="@(() => _removeTarget = null)">
    <BodyContent>
        @if (_removeTarget != null)
        {
            <div class="d-flex align-items-start gap-3">
                <div class="flex-shrink-0">
                    <i class="ri-alert-line fs-2 text-danger" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="mb-1">
                        @L["Placement.RemoveBodyPrefix"]
                        <strong>@_removeTarget.FullName</strong>
                        @string.Format(L["Placement.RemoveLegSuffix"], _removeTarget.CurrentTreeSide)
                    </p>
                    <p class="mb-1 text-muted small">
                        @string.Format(L["Placement.RemoveOpportunityNote"], 2 - _removeTarget.PlacementOpportunitiesUsed)
                    </p>
                    @if (_removeTarget.PlacementOpportunitiesUsed == 1)
                    {
                        <div class="alert alert-warning py-2 mb-0 mt-2 small">
                            <i class="ri-alert-line me-1" aria-hidden="true"></i>
                            <strong>@L["Placement.RemoveLastWarningTitle"]</strong>
                            @L["Placement.RemoveLastWarningBody"]
                        </div>
                    }
                </div>
            </div>
        }
    </BodyContent>
</ConfirmModal>

@code {
    [Parameter] public string HistoryRoute   { get; set; } = "/team/placement/history";
    [Parameter] public bool   IsAdminContext { get; set; }

    private bool   _isLoading = true;
    private bool   _isRemoving;
    private string? _error;

    private List<PendingPlacementDto> _placements = new();
    private PendingPlacementDto? _wizardPlacement;
    private PendingPlacementDto? _removeTarget;

    private readonly string[] _tabs = { "All", "Pending", "Placed", "Blocked" };
    private string _activeTab = "All";

    private int _pendingCount     => _placements.Count(p => p.PlacementStatus == "Unplaced");
    private int _placedCount      => _placements.Count(p => p.PlacementStatus is "Placed" or "AutoPlaced");
    private int _autoPlacedCount  => _placements.Count(p => p.PlacementStatus == "AutoPlaced");
    private int _expiredCount     => _placements.Count(p => p.PlacementStatus == "Expired");

    private IEnumerable<PendingPlacementDto> FilteredPlacements => _activeTab switch
    {
        "Pending"  => _placements.Where(p => p.PlacementStatus is "Unplaced" or "Expired"),
        "Placed"   => _placements.Where(p => p.PlacementStatus is "Placed" or "AutoPlaced"),
        "Blocked"  => _placements.Where(p => p.IsBlocked),
        _          => _placements
    };

    private int GetTabCount(string tab) => tab switch
    {
        "Pending"  => _pendingCount,
        "Placed"   => _placedCount,
        "Blocked"  => _placements.Count(p => p.IsBlocked),
        _          => _placements.Count
    };

    private string TabLabel(string tab) => tab switch
    {
        "Pending"  => L["Placement.TabPending"].Value,
        "Placed"   => L["Placement.TabPlaced"].Value,
        "Blocked"  => L["Placement.TabBlocked"].Value,
        _          => L["Placement.TabAll"].Value
    };

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new(L["Nav.Dashboard"], "/dashboard"),
        new(L["Placement.BreadcrumbTeam"], "/team"),
        new(L["Placement.BreadcrumbPlacement"])
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _error     = null;
        StateHasChanged();

        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<IEnumerable<PendingPlacementDto>>>(
                "api/v1/bizcenter/placement/pending");

            _placements = response?.Data?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            _error = $"{L["Placement.LoadFailed"]} {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenWizard(PendingPlacementDto placement)
        => _wizardPlacement = placement;

    private void ConfirmRemove(PendingPlacementDto placement)
        => _removeTarget = placement;

    private async Task ExecuteRemove()
    {
        if (_removeTarget is null) return;
        _isRemoving = true;

        try
        {
            var resp = await Http.DeleteAsync(
                $"api/v1/bizcenter/placement/{_removeTarget.MemberId}");

            if (resp.IsSuccessStatusCode)
            {
                _removeTarget  = null;
                await LoadAsync();
            }
            else
            {
                var err = await resp.Content.ReadFromJsonAsync<ApiResponse<object>>();
                _error = err?.Message ?? L["Placement.RemoveError"];
                _removeTarget = null;
            }
        }
        catch (Exception ex)
        {
            _error = $"{L["Placement.UnexpectedErrorPrefix"]} {ex.Message}";
            _removeTarget = null;
        }
        finally
        {
            _isRemoving = false;
        }
    }

    private async Task OnWizardSuccess()
    {
        _wizardPlacement = null;
        await LoadAsync();
    }

    // DTO shapes used locally (mirrors BizCenter DTOs)
    private class ApiResponse<T>
    {
        public bool     Success { get; set; }
        public T?       Data    { get; set; }
        public string?  Message { get; set; }
        public string?  ErrorCode { get; set; }
    }

    public class PendingPlacementDto
    {
        public string   MemberId                    { get; set; } = string.Empty;
        public string   FullName                    { get; set; } = string.Empty;
        public string   MemberCode                  { get; set; } = string.Empty;
        public string?  PhotoUrl                    { get; set; }
        public DateTime EnrolledAt                  { get; set; }
        public int      DaysRemainingInWindow       { get; set; }
        public double   WindowPercentUsed           { get; set; }
        public int      PlacementOpportunitiesUsed  { get; set; }
        public bool     IsAlreadyPlaced             { get; set; }
        public DateTime? PlacedAt                   { get; set; }
        public bool     CanCorrect                  { get; set; }
        public double   CorrectionHoursRemaining    { get; set; }
        public string?  CurrentTreeSide             { get; set; }
        public string?  CurrentParentMemberId       { get; set; }
        public string?  CurrentParentFullName       { get; set; }
        public bool     IsWindowExpired             { get; set; }
        public bool     IsBlocked                   { get; set; }
        public string   PlacementStatus             { get; set; } = string.Empty;
    }
}
