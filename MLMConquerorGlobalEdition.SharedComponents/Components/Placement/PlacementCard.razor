@using MLMConquerorGlobalEdition.SharedComponents.Components.Placement

@* Card for a single member pending placement or within correction window *@

<article class="placement-card @CardClass"
         aria-label="Placement: @Placement.FullName"
         tabindex="0">

    <div class="d-flex align-items-start gap-3 flex-wrap">
        <!-- Avatar -->
        <div class="flex-shrink-0">
            @if (!string.IsNullOrEmpty(Placement.PhotoUrl))
            {
                <img src="@Placement.PhotoUrl"
                     alt="Foto de @Placement.FullName"
                     class="rounded-circle object-fit-cover"
                     style="width:48px;height:48px"
                     loading="lazy" />
            }
            else
            {
                <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center"
                     style="width:48px;height:48px"
                     aria-hidden="true">
                    <i class="ri-user-line text-secondary fs-5"></i>
                </div>
            }
        </div>

        <!-- Info -->
        <div class="flex-grow-1 min-width-0">
            <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                <span class="fw-semibold text-truncate">@Placement.FullName</span>
                <code class="text-muted small">@Placement.MemberCode</code>
                <StatusBadge Status="@Placement.PlacementStatus" />
                @if (Placement.PlacementStatus == "AutoPlaced")
                {
                    <span class="auto-placed-badge" title="Colocado automáticamente por el sistema">
                        <i class="ri-robot-line" aria-hidden="true"></i>
                        Auto
                    </span>
                }
            </div>

            <div class="text-muted small mb-2">
                Reclutado el @Placement.EnrolledAt.ToString("dd MMM yyyy")
            </div>

            @if (Placement.IsAlreadyPlaced)
            {
                <!-- Current position -->
                <div class="d-flex align-items-center gap-2 small mb-2">
                    <i class="ri-map-pin-line text-success" aria-hidden="true"></i>
                    <span>
                        Pierna <strong>@Placement.CurrentTreeSide</strong>
                        bajo <strong>@(Placement.CurrentParentFullName ?? Placement.CurrentParentMemberId)</strong>
                    </span>
                </div>

                @if (Placement.CanCorrect)
                {
                    <!-- Correction countdown -->
                    <div class="d-flex align-items-center gap-2 small text-warning mb-2"
                         role="timer"
                         aria-label="Ventana de corrección: @Math.Floor(Placement.CorrectionHoursRemaining) horas restantes">
                        <i class="ri-timer-flash-line" aria-hidden="true"></i>
                        <span>
                            Ventana de corrección:
                            <strong>@Math.Floor(Placement.CorrectionHoursRemaining)h @(Math.Floor((Placement.CorrectionHoursRemaining % 1) * 60))m</strong>
                            restantes
                        </span>
                    </div>
                }
            }

            @if (!Placement.IsWindowExpired && !Placement.IsBlocked)
            {
                <!-- 30-day window progress bar -->
                <div class="mb-2">
                    <div class="d-flex justify-content-between small text-muted mb-1">
                        <span>Ventana de placement</span>
                        <span aria-live="polite">
                            @if (Placement.DaysRemainingInWindow > 0)
                            {
                                <span>@Placement.DaysRemainingInWindow día(s) restante(s)</span>
                            }
                            else
                            {
                                <span class="text-danger">Ventana cerrada</span>
                            }
                        </span>
                    </div>
                    <div class="placement-window-bar"
                         role="progressbar"
                         aria-valuenow="@((int)Placement.WindowPercentUsed)"
                         aria-valuemin="0"
                         aria-valuemax="100"
                         aria-label="Progreso de la ventana de placement">
                        <div class="placement-window-bar-fill @WindowBarClass"
                             style="width:@((int)Placement.WindowPercentUsed)%"></div>
                    </div>
                </div>
            }

            <!-- Opportunities used -->
            <div class="d-flex align-items-center gap-2 small">
                <span class="text-muted">Oportunidades:</span>
                <div class="opportunity-pips" aria-label="@Placement.PlacementOpportunitiesUsed de 2 oportunidades usadas">
                    <div class="opportunity-pip @(Placement.PlacementOpportunitiesUsed >= 1 ? "used" : "available")"
                         title="Oportunidad 1"></div>
                    <div class="opportunity-pip @(Placement.PlacementOpportunitiesUsed >= 2 ? "used" : "available")"
                         title="Oportunidad 2"></div>
                </div>
                <span class="text-muted">(@(Placement.PlacementOpportunitiesUsed)/2 usadas)</span>
            </div>
        </div>

        <!-- Actions -->
        <div class="d-flex flex-column gap-2 flex-shrink-0 align-self-center">
            @if (Placement.IsBlocked)
            {
                <span class="badge bg-secondary" title="Ambas oportunidades de placement agotadas">
                    <i class="ri-lock-line me-1" aria-hidden="true"></i>
                    Bloqueado
                </span>
            }
            else if (Placement.IsWindowExpired && !Placement.IsAlreadyPlaced)
            {
                <span class="badge bg-danger-subtle text-danger" title="La ventana de 30 días ha expirado">
                    <i class="ri-time-line me-1" aria-hidden="true"></i>
                    Expirado
                </span>
            }
            else if (!Placement.IsAlreadyPlaced)
            {
                <button class="btn btn-primary btn-sm"
                        @onclick="() => OnPlace.InvokeAsync(Placement)"
                        type="button"
                        aria-label="Colocar a @Placement.FullName en el Dual Team">
                    <i class="ri-user-add-line me-1" aria-hidden="true"></i>
                    Colocar
                </button>
            }
            else
            {
                @if (Placement.CanCorrect)
                {
                    <button class="btn btn-outline-warning btn-sm"
                            @onclick="() => OnMove.InvokeAsync(Placement)"
                            type="button"
                            aria-label="Mover a @Placement.FullName a otro nodo">
                        <i class="ri-drag-move-line me-1" aria-hidden="true"></i>
                        Mover
                    </button>
                    <button class="btn btn-outline-danger btn-sm"
                            @onclick="() => OnRemove.InvokeAsync(Placement)"
                            type="button"
                            aria-label="Eliminar placement de @Placement.FullName">
                        <i class="ri-delete-bin-line me-1" aria-hidden="true"></i>
                        Quitar
                    </button>
                }
            }
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired]
    public PlacementPage.PendingPlacementDto Placement { get; set; } = default!;

    [Parameter] public EventCallback<PlacementPage.PendingPlacementDto> OnPlace  { get; set; }
    [Parameter] public EventCallback<PlacementPage.PendingPlacementDto> OnMove   { get; set; }
    [Parameter] public EventCallback<PlacementPage.PendingPlacementDto> OnRemove { get; set; }

    private string CardClass => Placement.IsBlocked ? "is-blocked"
        : Placement.IsWindowExpired && !Placement.IsAlreadyPlaced ? "is-blocked"
        : Placement.IsAlreadyPlaced ? "is-placed"
        : Placement.DaysRemainingInWindow <= 3 ? "is-urgent"
        : Placement.DaysRemainingInWindow <= 7 ? "is-warning"
        : string.Empty;

    private string WindowBarClass =>
        Placement.DaysRemainingInWindow > 7  ? "safe"
        : Placement.DaysRemainingInWindow > 3 ? "warning"
        : "urgent";
}
