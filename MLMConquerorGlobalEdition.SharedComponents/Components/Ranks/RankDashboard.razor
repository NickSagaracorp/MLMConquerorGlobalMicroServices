@inject HttpClient Http
@inject IViewContextService ViewContext
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

@using MLMConquerorGlobalEdition.SharedComponents.Constants

@if (!ViewContext.IsInAnyRole(AppRoles.Ambassador) && !ViewContext.IsAdminContext)
{
    <div class="alert alert-warning">@L["Ranks.OnlyForAmbassadors"]</div>
    return;
}

<BreadcrumbNav Items="@_breadcrumb" />

<LoadingSpinner IsLoading="@_isLoading" />

@if (!_isLoading && _progress is not null)
{
    <!-- Stat Cards -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-4">
            <StatCard Title="@L["Ranks.CurrentRank"]"
                      Value="@_progress.CurrentRank"
                      Icon="ri-medal-line"
                      Color="warning" />
        </div>
        <div class="col-12 col-sm-4">
            <StatCard Title="@L["Ranks.PointsToNext"]"
                      Value="@_progress.PointsToNext.ToString("N0")"
                      Icon="ri-bar-chart-2-line"
                      Color="primary" />
        </div>
        <div class="col-12 col-sm-4">
            <StatCard Title="@L["Ranks.QualifiedMonths"]"
                      Value="@_progress.QualifiedMonths.ToString()"
                      Icon="ri-calendar-check-line"
                      Color="success" />
        </div>
    </div>

    <!-- Progress toward next rank -->
    <div class="card mb-4">
        <div class="card-header py-3">
            <h6 class="card-title mb-0 fw-semibold">@L["Ranks.ProgressTitle"]</h6>
        </div>
        <div class="card-body">
            @foreach (var req in _requirements)
            {
                var pct = req.Required > 0 ? (int)Math.Min(100m, req.Current * 100m / req.Required) : 0;
                <div class="mb-3">
                    <div class="d-flex justify-content-between small mb-1">
                        <span class="fw-medium">@req.Label</span>
                        <span class="text-muted">@req.Current / @req.Required</span>
                    </div>
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-primary" role="progressbar"
                             style="width: @(pct)%;"
                             aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="text-end small text-muted mt-1">@(pct)%</div>
                </div>
            }
        </div>
    </div>

    <!-- Admin-only: Manual Override -->
    <AdminOnlyWrapper Permission="@Permissions.Rank.Override">
        <div class="card border-warning mb-4">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="fw-semibold mb-1 text-warning">@L["Ranks.AdminOverrideTitle"]</h6>
                    <p class="text-muted small mb-0">@L["Ranks.AdminOverrideMessage"]</p>
                </div>
                <button class="btn btn-warning btn-sm" @onclick="@(() => _showOverrideModal = true)">
                    <i class="ri-edit-line me-1"></i>@L["Ranks.ManualOverrideButton"]
                </button>
            </div>
        </div>
    </AdminOnlyWrapper>

    <!-- Rank History Table -->
    <RankHistoryTable MemberProfileId="@MemberProfileId" />
}

@if (_showOverrideModal)
{
    <ConfirmModal IsVisible="true"
                  Title="@L["Ranks.OverrideModalTitle"]"
                  Message="@L["Ranks.OverrideModalMessage"]"
                  ConfirmLabel="@L["Ranks.OverrideModalConfirm"]"
                  ConfirmColor="warning"
                  OnConfirm="@HandleOverrideConfirmedAsync"
                  OnCancel="@(() => _showOverrideModal = false)" />
}

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool _isLoading = true;
    private bool _showOverrideModal;
    private RankProgress? _progress;
    private List<RankRequirementRow> _requirements = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new(L["Ranks.BreadcrumbHome"].Value,  "/dashboard"),
        new(L["Nav.Ranks"].Value, "/ranks"),
        new(L["Ranks.BreadcrumbProgress"].Value)
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        _isLoading = true;
        StateHasChanged();

        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<RankProgressDto>>(
                $"api/v1/bizcenter/ranks/dashboard");
            if (response?.Success == true && response.Data is not null)
            {
                var d = response.Data;
                _progress = new RankProgress(d.CurrentRank, d.CurrentPoints, d.PointsToNext, d.Percentage, d.QualifiedMonths);
                _requirements = d.Requirements.Select(r => new RankRequirementRow(r.Label, r.Current, r.Required)).ToList();
            }
        }
        catch { /* silently degrade */ }
        finally { _isLoading = false; }
    }

    private async Task HandleOverrideConfirmedAsync()
    {
        _showOverrideModal = false;
        try { await Http.PostAsJsonAsync($"api/v1/admin/members/{MemberProfileId}/rank/override", new { }); }
        catch { /* silently degrade */ }
    }

    // ── Local data models ────────────────────────────────────────────────────
    private class ApiResponse<T> { public bool Success { get; set; } public T? Data { get; set; } }

    private class RankProgressDto
    {
        public string CurrentRank    { get; set; } = string.Empty;
        public int    CurrentPoints  { get; set; }
        public int    PointsToNext   { get; set; }
        public double Percentage     { get; set; }
        public int    QualifiedMonths { get; set; }
        public List<RequirementDto> Requirements { get; set; } = new();
    }

    private class RequirementDto
    {
        public string  Label    { get; set; } = string.Empty;
        public decimal Current  { get; set; }
        public decimal Required { get; set; }
    }

    private record RankProgress(
        string CurrentRank,
        int    CurrentPoints,
        int    PointsToNext,
        double Percentage,
        int    QualifiedMonths);

    private record RankRequirementRow(string Label, decimal Current, decimal Required);
}
