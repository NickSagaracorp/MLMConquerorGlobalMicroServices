@inject HttpClient Http
@inject IViewContextService ViewContext
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

@using MLMConquerorGlobalEdition.SharedComponents.Constants

<BreadcrumbNav Items="@_breadcrumb" />

<div class="card">
    <div class="card-header py-3">
        <h6 class="card-title mb-0 fw-semibold">@L["Ranks.HistoryTitle"]</h6>
    </div>
    <div class="card-body p-0">
        <LoadingSpinner IsLoading="@_isLoading" />
        @if (!_isLoading)
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th>@L["Ranks.ColAchievedDate"]</th>
                            <th>@L["Ranks.ColRank"]</th>
                            <th>@L["Ranks.ColQualificationPeriod"]</th>
                            <th>@L["Ranks.ColTriggeredBy"]</th>
                            <th>@L["Ranks.ColCertificate"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_items.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">@L["Common.NoDataAvailable"]</td></tr>
                        }
                        @foreach (var r in _items)
                        {
                            <tr>
                                <td>@r.AchievedDate.ToString("MMM dd, yyyy")</td>
                                <td><span class="badge bg-warning text-dark">@r.RankName</span></td>
                                <td>@r.QualificationPeriod</td>
                                <td>
                                    @if (ViewContext.IsAdminContext)
                                    {
                                        <AdminOnlyWrapper Permission="@Permissions.Rank.View">
                                            @if (r.IsManualOverride)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="ri-user-settings-line me-1"></i>@L["Ranks.TriggerManual"]
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">
                                                    <i class="ri-settings-3-line me-1"></i>@L["Ranks.TriggerAutomatic"]
                                                </span>
                                            }
                                        </AdminOnlyWrapper>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(r.CertificateUrl))
                                    {
                                        <a href="@r.CertificateUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                            <i class="ri-file-pdf-line me-1"></i>@L["Common.Download"]
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@L["Ranks.CertificateNotGenerated"]</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_total > _pageSize)
            {
                var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                <div class="d-flex justify-content-center py-3">
                    <nav aria-label="@L["Ranks.HistoryPaginationAria"]">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page - 1)" aria-label="@L["Common.Previous"]">&#x2039;</button>
                            </li>
                            @for (var pg = 1; pg <= totalPages; pg++)
                            {
                                var p = pg;
                                <li class="page-item @(p == _page ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(p)">@p</button>
                                </li>
                            }
                            <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page + 1)" aria-label="@L["Common.Next"]">&#x203A;</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool _isLoading = true;
    private int  _page = 1, _pageSize = 10, _total;
    private List<RankHistoryItem> _items = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new(L["Ranks.BreadcrumbHome"].Value,  "/dashboard"),
        new(L["Nav.Ranks"].Value, "/ranks"),
        new(L["Ranks.BreadcrumbHistory"].Value)
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await LoadPageAsync(1);
    }

    private async Task ChangePage(int page) => await LoadPageAsync(page);

    private async Task LoadPageAsync(int page)
    {
        _page = page;
        _isLoading = true;
        StateHasChanged();
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<PagedData<RankHistoryItem>>>(
                $"api/v1/bizcenter/ranks/history?page={page}&pageSize={_pageSize}");
            if (response?.Success == true && response.Data is not null)
            {
                _items = response.Data.Items;
                _total = response.Data.TotalCount;
            }
        }
        catch { /* silently degrade */ }
        finally { _isLoading = false; }
    }

    private class ApiResponse<T> { public bool Success { get; set; } public T? Data { get; set; } }
    private class PagedData<T>   { public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    private record RankHistoryItem(
        DateTime AchievedDate,
        string   RankName,
        string   QualificationPeriod,
        string?  CertificateUrl,
        bool     IsManualOverride);
}
