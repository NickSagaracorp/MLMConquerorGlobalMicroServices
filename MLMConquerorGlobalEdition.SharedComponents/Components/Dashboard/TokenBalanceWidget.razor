@inject HttpClient Http
@inject IViewContextService ViewContext
@inject IStringLocalizer<SharedResources> L

<div class="card h-100">
    <div class="card-header d-flex align-items-center justify-content-between py-3">
        <h6 class="card-title mb-0 fw-semibold">@L["TokenWidget.Title"]</h6>
        <AdminOnlyWrapper Permission="@Permissions.Tokens.AdminGrant">
            <button class="btn btn-sm btn-outline-primary" @onclick="() => _showGrantModal = true">
                <i class="ri-add-line me-1"></i>@L["TokenWidget.GrantTokens"]
            </button>
        </AdminOnlyWrapper>
    </div>
    <div class="card-body">
        <LoadingSpinner IsLoading="@_isLoading" />
        @if (!_isLoading)
        {
            @foreach (var b in _balances)
            {
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="small text-muted">@b.TokenTypeName</span>
                    <span class="fw-semibold">@b.Balance</span>
                </div>
            }
            @if (!_balances.Any())
            {
                <EmptyState Icon="ri-copper-coin-line" Title="@L["TokenWidget.EmptyTitle"]" Message="@L["TokenWidget.EmptyMessage"]" />
            }
        }
    </div>
</div>

@if (_showGrantModal)
{
    <ConfirmModal IsVisible="true"
                  Title="@L["TokenWidget.GrantModalTitle"]"
                  Message="@L["TokenWidget.GrantModalMessage"]"
                  ConfirmLabel="@L["TokenWidget.GrantConfirm"]"
                  ConfirmColor="primary"
                  OnConfirm="@(() => _showGrantModal = false)"
                  OnCancel="@(() => _showGrantModal = false)" />
}

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool _isLoading   = true;
    private bool _showGrantModal;
    private List<TokenBalanceItem> _balances = new();

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        _isLoading = true;
        StateHasChanged();

        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<List<TokenBalanceItem>>>(
                "api/v1/bizcenter/tokens/balances");

            if (response?.Success == true && response.Data is not null)
                _balances = response.Data;
        }
        catch { /* non-critical widget — silently degrade */ }
        finally
        {
            _isLoading = false;
        }
    }

    private class ApiResponse<T> { public bool Success { get; set; } public T? Data { get; set; } }

    private record TokenBalanceItem(string TokenTypeName, int Balance, bool IsGuestPass);
}
