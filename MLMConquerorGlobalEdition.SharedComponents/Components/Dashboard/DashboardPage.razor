@inject IViewContextService ViewContext
@inject HttpClient Http
@inject NavigationManager Nav

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Dashboard") })" />

@if (_isLoading)
{
    <LoadingSpinner IsLoading="true" />
}
else
{
    <!-- KPI Stats Row -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <StatCard Title="Total Earnings" Value="@_totalEarnings" Icon="ri-money-dollar-circle-line" Color="primary" Trend="@_earningsTrend" TrendUp="@_earningsTrendUp" />
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <StatCard Title="Team Size" Value="@_teamSize" Icon="ri-group-line" Color="success" />
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <StatCard Title="Token Balance" Value="@_tokenBalance" Icon="ri-copper-coin-line" Color="warning" />
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <StatCard Title="Current Rank" Value="@_currentRank" Icon="ri-medal-line" Color="info" />
        </div>
    </div>

    <!-- Fast Start Bonus Cards — Ambassador only -->
    @if (ViewContext.IsInAnyRole(AppRoles.Ambassador) || ViewContext.IsAdminContext)
    {
        <div class="mb-4">
            <h6 class="fw-semibold mb-3">Fast Start Bonus Windows</h6>
            <div class="fsb-row">
                @foreach (var fsb in _fsbWindows)
                {
                    <FastStartBonusCard Window="@fsb" />
                }
            </div>
        </div>
    }

    <!-- Activity Feed -->
    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <ActivityFeed MemberProfileId="@MemberProfileId" />
        </div>
        <div class="col-12 col-lg-4">
            <TokenBalanceWidget MemberProfileId="@MemberProfileId" />
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_error))
{
    <ApiErrorAlert ErrorMessage="@_error" />
}

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool    _isLoading      = true;
    private string  _totalEarnings  = "$0.00";
    private string  _teamSize       = "0";
    private string  _tokenBalance   = "0";
    private string  _currentRank    = "—";
    private string? _earningsTrend;
    private bool    _earningsTrendUp = true;
    private string? _error;

    private List<FsbWindowDto> _fsbWindows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        _isLoading = true;
        _error     = null;
        StateHasChanged();

        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<DashboardStatsDto>>(
                "api/v1/bizcenter/dashboard/stats");

            if (response?.Success == true && response.Data is not null)
            {
                var d = response.Data;
                _totalEarnings = d.TotalEarnings.ToString("C");
                _teamSize      = d.TeamSize.ToString();
                _tokenBalance  = d.TokenBalance.ToString();
                _currentRank   = d.CurrentRank ?? "—";
                _fsbWindows    = d.FsbWindows
                    .Select(w => new FsbWindowDto(w.WindowNumber, w.StartDate, w.EndDate, w.Earned, w.Status, w.IsActive, w.IsCompleted, w.SponsoredCount))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Local DTOs matching the API response ─────────────────────────────────
    private class ApiResponse<T> { public bool Success { get; set; } public T? Data { get; set; } }

    private class DashboardStatsDto
    {
        public decimal TotalEarnings { get; set; }
        public int     TeamSize      { get; set; }
        public int     TokenBalance  { get; set; }
        public string? CurrentRank   { get; set; }
        public List<FsbWindowApiDto> FsbWindows { get; set; } = new();
    }

    private class FsbWindowApiDto
    {
        public int       WindowNumber   { get; set; }
        public DateTime? StartDate      { get; set; }
        public DateTime? EndDate        { get; set; }
        public decimal   Earned         { get; set; }
        public string    Status         { get; set; } = string.Empty;
        public bool      IsActive       { get; set; }
        public bool      IsCompleted    { get; set; }
        public int       SponsoredCount { get; set; }
    }

    public record FsbWindowDto(
        int       WindowNumber,
        DateTime? StartDate,
        DateTime? EndDate,
        decimal   Earned,
        string    Status,
        bool      IsActive,
        bool      IsCompleted,
        int       SponsoredCount);
}
