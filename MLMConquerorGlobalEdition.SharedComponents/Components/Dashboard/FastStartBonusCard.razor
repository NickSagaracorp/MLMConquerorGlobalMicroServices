@using MLMConquerorGlobalEdition.SharedComponents.Components.Dashboard
@implements IDisposable

@{
    var fsbCardClass = Window.IsCompleted ? "fsb-card fsb-complete"
                     : Window.IsActive    ? "fsb-card fsb-active"
                     :                     "fsb-card fsb-locked position-relative";

    var footerClass = Window.IsCompleted ? "fsb-footerline completed"
                    : Window.IsActive    ? "fsb-footerline available"
                    :                     "fsb-footerline locked";

    string SlotClass(int slotIndex)
    {
        if (!Window.IsCompleted && !Window.IsActive)
            return "fsb-person-big locked";
        var filled = Window.SponsoredCount >= slotIndex;
        if (!filled) return "fsb-person-big inactive";
        return Window.IsCompleted ? "fsb-person-big active-green" : "fsb-person-big active-blue";
    }
}

<div class="fsb-card-wrap">
    <div class="@fsbCardClass">
        <div class="fsb-topline">
            <div class="fsb-title">FAST START BONUS @Window.WindowNumber</div>
        </div>
        <div class="fsb-bottom">
            <div class="fsb-icons-area d-flex align-items-center"
                 style="@(!Window.IsCompleted && !Window.IsActive ? "opacity:.7;filter:grayscale(.4);" : "")">
                <div class="@SlotClass(1)"><i class="ri-user-fill" aria-hidden="true"></i></div>
                <div class="@SlotClass(2)"><i class="ri-user-fill" aria-hidden="true"></i></div>
            </div>
            <div class="fsb-timer">@_timerDisplay</div>
        </div>
        @if (!Window.IsCompleted && !Window.IsActive)
        {
            <div class="fsb-black-layer"><i class="ri-lock-line" aria-hidden="true"></i>Locked &mdash; Coming Soon</div>
        }
    </div>
    <div class="@footerClass">
        <span>@(Window.StartDate.HasValue ? Window.StartDate.Value.ToString("MM/dd/yyyy HH:mm:ss") : "--")</span>
        <span>@(Window.EndDate.HasValue ? Window.EndDate.Value.ToString("MM/dd/yyyy HH:mm:ss") : "--")</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public DashboardPage.FsbWindowDto Window { get; set; } = default!;

    private string _timerDisplay = "--D --H --M --S";
    private System.Threading.Timer? _timer;

    protected override void OnParametersSet()
    {
        UpdateTimerDisplay();
        if (Window.IsActive && Window.EndDate.HasValue)
        {
            _timer?.Dispose();
            _timer = new System.Threading.Timer(_ => InvokeAsync(() =>
            {
                UpdateTimerDisplay();
                StateHasChanged();
            }), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        }
    }

    private void UpdateTimerDisplay()
    {
        if (Window.IsCompleted)
        {
            _timerDisplay = Window.Earned > 0 ? Window.Earned.ToString("C") : "COMPLETED!";
            return;
        }
        if (Window.IsActive && Window.EndDate.HasValue)
        {
            _timerDisplay = FmtDHMS(Window.EndDate.Value - DateTime.UtcNow);
            return;
        }
        if (!Window.IsCompleted && !Window.IsActive && Window.StartDate.HasValue)
        {
            _timerDisplay = FmtDHMS(Window.StartDate.Value - DateTime.UtcNow);
            return;
        }
        _timerDisplay = "--D --H --M --S";
    }

    private static string FmtDHMS(TimeSpan ts)
    {
        if (ts.TotalSeconds <= 0) return "COMPLETED!";
        return $"{(int)ts.TotalDays}D {ts.Hours}H {ts.Minutes}M {ts.Seconds}S";
    }

    public void Dispose() => _timer?.Dispose();
}
