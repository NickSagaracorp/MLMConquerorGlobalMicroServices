@inject HttpClient Http
@inject IViewContextService ViewContext
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

@using Microsoft.Extensions.Localization
@using MLMConquerorGlobalEdition.SharedComponents.Resources
@using Syncfusion.Blazor.Grids
@using Syncfusion.Blazor.Calendars
@using Syncfusion.Blazor.Inputs

@if (ShowBreadcrumb) { <BreadcrumbNav Items="@_breadcrumb" /> }

<!-- Toolbar: search + date range -->
<div class="card bg-white border-0 rounded-3 mb-4">
    <div class="card-body p-0">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 p-3">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <div class="position-relative" style="min-width:240px">
                    <SfTextBox Placeholder="@L["Team.MyTeamSearchPlaceholder"]"
                               @bind-Value="_search"
                               CssClass="form-control form-control-sm" />
                </div>
                <SfDateRangePicker TValue="DateTime?" Placeholder="@L["Team.JoinDateRange"]"
                                   CssClass="form-control form-control-sm"
                                   Style="min-width:220px"
                                   @bind-StartDate="_from"
                                   @bind-EndDate="_to" />
                <button class="btn btn-primary btn-sm" @onclick="SearchAsync">
                    <i class="ri-search-line me-1"></i>@L["Common.Search"]
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearAsync">
                    <i class="ri-refresh-line"></i>
                </button>
            </div>
            <small class="text-muted">@_totalCount @L["Common.Members"]</small>
        </div>

        @if (_isLoading)
        {
            <LoadingSpinner IsLoading="true" />
        }
        else if (_error is not null)
        {
            <div class="alert alert-danger m-3">@_error</div>
        }
        else
        {
            <SfGrid TValue="EnrollmentMyTeamMemberDto" DataSource="@_items"
                    AllowPaging="true" AllowSorting="true" AllowResizing="true"
                    AllowFiltering="true" GridLines="GridLine.Horizontal">
                <GridEvents TValue="EnrollmentMyTeamMemberDto" RowSelected="OnRowSelected" />
                <GridPageSettings PageSize="20" PageSizes="@(new int[]{20,50,100})" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.EnrollDate)"
                                HeaderText="@L["Reports.JoinDate"]" Width="115" TextAlign="TextAlign.Center"
                                Format="MM/dd/yyyy" Type="ColumnType.Date">
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).EnrollDate.ToString("MM/dd/yyyy"))
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.MemberId)"
                                HeaderText="@L["Reports.Id"]" Width="120" Type="ColumnType.String">
                        <Template>
                            <code class="text-primary">@(((EnrollmentMyTeamMemberDto)context).MemberId)</code>
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.FullName)"
                                HeaderText="@L["Reports.Name"]" Width="160" Type="ColumnType.String">
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).FullName)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.Email)"
                                HeaderText="@L["Reports.Email"]" Width="200" Type="ColumnType.String">
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).Email)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.Phone)"
                                HeaderText="@L["Reports.Phone"]" Width="140" Type="ColumnType.String">
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).Phone ?? "—")
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.Level)"
                                HeaderText="@L["Reports.Level"]" Width="80" TextAlign="TextAlign.Center"
                                Type="ColumnType.Integer">
                        <Template>
                            <span class="badge bg-secondary">L@(((EnrollmentMyTeamMemberDto)context).Level)</span>
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.Country)"
                                HeaderText="@L["Reports.Country"]" Width="100" Type="ColumnType.String">
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).Country)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.SponsorFullName)"
                                HeaderText="@L["Reports.Sponsor"]" Width="150" Type="ColumnType.String">
                        <Template>
                            @{ var m = (EnrollmentMyTeamMemberDto)context; }
                            @(m.SponsorFullName ?? m.SponsorMemberId ?? "—")
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.DualUplineFullName)"
                                HeaderText="@L["Reports.DualUpline"]" Width="150" Type="ColumnType.String">
                        <Template>
                            @{ var m2 = (EnrollmentMyTeamMemberDto)context; }
                            @(m2.DualUplineFullName ?? m2.DualUplineMemberId ?? "—")
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.AccountStatus)"
                                HeaderText="@L["Reports.BizStatus"]" Width="110" TextAlign="TextAlign.Center"
                                Type="ColumnType.String">
                        <Template>
                            <StatusBadge Status="@(((EnrollmentMyTeamMemberDto)context).AccountStatus)" />
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.MembershipStatus)"
                                HeaderText="@L["Reports.MembershipStatus"]" Width="140" TextAlign="TextAlign.Center"
                                Type="ColumnType.String">
                        <Template>
                            <StatusBadge Status="@(((EnrollmentMyTeamMemberDto)context).MembershipStatus)" />
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.IsQualified)"
                                HeaderText="@L["Reports.Qualified"]" Width="110" TextAlign="TextAlign.Center"
                                Type="ColumnType.Boolean" DisplayAsCheckBox="false">
                        <Template>
                            @{ var isQ = ((EnrollmentMyTeamMemberDto)context).IsQualified; }
                            <span class="badge @(isQ ? "bg-success bg-opacity-10 text-success" : "bg-warning bg-opacity-10 text-warning") p-2 fs-12 fw-normal">
                                @(isQ ? L["Reports.Qualified"] : L["Reports.Unqualified"])
                            </span>
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.MembershipLevelName)"
                                HeaderText="@L["Reports.Membership"]" Width="200" Type="ColumnType.String">
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).MembershipLevelName ?? "—")
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.CurrentRankName)"
                                HeaderText="@L["Reports.Rank"]" Width="130" Type="ColumnType.String">
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).CurrentRankName ?? "—")
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.RankDate)"
                                HeaderText="@L["Reports.RankDate"]" Width="110" TextAlign="TextAlign.Center"
                                Format="MM/dd/yyyy" Type="ColumnType.Date">
                        <Template>
                            @{ var rd = ((EnrollmentMyTeamMemberDto)context).RankDate; }
                            @(rd.HasValue ? rd.Value.ToString("MM/dd/yyyy") : "—")
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.LifetimeRankName)"
                                HeaderText="@L["Reports.LifetimeRank"]" Width="130" Type="ColumnType.String">
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).LifetimeRankName ?? "—")
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.NextRankPercent)"
                                HeaderText="@L["Reports.NextRankPercent"]" Width="100" TextAlign="TextAlign.Center"
                                Type="ColumnType.Integer">
                        <Template>
                            @{ var pct = ((EnrollmentMyTeamMemberDto)context).NextRankPercent; }
                            <div style="position:relative;width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:conic-gradient(#605DFF @(pct)%, #ECEEF2 @(pct)%);margin:auto">
                                <div style="position:absolute;width:80%;height:80%;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                    <span style="font-size:11px;font-weight:600">@(pct)%</span>
                                </div>
                            </div>
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.QualificationPoints)"
                                HeaderText="@L["Reports.QualPoints"]" Width="115" TextAlign="TextAlign.Right"
                                Type="ColumnType.Integer">
                        <HeaderTemplate>
                            <span title="@L["Reports.QualifyHeaderTooltip"]">
                                @L["Reports.QualPoints"] <i class="ri-information-line text-muted small"></i>
                            </span>
                        </HeaderTemplate>
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).QualificationPoints.ToString("N0"))
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.EnrollmentTeamPoints)"
                                HeaderText="@L["Reports.EnrollPoints"]" Width="120" TextAlign="TextAlign.Right"
                                Type="ColumnType.Integer">
                        <HeaderTemplate>
                            <span title="@L["Reports.EnrollPointsTooltip"]">
                                @L["Reports.EnrollPoints"] <i class="ri-information-line text-muted small"></i>
                            </span>
                        </HeaderTemplate>
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).EnrollmentTeamPoints.ToString("N0"))
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.LeftTeamPoints)"
                                HeaderText="@L["Reports.LeftPoints"]" Width="110" TextAlign="TextAlign.Right"
                                Type="ColumnType.Decimal">
                        <HeaderTemplate>
                            <span title="@L["Reports.LeftPointsTooltip"]">
                                @L["Reports.LeftPoints"] <i class="ri-information-line text-muted small"></i>
                            </span>
                        </HeaderTemplate>
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).LeftTeamPoints.ToString("N0"))
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(EnrollmentMyTeamMemberDto.RightTeamPoints)"
                                HeaderText="@L["Reports.RightPoints"]" Width="110" TextAlign="TextAlign.Right"
                                Type="ColumnType.Decimal">
                        <HeaderTemplate>
                            <span title="@L["Reports.RightPointsTooltip"]">
                                @L["Reports.RightPoints"] <i class="ri-information-line text-muted small"></i>
                            </span>
                        </HeaderTemplate>
                        <Template>
                            @(((EnrollmentMyTeamMemberDto)context).RightTeamPoints.ToString("N0"))
                        </Template>
                    </GridColumn>

                    @if (ViewContext.IsAdminContext)
                    {
                        <GridColumn HeaderText="" Width="80" TextAlign="TextAlign.Center"
                                    AllowSorting="false" AllowFiltering="false">
                            <Template>
                                <button class="btn btn-xs btn-outline-secondary"
                                        @onclick="@(() => Nav.NavigateTo($"/admin/members/{((EnrollmentMyTeamMemberDto)context).MemberId}"))"
                                        title="@L["Team.ViewInAdmin"]">
                                    <i class="ri-eye-line"></i>
                                </button>
                            </Template>
                        </GridColumn>
                    }

                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

@if (_selected is not null)
{
    <div class="offcanvas-backdrop fade show" @onclick="() => _selected = null"></div>
    <div class="offcanvas offcanvas-end show" style="visibility:visible" tabindex="-1" aria-labelledby="mm-offcanvas-title">
        <div class="offcanvas-header border-bottom p-4">
            <h5 class="offcanvas-title fs-18 mb-0" id="mm-offcanvas-title">@_selected.FullName</h5>
            <button type="button" class="btn-close" @onclick="() => _selected = null" aria-label="@L["Common.Close"]"></button>
        </div>
        <div class="offcanvas-body p-4">
            <div class="form-group mb-4">
                <strong>@L["Team.IdLabel"]</strong> <code class="text-primary">@_selected.MemberId</code>
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.JoinDateLabel"]</strong> @_selected.EnrollDate.ToString("MM/dd/yyyy")
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.EmailLabel"]</strong> @_selected.Email
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.PhoneLabel"]</strong> @(_selected.Phone ?? "—")
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.LevelLabel"]</strong> <span class="badge bg-secondary">L@(_selected.Level)</span>
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.CountryLabel"]</strong> @_selected.Country
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.SponsorLabel"]</strong> @(_selected.SponsorFullName ?? _selected.SponsorMemberId ?? "—")
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.DualTeamUplineLabel"]</strong> @(_selected.DualUplineFullName ?? _selected.DualUplineMemberId ?? "—")
            </div>

            <div class="form-group mb-4">
                <strong>@L["Team.BizCenterStatusLabel"]</strong>
                <StatusBadge Status="@_selected.AccountStatus" />
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.MembershipStatusLabel"]</strong>
                <StatusBadge Status="@_selected.MembershipStatus" />
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.QualifiedLabel"]</strong>
                <span class="badge @(_selected.IsQualified ? "bg-success bg-opacity-10 text-success" : "bg-warning bg-opacity-10 text-warning") p-2 fs-12 fw-normal">
                    @(_selected.IsQualified ? L["Reports.Qualified"] : L["Reports.Unqualified"])
                </span>
            </div>

            <div class="form-group mb-4">
                <strong>@L["Team.MembershipLabel"]</strong> @(_selected.MembershipLevelName ?? "—")
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.RankLabel"]</strong> @(_selected.CurrentRankName ?? "—")
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.RankDateLabel"]</strong> @(_selected.RankDate.HasValue ? _selected.RankDate.Value.ToString("MM/dd/yyyy") : "—")
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.LifetimeRankLabel"]</strong> @(_selected.LifetimeRankName ?? "—")
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.NextRankPercentLabel"]</strong> @(_selected.NextRankPercent)%
            </div>

            <div class="form-group mb-4">
                <strong>@L["Team.QualificationPointsLabel"]</strong> @(_selected.QualificationPoints.ToString("N0"))
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.EnrollmentTeamPointsLabel"]</strong> @(_selected.EnrollmentTeamPoints.ToString("N0"))
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.LeftTeamPointsLabel"]</strong> @(_selected.LeftTeamPoints.ToString("N0"))
            </div>
            <div class="form-group mb-4">
                <strong>@L["Team.RightTeamPointsLabel"]</strong> @(_selected.RightTeamPoints.ToString("N0"))
            </div>

            @if (_selected.MembershipStatus == "Cancelled")
            {
                <div class="form-group mb-4">
                    <strong>@L["Team.CancellationDate"]</strong>
                    @(_selected.CancellationDate.HasValue ? _selected.CancellationDate.Value.ToString("MM/dd/yyyy") : "—")
                </div>
            }
            else if (_selected.MembershipStatus == "Suspended")
            {
                <div class="form-group mb-4">
                    <strong>@L["Team.SuspensionDate"]</strong>
                    @(_selected.SuspensionDate.HasValue ? _selected.SuspensionDate.Value.ToString("MM/dd/yyyy") : "—")
                </div>
            }

            @if (!_selected.IsQualified)
            {
                <div class="form-group mb-4">
                    <strong>@L["Team.LastPaymentDate"]</strong>
                    @(_selected.LastPaymentDate.HasValue ? _selected.LastPaymentDate.Value.ToString("MM/dd/yyyy") : "—")
                </div>
            }

            <div class="form-group d-flex gap-3">
                <button type="button" class="btn btn-primary text-white fw-semibold py-2 px-2 px-sm-3"
                        @onclick="() => _selected = null">
                    <span class="py-sm-1 d-block">
                        <i class="ri-close-line text-white"></i>
                        <span>@L["Common.Close"]</span>
                    </span>
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;
    [Parameter] public string ApiBaseUrl     { get; set; } = "api/v1/bizcenter/team/enrollment";
    [Parameter] public bool   ShowBreadcrumb { get; set; } = true;

    private bool   _isLoading  = true;
    private string? _error;
    private int    _totalCount;
    private EnrollmentMyTeamMemberDto? _selected;
    private int    _page       = 1;
    private const int PageSize = 20;
    private string? _search;
    private DateTime? _from;
    private DateTime? _to;
    private List<EnrollmentMyTeamMemberDto> _items = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new(L["Nav.Dashboard"], "/dashboard"),
        new(L["Sidebar.EnrollmentTeam"]),
        new(L["Sidebar.MyTeam"])
    };

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(MemberProfileId))
            await LoadAsync(1);
    }

    private void OnRowSelected(RowSelectEventArgs<EnrollmentMyTeamMemberDto> args)
        => _selected = args.Data;

    private async Task SearchAsync() => await LoadAsync(1);

    private async Task ClearAsync()
    {
        _search = null; _from = null; _to = null;
        await LoadAsync(1);
    }

    private async Task LoadAsync(int page)
    {
        _page = page; _isLoading = true; _error = null; StateHasChanged();
        try
        {
            var url = $"{ApiBaseUrl}/my-team?page={page}&pageSize={PageSize}";
            if (!string.IsNullOrWhiteSpace(_search)) url += $"&search={Uri.EscapeDataString(_search)}";
            if (_from.HasValue)  url += $"&from={_from.Value:yyyy-MM-dd}";
            if (_to.HasValue)    url += $"&to={_to.Value:yyyy-MM-dd}";

            var resp = await Http.GetFromJsonAsync<ApiResp<PagedData<EnrollmentMyTeamMemberDto>>>(url);
            if (resp?.Success == true && resp.Data is not null)
            {
                _items      = resp.Data.Items;
                _totalCount = resp.Data.TotalCount;
            }
            else { _error = resp?.Errors?.FirstOrDefault() ?? L["Team.LoadFailedTeam"]; }
        }
        catch (Exception ex) { _error = $"{L["Team.ApiErrorPrefix"]} {ex.Message}"; }
        finally { _isLoading = false; }
    }

    private class ApiResp<T>  { public bool Success { get; set; } public T? Data { get; set; } public IEnumerable<string>? Errors { get; set; } }
    private class PagedData<T>{ public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    public class EnrollmentMyTeamMemberDto
    {
        public string    MemberId            { get; set; } = string.Empty;
        public string    FullName            { get; set; } = string.Empty;
        public string    Email               { get; set; } = string.Empty;
        public string?   Phone               { get; set; }
        public string    Country             { get; set; } = string.Empty;
        public int       Level               { get; set; }
        public DateTime  EnrollDate          { get; set; }
        public string?   SponsorMemberId     { get; set; }
        public string?   SponsorFullName     { get; set; }
        public string?   DualUplineMemberId  { get; set; }
        public string?   DualUplineFullName  { get; set; }
        public string    AccountStatus       { get; set; } = string.Empty;
        public string    MembershipStatus    { get; set; } = string.Empty;
        public bool      IsQualified         { get; set; }
        public string?   MembershipLevelName { get; set; }
        public string?   CurrentRankName     { get; set; }
        public DateTime? RankDate            { get; set; }
        public string?   LifetimeRankName    { get; set; }
        public int       NextRankPercent     { get; set; }
        public int       QualificationPoints    { get; set; }
        public int       EnrollmentTeamPoints   { get; set; }
        public decimal   LeftTeamPoints         { get; set; }
        public decimal   RightTeamPoints        { get; set; }
        public DateTime? SuspensionDate         { get; set; }
        public DateTime? CancellationDate       { get; set; }
        public DateTime? LastPaymentDate        { get; set; }
    }
}
