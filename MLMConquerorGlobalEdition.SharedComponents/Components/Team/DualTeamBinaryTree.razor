@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@using System.Net.Http.Json
@implements IAsyncDisposable

@if (ShowBreadcrumb) { <BreadcrumbNav Items="@_breadcrumb" /> }

<style>
    .genealogy-body {
        white-space: nowrap;
        overflow: hidden;
        position: relative;
        background: linear-gradient(180deg, #f8f9fb, #eef1f4);
        border-radius: 10px;
        padding: 20px;
        min-height: 480px;
        text-align: center;
        cursor: grab;
    }
    .genealogy-tree ul {
        padding-top: 16px;
        position: relative;
        display: flex;
        justify-content: center;
        gap: 24px;
        list-style: none;
        padding-left: 0;
    }
    .genealogy-tree li {
        list-style: none;
        text-align: center;
        position: relative;
        padding: 16px 8px 0 8px;
    }
    .genealogy-tree li::before,
    .genealogy-tree li::after {
        content: '';
        position: absolute;
        top: 0;
        border-top: 2px dashed #c9c9c9;
        width: 50%;
        height: 16px;
    }
    .genealogy-tree li::before { right: 50%; }
    .genealogy-tree li::after  { left: 50%; border-left: 2px dashed #c9c9c9; }
    .genealogy-tree li:only-child::after,
    .genealogy-tree li:only-child::before { display: none; }
    .genealogy-tree li:only-child { padding-top: 0; }
    .genealogy-tree ul ul::before {
        content: '';
        position: absolute;
        top: 0;
        left: 50%;
        border-left: 2px dashed #c9c9c9;
        width: 0;
        height: 16px;
    }
    .member-view-box {
        display: inline-block;
        text-align: center;
        border-radius: 10px;
        background: #fff;
        box-shadow: 0 6px 18px rgba(0,0,0,.07);
        padding: 8px 10px;
        width: 140px;
    }
    .member-header {
        font-weight: 600;
        color: #fff;
        border-radius: 8px 8px 0 0;
        padding: 5px 8px;
        font-size: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 24px;
    }
    .status-qualified   .member-header { background: #2ecc71; }
    .status-unqualified .member-header { background: #7d2a3b; }
    .status-cancelled   .member-header { background: #9aa0a6; }
    .member-avatar {
        width: 66px;
        height: 66px;
        border-radius: 50%;
        background: #605DFF;
        color: #fff;
        font-weight: 700;
        font-size: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 6px auto 0;
        box-shadow: 0 2px 6px rgba(0,0,0,.15);
        cursor: pointer;
        transition: transform .15s;
    }
    .member-avatar:hover { transform: scale(1.06); }
    .member-footer {
        margin-top: 6px;
        font-weight: 700;
        font-size: 13px;
        color: #222;
    }
    .placeholder-node {
        width: 66px;
        height: 66px;
        border: 2px dashed #cfd6df;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-size: 22px;
        color: #7b8794;
        background: #fafbff;
        margin: 6px auto 0;
    }
    .revert-btn {
        margin-top: 6px;
        font-size: 11px;
        line-height: 1;
        border: 1px solid #ffb4b4;
        color: #b42318;
        background: #fff4f4;
        padding: 5px 9px;
        border-radius: 8px;
        cursor: pointer;
        display: inline-block;
        transition: background .15s;
    }
    .revert-btn:hover  { background: #ffe5e5; }
    .revert-btn:disabled { opacity: .55; cursor: not-allowed; }
</style>

<div class="card bg-white border-0 rounded-3 mb-4">
    <div class="card-body p-4">

        @* ── Leg stats ─────────────────────────────────────────────────────── *@
        <div class="row g-3 mb-4">
            <div class="col-12 col-sm-6">
                <div class="card border-0 rounded-3" style="background:rgb(96,93,255)">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="ri-arrow-left-circle-line fs-40 text-white"></i>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <span class="text-white opacity-75 fs-13">Left Leg Points</span>
                                <h3 class="fs-22 mt-1 mb-0 text-white fw-bold">
                                    @if (_statsLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    else
                                    {
                                        @_leftLegPoints.ToString("N0")
                                    }
                                </h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6">
                <div class="card border-0 rounded-3" style="background:#4299e1">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <i class="ri-arrow-right-circle-line fs-40 text-white"></i>
                            </div>
                            <div class="flex-grow-1 ms-3">
                                <span class="text-white opacity-75 fs-13">Right Leg Points</span>
                                <h3 class="fs-22 mt-1 mb-0 text-white fw-bold">
                                    @if (_statsLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    else
                                    {
                                        @_rightLegPoints.ToString("N0")
                                    }
                                </h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Legend ────────────────────────────────────────────────────────── *@
        <div class="d-flex gap-3 mb-3 flex-wrap">
            <span class="d-flex align-items-center gap-2 fs-13">
                <span style="width:12px;height:12px;border-radius:50%;background:#2ecc71;display:inline-block"></span>
                Qualified
            </span>
            <span class="d-flex align-items-center gap-2 fs-13">
                <span style="width:12px;height:12px;border-radius:50%;background:#7d2a3b;display:inline-block"></span>
                Unqualified
            </span>
            <span class="d-flex align-items-center gap-2 fs-13">
                <span style="width:12px;height:12px;border-radius:50%;background:#9aa0a6;display:inline-block"></span>
                Cancelled / Inactive
            </span>
        </div>

        @* ── Breadcrumb trail when navigated deep ─────────────────────────── *@
        @if (_navStack.Count > 0)
        {
            <div class="d-flex align-items-center gap-1 flex-wrap mb-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="NavigateToRoot">
                    <i class="ri-home-line me-1"></i>Root
                </button>
                @foreach (var (nodeId, name) in _navStack)
                {
                    var nid = nodeId;
                    <i class="ri-arrow-right-s-line text-muted"></i>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => NavigateTo(nid)">@name</button>
                }
            </div>
        }

        @* ── Tree ──────────────────────────────────────────────────────────── *@
        @if (_treeLoading)
        {
            <LoadingSpinner IsLoading="true" />
        }
        else if (_treeError is not null)
        {
            <div class="alert alert-danger">@_treeError</div>
        }
        else if (_rootNode is not null)
        {
            <div class="genealogy-body" id="@_treeContainerId">
                <div class="genealogy-tree">
                    <ul>
                        <li>
                            @RenderNode(_rootNode, 0)
                        </li>
                    </ul>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="ri-share-circle-line fs-2 d-block mb-2"></i>
                No tree data available.
            </div>
        }

        @* ── Unplacement error toast ──────────────────────────────────────────── *@
        @if (_unplacementError is not null)
        {
            <div class="alert alert-danger alert-dismissible mt-3" role="alert">
                @_unplacementError
                <button type="button" class="btn-close" @onclick="() => _unplacementError = null"></button>
            </div>
        }

        @* ── Placement Modal ──────────────────────────────────────────────────── *@
        @if (_placementModalVisible)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                Seleccionar ambassador — pierna <strong>@_placementSide</strong>
                            </h5>
                            <button type="button" class="btn-close"
                                    disabled="@_placingMember"
                                    @onclick="() => { _placementModalVisible = false; _selectedPlacementCandidate = null; }">
                            </button>
                        </div>
                        <div class="modal-body" style="max-height:360px;overflow-y:auto;padding:0">
                            @if (_placementModalError is not null)
                            {
                                <div class="alert alert-danger m-3 mb-0">@_placementModalError</div>
                            }
                            @if (_placementCandidateLoading)
                            {
                                <div class="text-center py-4">
                                    <span class="spinner-border text-primary"></span>
                                </div>
                            }
                            else if (!_placementCandidates.Any() && _placementModalError is null)
                            {
                                <div class="alert alert-warning m-3">No hay ambassadors disponibles para placement.</div>
                            }
                            else
                            {
                                @foreach (var candidate in _placementCandidates)
                                {
                                    var c        = candidate;
                                    var selected = _selectedPlacementCandidate?.MemberId == c.MemberId;
                                    <div class="d-flex align-items-center gap-3 px-3 py-2"
                                         style="cursor:@(_placingMember ? "default" : "pointer");
                                                border-bottom:1px solid #f0f0f0;
                                                background:@(selected ? "#eef4ff" : "transparent");
                                                opacity:@(_placingMember && !selected ? "0.5" : "1");
                                                transition:background .1s"
                                         @onclick="() => { if (!_placingMember) _selectedPlacementCandidate = selected ? null : c; }">
                                        @if (!string.IsNullOrEmpty(c.PhotoUrl))
                                        {
                                            <img src="@c.PhotoUrl" class="rounded-circle" width="40" height="40"
                                                 style="object-fit:cover;flex-shrink:0" alt="@c.FullName" />
                                        }
                                        else
                                        {
                                            <div style="width:40px;height:40px;border-radius:50%;background:#605DFF;
                                                        color:#fff;display:flex;align-items:center;justify-content:center;
                                                        font-weight:700;font-size:16px;flex-shrink:0">
                                                @(c.FullName.Length > 0 ? c.FullName[0].ToString().ToUpper() : "?")
                                            </div>
                                        }
                                        <div class="flex-grow-1">
                                            <div class="fw-medium">@c.FullName</div>
                                            <div class="text-muted" style="font-size:12px">@c.MemberId</div>
                                        </div>
                                        @if (selected)
                                        {
                                            <i class="ri-checkbox-circle-fill text-primary fs-5 ms-auto"></i>
                                        }
                                    </div>
                                }
                            }
                        </div>

                        @* Footer changes based on selection state *@
                        @if (_selectedPlacementCandidate is not null)
                        {
                            var sel   = _selectedPlacementCandidate;
                            var pts   = 1 + sel.FloatingSubtreeSize;
                            <div class="modal-footer flex-column align-items-stretch gap-2 pt-3"
                                 style="border-top:2px solid #e9ecef">
                                <div class="rounded-3 p-3" style="background:#f8f9ff;border:1px solid #dde3ff">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <i class="ri-user-add-line text-primary"></i>
                                        <span class="fw-semibold" style="font-size:13px">Confirmación de Placement</span>
                                    </div>
                                    <div style="font-size:13px;line-height:1.6">
                                        <div>
                                            <span class="text-muted">Ambassador:</span>
                                            <strong class="ms-1">@sel.FullName</strong>
                                        </div>
                                        <div>
                                            <span class="text-muted">Bajo:</span>
                                            <strong class="ms-1">@_placementTargetParentName</strong>
                                            <span class="badge ms-1" style="background:#605DFF;font-size:10px">pierna @_placementSide</span>
                                        </div>
                                        <div class="mt-1">
                                            <span class="text-muted">Puntos que aportará a</span>
                                            <strong class="ms-1">@_placementTargetParentName</strong>
                                            <span class="ms-1">:</span>
                                            <span class="badge bg-success ms-1" style="font-size:11px">
                                                +@pts @(pts == 1 ? "punto" : "puntos")
                                            </span>
                                            @if (sel.FloatingSubtreeSize > 0)
                                            {
                                                <span class="text-muted ms-1" style="font-size:11px">
                                                    (él + @sel.FloatingSubtreeSize en su subárbol)
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex gap-2 justify-content-end">
                                    <button class="btn btn-outline-secondary btn-sm"
                                            disabled="@_placingMember"
                                            @onclick="() => _selectedPlacementCandidate = null">
                                        Cambiar selección
                                    </button>
                                    <button class="btn btn-primary btn-sm"
                                            disabled="@_placingMember"
                                            @onclick="async () => await PlaceSelectedMember(sel.MemberId)">
                                        @if (_placingMember)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        Confirmar Placement
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="modal-footer">
                                <button class="btn btn-secondary btn-sm"
                                        disabled="@_placingMember"
                                        @onclick="() => _placementModalVisible = false">
                                    Cancelar
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        @* ── Unplacement Confirmation Modal ───────────────────────────────────── *@
        @if (_confirmUnplaceMemberId is not null)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
                <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
                    <div class="modal-content">
                        <div class="modal-header border-0 pb-0">
                            <h5 class="modal-title text-danger">
                                <i class="ri-error-warning-line me-2"></i>Confirmar Revert Placement
                            </h5>
                            <button type="button" class="btn-close"
                                    @onclick="() => _confirmUnplaceMemberId = null"
                                    disabled="@(_unplacingMemberId is not null)"></button>
                        </div>
                        <div class="modal-body pt-2">
                            <p class="mb-1">
                                ¿Está seguro que desea revertir el placement de
                                <strong>@_confirmUnplaceMemberName</strong>?
                            </p>
                            <p class="text-muted" style="font-size:13px">
                                El ambassador y su subárbol quedarán desvinculados del árbol dual.
                                Podrán ser re-colocados posteriormente y su subárbol los acompañará.
                            </p>
                        </div>
                        <div class="modal-footer border-0 pt-0">
                            <button class="btn btn-secondary btn-sm"
                                    @onclick="() => _confirmUnplaceMemberId = null"
                                    disabled="@(_unplacingMemberId is not null)">
                                Cancelar
                            </button>
                            <button class="btn btn-danger btn-sm"
                                    disabled="@(_unplacingMemberId is not null)"
                                    @onclick="async () => {
                                        var mid = _confirmUnplaceMemberId!;
                                        _confirmUnplaceMemberId = null;
                                        await UnplaceMemberAsync(mid);
                                    }">
                                @if (_unplacingMemberId is not null)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                Confirmar Revert
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

@code {
    // ── Parameters ───────────────────────────────────────────────────────────
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;
    [Parameter] public string ApiBaseUrl           { get; set; } = "api/v1/bizcenter/team";
    [Parameter] public string PlacementApiBaseUrl  { get; set; } = "api/v1/admin/placement";
    [Parameter] public bool   ShowBreadcrumb       { get; set; } = true;
    [Parameter] public bool   AllowUnplacement     { get; set; } = false;

    // ── JS interop ───────────────────────────────────────────────────────────
    private IJSObjectReference? _jsModule;
    private string _treeContainerId => "dtree-" + MemberProfileId.Replace("-", "").Replace("_", "");

    // ── State ────────────────────────────────────────────────────────────────
    private bool   _treeLoading  = true;
    private bool   _statsLoading = true;
    private string? _treeError;
    private string _currentRootId = string.Empty;

    private DualTreeNodeDto?      _rootNode;
    private int                   _leftLegPoints;
    private int                   _rightLegPoints;

    // Navigation breadcrumb stack: list of (memberId, displayName)
    private List<(string Id, string Name)> _navStack = new();

    // ── Placement modal state ─────────────────────────────────────────────────
    private bool   _placementModalVisible     = false;
    private bool   _placementCandidateLoading = false;
    private bool   _placingMember             = false;
    private string _placementTargetParentId   = string.Empty;
    private string _placementTargetParentName = string.Empty;
    private string _placementSide             = string.Empty;
    private string? _placementModalError;
    private List<PlacementCandidateDto> _placementCandidates = new();
    private PlacementCandidateDto?      _selectedPlacementCandidate;

    // ── Unplacement state ─────────────────────────────────────────────────────
    private string? _unplacingMemberId;        // non-null while the DELETE call is in flight
    private string? _unplacementError;
    private string? _confirmUnplaceMemberId;   // non-null when confirmation modal is open
    private string  _confirmUnplaceMemberName = string.Empty;

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new("Dashboard", "/dashboard"),
        new("Dual Team"),
        new("Visualizer")
    };

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(MemberProfileId) && _currentRootId != MemberProfileId)
        {
            _currentRootId = MemberProfileId;
            _navStack.Clear();
            await Task.WhenAll(LoadNodeAsync(_currentRootId), LoadStatsAsync(_currentRootId));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _jsModule = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./_content/MLMConquerorGlobalEdition.SharedComponents/js/dualtree.js");

        if (_jsModule is not null && !_treeLoading && _rootNode is not null)
            await _jsModule.InvokeVoidAsync("initPan", _treeContainerId);
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
            await _jsModule.DisposeAsync();
    }

    // ── Data loading ─────────────────────────────────────────────────────────
    private async Task LoadNodeAsync(string memberId)
    {
        _treeLoading = true;
        _treeError   = null;
        StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<DualTreeNodeDto>>(
                $"{ApiBaseUrl}/dual-tree/node/{Uri.EscapeDataString(memberId)}");
            _rootNode = resp?.Success == true ? resp.Data : null;
            if (_rootNode is null) _treeError = "Failed to load tree node.";
        }
        catch (Exception ex)
        {
            _treeError = $"API error: {ex.Message}";
        }
        finally
        {
            _treeLoading = false;
        }
    }

    private async Task LoadStatsAsync(string memberId)
    {
        _statsLoading = true;
        StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<DualTreeStatsDto>>(
                $"{ApiBaseUrl}/dual-tree/stats/{Uri.EscapeDataString(memberId)}");
            if (resp?.Success == true && resp.Data is not null)
            {
                _leftLegPoints  = resp.Data.LeftLegPoints;
                _rightLegPoints = resp.Data.RightLegPoints;
            }
        }
        catch { /* stats are supplemental — degrade silently */ }
        finally
        {
            _statsLoading = false;
        }
    }

    // ── Navigation ───────────────────────────────────────────────────────────
    private async Task ResetPanAsync()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("resetPan", _treeContainerId);
    }

    private async Task DrillIntoNode(DualTreeChildDto child)
    {
        if (_rootNode is not null)
            _navStack.Add((_rootNode.MemberId, _rootNode.FullName));

        await ResetPanAsync();
        _currentRootId = child.MemberId;
        await LoadNodeAsync(child.MemberId);
    }

    private async Task DrillIntoNodeById(string memberId, string fullName, string parentId, string parentName)
    {
        _navStack.Add((parentId, parentName));
        await ResetPanAsync();
        _currentRootId = memberId;
        await LoadNodeAsync(memberId);
    }

    private async Task NavigateTo(string memberId)
    {
        var idx = _navStack.FindIndex(x => x.Id == memberId);
        if (idx >= 0) _navStack = _navStack.Take(idx).ToList();
        await ResetPanAsync();
        _currentRootId = memberId;
        await LoadNodeAsync(memberId);
    }

    private async Task NavigateToRoot()
    {
        _navStack.Clear();
        await ResetPanAsync();
        _currentRootId = MemberProfileId;
        await Task.WhenAll(LoadNodeAsync(MemberProfileId), LoadStatsAsync(MemberProfileId));
    }

    // ── Placement modal ──────────────────────────────────────────────────────
    private async Task OpenPlacementModal(string targetParentMemberId, string parentName, string side)
    {
        _placementTargetParentId    = targetParentMemberId;
        _placementTargetParentName  = parentName;
        _placementSide              = side == "L" ? "Left" : "Right";
        _placementModalError        = null;
        _placementCandidates        = new();
        _selectedPlacementCandidate = null;
        _placementModalVisible      = true;
        _placementCandidateLoading  = true;
        StateHasChanged();

        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<PlacementCandidateDto>>>(
                $"{ApiBaseUrl}/dual-tree/available-for-placement");
            _placementCandidates = resp?.Success == true ? resp.Data ?? new() : new();
            if (!_placementCandidates.Any())
                _placementModalError = "No members available for placement.";
        }
        catch (Exception ex)
        {
            _placementModalError = $"Error loading candidates: {ex.Message}";
        }
        finally
        {
            _placementCandidateLoading = false;
            StateHasChanged();
        }
    }

    private async Task PlaceSelectedMember(string memberToPlaceId)
    {
        _placingMember       = true;
        _placementModalError = null;
        StateHasChanged();

        try
        {
            var body = new
            {
                memberToPlaceId,
                targetParentMemberId = _placementTargetParentId,
                side = _placementSide
            };
            var response = await Http.PostAsJsonAsync(PlacementApiBaseUrl, body);
            if (response.IsSuccessStatusCode)
            {
                _placementModalVisible = false;
                await Task.WhenAll(LoadNodeAsync(_currentRootId), LoadStatsAsync(_currentRootId));
            }
            else
            {
                _placementModalError = $"Placement failed: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            _placementModalError = $"Error: {ex.Message}";
        }
        finally
        {
            _placingMember = false;
            StateHasChanged();
        }
    }

    private async Task UnplaceMemberAsync(string memberId)
    {
        _unplacingMemberId = memberId;
        _unplacementError  = null;
        StateHasChanged();
        try
        {
            var response = await Http.DeleteAsync($"{PlacementApiBaseUrl}/{Uri.EscapeDataString(memberId)}");
            if (response.IsSuccessStatusCode)
                await Task.WhenAll(LoadNodeAsync(_currentRootId), LoadStatsAsync(_currentRootId));
            else
                _unplacementError = $"Error al revertir placement ({(int)response.StatusCode}).";
        }
        catch (Exception ex)
        {
            _unplacementError = $"Error: {ex.Message}";
        }
        finally
        {
            _unplacingMemberId = null;
            StateHasChanged();
        }
    }

    // ── Tree rendering (recursive up to 3 levels) ────────────────────────────
    private RenderFragment RenderNode(DualTreeNodeDto node, int depth) => __builder =>
    {
        var statusClass = ResolveStatusClass(node.StatusCode);
        <div class="member-view-box @statusClass">
            <div class="member-header">@node.StatusCode</div>
            <div class="member-avatar" title="@node.FullName — Click to drill in"
                 @onclick="() => { }">
                @(node.FullName.Length > 0 ? node.FullName[0].ToString().ToUpper() : "?")
            </div>
            <div class="member-footer" style="white-space:normal;word-break:break-word">@node.FullName</div>
            <div style="font-size:11px;color:#888;margin-top:2px;cursor:help"
                 title="@BuildRootPointsTooltip(node.Points, node.PersonalPoints)">
                @node.Points.ToString("N0") pts
            </div>
        </div>

        @* Render children if within depth limit *@
        @if (depth < 2)
        {
            <ul>
                @* Left slot *@
                <li>
                    @if (node.LeftChild is not null)
                    {
                        var left = node.LeftChild;
                        @RenderChildNode(left, depth + 1)
                    }
                    else
                    {
                        @RenderEmptySlot(node.MemberId, node.FullName, "L")
                    }
                </li>
                @* Right slot *@
                <li>
                    @if (node.RightChild is not null)
                    {
                        var right = node.RightChild;
                        @RenderChildNode(right, depth + 1)
                    }
                    else
                    {
                        @RenderEmptySlot(node.MemberId, node.FullName, "R")
                    }
                </li>
            </ul>
        }
        else if (depth == 2)
        {
            @* At max depth — show expand button if children exist *@
            var hasChildren = node.LeftChild is not null || node.RightChild is not null;
            @if (hasChildren)
            {
                var n = node;
                <div style="margin-top:8px">
                    <button class="btn btn-outline-primary btn-sm" style="font-size:11px"
                            @onclick="async () => await DrillIntoNodeById(n.MemberId, n.FullName, _currentRootId, _rootNode?.FullName ?? string.Empty)">
                        <i class="ri-expand-diagonal-line me-1"></i>Expand
                    </button>
                </div>
            }
        }
    };

    private RenderFragment RenderChildNode(DualTreeChildDto child, int depth) => __builder =>
    {
        var statusClass   = ResolveStatusClass(child.StatusCode);
        var capturedChild = child;
        <div class="member-view-box @statusClass">
            <div class="member-header">@child.StatusCode</div>
            <div class="member-avatar" title="@child.FullName — Click to drill in"
                 @onclick="async () => await DrillIntoNode(capturedChild)">
                @(child.FullName.Length > 0 ? child.FullName[0].ToString().ToUpper() : "?")
            </div>
            <div class="member-footer" style="white-space:normal;word-break:break-word">@child.FullName</div>
            <div style="font-size:11px;color:#888;margin-top:2px;cursor:help"
                 title="@BuildPointsTooltip(child.Points, child.PersonalPoints)">
                @((child.Points + child.PersonalPoints).ToString("N0")) pts
            </div>
            @if (AllowUnplacement)
            {
                var mid  = child.MemberId;
                var name = child.FullName;
                var busy = _unplacingMemberId == mid;
                <button class="revert-btn" disabled="@busy"
                        @onclick:stopPropagation="true"
                        @onclick="() => { _confirmUnplaceMemberId = mid; _confirmUnplaceMemberName = name; }">
                    @(busy ? "..." : "Revert Placement")
                </button>
            }
        </div>

        @* Level 2: show actual grandchildren or empty slots *@
        @if (depth < 2)
        {
            <ul>
                <li>
                    @if (child.LeftChild is not null)
                    {
                        var gc = child.LeftChild;
                        @RenderGrandchildNode(gc, child)
                    }
                    else
                    {
                        @RenderEmptySlot(child.MemberId, child.FullName, "L")
                    }
                </li>
                <li>
                    @if (child.RightChild is not null)
                    {
                        var gc = child.RightChild;
                        @RenderGrandchildNode(gc, child)
                    }
                    else
                    {
                        @RenderEmptySlot(child.MemberId, child.FullName, "R")
                    }
                </li>
            </ul>
        }
    };

    private RenderFragment RenderGrandchildNode(DualTreeGrandchildDto gc, DualTreeChildDto parent) => __builder =>
    {
        var capturedGc     = gc;
        var capturedParent = parent;
        var statusClass    = ResolveStatusClass(gc.StatusCode);
        <div class="member-view-box @statusClass" style="cursor:pointer"
             title="@gc.FullName — Click to drill in"
             @onclick="async () => await DrillIntoNodeById(capturedGc.MemberId, capturedGc.FullName, capturedParent.MemberId, capturedParent.FullName)">
            <div class="member-header">@gc.StatusCode</div>
            <div class="member-avatar">
                @(gc.FullName.Length > 0 ? gc.FullName[0].ToString().ToUpper() : "?")
            </div>
            <div class="member-footer" style="white-space:normal;word-break:break-word">@gc.FullName</div>
            <div style="font-size:11px;color:#888;margin-top:2px;cursor:help"
                 title="@BuildPointsTooltip(gc.Points, gc.PersonalPoints)">
                @((gc.Points + gc.PersonalPoints).ToString("N0")) pts
            </div>
            @if (gc.HasLeft || gc.HasRight)
            {
                <div style="font-size:10px;color:#888;margin-top:2px">
                    <i class="ri-expand-diagonal-line"></i> expand
                </div>
            }
            @if (AllowUnplacement)
            {
                var mid  = gc.MemberId;
                var name = gc.FullName;
                var busy = _unplacingMemberId == mid;
                <button class="revert-btn" disabled="@busy"
                        @onclick:stopPropagation="true"
                        @onclick="() => { _confirmUnplaceMemberId = mid; _confirmUnplaceMemberName = name; }">
                    @(busy ? "..." : "Revert Placement")
                </button>
            }
        </div>
    };

    private RenderFragment RenderEmptySlot(string parentMemberId, string parentName, string side) => __builder =>
    {
        var capturedParent     = parentMemberId;
        var capturedParentName = parentName;
        var capturedSide       = side;
        <div class="member-view-box" style="opacity:.65;cursor:pointer"
             @onclick="async () => await OpenPlacementModal(capturedParent, capturedParentName, capturedSide)">
            <div class="member-header" style="background:#b0b8c1">@side Empty</div>
            <div class="placeholder-node" title="Click to place a member">
                <i class="ri-add-line"></i>
            </div>
            <div class="member-footer" style="color:#b0b8c1;font-size:12px">Open Slot</div>
        </div>
    };

    // ── Helpers ──────────────────────────────────────────────────────────────
    private static string ResolveStatusClass(string statusCode) =>
        statusCode?.ToLower() switch
        {
            "qualified"             => "status-qualified",
            "active-qualified"      => "status-qualified",
            "unqualified"           => "status-unqualified",
            "active-unqualified"    => "status-unqualified",
            "active"                => "status-unqualified",
            "inactive"              => "status-cancelled",
            "suspended"             => "status-cancelled",
            "terminated"            => "status-cancelled",
            "cancelled"             => "status-cancelled",
            _                       => "status-unqualified"
        };

    // ── DTOs ─────────────────────────────────────────────────────────────────
    private class ApiWrapper<T> { public bool Success { get; set; } public T? Data { get; set; } }

    private record PlacementCandidateDto(string MemberId, string FullName, string? PhotoUrl, int FloatingSubtreeSize = 0);

    private class DualTreeNodeDto
    {
        public string           MemberId       { get; set; } = string.Empty;
        public string           FullName       { get; set; } = string.Empty;
        public string           StatusCode     { get; set; } = string.Empty;
        public int              Points         { get; set; }
        public int              PersonalPoints { get; set; }
        public DualTreeChildDto? LeftChild     { get; set; }
        public DualTreeChildDto? RightChild    { get; set; }
    }

    private class DualTreeChildDto
    {
        public string                MemberId       { get; set; } = string.Empty;
        public string                FullName       { get; set; } = string.Empty;
        public string                StatusCode     { get; set; } = string.Empty;
        public int                   Points         { get; set; }
        public int                   PersonalPoints { get; set; }
        public bool                  HasLeft        { get; set; }
        public bool                  HasRight       { get; set; }
        public DualTreeGrandchildDto? LeftChild     { get; set; }
        public DualTreeGrandchildDto? RightChild    { get; set; }
    }

    private class DualTreeGrandchildDto
    {
        public string MemberId       { get; set; } = string.Empty;
        public string FullName       { get; set; } = string.Empty;
        public string StatusCode     { get; set; } = string.Empty;
        public int    Points         { get; set; }
        public int    PersonalPoints { get; set; }
        public bool   HasLeft        { get; set; }
        public bool   HasRight       { get; set; }
    }

    /// <summary>
    /// Tooltip for non-root nodes: the visible number IS the contribution to the
    /// upline's leg. The tooltip breaks it down into personal + downline.
    /// </summary>
    private static string BuildPointsTooltip(int downlinePts, int personalPts)
    {
        var contribution = downlinePts + personalPts;
        return $"Contribution to upline's leg: {contribution:N0}\n" +
               $"  • Personal points: {personalPts:N0}\n" +
               $"  • Downline points: {downlinePts:N0}";
    }

    /// <summary>
    /// Tooltip for the root node: the visible number is the sum of both legs
    /// (= total downline points). No "upline contribution" since the root has no parent here.
    /// </summary>
    private static string BuildRootPointsTooltip(int downlinePts, int personalPts)
    {
        return $"Total downline points (left + right legs): {downlinePts:N0}\n" +
               $"  • Personal points (not included): {personalPts:N0}";
    }

    private class DualTreeStatsDto
    {
        public int LeftLegPoints  { get; set; }
        public int RightLegPoints { get; set; }
    }
}
