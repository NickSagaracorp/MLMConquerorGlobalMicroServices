@inject HttpClient Http
@inject NavigationManager Nav
@using System.Net.Http.Json

@if (ShowBreadcrumb) { <BreadcrumbNav Items="@_breadcrumb" /> }

<div class="card bg-white border-0 rounded-3 mb-4">
    <div class="card-body p-0">

        @* ── Search header ────────────────────────────────────────────────── *@
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 p-4">
            <div class="position-relative table-src-form me-0">
                <input type="text"
                       class="form-control"
                       placeholder="Search here"
                       value="@_search"
                       @oninput="OnSearchInput" />
                <i class="ri-search-line position-absolute top-50 start-0 translate-middle-y"></i>
            </div>
        </div>

        @* ── Body ─────────────────────────────────────────────────────────── *@
        @if (_isLoading)
        {
            <LoadingSpinner IsLoading="true" />
        }
        else if (_error is not null)
        {
            <div class="alert alert-danger m-3">@_error</div>
        }
        else
        {
            <div class="default-table-area style-two default-table-width">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Join Date</th>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Level</th>
                                <th>Leg</th>
                                <th>Country</th>
                                <th>Sponsor</th>
                                <th>Dual Team Upline</th>
                                <th>Biz Center Status</th>
                                <th>Membership Status</th>
                                <th>Qualified</th>
                                <th>Membership</th>
                                <th>Rank</th>
                                <th>Rank Date</th>
                                <th>Lifetime Rank</th>
                                <th>Next Rank %</th>
                                <th>Qual. Points</th>
                                <th>Enroll. Team Pts</th>
                                <th>Left Team Pts</th>
                                <th>Right Team Pts</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!_items.Any())
                            {
                                <tr>
                                    <td colspan="20" class="text-center text-muted py-4">No records to display.</td>
                                </tr>
                            }
                            @foreach (var m in _items)
                            {
                                <tr>
                                    <td class="text-body">@m.JoinDate.ToString("MMM dd, yyyy")</td>
                                    <td class="text-body"><code>@m.MemberId</code></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width:32px;height:32px;border-radius:50%;background:#605DFF22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                                <span style="font-size:12px;font-weight:700;color:#605DFF">
                                                    @(m.FullName.Length > 0 ? m.FullName[0].ToString().ToUpper() : "?")
                                                </span>
                                            </div>
                                            <span class="fw-medium">@m.FullName</span>
                                        </div>
                                    </td>
                                    <td class="text-body">@m.Level</td>
                                    <td>
                                        <span class="badge @(m.Leg == "Left" ? "bg-primary bg-opacity-10 text-primary" : "bg-info bg-opacity-10 text-info") p-2 fs-12 fw-normal">
                                            @m.Leg
                                        </span>
                                    </td>
                                    <td class="text-body">@m.Country</td>
                                    <td class="text-body">@(string.IsNullOrEmpty(m.SponsorName) ? "—" : m.SponsorName)</td>
                                    <td class="text-body">@(string.IsNullOrEmpty(m.DualTeamUplineName) ? "—" : m.DualTeamUplineName)</td>
                                    <td>@RenderStatusBadge(m.BizCenterStatus)</td>
                                    <td>@RenderStatusBadge(m.MembershipStatus)</td>
                                    <td>@RenderQualifiedBadge(m.QualifiedStatus)</td>
                                    <td class="text-body">@(string.IsNullOrEmpty(m.MembershipName) ? "—" : m.MembershipName)</td>
                                    <td class="text-body">@(string.IsNullOrEmpty(m.RankName) ? "—" : m.RankName)</td>
                                    <td class="text-body">@(m.RankDate.HasValue ? m.RankDate.Value.ToString("MMM dd, yyyy") : "—")</td>
                                    <td class="text-body">@(string.IsNullOrEmpty(m.LifetimeRankName) ? "—" : m.LifetimeRankName)</td>
                                    <td>
                                        @RenderNextRankDonut(m.NextRankPercent)
                                    </td>
                                    <td class="text-body">@m.QualificationPoints.ToString("N0")</td>
                                    <td class="text-body">@m.EnrollmentTeamPoints.ToString("N0")</td>
                                    <td class="text-body">@m.LeftTeamPoints.ToString("N0")</td>
                                    <td class="text-body">@m.RightTeamPoints.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* ── Pagination ───────────────────────────────────────────── *@
                <div class="p-4 pt-lg-4">
                    <div class="d-flex justify-content-center justify-content-sm-between align-items-center text-center flex-wrap gap-2 showing-wrap">
                        <span class="fs-12 fw-medium">Showing @_items.Count of @_total Results</span>
                        @if (_totalPages > 1)
                        {
                            <nav>
                                <ul class="pagination mb-0 justify-content-center">
                                    <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                        <button class="page-link icon" @onclick="() => LoadAsync(_page - 1)">
                                            <i class="ri-arrow-left-s-line"></i>
                                        </button>
                                    </li>
                                    @for (var pg = 1; pg <= _totalPages; pg++)
                                    {
                                        var p = pg;
                                        <li class="page-item @(p == _page ? "active" : "")">
                                            <button class="page-link" @onclick="() => LoadAsync(p)">@p</button>
                                        </li>
                                    }
                                    <li class="page-item @(_page >= _totalPages ? "disabled" : "")">
                                        <button class="page-link icon" @onclick="() => LoadAsync(_page + 1)">
                                            <i class="ri-arrow-right-s-line"></i>
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    // ── Parameters ───────────────────────────────────────────────────────────
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;
    [Parameter] public string ApiBaseUrl      { get; set; } = "api/v1/bizcenter/team";
    [Parameter] public bool   ShowBreadcrumb  { get; set; } = true;

    // ── State ────────────────────────────────────────────────────────────────
    private bool   _isLoading  = true;
    private string? _error;
    private string? _search;
    private int    _page       = 1;
    private int    _total;
    private int    _totalPages;
    private const int PageSize = 20;

    private List<DualTeamMemberDto> _items = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new("Dashboard", "/dashboard"),
        new("Dual Team"),
        new("My Team")
    };

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(MemberProfileId))
            await LoadAsync(1);
    }

    // ── Data loading ─────────────────────────────────────────────────────────
    private async Task LoadAsync(int page)
    {
        _page      = page;
        _isLoading = true;
        _error     = null;
        StateHasChanged();

        try
        {
            var url = $"{ApiBaseUrl}/members?page={page}&pageSize={PageSize}";
            if (!string.IsNullOrWhiteSpace(_search))
                url += $"&search={Uri.EscapeDataString(_search)}";

            var resp = await Http.GetFromJsonAsync<ApiWrapper<PagedData<DualTeamMemberDto>>>(url);
            if (resp?.Success == true && resp.Data is not null)
            {
                _items      = resp.Data.Items;
                _total      = resp.Data.TotalCount;
                _totalPages = (int)Math.Ceiling((double)_total / PageSize);
            }
            else
            {
                _error = "Failed to load team members.";
            }
        }
        catch (Exception ex)
        {
            _error = $"API error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Search debounce ──────────────────────────────────────────────────────
    private System.Threading.CancellationTokenSource? _searchCts;

    private async Task OnSearchInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        _search = e.Value?.ToString();
        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        var token = _searchCts.Token;
        try
        {
            await Task.Delay(350, token);
            if (!token.IsCancellationRequested)
                await LoadAsync(1);
        }
        catch (TaskCanceledException) { /* debounced */ }
    }

    // ── Render helpers ───────────────────────────────────────────────────────

    private RenderFragment RenderNextRankDonut(int pct) => __builder =>
    {
        <div style="position:relative;width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:conic-gradient(#605DFF @(pct)%, #ECEEF2 @(pct)%)">
            <div style="position:absolute;width:80%;height:80%;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                <p class="text-body fw-semibold mb-0" style="font-size:12px">@(pct)%</p>
            </div>
        </div>
    };

    private RenderFragment RenderStatusBadge(string status) => __builder =>
    {
        var cls = status?.ToLower() switch
        {
            "active"     => "success",
            "inactive"   => "warning",
            "suspended"  => "warning",
            "cancelled"  => "danger",
            "terminated" => "danger",
            _            => "secondary"
        };
        <span class="badge bg-@cls bg-opacity-10 text-@cls p-2 fs-12 fw-normal">@(status ?? "—")</span>
    };

    private RenderFragment RenderQualifiedBadge(string status) => __builder =>
    {
        if (string.Equals(status, "Qualified", StringComparison.OrdinalIgnoreCase))
        {
            <span class="badge bg-success bg-opacity-10 text-success p-2 fs-12 fw-normal">Qualified</span>
        }
        else
        {
            <span class="badge bg-warning bg-opacity-10 text-warning p-2 fs-12 fw-normal">Unqualified</span>
        }
    };

    // ── DTOs ─────────────────────────────────────────────────────────────────
    private class ApiWrapper<T> { public bool Success { get; set; } public T? Data { get; set; } }
    private class PagedData<T>  { public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    private record DualTeamMemberDto(
        string   MemberId,
        string   FullName,
        int      Level,
        string   Leg,
        string   Country,
        string   SponsorName,
        string   DualTeamUplineName,
        string   BizCenterStatus,
        string   MembershipStatus,
        string   QualifiedStatus,
        string   MembershipName,
        string   RankName,
        DateTime? RankDate,
        string   LifetimeRankName,
        int      NextRankPercent,
        int      QualificationPoints,
        int      EnrollmentTeamPoints,
        int      LeftTeamPoints,
        int      RightTeamPoints,
        DateTime JoinDate);
}
