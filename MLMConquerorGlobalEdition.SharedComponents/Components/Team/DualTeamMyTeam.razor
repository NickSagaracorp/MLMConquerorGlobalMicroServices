@inject HttpClient Http
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L
@using System.Net.Http.Json
@using Microsoft.Extensions.Localization
@using MLMConquerorGlobalEdition.SharedComponents.Resources
@using Syncfusion.Blazor.Grids

@if (ShowBreadcrumb) { <BreadcrumbNav Items="@_breadcrumb" /> }

<div class="card bg-white border-0 rounded-3 mb-4">
    <div class="card-body p-0">

        @* ── Search header ────────────────────────────────────────────────── *@
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 p-4">
            <div class="position-relative table-src-form me-0">
                <input type="text"
                       class="form-control"
                       placeholder="@L["Team.SearchPlaceholderHere"]"
                       value="@_search"
                       @oninput="OnSearchInput" />
                <i class="ri-search-line position-absolute top-50 start-0 translate-middle-y"></i>
            </div>
            <div class="d-flex align-items-center gap-2">
                <small class="text-muted">@_total @L["Common.Members"]</small>
                <button type="button"
                        class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1"
                        title="@L["Team.RefreshTitle"]"
                        disabled="@_isLoading"
                        @onclick="RefreshAsync">
                    <i class="ri-refresh-line"></i>
                    <span>@L["Common.Refresh"]</span>
                </button>
            </div>
        </div>

        @* ── Body ─────────────────────────────────────────────────────────── *@
        @if (_isLoading)
        {
            <LoadingSpinner IsLoading="true" />
        }
        else if (_error is not null)
        {
            <div class="alert alert-danger m-3">@_error</div>
        }
        else
        {
            <SfGrid TValue="DualTeamMyTeamMemberDto" DataSource="@_items"
                    AllowPaging="true" AllowSorting="true" AllowResizing="true"
                    AllowFiltering="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="20" PageSizes="@(new int[]{20,50,100})" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.EnrollDate)"
                                HeaderText="@L["Reports.JoinDate"]" Width="125" TextAlign="TextAlign.Center"
                                Format="MMM dd, yyyy" Type="ColumnType.Date">
                        <Template>
                            @(((DualTeamMyTeamMemberDto)context).EnrollDate.ToString("MMM dd, yyyy"))
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.MemberId)"
                                HeaderText="@L["Reports.Id"]" Width="120" Type="ColumnType.String">
                        <Template>
                            <code>@(((DualTeamMyTeamMemberDto)context).MemberId)</code>
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.FullName)"
                                HeaderText="@L["Reports.Name"]" Width="200" Type="ColumnType.String">
                        <Template>
                            @{ var m = (DualTeamMyTeamMemberDto)context; }
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:32px;height:32px;border-radius:50%;background:#605DFF22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                    <span style="font-size:12px;font-weight:700;color:#605DFF">
                                        @(m.FullName.Length > 0 ? m.FullName[0].ToString().ToUpper() : "?")
                                    </span>
                                </div>
                                <span class="fw-medium">@m.FullName</span>
                            </div>
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.Level)"
                                HeaderText="@L["Reports.Level"]" Width="80" TextAlign="TextAlign.Center"
                                Type="ColumnType.Integer" />

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.Leg)"
                                HeaderText="@L["Reports.Leg"]" Width="100" TextAlign="TextAlign.Center"
                                Type="ColumnType.String">
                        <Template>
                            @{ var lm = (DualTeamMyTeamMemberDto)context; }
                            <span class="badge @(lm.Leg == "Left" ? "bg-primary bg-opacity-10 text-primary" : "bg-info bg-opacity-10 text-info") p-2 fs-12 fw-normal">
                                @(string.IsNullOrEmpty(lm.Leg) ? "—" : (lm.Leg == "Left" ? L["Team.LegLeft"].Value : (lm.Leg == "Right" ? L["Team.LegRight"].Value : lm.Leg)))
                            </span>
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.Country)"
                                HeaderText="@L["Reports.Country"]" Width="110" Type="ColumnType.String" />

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.SponsorFullName)"
                                HeaderText="@L["Reports.Sponsor"]" Width="150" Type="ColumnType.String">
                        <Template>
                            @{ var sm = (DualTeamMyTeamMemberDto)context; }
                            @(string.IsNullOrEmpty(sm.SponsorFullName) ? "—" : sm.SponsorFullName)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.DualUplineFullName)"
                                HeaderText="@L["Reports.DualTeamUpline"]" Width="160" Type="ColumnType.String">
                        <Template>
                            @{ var um = (DualTeamMyTeamMemberDto)context; }
                            @(string.IsNullOrEmpty(um.DualUplineFullName) ? "—" : um.DualUplineFullName)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.AccountStatus)"
                                HeaderText="@L["Reports.BizCenterStatus"]" Width="140" TextAlign="TextAlign.Center"
                                Type="ColumnType.String">
                        <Template>
                            @RenderStatusBadge(((DualTeamMyTeamMemberDto)context).AccountStatus)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.MembershipStatus)"
                                HeaderText="@L["Reports.MembershipStatus"]" Width="150" TextAlign="TextAlign.Center"
                                Type="ColumnType.String">
                        <Template>
                            @RenderStatusBadge(((DualTeamMyTeamMemberDto)context).MembershipStatus)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.IsQualified)"
                                HeaderText="@L["Reports.Qualified"]" Width="120" TextAlign="TextAlign.Center"
                                Type="ColumnType.Boolean">
                        <Template>
                            @RenderQualifiedBadge(((DualTeamMyTeamMemberDto)context).IsQualified)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.MembershipLevelName)"
                                HeaderText="@L["Reports.Membership"]" Width="180" Type="ColumnType.String">
                        <Template>
                            @{ var mm = (DualTeamMyTeamMemberDto)context; }
                            @(string.IsNullOrEmpty(mm.MembershipLevelName) ? "—" : mm.MembershipLevelName)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.CurrentRankName)"
                                HeaderText="@L["Reports.Rank"]" Width="130" Type="ColumnType.String">
                        <Template>
                            @{ var rm = (DualTeamMyTeamMemberDto)context; }
                            @(string.IsNullOrEmpty(rm.CurrentRankName) ? "—" : rm.CurrentRankName)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.RankDate)"
                                HeaderText="@L["Reports.RankDate"]" Width="125" TextAlign="TextAlign.Center"
                                Format="MMM dd, yyyy" Type="ColumnType.Date">
                        <Template>
                            @{ var rd = ((DualTeamMyTeamMemberDto)context).RankDate; }
                            @(rd.HasValue ? rd.Value.ToString("MMM dd, yyyy") : "—")
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.LifetimeRankName)"
                                HeaderText="@L["Reports.LifetimeRank"]" Width="140" Type="ColumnType.String">
                        <Template>
                            @{ var ltm = (DualTeamMyTeamMemberDto)context; }
                            @(string.IsNullOrEmpty(ltm.LifetimeRankName) ? "—" : ltm.LifetimeRankName)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.NextRankPercent)"
                                HeaderText="@L["Reports.NextRankPercent"]" Width="110" TextAlign="TextAlign.Center"
                                Type="ColumnType.Integer">
                        <Template>
                            @RenderNextRankDonut(((DualTeamMyTeamMemberDto)context).NextRankPercent)
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.QualificationPoints)"
                                HeaderText="@L["Reports.QualPoints"]" Width="115" TextAlign="TextAlign.Right"
                                Type="ColumnType.Integer">
                        <Template>
                            @(((DualTeamMyTeamMemberDto)context).QualificationPoints.ToString("N0"))
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.EnrollmentTeamPoints)"
                                HeaderText="@L["Reports.EnrollTeamPoints"]" Width="135" TextAlign="TextAlign.Right"
                                Type="ColumnType.Integer">
                        <Template>
                            @(((DualTeamMyTeamMemberDto)context).EnrollmentTeamPoints.ToString("N0"))
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.LeftTeamPoints)"
                                HeaderText="@L["Reports.LeftTeamPoints"]" Width="125" TextAlign="TextAlign.Right"
                                Type="ColumnType.Decimal">
                        <Template>
                            @(((DualTeamMyTeamMemberDto)context).LeftTeamPoints.ToString("N0"))
                        </Template>
                    </GridColumn>

                    <GridColumn Field="@nameof(DualTeamMyTeamMemberDto.RightTeamPoints)"
                                HeaderText="@L["Reports.RightTeamPoints"]" Width="125" TextAlign="TextAlign.Right"
                                Type="ColumnType.Decimal">
                        <Template>
                            @(((DualTeamMyTeamMemberDto)context).RightTeamPoints.ToString("N0"))
                        </Template>
                    </GridColumn>

                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

@code {
    // ── Parameters ───────────────────────────────────────────────────────────
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;
    [Parameter] public string ApiBaseUrl      { get; set; } = "api/v1/bizcenter/team/dual-tree";
    [Parameter] public bool   ShowBreadcrumb  { get; set; } = true;

    // ── State ────────────────────────────────────────────────────────────────
    private bool   _isLoading  = true;
    private string? _error;
    private string? _search;
    private int    _page       = 1;
    private int    _total;
    private const int PageSize = 20;

    private List<DualTeamMyTeamMemberDto> _items = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new(L["Nav.Dashboard"], "/dashboard"),
        new(L["Sidebar.DualTeam"]),
        new(L["Sidebar.MyTeam"])
    };

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(MemberProfileId))
            await LoadAsync(1);
    }

    // ── Data loading ─────────────────────────────────────────────────────────
    /// <summary>
    /// User-triggered "Refresh" action. Re-fetches the current page bypassing
    /// the BizCenter API's 5-minute cache so the user can see fresh data on
    /// demand (e.g., after a placement or rank change they expect to see).
    /// </summary>
    private Task RefreshAsync() => LoadAsync(_page, bypassCache: true);

    private async Task LoadAsync(int page, bool bypassCache = false)
    {
        _page      = page;
        _isLoading = true;
        _error     = null;
        StateHasChanged();

        try
        {
            var url = $"{ApiBaseUrl}/my-team?page={page}&pageSize={PageSize}";
            if (!string.IsNullOrWhiteSpace(_search))
                url += $"&search={Uri.EscapeDataString(_search)}";
            if (bypassCache)
                url += "&bypassCache=true";

            var resp = await Http.GetFromJsonAsync<ApiWrapper<PagedData<DualTeamMyTeamMemberDto>>>(url);
            if (resp?.Success == true && resp.Data is not null)
            {
                _items = resp.Data.Items;
                _total = resp.Data.TotalCount;
            }
            else
            {
                _error = L["Team.LoadFailedDualMembers"];
            }
        }
        catch (Exception ex)
        {
            _error = $"{L["Team.ApiErrorPrefix"]} {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Search debounce ──────────────────────────────────────────────────────
    private System.Threading.CancellationTokenSource? _searchCts;

    private async Task OnSearchInput(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        _search = e.Value?.ToString();
        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        var token = _searchCts.Token;
        try
        {
            await Task.Delay(350, token);
            if (!token.IsCancellationRequested)
                await LoadAsync(1);
        }
        catch (TaskCanceledException) { /* debounced */ }
    }

    // ── Render helpers ───────────────────────────────────────────────────────

    private RenderFragment RenderNextRankDonut(int pct) => __builder =>
    {
        <div style="position:relative;width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:conic-gradient(#605DFF @(pct)%, #ECEEF2 @(pct)%)">
            <div style="position:absolute;width:80%;height:80%;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                <p class="text-body fw-semibold mb-0" style="font-size:12px">@(pct)%</p>
            </div>
        </div>
    };

    private RenderFragment RenderStatusBadge(string status) => __builder =>
    {
        var cls = status?.ToLower() switch
        {
            "active"     => "success",
            "inactive"   => "warning",
            "suspended"  => "warning",
            "cancelled"  => "danger",
            "terminated" => "danger",
            _            => "secondary"
        };
        <span class="badge bg-@cls bg-opacity-10 text-@cls p-2 fs-12 fw-normal">@(status ?? "—")</span>
    };

    private RenderFragment RenderQualifiedBadge(bool isQualified) => __builder =>
    {
        if (isQualified)
        {
            <span class="badge bg-success bg-opacity-10 text-success p-2 fs-12 fw-normal">@L["Reports.Qualified"]</span>
        }
        else
        {
            <span class="badge bg-warning bg-opacity-10 text-warning p-2 fs-12 fw-normal">@L["Reports.Unqualified"]</span>
        }
    };

    // ── DTOs ─────────────────────────────────────────────────────────────────
    private class ApiWrapper<T> { public bool Success { get; set; } public T? Data { get; set; } }
    private class PagedData<T>  { public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    // Field names match the backend DualTeamMyTeamMemberDto exactly so
    // System.Text.Json deserializes without remapping. Public class with
    // mutable properties is required by Syncfusion's reflection.
    public class DualTeamMyTeamMemberDto
    {
        public string    MemberId             { get; set; } = string.Empty;
        public string    FullName             { get; set; } = string.Empty;
        public string    Email                { get; set; } = string.Empty;
        public string?   Phone                { get; set; }
        public string    Country              { get; set; } = string.Empty;
        public int       Level                { get; set; }
        public string    Leg                  { get; set; } = string.Empty;
        public DateTime  EnrollDate           { get; set; }
        public string?   SponsorMemberId      { get; set; }
        public string?   SponsorFullName      { get; set; }
        public string?   DualUplineMemberId   { get; set; }
        public string?   DualUplineFullName   { get; set; }
        public string    AccountStatus        { get; set; } = string.Empty;
        public string    MembershipStatus     { get; set; } = string.Empty;
        public bool      IsQualified          { get; set; }
        public string?   MembershipLevelName  { get; set; }
        public string?   CurrentRankName      { get; set; }
        public DateTime? RankDate             { get; set; }
        public string?   LifetimeRankName     { get; set; }
        public int       NextRankPercent      { get; set; }
        public int       QualificationPoints  { get; set; }
        public int       EnrollmentTeamPoints { get; set; }
        public decimal   LeftTeamPoints       { get; set; }
        public decimal   RightTeamPoints      { get; set; }
    }
}
