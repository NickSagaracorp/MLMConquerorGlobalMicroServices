@inject IViewContextService ViewContext
@inject HttpClient Http
@inject NavigationManager Nav

@using MLMConquerorGlobalEdition.SharedComponents.Constants

<BreadcrumbNav Items="@_breadcrumb" />

<div class="card">
    <div class="card-header py-3">
        <h6 class="card-title mb-0 fw-semibold">My Dual Team Members</h6>
    </div>
    <div class="card-body p-0">
        <LoadingSpinner IsLoading="@_isLoading" />
        @if (!_isLoading)
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Member ID</th>
                            <th>Name</th>
                            <th>Side</th>
                            <th>Points</th>
                            <th>Enrolled</th>
                            <th>Status</th>
                            @if (ViewContext.IsAdminContext)
                            {
                                <th class="text-center">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (!_items.Any())
                        {
                            <tr><td colspan="7" class="text-center text-muted py-4">No data available.</td></tr>
                        }
                        @foreach (var m in _items)
                        {
                            <tr>
                                <td><code>@m.MemberId</code></td>
                                <td>@m.FullName</td>
                                <td><span class="badge bg-@(m.Side == "Left" ? "primary" : "info")">@m.Side</span></td>
                                <td>@m.Points.ToString("N0")</td>
                                <td>@m.EnrolledAt.ToString("MMM dd, yyyy")</td>
                                <td><StatusBadge Status="@m.Status" /></td>
                                @if (ViewContext.IsAdminContext)
                                {
                                    <td class="text-center">
                                        <button class="btn btn-xs btn-outline-secondary"
                                                @onclick="() => ViewMemberAsAdmin(m.MemberId)"
                                                title="View as Admin">
                                            <i class="ri-eye-line"></i>
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_total > _pageSize)
            {
                var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                <div class="d-flex justify-content-center py-3">
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page - 1)">&#x2039;</button>
                            </li>
                            @for (var pg = 1; pg <= totalPages; pg++)
                            {
                                var p = pg;
                                <li class="page-item @(p == _page ? "active" : "")">
                                    <button class="page-link" @onclick="() => ChangePage(p)">@p</button>
                                </li>
                            }
                            <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page + 1)">&#x203A;</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool _isLoading = true;
    private int  _page = 1, _pageSize = 20, _total;
    private List<TeamMemberDto> _items = new();

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new("Dashboard", "/dashboard"),
        new("My Dual Team")
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await LoadPageAsync(1);
    }

    private async Task ChangePage(int page) => await LoadPageAsync(page);

    private async Task LoadPageAsync(int page)
    {
        _page = page; _isLoading = true; StateHasChanged();
        // TODO: GET /api/v1/bizcenter/team/members?memberId={MemberProfileId}&page={page}&pageSize={_pageSize}
        await Task.Delay(50);
        _isLoading = false;
    }

    private void ViewMemberAsAdmin(string memberId)
        => Nav.NavigateTo($"/admin/members/{memberId}");

    public record TeamMemberDto(
        string   MemberId,
        string   FullName,
        string   Side,
        decimal  Points,
        DateTime EnrolledAt,
        string   Status);
}
