@inject HttpClient Http

@*
    Address editor. PUT /profile is the only place the server logs changes to
    the address-history table, so we send the whole editable payload here too.
    The reason field is forwarded but optional; the API tolerates null.
*@

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 border-bottom pb-3 mb-3">
            <h6 class="fs-18 mb-0 fw-semibold">
                <i class="ri-map-pin-line me-2 text-primary"></i>Address &amp; Contact
            </h6>
            <button class="btn btn-sm btn-outline-secondary"
                    @onclick="() => OnHistoryRequested.InvokeAsync()">
                <i class="ri-history-line me-1"></i>View address history
            </button>
        </div>

        <EditForm Model="_form" OnValidSubmit="SaveAsync">
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label small">Phone</label>
                    <InputText class="form-control" @bind-Value="_form.Phone" placeholder="(+1) 555 123 4567" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small">WhatsApp</label>
                    <InputText class="form-control" @bind-Value="_form.WhatsApp" placeholder="(+1) 555 123 4567" />
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label small">Country</label>
                    <InputText class="form-control" @bind-Value="_form.Country" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small">State / Province</label>
                    <InputText class="form-control" @bind-Value="_form.State" />
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label small">City</label>
                    <InputText class="form-control" @bind-Value="_form.City" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small">ZIP / Postal Code</label>
                    <InputText class="form-control" @bind-Value="_form.ZipCode" />
                </div>

                <div class="col-12">
                    <label class="form-label small">Address</label>
                    <InputText class="form-control" @bind-Value="_form.Address" placeholder="Street, number, unit" />
                </div>

                <div class="col-12">
                    <label class="form-label small">
                        Reason for change <span class="text-muted">(optional, helps support audit)</span>
                    </label>
                    <InputTextArea class="form-control" rows="2" @bind-Value="_form.AddressChangeReason" />
                </div>
            </div>

            <div class="mt-3 d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary" disabled="@_busy" @onclick="ResetForm">
                    Reset
                </button>
                <button type="submit" class="btn btn-primary" disabled="@(_busy || !HasChanges())">
                    @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    Save changes
                </button>
            </div>

            @if (!string.IsNullOrEmpty(_success)) { <div class="alert alert-success small mt-3 mb-0">@_success</div> }
            @if (!string.IsNullOrEmpty(_error))   { <ApiErrorAlert ErrorMessage="@_error" /> }
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public string?  Phone            { get; set; }
    [Parameter] public string?  WhatsApp         { get; set; }
    [Parameter] public string?  Country          { get; set; }
    [Parameter] public string?  State            { get; set; }
    [Parameter] public string?  City             { get; set; }
    [Parameter] public string?  Address          { get; set; }
    [Parameter] public string?  ZipCode          { get; set; }
    [Parameter] public string?  DefaultLanguage  { get; set; }
    [Parameter] public string?  PayoutFrequency  { get; set; }
    [Parameter] public bool     ShowBusinessName { get; set; }
    [Parameter] public bool     IsEmailPublic    { get; set; }
    [Parameter] public bool     IsPhonePublic    { get; set; }

    [Parameter] public EventCallback OnSaved             { get; set; }
    [Parameter] public EventCallback OnHistoryRequested  { get; set; }

    private AddressForm _form    = new();
    private AddressForm _initial = new();
    private bool        _busy;
    private string?     _success;
    private string?     _error;

    protected override void OnParametersSet()
    {
        // Snapshot the inbound DTO into the editable form. We keep _initial so
        // the Reset button and the change-detection logic both have a baseline.
        _initial = new AddressForm
        {
            Phone               = Phone    ?? string.Empty,
            WhatsApp            = WhatsApp ?? string.Empty,
            Country             = Country  ?? string.Empty,
            State               = State    ?? string.Empty,
            City                = City     ?? string.Empty,
            Address             = Address  ?? string.Empty,
            ZipCode             = ZipCode  ?? string.Empty,
            AddressChangeReason = string.Empty
        };
        _form = Clone(_initial);
    }

    private bool HasChanges() =>
        _form.Phone    != _initial.Phone    ||
        _form.WhatsApp != _initial.WhatsApp ||
        _form.Country  != _initial.Country  ||
        _form.State    != _initial.State    ||
        _form.City     != _initial.City     ||
        _form.Address  != _initial.Address  ||
        _form.ZipCode  != _initial.ZipCode  ||
        !string.IsNullOrEmpty(_form.AddressChangeReason);

    private void ResetForm()
    {
        _form = Clone(_initial);
        _success = null; _error = null;
    }

    private static AddressForm Clone(AddressForm src) => new()
    {
        Phone               = src.Phone,
        WhatsApp            = src.WhatsApp,
        Country             = src.Country,
        State               = src.State,
        City                = src.City,
        Address             = src.Address,
        ZipCode             = src.ZipCode,
        AddressChangeReason = src.AddressChangeReason
    };

    private async Task SaveAsync()
    {
        _busy = true; _success = null; _error = null; StateHasChanged();
        try
        {
            var resp = await Http.PutAsJsonAsync("api/v1/bizcenter/profile", new
            {
                _form.Phone,
                _form.WhatsApp,
                _form.Country,
                _form.State,
                _form.City,
                _form.Address,
                _form.ZipCode,
                _form.AddressChangeReason,
                DefaultLanguage,
                PayoutFrequency,
                ShowBusinessName,
                IsEmailPublic,
                IsPhonePublic
            });

            if (resp.IsSuccessStatusCode)
            {
                _success = "Profile saved.";
                _initial = Clone(_form);
                _form.AddressChangeReason = string.Empty;
                await OnSaved.InvokeAsync();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _error = $"Failed to save profile ({(int)resp.StatusCode}). {body}";
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; StateHasChanged(); }
    }

    private class AddressForm
    {
        public string Phone               { get; set; } = string.Empty;
        public string WhatsApp            { get; set; } = string.Empty;
        public string Country             { get; set; } = string.Empty;
        public string State               { get; set; } = string.Empty;
        public string City                { get; set; } = string.Empty;
        public string Address             { get; set; } = string.Empty;
        public string ZipCode             { get; set; } = string.Empty;
        public string AddressChangeReason { get; set; } = string.Empty;
    }
}
