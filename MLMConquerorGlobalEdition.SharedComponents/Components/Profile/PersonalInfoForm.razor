@inject HttpClient Http

<EditForm Model="@_form" OnValidSubmit="SaveAsync">
    <div class="row g-3">
        <div class="col-12 col-sm-6">
            <label class="form-label">First Name</label>
            <InputText class="form-control" @bind-Value="_form.FirstName" disabled="@IsReadOnly" />
        </div>
        <div class="col-12 col-sm-6">
            <label class="form-label">Last Name</label>
            <InputText class="form-control" @bind-Value="_form.LastName" disabled="@IsReadOnly" />
        </div>
        <div class="col-12 col-sm-6">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="_form.Email" disabled="true" />
            <div class="form-text text-muted">Email changes use the Credentials tab.</div>
        </div>
        <div class="col-12 col-sm-6">
            <label class="form-label">Phone</label>
            <InputText class="form-control" @bind-Value="_form.Phone" disabled="@IsReadOnly" />
        </div>
        <div class="col-12 col-sm-6">
            <label class="form-label">Country</label>
            <InputText class="form-control" @bind-Value="_form.Country" disabled="@IsReadOnly" />
        </div>
        <div class="col-12 col-sm-6">
            <label class="form-label">City</label>
            <InputText class="form-control" @bind-Value="_form.City" disabled="@IsReadOnly" />
        </div>
    </div>

    @if (!IsReadOnly)
    {
        <div class="mt-4">
            <button type="submit" class="btn btn-primary" disabled="@_saving">
                @if (_saving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Save Changes
            </button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_successMsg))
    {
        <div class="alert alert-success mt-3">@_successMsg</div>
    }
    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <ApiErrorAlert ErrorMessage="@_errorMsg" />
    }
</EditForm>

@code {
    [Parameter] public UserProfilePage.MemberProfileDto? Profile { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }

    private PersonalInfoFormModel _form   = new();
    private bool    _saving    = false;
    private string? _successMsg;
    private string? _errorMsg;

    protected override void OnParametersSet()
    {
        if (Profile is null) return;
        _form = new PersonalInfoFormModel
        {
            FirstName = Profile.FirstName,
            LastName  = Profile.LastName,
            Email     = Profile.Email,
            Phone     = Profile.Phone ?? string.Empty,
            Country   = Profile.Country ?? string.Empty,
            City      = Profile.City ?? string.Empty
        };
    }

    private async Task SaveAsync()
    {
        _saving     = true;
        _successMsg = null;
        _errorMsg   = null;

        try
        {
            // TODO: PUT /api/v1/bizcenter/profile
            await Task.Delay(300);
            _successMsg = "Profile updated successfully.";
        }
        catch (Exception ex)
        {
            _errorMsg = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    public class PersonalInfoFormModel
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName  { get; set; } = string.Empty;
        public string Email     { get; set; } = string.Empty;
        public string Phone     { get; set; } = string.Empty;
        public string Country   { get; set; } = string.Empty;
        public string City      { get; set; } = string.Empty;
    }
}
