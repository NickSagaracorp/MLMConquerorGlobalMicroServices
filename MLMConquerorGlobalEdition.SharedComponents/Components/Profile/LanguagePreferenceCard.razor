@inject HttpClient Http
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

@using Microsoft.Extensions.Localization
@using MLMConquerorGlobalEdition.SharedComponents.Resources
@using MLMConquerorGlobalEdition.SharedKernel

@*
    Language picker. The persisted value drives default-language behavior across
    the app. After persisting through PUT /profile we hit the host's /culture
    endpoint so the .NET RequestLocalization cookie gets refreshed and the new
    language applies to the current session immediately (full reload, by design).

    Visible strings come from SharedResources.{culture}.resx via IStringLocalizer.
    Each language button label uses the "Lang.{code}" key, so the endonym is
    pulled from the resx (with English fallback) instead of being hardcoded.
*@

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body p-4">
        <h6 class="fs-18 mb-1 fw-semibold">
            <i class="ri-translate-2 me-2 text-primary"></i>@L["LanguageCard.Title"]
        </h6>
        <p class="text-muted small mb-3">
            @L["LanguageCard.Description"]
        </p>

        <div class="row g-2">
            @foreach (var lang in _languages)
            {
                var isActive = string.Equals(_selected, lang.Code, StringComparison.OrdinalIgnoreCase);
                <div class="col-6 col-md-4">
                    <button type="button"
                            class="btn w-100 text-start d-flex align-items-center gap-2 @(isActive ? "btn-primary" : "btn-outline-secondary")"
                            @onclick="() => SelectAsync(lang.Code)">
                        <span class="fs-5">@lang.Flag</span>
                        <span class="flex-grow-1">@L[$"Lang.{lang.Code}"]</span>
                        @if (isActive)
                        {
                            <i class="ri-check-line"></i>
                        }
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string? CurrentLanguage  { get; set; }
    [Parameter] public string?  Phone           { get; set; }
    [Parameter] public string?  WhatsApp        { get; set; }
    [Parameter] public string?  Country         { get; set; }
    [Parameter] public string?  State           { get; set; }
    [Parameter] public string?  City            { get; set; }
    [Parameter] public string?  Address         { get; set; }
    [Parameter] public string?  ZipCode         { get; set; }
    [Parameter] public string?  PayoutFrequency { get; set; }
    [Parameter] public bool     ShowBusinessName { get; set; }
    [Parameter] public bool     IsEmailPublic    { get; set; }
    [Parameter] public bool     IsPhonePublic    { get; set; }

    [Parameter] public EventCallback<string> OnLanguageChanged { get; set; }

    private record Language(string Code, string Flag);
    private readonly List<Language> _languages = new()
    {
        new("en", "🇺🇸"),
        new("es", "🇪🇸"),
        new("pt", "🇵🇹"),
        new("fr", "🇫🇷"),
        new("de", "🇩🇪"),
        new("zh", "🇨🇳"),
        new("it", "🇮🇹"),
        new("kr", "🇰🇷"),
        new("ge", "🇬🇪")
    };

    private string _selected = "en";

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(CurrentLanguage))
            _selected = CurrentLanguage!;
    }

    private void SelectAsync(string code)
    {
        if (_selected == code) return;
        _selected = code;

        // Fire-and-forget the persistence PUT so we don't make the user wait
        // ~200-500ms for the API roundtrip before the language visibly
        // changes. The HttpClient request goes out immediately and reaches
        // the server even if the navigation below tears down the circuit
        // moments later. Worst case (network drop): the cookie still applied
        // for this session, but the preference reverts to the old value next
        // login — acceptable degradation for a 5x perceived speed win.
        _ = Http.PutAsJsonAsync("api/v1/bizcenter/profile", new
        {
            Phone, WhatsApp, Country, State, City, Address, ZipCode,
            AddressChangeReason = (string?)null,
            DefaultLanguage = code,
            PayoutFrequency,
            ShowBusinessName, IsEmailPublic, IsPhonePublic
        });

        // Navigate immediately so the RequestLocalization cookie flips and
        // the new culture is visible on the next request.
        var cultureName = LanguageCodeMapper.ToCultureName(code);
        var redirectTo  = Uri.EscapeDataString(Nav.Uri);
        Nav.NavigateTo(
            $"/culture?culture={Uri.EscapeDataString(cultureName)}&redirectUri={redirectTo}",
            forceLoad: true);
    }
}
