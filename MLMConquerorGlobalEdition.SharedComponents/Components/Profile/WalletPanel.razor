@inject HttpClient Http
@inject IViewContextService ViewContext
@inject IStringLocalizer<SharedResources> L

<LoadingSpinner IsLoading="@_isLoading" />

@if (!_isLoading)
{
    @if (_alertMsg is not null)
    {
        <div class="alert @(_alertIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
            @_alertMsg <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
        </div>
    }

    @* ─── Tabs: Payment Method (cards + transactions) | Payout Options (gateways + history) ─── *@
    <ul class="nav nav-tabs mb-3" role="tablist">
        <li class="nav-item">
            <button class="nav-link @(_activeTab == "payment" ? "active" : "")"
                    @onclick='() => _activeTab = "payment"'>
                <i class="ri-bank-card-line me-1"></i>@L["PaymentMethod.PaymentMethodTab"]
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_activeTab == "payout" ? "active" : "")"
                    @onclick='() => _activeTab = "payout"'>
                <i class="ri-wallet-3-line me-1"></i>@L["PaymentMethod.PayoutOptionsTab"]
            </button>
        </li>
    </ul>

    @if (_activeTab == "payment")
    {
        <PaymentMethodTab />
        <div class="mt-4">
            <BillingHistoryTable />
        </div>
    }
    else
    {
    <div class="row g-3">
        @* ─── Active wallets per gateway ─────────────────────────────────────── *@
        <div class="col-12">
            <div class="card">
                <div class="card-header py-3 d-flex align-items-center">
                    <h6 class="card-title mb-0 fw-semibold flex-grow-1">
                        <i class="ri-wallet-3-line me-2 text-primary"></i>@L["PaymentMethod.PayoutOptionsTitle"]
                    </h6>
                    <small class="text-muted">@L["PaymentMethod.PayoutOptionsHint"]</small>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @foreach (var gw in _supportedGateways)
                        {
                            var existing = _wallets.FirstOrDefault(w => w.WalletType == gw.Code);
                            var info     = _gatewayInfos.FirstOrDefault(i => i.WalletType == gw.Code);
                            var isPreferred = existing?.IsPreferred == true;
                            var canBeDefault = existing is not null && !isPreferred && existing.StatusName == "Approved";
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="card h-100 @(isPreferred ? "border-success border-2 shadow-sm" : "")">
                                    @if (isPreferred)
                                    {
                                        <div class="bg-success bg-opacity-10 border-bottom border-success py-2 px-3">
                                            <span class="text-success fw-semibold small">
                                                <i class="ri-star-fill me-1"></i>@L["PaymentMethod.DefaultReceiving"]
                                            </span>
                                        </div>
                                    }
                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex align-items-start mb-2">
                                            <i class="@gw.Icon fs-22 me-2 text-primary"></i>
                                            <div class="flex-grow-1">
                                                <h6 class="mb-0 fw-semibold">@(info?.DisplayName ?? gw.Label)</h6>
                                                @if (info is not null)
                                                {
                                                    <div class="small text-muted mt-1">
                                                        <i class="ri-money-dollar-circle-line me-1"></i>@L["PaymentMethod.AdminFee"] <strong>@info.AdminFeeDisplay</strong> @L["PaymentMethod.PerPayout"]
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        @if (info is not null && !string.IsNullOrEmpty(info.Description))
                                        {
                                            <div class="small text-muted mb-3 border-start border-3 ps-2 fst-italic"
                                                 style="white-space:pre-wrap;line-height:1.4">@info.Description</div>
                                        }

                                        <hr class="my-2" />

                                        @if (existing is not null)
                                        {
                                            <div class="small mb-1">
                                                <span class="text-muted">@L["PaymentMethod.Account"]</span>
                                                <code class="ms-1 text-break">@(existing.AccountIdentifier ?? "—")</code>
                                            </div>
                                            <div class="small mb-1">
                                                <span class="text-muted">@L["PaymentMethod.Status"]</span>
                                                <span class="badge @StatusBadgeClass(existing.Status) ms-1">@existing.StatusName</span>
                                            </div>
                                            <div class="small text-muted mb-2">@L["PaymentMethod.UpdatedPrefix"] @existing.LastUpdateDate.ToString("MMM dd, yyyy")</div>
                                        }
                                        else
                                        {
                                            <div class="small text-muted mb-2 fst-italic">@L["PaymentMethod.NotConfigured"]</div>
                                        }

                                        <div class="mt-auto d-grid gap-2">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => OpenEdit(gw)">
                                                <i class="ri-edit-line me-1"></i>@(existing is null ? L["PaymentMethod.AddAccount"].Value : L["PaymentMethod.EditAccount"].Value)
                                            </button>

                                            @if (isPreferred)
                                            {
                                                <button class="btn btn-sm btn-success" disabled>
                                                    <i class="ri-check-line me-1"></i>@L["PaymentMethod.CurrentlyDefault"]
                                                </button>
                                            }
                                            else if (canBeDefault)
                                            {
                                                <button class="btn btn-sm btn-outline-success"
                                                        disabled="@_busy"
                                                        title="@L["PaymentMethod.SetAsDefaultTooltip"]"
                                                        @onclick="() => SetDefaultAsync(existing!.WalletType)">
                                                    <i class="ri-star-line me-1"></i>@L["PaymentMethod.SetAsDefault"]
                                                </button>
                                            }
                                            else if (existing is not null && existing.StatusName != "Approved")
                                            {
                                                <button class="btn btn-sm btn-outline-secondary" disabled
                                                        title="@L["PaymentMethod.PendingApprovalTooltip"]">
                                                    <i class="ri-lock-line me-1"></i>@L["PaymentMethod.PendingApproval"]
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ─── Wallet history (visible to member + admin; admin gets API logs too) ─── *@
        <div class="col-12">
            <div class="card">
                <div class="card-header py-3 d-flex align-items-center">
                    <h6 class="card-title mb-0 fw-semibold flex-grow-1">
                        <i class="ri-history-line me-2 text-warning"></i>@L["PaymentMethod.WalletHistoryTitle"]
                    </h6>
                    <small class="text-muted">@L["PaymentMethod.WalletHistoryHint"]</small>
                </div>
                <div class="card-body p-0">
                    <LoadingSpinner IsLoading="@_historyLoading" />
                    @if (!_historyLoading)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="py-3 px-3 fw-semibold small text-uppercase text-muted">@L["Common.When"]</th>
                                        <th class="py-3 px-3 fw-semibold small text-uppercase text-muted">@L["PaymentMethod.History.Gateway"]</th>
                                        <th class="py-3 px-3 fw-semibold small text-uppercase text-muted">@L["PaymentMethod.History.Change"]</th>
                                        <th class="py-3 px-3 fw-semibold small text-uppercase text-muted">@L["PaymentMethod.History.FromTo"]</th>
                                        <th class="py-3 px-3 fw-semibold small text-uppercase text-muted">@L["Common.Status"]</th>
                                        <th class="py-3 px-3 fw-semibold small text-uppercase text-muted">@L["Common.By"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!_history.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-5">
                                                <i class="ri-history-line d-block mb-2 text-muted" style="font-size:2rem;opacity:0.5"></i>
                                                @L["PaymentMethod.NoWalletChanges"]
                                            </td>
                                        </tr>
                                    }
                                    @foreach (var h in _history)
                                    {
                                        var isAccountChange = h.Action == "AccountChanged";
                                        var gatewayName     = ResolveGatewayName(h.WalletType);
                                        var gatewayIcon     = ResolveGatewayIcon(h.WalletType);
                                        <tr>
                                            <td class="py-3 px-3 small text-nowrap"
                                                style="@(isAccountChange ? "border-left: 3px solid var(--bs-warning);" : "")">
                                                @h.OccurredAt.ToString("MMM dd, yyyy HH:mm")
                                            </td>
                                            <td class="py-3 px-3">
                                                <span class="d-inline-flex align-items-center gap-1 badge bg-light text-dark border fw-normal">
                                                    <i class="@gatewayIcon"></i>
                                                    <span>@gatewayName</span>
                                                </span>
                                            </td>
                                            <td class="py-3 px-3 small">@FormatAction(h.Action)</td>
                                            <td class="py-3 px-3">@RenderTransition(h)</td>
                                            <td class="py-3 px-3">
                                                @if (h.OldStatus != h.NewStatus)
                                                {
                                                    <span class="d-inline-flex align-items-center gap-1 small">
                                                        <span class="badge @StatusBadgeClass(h.OldStatus)">@StatusName(h.OldStatus)</span>
                                                        <i class="ri-arrow-right-line text-muted"></i>
                                                        <span class="badge @StatusBadgeClass(h.NewStatus)">@StatusName(h.NewStatus)</span>
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="small text-muted fst-italic">@L["PaymentMethod.History.NoChange"]</span>
                                                }
                                            </td>
                                            <td class="py-3 px-3">
                                                <code class="small text-muted" title="@h.ChangedBy">
                                                    @TruncateId(h.ChangedBy)
                                                </code>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ─── API call/response logs — admin only ─────────────────────────── *@
        @if (ViewContext.IsAdminContext)
        {
            <div class="col-12">
                <div class="card border-info">
                    <div class="card-header py-3">
                        <h6 class="card-title mb-0 fw-semibold">
                            <i class="ri-code-s-slash-line me-2 text-info"></i>@L["PaymentMethod.ApiLogTitle"]
                            <small class="text-muted ms-2">@L["PaymentMethod.ApiLogHint"]</small>
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <LoadingSpinner IsLoading="@_apiLogsLoading" />
                        @if (!_apiLogsLoading)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>@L["Common.When"]</th>
                                            <th>@L["PaymentMethod.History.Gateway"]</th>
                                            <th>@L["PaymentMethod.Log.Operation"]</th>
                                            <th>@L["PaymentMethod.Log.Endpoint"]</th>
                                            <th>@L["Common.Status"]</th>
                                            <th>@L["PaymentMethod.Log.Duration"]</th>
                                            <th>@L["PaymentMethod.Log.Result"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!_apiLogs.Any())
                                        {
                                            <tr><td colspan="7" class="text-center text-muted py-4">@L["PaymentMethod.NoApiLogs"]</td></tr>
                                        }
                                        @foreach (var log in _apiLogs)
                                        {
                                            <tr>
                                                <td class="small">@log.OccurredAt.ToString("MMM dd HH:mm:ss")</td>
                                                <td><span class="badge bg-light text-dark border">@log.WalletType</span></td>
                                                <td class="small">@log.Operation</td>
                                                <td class="small text-truncate" style="max-width:240px"><code>@log.HttpMethod @log.Endpoint</code></td>
                                                <td>
                                                    <span class="badge @(log.Success ? "bg-success" : "bg-danger")">@log.HttpStatusCode</span>
                                                </td>
                                                <td class="small">@log.DurationMs ms</td>
                                                <td>
                                                    <button class="btn btn-link btn-sm p-0" @onclick="() => _expandedLogId = (_expandedLogId == log.Id ? -1 : log.Id)">
                                                        @(_expandedLogId == log.Id ? L["PaymentMethod.Log.Hide"].Value : L["PaymentMethod.Log.View"].Value)
                                                    </button>
                                                </td>
                                            </tr>
                                            @if (_expandedLogId == log.Id)
                                            {
                                                <tr><td colspan="7" class="bg-light p-3">
                                                    <div class="row g-2">
                                                        <div class="col-md-6">
                                                            <div class="small fw-semibold text-muted mb-1">@L["PaymentMethod.Log.Request"]</div>
                                                            <pre class="small mb-0" style="max-height:160px;overflow:auto">@(log.RequestBody ?? "—")</pre>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="small fw-semibold text-muted mb-1">@L["PaymentMethod.Log.Response"] @(log.Success ? "" : L["PaymentMethod.Log.ResponseError"].Value)</div>
                                                            <pre class="small mb-0" style="max-height:160px;overflow:auto">@(log.ResponseBody ?? log.ErrorMessage ?? "—")</pre>
                                                        </div>
                                                    </div>
                                                </td></tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
    } @* end of else (Payout Options tab) *@

    @* ─── Edit modal ─────────────────────────────────────────────────────── *@
    @if (_editing is not null)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.4)">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="@_editing.Icon me-2"></i>@_editing.Label</h5>
                        <button type="button" class="btn-close" @onclick="() => _editing = null"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label small">@_editing.AccountFieldLabel <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" placeholder="@_editing.AccountFieldPlaceholder"
                                   @bind="_editAccountIdentifier" />
                            <div class="form-text small">@_editing.HelpText</div>
                        </div>
                        @if (_editing.Code == 4) @* eWallet *@
                        {
                            <div class="mb-3">
                                <label class="form-label small">@L["PaymentMethod.EWalletPasswordLabel"]</label>
                                <input type="password" class="form-control" @bind="_editPassword" />
                                <div class="form-text small">@L["PaymentMethod.EWalletPasswordHint"]</div>
                            </div>
                        }
                        <div class="mb-0">
                            <label class="form-label small">@L["PaymentMethod.NotesLabel"]</label>
                            <textarea class="form-control" rows="2" @bind="_editNotes"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-outline-secondary" @onclick="() => _editing = null">@L["Common.Cancel"]</button>
                        <button class="btn btn-primary" disabled="@_busy" @onclick="SaveEditAsync">
                            @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            @L["Common.Save"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool   _isLoading      = true;
    private bool   _historyLoading;
    private bool   _apiLogsLoading;
    private bool   _busy;
    private string? _alertMsg;
    private bool   _alertIsError;
    private long   _expandedLogId  = -1;
    private string _activeTab      = "payment";  // "payment" | "payout"

    private List<WalletDto>           _wallets       = new();
    private List<GatewayInfoDto>      _gatewayInfos  = new();
    private List<WalletHistoryItem>   _history       = new();
    private List<WalletApiLogItem>    _apiLogs       = new();

    private GatewayDescriptor? _editing;
    private string?  _editAccountIdentifier;
    private string?  _editPassword;
    private string?  _editNotes;

    // Apex four gateways the company supports today. Built lazily so the
    // localizer is available at construction time.
    private List<GatewayDescriptor>? _supportedGatewaysCache;
    private List<GatewayDescriptor> _supportedGateways => _supportedGatewaysCache ??= new()
    {
        new(4,  L["PaymentMethod.Gateway.EWalletLabel"].Value,  "ri-bank-card-line",  L["PaymentMethod.Gateway.EWalletField"].Value,  L["PaymentMethod.Gateway.EmailPlaceholder"].Value,
            L["PaymentMethod.Gateway.EWalletHelp"].Value),
        new(1,  L["PaymentMethod.Gateway.DwollaLabel"].Value,   "ri-bank-line",       L["PaymentMethod.Gateway.DwollaField"].Value,   L["PaymentMethod.Gateway.EmailPlaceholder"].Value,
            L["PaymentMethod.Gateway.DwollaHelp"].Value),
        new(9,  L["PaymentMethod.Gateway.CryptoLabel"].Value,   "ri-coin-line",       L["PaymentMethod.Gateway.CryptoField"].Value,   L["PaymentMethod.Gateway.CryptoPlaceholder"].Value,
            L["PaymentMethod.Gateway.CryptoHelp"].Value),
        new(10, L["PaymentMethod.Gateway.AdvCashLabel"].Value,  "ri-wallet-line",     L["PaymentMethod.Gateway.AdvCashField"].Value,  L["PaymentMethod.Gateway.EmailPlaceholder"].Value,
            L["PaymentMethod.Gateway.AdvCashHelp"].Value)
    };

    private string BizCenterBaseUrl => "api/v1/bizcenter/wallets";
    private string AdminBaseUrl     => $"api/v1/admin/members/{MemberProfileId}/wallets";
    private string ListUrl          => ViewContext.IsAdminContext ? AdminBaseUrl : BizCenterBaseUrl;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        _isLoading = true; StateHasChanged();
        try
        {
            await Task.WhenAll(
                LoadWalletsAsync(),
                LoadGatewayInfoAsync(),
                LoadHistoryAsync(),
                LoadApiLogsAsync());
        }
        finally { _isLoading = false; }
    }

    private async Task LoadGatewayInfoAsync()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<GatewayInfoDto>>>(
                "api/v1/bizcenter/payment-gateways");
            if (resp?.Success == true) _gatewayInfos = resp.Data ?? new();
        }
        catch { /* silently degrade — cards still render with built-in metadata */ }
    }

    private async Task LoadWalletsAsync()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<List<WalletDto>>>(ListUrl);
            if (resp?.Success == true) _wallets = resp.Data ?? new();
        }
        catch { /* silently degrade */ }
    }

    private async Task LoadHistoryAsync()
    {
        _historyLoading = true; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<PagedData<WalletHistoryItem>>>(
                $"{ListUrl}/history?page=1&pageSize=50");
            if (resp?.Success == true && resp.Data is not null)
                _history = resp.Data.Items;
        }
        catch { }
        finally { _historyLoading = false; }
    }

    private async Task LoadApiLogsAsync()
    {
        if (!ViewContext.IsAdminContext) return;
        _apiLogsLoading = true; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<PagedData<WalletApiLogItem>>>(
                $"{AdminBaseUrl}/api-logs?page=1&pageSize=50");
            if (resp?.Success == true && resp.Data is not null)
                _apiLogs = resp.Data.Items;
        }
        catch { }
        finally { _apiLogsLoading = false; }
    }

    private void OpenEdit(GatewayDescriptor gw)
    {
        _editing = gw;
        var existing = _wallets.FirstOrDefault(w => w.WalletType == gw.Code);
        _editAccountIdentifier = existing?.AccountIdentifier ?? string.Empty;
        _editPassword          = null;
        _editNotes             = existing?.Notes;
    }

    private async Task SaveEditAsync()
    {
        if (_editing is null) return;
        if (string.IsNullOrWhiteSpace(_editAccountIdentifier))
        { _alertMsg = L["PaymentMethod.AccountIdRequired"]; _alertIsError = true; return; }

        // Pre-validate locally so the user gets instant feedback before the round trip.
        var trimmed     = _editAccountIdentifier!.Trim();
        var localError  = ValidateLocally(_editing.Code, trimmed);
        if (localError is not null)
        { _alertMsg = localError; _alertIsError = true; return; }

        _busy = true; StateHasChanged();
        try
        {
            var url = $"{ListUrl}/{_editing.Code}";
            var payload = new
            {
                accountIdentifier         = trimmed,
                notes                     = _editNotes,
                eWalletPasswordEncrypted  = string.IsNullOrEmpty(_editPassword) ? null : $"ENC:{_editPassword}"
            };
            var resp = await Http.PutAsJsonAsync(url, payload);
            if (resp.IsSuccessStatusCode)
            {
                _alertMsg = $"{_editing.Label} {L["PaymentMethod.WalletUpdatedSuffix"]}"; _alertIsError = false;
                _editing = null;
                await LoadWalletsAsync();
                await LoadHistoryAsync();
                await LoadApiLogsAsync();
            }
            else
            {
                // Try to extract a clean error message from the API response envelope.
                var body = await resp.Content.ReadAsStringAsync();
                var msg = TryExtractApiError(body) ?? body;
                _alertMsg = msg; _alertIsError = true;
            }
        }
        catch (Exception ex) { _alertMsg = $"{L["PaymentMethod.ErrorPrefix"]} {ex.Message}"; _alertIsError = true; }
        finally { _busy = false; StateHasChanged(); }
    }

    /// <summary>Mirrors the server-side validation so the user gets instant feedback.</summary>
    private string? ValidateLocally(int walletTypeCode, string value)
    {
        var isEmail = System.Text.RegularExpressions.Regex.IsMatch(
            value, @"^[^\s@]+@[^\s@]+\.[^\s@]+$");

        if (walletTypeCode == 9) // Crypto
        {
            if (isEmail)
                return L["PaymentMethod.Validation.CryptoRequired"];

            var looksLikeCrypto =
                System.Text.RegularExpressions.Regex.IsMatch(value, @"^(bc1)[a-z0-9]{6,87}$") ||
                System.Text.RegularExpressions.Regex.IsMatch(value, @"^[13][a-km-zA-HJ-NP-Z1-9]{25,34}$") ||
                System.Text.RegularExpressions.Regex.IsMatch(value, @"^0x[a-fA-F0-9]{40}$") ||
                System.Text.RegularExpressions.Regex.IsMatch(value, @"^T[1-9A-HJ-NP-Za-km-z]{33}$");

            return looksLikeCrypto ? null
                : L["PaymentMethod.Validation.CryptoInvalid"].Value;
        }

        // Email-based gateways (eWallet 4 / Dwolla 1 / Advancash 10)
        if (!isEmail)
            return L["PaymentMethod.Validation.EmailRequired"];

        return null;
    }

    private static string? TryExtractApiError(string body)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(body);
            if (doc.RootElement.TryGetProperty("errors", out var errors)
                && errors.ValueKind == System.Text.Json.JsonValueKind.Array
                && errors.GetArrayLength() > 0)
                return errors[0].GetString();
            if (doc.RootElement.TryGetProperty("message", out var m) && m.ValueKind == System.Text.Json.JsonValueKind.String)
                return m.GetString();
        }
        catch { }
        return null;
    }

    private async Task SetDefaultAsync(int walletType)
    {
        _busy = true; StateHasChanged();
        try
        {
            var resp = await Http.PutAsync($"{ListUrl}/{walletType}/default", null);
            if (resp.IsSuccessStatusCode)
            {
                _alertMsg = L["PaymentMethod.DefaultWalletUpdated"]; _alertIsError = false;
                await LoadWalletsAsync();
                await LoadHistoryAsync();
            }
            else
            {
                var err = await resp.Content.ReadAsStringAsync();
                _alertMsg = $"{L["PaymentMethod.CouldNotSetWalletDefaultPrefix"]} {err}"; _alertIsError = true;
            }
        }
        catch (Exception ex) { _alertMsg = $"{L["PaymentMethod.ErrorPrefix"]} {ex.Message}"; _alertIsError = true; }
        finally { _busy = false; StateHasChanged(); }
    }

    private string FormatAction(string action) => action switch
    {
        "Created"        => L["PaymentMethod.Action.Created"],
        "AccountChanged" => L["PaymentMethod.Action.AccountChanged"],
        "StatusChanged"  => L["PaymentMethod.Action.StatusChanged"],
        "SetAsDefault"   => L["PaymentMethod.Action.SetAsDefault"],
        "UnsetAsDefault" => L["PaymentMethod.Action.UnsetAsDefault"],
        "Deleted"        => L["PaymentMethod.Action.Deleted"],
        _                => action
    };

    private const string TruncateStyle =
        "max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:inline-block;vertical-align:middle;";

    private static RenderFragment RenderTransition(WalletHistoryItem h) => __builder =>
    {
        if (h.Action == "AccountChanged" && (!string.IsNullOrEmpty(h.OldAccountIdentifier) || !string.IsNullOrEmpty(h.NewAccountIdentifier)))
        {
            <code class="small" style="@TruncateStyle" title="@(h.OldAccountIdentifier ?? "")">@(h.OldAccountIdentifier ?? "—")</code>
            <i class="ri-arrow-right-line mx-1 text-warning"></i>
            <code class="small fw-semibold text-warning" style="@TruncateStyle" title="@(h.NewAccountIdentifier ?? "")">@(h.NewAccountIdentifier ?? "—")</code>
        }
        else if (h.Action == "Created")
        {
            <span class="text-muted">— → </span>
            <code class="small" style="@TruncateStyle" title="@(h.NewAccountIdentifier ?? "")">@(h.NewAccountIdentifier ?? "—")</code>
        }
        else if (h.Action == "SetAsDefault" || h.Action == "UnsetAsDefault")
        {
            <code class="small" style="@TruncateStyle" title="@(h.NewAccountIdentifier ?? "")">@(h.NewAccountIdentifier ?? "—")</code>
        }
        else
        {
            <span class="text-muted small">—</span>
        }
    };

    private static string StatusBadgeClass(int status) => status switch
    {
        1 => "bg-warning text-dark",      // Pending
        2 => "bg-success",                // Approved
        3 => "bg-danger",                 // Rejected
        _ => "bg-secondary"
    };

    private string StatusName(int status) => status switch
    {
        1 => L["WalletStatus.Pending"],
        2 => L["WalletStatus.Approved"],
        3 => L["WalletStatus.Rejected"],
        _ => "—"
    };

    private string ResolveGatewayName(int walletType)
    {
        var info = _gatewayInfos.FirstOrDefault(i => i.WalletType == walletType);
        if (info is not null && !string.IsNullOrWhiteSpace(info.DisplayName))
            return info.DisplayName;
        if (info is not null && !string.IsNullOrWhiteSpace(info.WalletTypeName))
            return info.WalletTypeName;

        var supported = _supportedGateways.FirstOrDefault(g => g.Code == walletType);
        if (supported is not null) return supported.Label;

        return walletType.ToString();
    }

    private string ResolveGatewayIcon(int walletType)
    {
        var supported = _supportedGateways.FirstOrDefault(g => g.Code == walletType);
        return supported?.Icon ?? "ri-wallet-3-line";
    }

    private static string TruncateId(string? id)
    {
        if (string.IsNullOrWhiteSpace(id)) return "—";
        return id.Length > 8 ? id.Substring(0, 8) + "…" : id;
    }

