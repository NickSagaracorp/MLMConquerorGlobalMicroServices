@*
    Read-only Contact Info card on the Profile tab. The "Edit" button surfaces
    the editable contact + address modal owned by the parent UserProfilePage.
*@

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 border-bottom pb-3 mb-3">
            <h6 class="fs-18 mb-0 fw-semibold">
                <i class="ri-phone-line me-2 text-primary"></i>Contact Info
            </h6>
            @if (CanEdit)
            {
                <button type="button"
                        class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"
                        @onclick="() => OnEditRequested.InvokeAsync()">
                    <i class="ri-edit-line"></i>
                    <span>Edit Contact &amp; Address</span>
                </button>
            }
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label text-muted small mb-1">Phone</label>
                <div class="fw-medium">@DisplayOrDash(Phone)</div>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label text-muted small mb-1">WhatsApp</label>
                <div class="fw-medium">@DisplayOrDash(WhatsApp)</div>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label text-muted small mb-1">Email</label>
                <div class="fw-medium text-break">@DisplayOrDash(Email)</div>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label text-muted small mb-1">Country</label>
                <div class="fw-medium">@DisplayOrDash(Country)</div>
            </div>
            <div class="col-12">
                <label class="form-label text-muted small mb-1">Address</label>
                <div class="fw-medium">@FormatAddress()</div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? Phone    { get; set; }
    [Parameter] public string? WhatsApp { get; set; }
    [Parameter] public string? Email    { get; set; }
    [Parameter] public string? Country  { get; set; }
    [Parameter] public string? State    { get; set; }
    [Parameter] public string? City     { get; set; }
    [Parameter] public string? Address  { get; set; }
    [Parameter] public string? ZipCode  { get; set; }
    [Parameter] public bool    CanEdit  { get; set; }

    [Parameter] public EventCallback OnEditRequested { get; set; }

    private static string DisplayOrDash(string? v) =>
        string.IsNullOrWhiteSpace(v) ? "—" : v;

    private string FormatAddress()
    {
        var parts = new[] { Address, City, State, ZipCode, Country }
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToArray();
        return parts.Length == 0 ? "—" : string.Join(", ", parts!);
    }
}
