@inject HttpClient Http

<div class="row g-4">
    <!-- Change Password -->
    <div class="col-12">
        <h6 class="fw-semibold mb-3">Change Password</h6>
        <EditForm Model="@_pwForm" OnValidSubmit="ChangePasswordAsync">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Current Password</label>
                    <InputText type="password" class="form-control" @bind-Value="_pwForm.CurrentPassword" />
                </div>
                <div class="col-12 col-sm-6">
                    <label class="form-label">New Password</label>
                    <InputText type="password" class="form-control" @bind-Value="_pwForm.NewPassword" />
                </div>
                <div class="col-12 col-sm-6">
                    <label class="form-label">Confirm New Password</label>
                    <InputText type="password" class="form-control" @bind-Value="_pwForm.ConfirmPassword" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary mt-3" disabled="@_savingPw">
                @if (_savingPw) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Update Password
            </button>
        </EditForm>
        @if (!string.IsNullOrEmpty(_pwSuccess)) { <div class="alert alert-success mt-2">@_pwSuccess</div> }
        @if (!string.IsNullOrEmpty(_pwError))   { <ApiErrorAlert ErrorMessage="@_pwError" /> }
    </div>

    <hr />

    <!-- Change Email -->
    <div class="col-12">
        <h6 class="fw-semibold mb-3">Change Email</h6>
        <EditForm Model="@_emailForm" OnValidSubmit="ChangeEmailAsync">
            <div class="row g-3">
                <div class="col-12 col-sm-6">
                    <label class="form-label">New Email</label>
                    <InputText type="email" class="form-control" @bind-Value="_emailForm.NewEmail" />
                </div>
                <div class="col-12 col-sm-6">
                    <label class="form-label">Current Password</label>
                    <InputText type="password" class="form-control" @bind-Value="_emailForm.Password" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary mt-3" disabled="@_savingEmail">
                @if (_savingEmail) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Update Email
            </button>
        </EditForm>
        @if (!string.IsNullOrEmpty(_emailSuccess)) { <div class="alert alert-success mt-2">@_emailSuccess</div> }
        @if (!string.IsNullOrEmpty(_emailError))   { <ApiErrorAlert ErrorMessage="@_emailError" /> }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private PasswordForm _pwForm        = new();
    private EmailForm    _emailForm     = new();
    private bool    _savingPw     = false;
    private bool    _savingEmail  = false;
    private string? _pwSuccess;
    private string? _pwError;
    private string? _emailSuccess;
    private string? _emailError;

    private async Task ChangePasswordAsync()
    {
        _savingPw  = true;
        _pwSuccess = null;
        _pwError   = null;
        try
        {
            // TODO: PUT /api/v1/auth/change-password
            await Task.Delay(300);
            _pwSuccess  = "Password changed successfully.";
            _pwForm     = new();
        }
        catch (Exception ex) { _pwError = ex.Message; }
        finally { _savingPw = false; }
    }

    private async Task ChangeEmailAsync()
    {
        _savingEmail  = true;
        _emailSuccess = null;
        _emailError   = null;
        try
        {
            // TODO: PUT /api/v1/bizcenter/profile/credentials/email
            await Task.Delay(300);
            _emailSuccess = "Email updated successfully. A confirmation has been sent.";
            _emailForm    = new();
        }
        catch (Exception ex) { _emailError = ex.Message; }
        finally { _savingEmail = false; }
    }

    public class PasswordForm
    {
        public string CurrentPassword { get; set; } = string.Empty;
        public string NewPassword     { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    public class EmailForm
    {
        public string NewEmail { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
