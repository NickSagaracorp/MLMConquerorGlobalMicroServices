@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

@*
    Paginated table of past address changes. Each row shows previous/new
    addresses side-by-side so a support agent can audit at a glance. The reason
    text is shown when present — useful for fraud reviews.
*@

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.45);">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-semibold">
                        <i class="ri-history-line me-2"></i>@L["AddressHistory.Title"]
                    </h5>
                    <button type="button" class="btn-close" @onclick="OnClose"></button>
                </div>
                <div class="modal-body p-0">
                    <LoadingSpinner IsLoading="@_loading" />
                    @if (!_loading)
                    {
                        @if (_items.Count == 0)
                        {
                            <div class="text-center py-5">
                                <i class="ri-archive-line text-muted" style="font-size:2.5rem"></i>
                                <p class="text-muted mt-2 mb-0">@L["AddressHistory.Empty"]</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>@L["Common.When"]</th>
                                            <th>@L["AddressHistory.Previous"]</th>
                                            <th>@L["AddressHistory.New"]</th>
                                            <th>@L["AddressHistory.Reason"]</th>
                                            <th>@L["Common.By"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var h in _items)
                                        {
                                            <tr>
                                                <td class="small text-nowrap">@h.ChangedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                                <td class="small">@FormatAddress(h.PreviousAddress, h.PreviousCity, h.PreviousState, h.PreviousZipCode, h.PreviousCountry)</td>
                                                <td class="small fw-medium">@FormatAddress(h.NewAddress, h.NewCity, h.NewState, h.NewZipCode, h.NewCountry)</td>
                                                <td class="small text-muted">@(string.IsNullOrEmpty(h.Reason) ? "—" : h.Reason)</td>
                                                <td class="small text-muted">@(string.IsNullOrEmpty(h.ChangedBy) ? "—" : h.ChangedBy)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            @if (_total > _pageSize)
                            {
                                var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                                <div class="d-flex justify-content-center py-3">
                                    <nav>
                                        <ul class="pagination pagination-sm mb-0">
                                            <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => Go(_page - 1)">&#x2039;</button>
                                            </li>
                                            @for (var pg = 1; pg <= totalPages; pg++)
                                            {
                                                var p = pg;
                                                <li class="page-item @(p == _page ? "active" : "")">
                                                    <button class="page-link" @onclick="() => Go(p)">@p</button>
                                                </li>
                                            }
                                            <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                                <button class="page-link" @onclick="() => Go(_page + 1)">&#x203A;</button>
                                            </li>
                                        </ul>
                                    </nav>
                                </div>
                            }
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="OnClose">@L["Common.Close"]</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool   _loading;
    private int    _page = 1;
    private int    _pageSize = 20;
    private int    _total;
    private List<HistoryItem> _items = new();
    private bool   _wasVisible;

    protected override async Task OnParametersSetAsync()
    {
        // Only refetch on the transition from hidden to visible, otherwise the
        // dialog would re-load every time the parent re-renders.
        if (IsVisible && !_wasVisible)
            await LoadAsync(1);
        _wasVisible = IsVisible;
    }

    private async Task Go(int page) => await LoadAsync(page);

    private async Task LoadAsync(int page)
    {
        _loading = true; _page = page; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<PagedData<HistoryItem>>>(
                $"api/v1/bizcenter/profile/address-history?page={page}&pageSize={_pageSize}");
            if (resp?.Success == true && resp.Data is not null)
            {
                _items = resp.Data.Items;
                _total = resp.Data.TotalCount;
            }
        }
        catch { /* silently degrade — modal already shows empty state */ }
        finally { _loading = false; StateHasChanged(); }
    }

    private static string FormatAddress(string? line, string? city, string? state, string? zip, string? country)
    {
        var parts = new[] { line, city, state, zip, country }
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToArray();
        return parts.Length == 0 ? "—" : string.Join(", ", parts!);
    }

    private class ApiWrapper<T> { public bool Success { get; set; } public T? Data { get; set; } }
    private class PagedData<T>  { public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    private class HistoryItem
    {
        public long     Id              { get; set; }
        public DateTime ChangedAt       { get; set; }
        public string?  ChangedBy       { get; set; }
        public string?  PreviousAddress { get; set; }
        public string?  PreviousCity    { get; set; }
        public string?  PreviousState   { get; set; }
        public string?  PreviousZipCode { get; set; }
        public string?  PreviousCountry { get; set; }
        public string?  NewAddress      { get; set; }
        public string?  NewCity         { get; set; }
        public string?  NewState        { get; set; }
        public string?  NewZipCode      { get; set; }
        public string?  NewCountry      { get; set; }
        public string?  Reason          { get; set; }
    }
}
