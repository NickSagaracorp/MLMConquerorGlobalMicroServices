@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

@*
    Read-only paginated audit of email/password/2FA changes for the current
    member. Renders a "Kind" pill so the user can spot anomalies quickly, plus
    a truncated user-agent for forensic context. The IP is shown verbatim.
*@

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-header bg-transparent py-3">
        <h6 class="card-title mb-0 fw-semibold">
            <i class="ri-shield-keyhole-line me-2 text-primary"></i>@L["CredentialsHistory.Title"]
        </h6>
    </div>
    <div class="card-body p-0">
        <LoadingSpinner IsLoading="@_loading" />
        @if (!_loading)
        {
            @if (_items.Count == 0)
            {
                <div class="text-center py-4">
                    <i class="ri-archive-line text-muted" style="font-size:2rem"></i>
                    <p class="text-muted small mt-2 mb-0">@L["CredentialsHistory.Empty"]</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>@L["CredentialsHistory.Kind"]</th>
                                <th>@L["Common.When"]</th>
                                <th>@L["Common.IpAddress"]</th>
                                <th>@L["Common.UserAgent"]</th>
                                <th>@L["Common.By"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _items)
                            {
                                <tr>
                                    <td>
                                        <span class="badge @KindClass(c.Kind)">
                                            <i class="@KindIcon(c.Kind) me-1"></i>@c.Kind
                                        </span>
                                    </td>
                                    <td class="small text-nowrap">@c.ChangedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                    <td class="small font-monospace">@(string.IsNullOrEmpty(c.IpAddress) ? "—" : c.IpAddress)</td>
                                    <td class="small text-muted text-truncate" style="max-width: 320px"
                                        title="@c.UserAgent">@(string.IsNullOrEmpty(c.UserAgent) ? "—" : c.UserAgent)</td>
                                    <td class="small text-muted">@(string.IsNullOrEmpty(c.ChangedBy) ? "—" : c.ChangedBy)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (_total > _pageSize)
                {
                    var totalPages = (int)Math.Ceiling((double)_total / _pageSize);
                    <div class="d-flex justify-content-center py-3">
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item @(_page <= 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => LoadAsync(_page - 1)">&#x2039;</button>
                                </li>
                                @for (var pg = 1; pg <= totalPages; pg++)
                                {
                                    var p = pg;
                                    <li class="page-item @(p == _page ? "active" : "")">
                                        <button class="page-link" @onclick="() => LoadAsync(p)">@p</button>
                                    </li>
                                }
                                <li class="page-item @(_page >= totalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="() => LoadAsync(_page + 1)">&#x203A;</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            }
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private int  _page = 1;
    private int  _pageSize = 10;
    private int  _total;
    private List<CredentialChange> _items = new();

    protected override async Task OnInitializedAsync() => await LoadAsync(1);

    private async Task LoadAsync(int page)
    {
        _loading = true; _page = page; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiWrapper<PagedData<CredentialChange>>>(
                $"api/v1/bizcenter/profile/credentials-history?page={page}&pageSize={_pageSize}");
            if (resp?.Success == true && resp.Data is not null)
            {
                _items = resp.Data.Items;
                _total = resp.Data.TotalCount;
            }
        }
        catch { /* silently degrade — empty state already covers it */ }
        finally { _loading = false; StateHasChanged(); }
    }

    private static string KindClass(string kind) => kind switch
    {
        "Email"      => "bg-info-subtle text-info",
        "Password"   => "bg-warning-subtle text-warning",
        "TwoFactor"  => "bg-success-subtle text-success",
        _            => "bg-secondary-subtle text-secondary"
    };

    private static string KindIcon(string kind) => kind switch
    {
        "Email"      => "ri-mail-line",
        "Password"   => "ri-key-2-line",
        "TwoFactor"  => "ri-shield-check-line",
        _            => "ri-information-line"
    };

    private class ApiWrapper<T> { public bool Success { get; set; } public T? Data { get; set; } }
    private class PagedData<T>  { public List<T> Items { get; set; } = new(); public int TotalCount { get; set; } }

    private class CredentialChange
    {
        public long     Id        { get; set; }
        public DateTime ChangedAt { get; set; }
        public string?  ChangedBy { get; set; }
        public string   Kind      { get; set; } = string.Empty;
        public string?  IpAddress { get; set; }
        public string?  UserAgent { get; set; }
    }
}
