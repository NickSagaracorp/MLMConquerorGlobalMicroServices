@inject IViewContextService ViewContext
@inject HttpClient Http
@inject IJSRuntime JS

@*
    Orchestrator for the My Profile experience. Loads the full ProfileDto once,
    then routes the data into focused, narrow sub-cards. Three top-level tabs
    (Profile / Account / Billing & Commissions) mirror the reference template.

    Editing is split deliberately:
      • Identity (name, DOB, business, SSN) is read-only — see PersonalInfoCard.
      • Contact + Address is editable from a dedicated card on the Profile tab.
      • Email + Password live on the Account tab via CredentialsForm.
      • Payouts (frequency + gateways + cards) live on the Billing tab.
*@

<BreadcrumbNav Items="@_breadcrumb" />

<LoadingSpinner IsLoading="@_isLoading" />

@if (!_isLoading && _profile is not null)
{
    <ProfileHeaderCard MemberId="@_profile.MemberId"
                       FullName="@($"{_profile.FirstName} {_profile.LastName}".Trim())"
                       MemberType="@_profile.MemberType"
                       Status="@_profile.Status"
                       MembershipLevel="@(_profile.Membership?.LevelName ?? "")"
                       PhotoUrl="@_profile.PhotoUrl"
                       CanEdit="@_canEdit"
                       OnPhotoChanged="OnPhotoChangedAsync" />

    <ul class="nav nav-pills profile-top-tabs mb-4 d-flex flex-wrap gap-2" role="tablist">
        <li class="nav-item">
            <button class="nav-link @(_tab == "profile" ? "active" : "")"
                    @onclick='() => _tab = "profile"' type="button">
                <i class="ri-user-line me-1"></i>Profile
            </button>
        </li>
        @if (_canEdit)
        {
            <li class="nav-item">
                <button class="nav-link @(_tab == "account" ? "active" : "")"
                        @onclick='() => _tab = "account"' type="button">
                    <i class="ri-shield-keyhole-line me-1"></i>Account &amp; Security
                </button>
            </li>
        }
        <li class="nav-item">
            <button class="nav-link @(_tab == "billing" ? "active" : "")"
                    @onclick='() => _tab = "billing"' type="button">
                <i class="ri-bank-card-line me-1"></i>Billing &amp; Commissions
            </button>
        </li>
    </ul>

    @if (_tab == "profile")
    {
        <div class="row g-4">
            <div class="col-12 col-xl-8">
                <PersonalInfoCard MemberId="@_profile.MemberId"
                                  FirstName="@_profile.FirstName"
                                  LastName="@_profile.LastName"
                                  DateOfBirth="@_profile.DateOfBirth"
                                  BusinessName="@_profile.BusinessName"
                                  SsnLast4="@_profile.SsnLast4"
                                  EnrollDate="@_profile.EnrollDate" />

                <ContactInfoCard Phone="@_profile.Phone"
                                 WhatsApp="@_profile.WhatsApp"
                                 Email="@_profile.Email"
                                 Country="@_profile.Country"
                                 State="@_profile.State"
                                 City="@_profile.City"
                                 Address="@_profile.Address"
                                 ZipCode="@_profile.ZipCode"
                                 CanEdit="@_canEdit"
                                 OnEditRequested="ScrollToAddressEditor" />

                @if (_canEdit)
                {
                    <div id="address-editor">
                        <AddressCard Phone="@_profile.Phone"
                                     WhatsApp="@_profile.WhatsApp"
                                     Country="@_profile.Country"
                                     State="@_profile.State"
                                     City="@_profile.City"
                                     Address="@_profile.Address"
                                     ZipCode="@_profile.ZipCode"
                                     DefaultLanguage="@_profile.DefaultLanguage"
                                     PayoutFrequency="@_profile.PayoutFrequency"
                                     ShowBusinessName="@_profile.ShowBusinessName"
                                     IsEmailPublic="@_profile.IsEmailPublic"
                                     IsPhonePublic="@_profile.IsPhonePublic"
                                     OnSaved="LoadProfileAsync"
                                     OnHistoryRequested="() => _showAddressHistory = true" />
                    </div>
                }
            </div>

            <div class="col-12 col-xl-4">
                <MembershipCard Snapshot="@_membershipSnapshot" />

                @if (_canEdit)
                {
                    <WebsiteSlugCard InitialSlug="@_profile.ReplicateSiteSlug"
                                     UrlPrefix="@_websitePrefix"
                                     OnSaved="OnSlugSaved" />

                    <DisplayPreferencesCard ShowBusinessName="@_profile.ShowBusinessName"
                                            IsEmailPublic="@_profile.IsEmailPublic"
                                            IsPhonePublic="@_profile.IsPhonePublic"
                                            Phone="@_profile.Phone"
                                            WhatsApp="@_profile.WhatsApp"
                                            Country="@_profile.Country"
                                            State="@_profile.State"
                                            City="@_profile.City"
                                            Address="@_profile.Address"
                                            ZipCode="@_profile.ZipCode"
                                            DefaultLanguage="@_profile.DefaultLanguage"
                                            PayoutFrequency="@_profile.PayoutFrequency"
                                            OnPersisted="LoadProfileAsync" />

                    <LanguagePreferenceCard CurrentLanguage="@_profile.DefaultLanguage"
                                            Phone="@_profile.Phone"
                                            WhatsApp="@_profile.WhatsApp"
                                            Country="@_profile.Country"
                                            State="@_profile.State"
                                            City="@_profile.City"
                                            Address="@_profile.Address"
                                            ZipCode="@_profile.ZipCode"
                                            PayoutFrequency="@_profile.PayoutFrequency"
                                            ShowBusinessName="@_profile.ShowBusinessName"
                                            IsEmailPublic="@_profile.IsEmailPublic"
                                            IsPhonePublic="@_profile.IsPhonePublic"
                                            OnLanguageChanged="OnLanguageChangedAsync" />
                }
            </div>
        </div>
    }
    else if (_tab == "account" && _canEdit)
    {
        <div class="row g-4">
            <div class="col-12 col-xl-8">
                <div class="card border-0 shadow-sm rounded-3 mb-4">
                    <div class="card-body p-4">
                        <h6 class="fs-18 mb-3 fw-semibold">
                            <i class="ri-key-2-line me-2 text-primary"></i>Email &amp; Password
                        </h6>
                        <CredentialsForm MemberProfileId="@MemberProfileId" />
                    </div>
                </div>

                <CredentialsHistoryTable />
            </div>
            <div class="col-12 col-xl-4">
                <SecurityLogTable MemberProfileId="@MemberProfileId" />
            </div>
        </div>
    }
    else if (_tab == "billing")
    {
        <div class="row g-4">
            <div class="col-12 col-lg-7">
                <BillingInfoCard DefaultCard="@_defaultCard"
                                 Address="@_profile.Address"
                                 City="@_profile.City"
                                 State="@_profile.State"
                                 ZipCode="@_profile.ZipCode"
                                 Country="@_profile.Country"
                                 OnManageCardsRequested="ScrollToCards" />

                <div id="cards-section">
                    <PaymentMethodTab @ref="_paymentTabRef" />
                </div>
            </div>
            <div class="col-12 col-lg-5">
                @if (_canEdit)
                {
                    <PayoutFrequencyCard CurrentFrequency="@_profile.PayoutFrequency"
                                         Phone="@_profile.Phone"
                                         WhatsApp="@_profile.WhatsApp"
                                         Country="@_profile.Country"
                                         State="@_profile.State"
                                         City="@_profile.City"
                                         Address="@_profile.Address"
                                         ZipCode="@_profile.ZipCode"
                                         DefaultLanguage="@_profile.DefaultLanguage"
                                         ShowBusinessName="@_profile.ShowBusinessName"
                                         IsEmailPublic="@_profile.IsEmailPublic"
                                         IsPhonePublic="@_profile.IsPhonePublic"
                                         OnChanged="OnPayoutFrequencyChangedAsync" />
                }

                <WalletPanel MemberProfileId="@MemberProfileId" />
            </div>

            <div class="col-12">
                <BillingHistoryTable />
            </div>
        </div>
    }
}

@if (!string.IsNullOrEmpty(_error))
{
    <ApiErrorAlert ErrorMessage="@_error" />
}

<AddressHistoryModal IsVisible="@_showAddressHistory"
                     OnClose="() => _showAddressHistory = false" />

@code {
    [Parameter, EditorRequired] public string MemberProfileId { get; set; } = string.Empty;

    private bool    _isLoading = true;
    private string  _tab       = "profile";
    private string? _error;
    private bool    _showAddressHistory;

    private ProfileApiDto? _profile;
    private MembershipCard.MembershipSnapshot? _membershipSnapshot;
    private BillingInfoCard.DefaultCardInfo?   _defaultCard;
    private PaymentMethodTab? _paymentTabRef;

    // The public-page URL prefix shown next to the slug input. Could later
    // come from config; hardcoding the dominant brand is fine for now.
    private const string _websitePrefix = "mlmconqueror.com/";

    private bool _canEdit =>
        ViewContext.ViewingMemberId == ViewContext.ViewerUserId
        || ViewContext.IsAdminContext;

    private List<BreadcrumbNav.BreadcrumbItem> _breadcrumb => new()
    {
        new("Dashboard", "/dashboard"),
        new("Profile")
    };

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(MemberProfileId)) return;
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _isLoading = true; _error = null; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResponse<ProfileApiDto>>(
                "api/v1/bizcenter/profile");
            if (resp?.Success == true && resp.Data is not null)
            {
                _profile = resp.Data;
                _membershipSnapshot = _profile.Membership is null ? null : new MembershipCard.MembershipSnapshot
                {
                    LevelId     = _profile.Membership.LevelId,
                    LevelName   = _profile.Membership.LevelName,
                    Status      = _profile.Membership.Status,
                    StartDate   = _profile.Membership.StartDate,
                    ExpireDate  = _profile.Membership.ExpireDate,
                    IsAutoRenew = _profile.Membership.IsAutoRenew
                };
                await LoadDefaultCardAsync();
            }
            else
            {
                _error = resp?.Message ?? "Failed to load profile.";
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _isLoading = false; StateHasChanged(); }
    }

    private async Task LoadDefaultCardAsync()
    {
        try
        {
            // Pull cards through the same endpoint PaymentMethodTab uses;
            // pick the IsDefault one for the BillingInfoCard preview.
            var resp = await Http.GetFromJsonAsync<ApiResponse<List<CreditCardApiDto>>>(
                "api/v1/bizcenter/billing/credit-cards");
            var def = resp?.Data?.FirstOrDefault(c => c.IsDefault);
            _defaultCard = def is null ? null : new BillingInfoCard.DefaultCardInfo
            {
                Brand       = def.CardBrand,
                Last4       = def.Last4,
                ExpiryMonth = def.ExpiryMonth,
                ExpiryYear  = def.ExpiryYear,
                Holder      = $"{_profile?.FirstName} {_profile?.LastName}".Trim()
            };
        }
        catch { /* leave _defaultCard null — empty state will render */ }
    }

    private Task OnPhotoChangedAsync(string newUrl)
    {
        if (_profile is not null) _profile.PhotoUrl = newUrl;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnSlugSaved(string newSlug)
    {
        if (_profile is not null) _profile.ReplicateSiteSlug = newSlug;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnLanguageChangedAsync(string lang)
    {
        if (_profile is not null) _profile.DefaultLanguage = lang;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnPayoutFrequencyChangedAsync(string freq)
    {
        if (_profile is not null) _profile.PayoutFrequency = freq;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task ScrollToAddressEditor()
    {
        // Scroll the editable AddressCard into view so the user knows what
        // happened after clicking "Edit Contact & Address" on the read-only card.
        try
        {
            await JS.InvokeVoidAsync("eval",
                "document.getElementById('address-editor')?.scrollIntoView({behavior:'smooth',block:'start'});");
        }
        catch { /* JS may be unavailable during prerender — ignore */ }
    }

    private async Task ScrollToCards()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "document.getElementById('cards-section')?.scrollIntoView({behavior:'smooth',block:'start'});");
        }
        catch { /* JS may be unavailable during prerender — ignore */ }
    }

    // ── DTOs ──────────────────────────────────────────────────────────────────
    private class ApiResponse<T>
    {
        public bool    Success { get; set; }
        public T?      Data    { get; set; }
        public string? Message { get; set; }
    }

    public class ProfileApiDto
    {
        public string   MemberId         { get; set; } = string.Empty;
        public string   FirstName        { get; set; } = string.Empty;
        public string   LastName         { get; set; } = string.Empty;
        public DateTime DateOfBirth      { get; set; }
        public string?  BusinessName     { get; set; }
        public string?  SsnLast4         { get; set; }
        public string   Email            { get; set; } = string.Empty;
        public string?  ReplicateSiteSlug{ get; set; }
        public string?  PhotoUrl         { get; set; }
        public string?  Phone            { get; set; }
        public string?  WhatsApp         { get; set; }
        public string?  Country          { get; set; }
        public string?  State            { get; set; }
        public string?  City             { get; set; }
        public string?  Address          { get; set; }
        public string?  ZipCode          { get; set; }
        public string   DefaultLanguage  { get; set; } = "en";
        public string   PayoutFrequency  { get; set; } = "Weekly";
        public bool     ShowBusinessName { get; set; }
        public bool     IsEmailPublic    { get; set; }
        public bool     IsPhonePublic    { get; set; }
        public string   MemberType       { get; set; } = string.Empty;
        public string   Status           { get; set; } = string.Empty;
        public DateTime EnrollDate       { get; set; }
        public string?  SponsorMemberId  { get; set; }
        public MembershipApiDto? Membership { get; set; }
    }

    public class MembershipApiDto
    {
        public int      LevelId     { get; set; }
        public string   LevelName   { get; set; } = string.Empty;
        public string   Status      { get; set; } = string.Empty;
        public DateTime StartDate   { get; set; }
        public DateTime? ExpireDate { get; set; }
        public bool     IsAutoRenew { get; set; }
    }

    private class CreditCardApiDto
    {
        public string Last4       { get; set; } = string.Empty;
        public string CardBrand   { get; set; } = "Unknown";
        public int    ExpiryMonth { get; set; }
        public int    ExpiryYear  { get; set; }
        public bool   IsDefault   { get; set; }
    }
}
