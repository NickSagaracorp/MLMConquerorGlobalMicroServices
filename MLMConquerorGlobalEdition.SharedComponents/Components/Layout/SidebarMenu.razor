@inject IViewContextService ViewContext
@inject NavigationManager Nav

<div class="logo position-relative">
    <a href="/dashboard" class="d-block text-decoration-none position-relative">
        <img src="assets/images/logo.svg" alt="logo-icon">
    </a>
    <button class="sidebar-burger-menu bg-transparent p-0 border-0 opacity-0 z-n1 position-absolute top-50 end-0 translate-middle-y"
            id="sidebar-burger-menu">
        <i data-feather="x"></i>
    </button>
</div>

<aside id="layout-menu" class="layout-menu menu-vertical menu active" data-simplebar>
    <ul class="menu-inner">

        <li class="menu-title small text-uppercase">
            <span class="menu-title-text">MENU</span>
        </li>

        <!-- Dashboard -->
        <li class="menu-item @IsActive("/dashboard")">
            <a href="/dashboard" class="menu-link">
                <span class="material-symbols-outlined menu-icon">home</span>
                <span class="title">Home</span>
            </a>
        </li>

        <!-- Enrollment Team -->
        <li class="menu-item @(IsEnrollmentActive() ? "active open" : "")">
            <a href="javascript:void(0);" class="menu-link menu-toggle">
                <span class="material-symbols-outlined menu-icon">group</span>
                <span class="title">Enrollment Team</span>
                <span class="count">4</span>
            </a>
            <ul class="menu-sub">
                <li class="menu-item @IsActive("/team/enrollment/my-team")">
                    <a href="/team/enrollment/my-team" class="menu-link">My Team</a>
                </li>
                <li class="menu-item @IsActive("/team/enrollment/visualizer")">
                    <a href="/team/enrollment/visualizer" class="menu-link">Visualizer</a>
                </li>
                <li class="menu-item @IsActive("/team/enrollment/branches")">
                    <a href="/team/enrollment/branches" class="menu-link">Branches</a>
                </li>
                <li class="menu-item @IsActive("/team/enrollment/customers")">
                    <a href="/team/enrollment/customers" class="menu-link">Customers</a>
                </li>
            </ul>
        </li>

        <!-- Dual Team — Ambassador only -->
        @if (ViewContext.IsInAnyRole(AppRoles.Ambassador) || ViewContext.IsAdminContext)
        {
            <li class="menu-item @(IsDualTeamActive() ? "active open" : "")">
                <a href="javascript:void(0);" class="menu-link menu-toggle">
                    <span class="material-symbols-outlined menu-icon">share</span>
                    <span class="title">Dual Team</span>
                    <span class="count">3</span>
                </a>
                <ul class="menu-sub">
                    <li class="menu-item @IsActive("/team/dual-myteam")">
                        <a href="/team/dual-myteam" class="menu-link">My Dual Team</a>
                    </li>
                    <li class="menu-item @IsActive("/team/dual-tree")">
                        <a href="/team/dual-tree" class="menu-link">Visualizer</a>
                    </li>
                    <li class="menu-item @IsActive("/team/residuals")">
                        <a href="/team/residuals" class="menu-link">Residuals</a>
                    </li>
                </ul>
            </li>
        }

        <!-- Commissions — Ambassador only -->
        @if (ViewContext.IsInAnyRole(AppRoles.Ambassador) || ViewContext.IsAdminContext)
        {
            <li class="menu-item @(IsCommissionsActive() ? "active open" : "")">
                <a href="javascript:void(0);" class="menu-link menu-toggle">
                    <span class="material-symbols-outlined menu-icon">paid</span>
                    <span class="title">Commissions</span>
                    <span class="count">5</span>
                </a>
                <ul class="menu-sub">
                    <li class="menu-item @IsExact("/commissions")">
                        <a href="/commissions" class="menu-link">Overview</a>
                    </li>
                    <li class="menu-item @IsActive("/commissions/presidential")">
                        <a href="/commissions/presidential" class="menu-link">Presidential Bonus</a>
                    </li>
                    <li class="menu-item @IsActive("/commissions/car-bonus")">
                        <a href="/commissions/car-bonus" class="menu-link">Car Bonus</a>
                    </li>
                    <li class="menu-item @IsActive("/commissions/fast-start")">
                        <a href="/commissions/fast-start" class="menu-link">Fast Start Bonus</a>
                    </li>
                    <li class="menu-item @IsActive("/commissions/boost")">
                        <a href="/commissions/boost" class="menu-link">Boost Bonus</a>
                    </li>
                </ul>
            </li>
        }

        <!-- Tokens -->
        <li class="menu-item @IsActive("/tokens")">
            <a href="/tokens" class="menu-link">
                <span class="material-symbols-outlined menu-icon">content_paste</span>
                <span class="title">Tokens</span>
            </a>
        </li>

        @* Placement menu removed — placements are performed from the Dual Team binary tree visualizer *@

        <!-- Loyalty -->
        <li class="menu-item @IsActive("/loyalty")">
            <a href="/loyalty" class="menu-link">
                <span class="material-symbols-outlined menu-icon">favorite</span>
                <span class="title">Loyalty Points</span>
            </a>
        </li>

        <!-- Marketing -->
        <li class="menu-item @IsActive("/marketing")">
            <a href="/marketing" class="menu-link">
                <span class="material-symbols-outlined menu-icon">campaign</span>
                <span class="title">Marketing</span>
            </a>
        </li>

        <!-- Ranks — Ambassador only -->
        @if (ViewContext.IsInAnyRole(AppRoles.Ambassador) || ViewContext.IsAdminContext)
        {
            <li class="menu-item @IsActive("/ranks")">
                <a href="/ranks" class="menu-link">
                    <span class="material-symbols-outlined menu-icon">workspace_premium</span>
                    <span class="title">Rank Dashboard</span>
                </a>
            </li>
        }

        <!-- Profile -->
        <li class="menu-item @IsActive("/profile")">
            <a href="/profile" class="menu-link">
                <span class="material-symbols-outlined menu-icon">account_circle</span>
                <span class="title">My Profile</span>
            </a>
        </li>

        <!-- Support Tickets -->
        <li class="menu-item @IsActive("/tickets")">
            <a href="/tickets" class="menu-link">
                <span class="material-symbols-outlined menu-icon">support</span>
                <span class="title">Support</span>
            </a>
        </li>

        <!-- Logout -->
        <li class="menu-item">
            <a href="/account/logout" class="menu-link">
                <span class="material-symbols-outlined menu-icon">logout</span>
                <span class="title">Logout</span>
            </a>
        </li>

    </ul>
</aside>

@code {
    private string IsActive(string href)
        => Nav.Uri.Contains(href, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;

    private string IsExact(string href)
    {
        var path = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
        return string.Equals(path, href.TrimEnd('/'), StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }

    private bool IsEnrollmentActive()
        => Nav.Uri.Contains("/team/enrollment", StringComparison.OrdinalIgnoreCase);

    private bool IsDualTeamActive()
        => Nav.Uri.Contains("/team/dual", StringComparison.OrdinalIgnoreCase);

    private bool IsCommissionsActive()
        => Nav.Uri.Contains("/commissions", StringComparison.OrdinalIgnoreCase);
}
