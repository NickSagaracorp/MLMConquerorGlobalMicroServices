@inherits LayoutComponentBase
@implements IDisposable
@inject IThemeService Theme
@inject IViewContextService ViewContext

@* Matches UI-Templates/event_details.html layout structure.
   Mirror of MainLayout but with the admin sidebar. *@

<div class="@(Theme.IsDarkMode ? "dark-mode" : "")">
    <ImpersonationBanner />

    <div class="sidebar-area" id="sidebar-area">
        <AdminSidebarMenu />
    </div>

    <div class="container-fluid">
        <div class="main-content d-flex flex-column">

            <HeaderArea />

            <div class="main-content-container overflow-hidden">
                <ErrorBoundary>
                    <ChildContent>@Body</ChildContent>
                    <ErrorContent Context="ex">
                        <div class="alert alert-danger m-3">
                            <h5 class="alert-heading"><i class="ri-error-warning-line me-2"></i>An error occurred</h5>
                            <p class="mb-1">@ex.Message</p>
                            <pre class="small text-muted mt-2" style="white-space:pre-wrap;">@ex.ToString()</pre>
                            <button class="btn btn-sm btn-outline-danger mt-2" onclick="window.location.reload()">Reload Page</button>
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </div>

            <div class="flex-grow-1"></div>

            <FooterArea />
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Theme.OnThemeChanged += StateHasChanged;
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= StateHasChanged;
    }
}
