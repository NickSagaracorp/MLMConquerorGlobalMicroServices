@inherits LayoutComponentBase
@implements IDisposable
@inject IThemeService Theme
@inject IViewContextService ViewContext
@inject IStringLocalizer<SharedResources> L

@* Matches UI-Templates/event_details.html layout structure:
     <body class="boxed-size">
       <div class="sidebar-area" id="sidebar-area"> ... </div>
       <div class="container-fluid">
         <div class="main-content d-flex flex-column">
           <header class="header-area"> ... </header>
           <div class="main-content-container"> ... page body ... </div>
           <div class="flex-grow-1"></div>
           <footer class="footer-area"> ... </footer>
         </div>
       </div>
     </body>
   Keep the dark-mode wrapper around everything so theme-toggle works. *@

<div class="@(Theme.IsDarkMode ? "dark-mode" : "")">
    <ImpersonationBanner />

    <div class="sidebar-area" id="sidebar-area">
        <SidebarMenu />
    </div>

    <div class="container-fluid">
        <div class="main-content d-flex flex-column">

            <HeaderArea />

            <div class="main-content-container overflow-hidden">
                <ErrorBoundary>
                    <ChildContent>@Body</ChildContent>
                    <ErrorContent Context="ex">
                        <div class="alert alert-danger m-3">
                            <h5 class="alert-heading"><i class="ri-error-warning-line me-2"></i>@L["Layout.ErrorOccurred"]</h5>
                            <p class="mb-1">@ex.Message</p>
                            <pre class="small text-muted mt-2" style="white-space:pre-wrap;">@ex.ToString()</pre>
                            <button class="btn btn-sm btn-outline-danger mt-2" onclick="window.location.reload()">@L["Layout.ReloadPage"]</button>
                        </div>
                    </ErrorContent>
                </ErrorBoundary>
            </div>

            <div class="flex-grow-1"></div>

            <FooterArea />
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Theme.OnThemeChanged += StateHasChanged;
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= StateHasChanged;
    }
}
