@page "/admin/members"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Members — Admin</PageTitle>

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Admin Dashboard", "/admin"), new("Members") })" />

<div class="card border-0 shadow-sm">
    <div class="card-header py-3 d-flex align-items-center gap-3 flex-wrap">
        <h6 class="card-title mb-0 fw-semibold flex-grow-1">
            <i class="ri-group-line me-2 text-primary"></i>Member Management
        </h6>
        <input class="form-control form-control-sm" style="min-width:220px"
               placeholder="Search by name, ID..."
               @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
        <select class="form-select form-select-sm w-auto" style="min-width:140px"
                @bind="_statusFilter" @bind:after="() => { _page = 1; _ = LoadAsync(); }">
            <option value="">All Statuses</option>
            <option value="Active">Active</option>
            <option value="Inactive">Inactive</option>
            <option value="Suspended">Suspended</option>
            <option value="Pending">Pending</option>
        </select>
        <button class="btn btn-primary btn-sm" @onclick="() => { _page = 1; _ = LoadAsync(); }">
            <i class="ri-search-line me-1"></i>Search
        </button>
    </div>
    @if (_retryMessage is not null)
    {
        <div class="alert @(_retryIsError ? "alert-danger" : "alert-success") alert-dismissible m-3">
            @_retryMessage
            <button type="button" class="btn-close" @onclick="() => _retryMessage = null"></button>
        </div>
    }
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else if (_error is not null)
        {
            <div class="alert alert-danger m-3">@_error</div>
        }
        else
        {
            <SfGrid TValue="AdminMemberDto" DataSource="@_members"
                    AllowPaging="true" AllowFiltering="true" AllowSorting="true" AllowResizing="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="50" PageSizes="@(new int[]{50,100,250,500,1000})" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>
                    <GridColumn Field="@nameof(AdminMemberDto.MemberId)" HeaderText="Member ID" Width="130" AllowFiltering="true">
                        <Template>
                            @{ var m = (AdminMemberDto)context; }
                            <a href="/admin/members/@m.MemberId" target="_blank" class="text-decoration-none">
                                <code class="text-primary">@m.MemberId</code>
                            </a>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.FirstName)" HeaderText="Name" Width="180" AllowFiltering="true">
                        <Template>
                            @{ var m = (AdminMemberDto)context; }
                            <a href="/admin/members/@m.MemberId" target="_blank" class="text-primary">
                                @m.FirstName @m.LastName
                            </a>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.Email)" HeaderText="Email" Width="200" AllowFiltering="true">
                        <Template>
                            @(((AdminMemberDto)context).Email ?? "—")
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.Phone)" HeaderText="Phone" Width="130" AllowFiltering="true">
                        <Template>
                            @(((AdminMemberDto)context).Phone ?? "—")
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.Country)" HeaderText="Country" Width="110" AllowFiltering="true" />
                    <GridColumn Field="@nameof(AdminMemberDto.ReplicateSiteSlug)" HeaderText="Website" Width="160" AllowFiltering="true">
                        <Template>
                            @(((AdminMemberDto)context).ReplicateSiteSlug ?? "—")
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.MembershipLevelName)" HeaderText="Membership" Width="150" AllowFiltering="true">
                        <Template>
                            @{ var lvl = ((AdminMemberDto)context).MembershipLevelName; }
                            @if (!string.IsNullOrWhiteSpace(lvl))
                            {
                                <span class="badge bg-info text-dark">@lvl</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.LifetimeRankName)" HeaderText="Lifetime Rank" Width="150" AllowFiltering="true">
                        <Template>
                            @{ var lr = ((AdminMemberDto)context).LifetimeRankName; }
                            @if (!string.IsNullOrWhiteSpace(lr))
                            {
                                <span class="badge bg-warning text-dark">@lr</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.SponsorFullName)" HeaderText="Sponsor" Width="180" AllowFiltering="true">
                        <Template>
                            @{ var m = (AdminMemberDto)context; }
                            @if (!string.IsNullOrWhiteSpace(m.SponsorMemberId) && !string.IsNullOrWhiteSpace(m.SponsorFullName))
                            {
                                <a href="/admin/members/@m.SponsorMemberId" target="_blank" class="text-primary">@m.SponsorFullName</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.DualTeamUplineFullName)" HeaderText="Upline" Width="180" AllowFiltering="true">
                        <Template>
                            @{ var m = (AdminMemberDto)context; }
                            @if (!string.IsNullOrWhiteSpace(m.DualTeamParentMemberId) && !string.IsNullOrWhiteSpace(m.DualTeamUplineFullName))
                            {
                                <a href="/admin/members/@m.DualTeamParentMemberId" target="_blank" class="text-primary">@m.DualTeamUplineFullName</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.MemberType)" HeaderText="Type" Width="120" AllowFiltering="true">
                        <Template>
                            <span class="badge bg-secondary">@(((AdminMemberDto)context).MemberType)</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.Status)" HeaderText="Status" Width="110" AllowFiltering="true">
                        <Template>
                            <span class="badge @StatusBadge(((AdminMemberDto)context).Status)">@(((AdminMemberDto)context).Status)</span>
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(AdminMemberDto.EnrollDate)" HeaderText="Enrolled" Width="130" Format="yyyy-MM-dd" Type="ColumnType.Date" AllowFiltering="true" />
                    <GridColumn Field="@nameof(AdminMemberDto.ExpirationDate)" HeaderText="Expiration Date" Width="140" Format="yyyy-MM-dd" Type="ColumnType.Date" AllowFiltering="true" />
                    <GridColumn HeaderText="Actions" Width="170" TextAlign="TextAlign.Center" AllowFiltering="false">
                        <Template>
                            @{ var m = (AdminMemberDto)context; }
                            <a href="/admin/members/@m.MemberId" target="_blank" class="btn btn-sm btn-outline-primary py-0 px-2" title="View Profile">
                                <i class="ri-eye-line"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-secondary py-0 px-2 ms-1" title="Binary Tree"
                                @onclick="@(() => Navigation.NavigateTo($"/admin/network/binary-tree?memberId={m.MemberId}"))">
                                <i class="ri-node-tree"></i>
                            </button>
                            @if (m.Status == "Pending")
                            {
                                <button class="btn btn-sm btn-outline-warning py-0 px-2 ms-1" title="Retry Complete Signup"
                                    disabled="@_retryingMemberId.Equals(m.MemberId)"
                                    @onclick="@(() => RetryCompleteAsync(m.MemberId))">
                                    @if (_retryingMemberId == m.MemberId)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                    }
                                    else
                                    {
                                        <i class="ri-refresh-line"></i>
                                    }
                                </button>
                            }
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>

            @if (_totalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top bg-light">
                    <small class="text-muted">@_totalCount members — Page @_page of @_totalPages</small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(_page == 1 ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page - 1)">‹</button>
                            </li>
                            @for (int i = Math.Max(1, _page - 2); i <= Math.Min(_totalPages, _page + 2); i++)
                            { var pg = i; <li class="page-item @(_page == pg ? "active" : "")"><button class="page-link" @onclick="() => ChangePage(pg)">@pg</button></li> }
                            <li class="page-item @(_page == _totalPages ? "disabled" : "")">
                                <button class="page-link" @onclick="() => ChangePage(_page + 1)">›</button>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<AdminMemberDto> _members = new();
    private bool    _loading           = true;
    private string? _error;
    private int     _page              = 1;
    private const int PageSize         = 20;
    private int     _totalCount;
    private int     _totalPages        = 1;
    private string  _search            = string.Empty;
    private string  _statusFilter      = string.Empty;
    private string  _retryingMemberId  = string.Empty;
    private string? _retryMessage;
    private bool    _retryIsError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            var url = $"api/v1/admin/members?page={_page}&pageSize={PageSize}";
            if (!string.IsNullOrWhiteSpace(_statusFilter)) url += $"&status={_statusFilter}";
            if (!string.IsNullOrWhiteSpace(_search))       url += $"&search={Uri.EscapeDataString(_search)}";
            var resp = await Http.GetFromJsonAsync<ApiResponse<PagedResult<AdminMemberDto>>>(url);
            if (resp?.Success == true && resp.Data is not null)
            {
                _members    = resp.Data.Items.ToList();
                _totalCount = resp.Data.TotalCount;
                _totalPages = resp.Data.TotalPages;
            }
            else { _error = resp?.Errors?.FirstOrDefault() ?? "Failed to load members."; }
        }
        catch (Exception ex) { _error = $"API error: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task ChangePage(int p) { if (p < 1 || p > _totalPages) return; _page = p; await LoadAsync(); }

    private async Task OnSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await LoadAsync(); } }

    private async Task RetryCompleteAsync(string memberId)
    {
        // Look up the pending order for this member via the pending-signups endpoint.
        _retryingMemberId = memberId;
        _retryMessage = null;
        StateHasChanged();
        try
        {
            var pending = await Http.GetFromJsonAsync<ApiResponse<List<PendingSignupDto>>>("api/v1/admin/signups/pending");
            var match = pending?.Data?.FirstOrDefault(p => p.MemberId == memberId);
            if (match is null)
            {
                _retryMessage = "No pending signup found for this member."; _retryIsError = true; return;
            }

            var resp = await Http.PostAsync($"api/v1/admin/signups/{match.OrderId}/retry-complete", null);
            if (resp.IsSuccessStatusCode)
            {
                _retryMessage = $"Signup completed for {memberId}. Reloading list…";
                _retryIsError = false;
                await LoadAsync();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                _retryMessage = $"Retry failed ({(int)resp.StatusCode}): {body}";
                _retryIsError = true;
            }
        }
        catch (Exception ex) { _retryMessage = $"Retry error: {ex.Message}"; _retryIsError = true; }
        finally { _retryingMemberId = string.Empty; StateHasChanged(); }
    }

    private static string StatusBadge(string status) => status switch
    { "Active" => "bg-success", "Inactive" => "bg-secondary", "Suspended" => "bg-danger", _ => "bg-secondary" };

    private record PendingSignupDto(string MemberId, string FullName, string Email,
        string Country, string? SponsorMemberId, DateTime EnrollDate, string OrderId, decimal OrderTotal);

    private record AdminMemberDto(string MemberId, string FirstName, string LastName,
        string? Phone, string? Email, string Country, string Status, string MemberType,
        DateTime EnrollDate, DateTime? ExpirationDate,
        string? SponsorMemberId, string? SponsorFullName,
        string? DualTeamParentMemberId, string? DualTeamUplineFullName,
        string? ReplicateSiteSlug, string? MembershipLevelName,
        string? LifetimeRankName,
        DateTime CreationDate);
    private record PagedResult<T>(IEnumerable<T> Items, int TotalCount, int Page, int PageSize, int TotalPages);
    private record ApiResponse<T>(bool Success, T? Data, IEnumerable<string>? Errors);
}
