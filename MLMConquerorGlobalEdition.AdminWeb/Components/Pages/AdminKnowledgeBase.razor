@page "/admin/helpdesk/kb"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin,Admin,SupportManager,SupportLevel1,SupportLevel2,SupportLevel3,IT")]
@inject IHttpClientFactory HttpClientFactory
@using Syncfusion.Blazor.RichTextEditor

<PageTitle>Knowledge Base — Admin</PageTitle>

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Admin Dashboard", "/admin"), new("Helpdesk", "/admin/helpdesk/dashboard"), new("Knowledge Base") })" />

@if (_alertMsg is not null)
{
    <div class="alert @(_alertIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
        @_alertMsg <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header py-3 d-flex align-items-center gap-2">
        <h6 class="card-title mb-0 fw-semibold flex-grow-1">
            <i class="ri-book-open-line me-2 text-primary"></i>Knowledge Base Articles
        </h6>
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync"><i class="ri-refresh-line"></i></button>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreate">
            <i class="ri-add-line me-1"></i>New Article
        </button>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else if (_items.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="ri-book-open-line fs-1 d-block mb-2"></i>
                <p class="mb-0">No knowledge base articles found. Create one to get started.</p>
            </div>
        }
        else
        {
            <SfGrid TValue="KbArticleSummaryDto" DataSource="@_items"
                    AllowPaging="true" AllowFiltering="true" AllowSorting="true" AllowResizing="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="50" PageSizes="@(new int[]{50,100,250})" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>
                    <GridColumn HeaderText="Title" Width="250">
                        <Template>
                            <span class="fw-semibold">@(((KbArticleSummaryDto)context).Title)</span>
                            <br /><small class="text-muted font-monospace">/@((KbArticleSummaryDto)context).Slug</small>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Category" Width="140">
                        <Template>
                            <span class="small text-muted">@(((KbArticleSummaryDto)context).CategoryName ?? "—")</span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Visibility" Width="110" TextAlign="TextAlign.Center">
                        <Template>
                            @{ var vis = ((KbArticleSummaryDto)context).Visibility; }
                            <span class="badge @(vis == "Public" ? "bg-success" : vis == "Internal" ? "bg-warning text-dark" : "bg-secondary")">
                                @vis
                            </span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Views" Width="80" TextAlign="TextAlign.Center">
                        <Template><span class="small">@(((KbArticleSummaryDto)context).ViewCount)</span></Template>
                    </GridColumn>
                    <GridColumn HeaderText="Helpful" Width="90" TextAlign="TextAlign.Center">
                        <Template>
                            @{ var a = (KbArticleSummaryDto)context; }
                            <span class="small text-success">+@a.HelpfulCount</span>
                            <span class="small text-danger ms-1">-@a.NotHelpfulCount</span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Published" Width="120">
                        <Template>
                            @{ var pub = ((KbArticleSummaryDto)context).PublishedAt; }
                            <span class="small text-muted">@(pub.HasValue ? pub.Value.ToString("yyyy-MM-dd") : "—")</span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Actions" Width="140" TextAlign="TextAlign.Center">
                        <Template>
                            @{ var item = (KbArticleSummaryDto)context; }
                            <button class="btn btn-sm btn-outline-primary py-0 me-1"
                                    @onclick="() => OpenEdit(item)"
                                    title="Edit">
                                <i class="ri-edit-line"></i>
                            </button>
                            @if (item.Visibility == "Draft" || !item.PublishedAt.HasValue)
                            {
                                <button class="btn btn-sm btn-outline-success py-0 me-1"
                                        @onclick="() => PublishArticle(item)"
                                        title="Publish">
                                    <i class="ri-upload-cloud-line"></i>
                                </button>
                            }
                            <button class="btn btn-sm btn-outline-danger py-0"
                                    @onclick="() => ConfirmDelete(item)"
                                    title="Delete">
                                <i class="ri-delete-bin-line"></i>
                            </button>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

@* ── Create / Edit Modal ── *@
@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">@(_editId is null ? "New KB Article" : "Edit KB Article")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_form.Title" @oninput="AutoSlug" placeholder="Article title" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Slug <span class="text-danger">*</span></label>
                            <input class="form-control font-monospace" @bind="_form.Slug" placeholder="url-friendly-slug" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Body <span class="text-danger">*</span></label>
                            <SfRichTextEditor @bind-Value="_form.Body" Height="340" Placeholder="Article content…">
                                <RichTextEditorToolbarSettings Items="@_rteToolbar" />
                            </SfRichTextEditor>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Category ID</label>
                            <input type="number" class="form-control" @bind="_form.CategoryId" min="1" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Visibility</label>
                            <select class="form-select" @bind="_form.Visibility">
                                <option value="0">Draft</option>
                                <option value="1">Internal</option>
                                <option value="2">Public</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Tags</label>
                            <input class="form-control" @bind="_form.TagsJson" placeholder='["tag1","tag2"]' />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editId is null ? "Create Article" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Publish Confirm Modal ── *@
@if (_showPublishConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold text-success">Publish Article</h5>
                    <button type="button" class="btn-close" @onclick="() => { _showPublishConfirm = false; _actionTarget = null; }"></button>
                </div>
                <div class="modal-body">
                    Publish <strong>@_actionTarget?.Title</strong>? It will become visible according to its visibility setting.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { _showPublishConfirm = false; _actionTarget = null; }">Cancel</button>
                    <button class="btn btn-success" @onclick="ConfirmedPublish" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Publish
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete Confirm Modal ── *@
@if (_showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold text-danger">Delete Article</h5>
                    <button type="button" class="btn-close" @onclick="() => { _showDeleteConfirm = false; _actionTarget = null; }"></button>
                </div>
                <div class="modal-body">
                    Delete <strong>@_actionTarget?.Title</strong>? This cannot be undone.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { _showDeleteConfirm = false; _actionTarget = null; }">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteArticle" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private static readonly List<ToolbarItemModel> _rteToolbar = new()
    {
        new() { Command = ToolbarCommand.Bold },
        new() { Command = ToolbarCommand.Italic },
        new() { Command = ToolbarCommand.Underline },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.Formats },
        new() { Command = ToolbarCommand.Alignments },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.OrderedList },
        new() { Command = ToolbarCommand.UnorderedList },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.CreateLink },
        new() { Command = ToolbarCommand.Image },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.SourceCode },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.Undo },
        new() { Command = ToolbarCommand.Redo }
    };

    private List<KbArticleSummaryDto> _items = new();
    private bool _loading = true;
    private bool _saving;
    private string? _alertMsg;
    private bool _alertIsError;
    private bool _showForm;
    private bool _showDeleteConfirm;
    private bool _showPublishConfirm;
    private string? _editId;
    private KbArticleFormModel _form = new();
    private KbArticleSummaryDto? _actionTarget;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var http = HttpClientFactory.CreateClient("HelpdeskApi");
            var resp = await http.GetFromJsonAsync<ApiResp<PagedData<KbArticleSummaryDto>>>("api/v1/kb/search?q=&page=1&pageSize=500");
            if (resp?.Success == true && resp.Data?.Items is not null)
                _items = resp.Data.Items.ToList();
            else { _alertMsg = resp?.Errors?.FirstOrDefault() ?? "Failed to load articles."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _loading = false; }
    }

    private void OpenCreate()
    {
        _editId = null;
        _form = new KbArticleFormModel();
        _showForm = true;
    }

    private void OpenEdit(KbArticleSummaryDto item)
    {
        _editId = item.Id;
        _form = new KbArticleFormModel
        {
            Title = item.Title,
            Slug = item.Slug,
            Body = string.Empty, // body not in summary — agent will load full article if needed
            CategoryId = item.CategoryId,
            Visibility = item.Visibility switch { "Internal" => "1", "Public" => "2", _ => "0" },
            TagsJson = "[]"
        };
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; _editId = null; }

    // Auto-generate slug from title while typing
    private void AutoSlug(Microsoft.AspNetCore.Components.ChangeEventArgs e)
    {
        if (_editId is not null) return; // don't overwrite on edit
        var raw = e.Value?.ToString() ?? string.Empty;
        _form.Slug = raw.ToLowerInvariant()
                        .Replace(" ", "-")
                        .Replace("'", string.Empty)
                        .Replace("\"", string.Empty);
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.Title)) { _alertMsg = "Title is required."; _alertIsError = true; return; }
        if (string.IsNullOrWhiteSpace(_form.Slug)) { _alertMsg = "Slug is required."; _alertIsError = true; return; }
        _saving = true;
        try
        {
            var http = HttpClientFactory.CreateClient("HelpdeskApi");
            var payload = new
            {
                _form.Title,
                _form.Slug,
                _form.Body,
                CategoryId = _form.CategoryId,
                TagsJson = _form.TagsJson,
                Visibility = int.TryParse(_form.Visibility, out var v) ? v : 0
            };
            HttpResponseMessage response;
            if (_editId is null)
                response = await http.PostAsJsonAsync("api/v1/kb/articles", payload);
            else
                response = await http.PutAsJsonAsync($"api/v1/kb/articles/{_editId}", payload);

            if (response.IsSuccessStatusCode)
            {
                _alertMsg = _editId is null ? "Article created." : "Article updated.";
                _alertIsError = false;
                CloseForm();
                await LoadAsync();
            }
            else { _alertMsg = $"Save failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private void PublishArticle(KbArticleSummaryDto item) { _actionTarget = item; _showPublishConfirm = true; }

    private async Task ConfirmedPublish()
    {
        if (_actionTarget is null) return;
        _saving = true;
        try
        {
            var http = HttpClientFactory.CreateClient("HelpdeskApi");
            var response = await http.PostAsync($"api/v1/kb/articles/{_actionTarget.Id}/publish", null);
            if (response.IsSuccessStatusCode)
            {
                _alertMsg = "Article published.";
                _alertIsError = false;
                _showPublishConfirm = false;
                _actionTarget = null;
                await LoadAsync();
            }
            else { _alertMsg = $"Publish failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(KbArticleSummaryDto item) { _actionTarget = item; _showDeleteConfirm = true; }

    private async Task DeleteArticle()
    {
        if (_actionTarget is null) return;
        _saving = true;
        try
        {
            var http = HttpClientFactory.CreateClient("HelpdeskApi");
            var response = await http.DeleteAsync($"api/v1/kb/articles/{_actionTarget.Id}");
            if (response.IsSuccessStatusCode)
            {
                _alertMsg = "Article deleted.";
                _alertIsError = false;
                _showDeleteConfirm = false;
                _actionTarget = null;
                await LoadAsync();
            }
            else { _alertMsg = $"Delete failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private record ApiResp<T>(bool Success, T? Data, IEnumerable<string>? Errors);
    private record PagedData<T>(IEnumerable<T>? Items, int TotalCount, int Page, int PageSize);

    private class KbArticleSummaryDto
    {
        public string Id { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public int CategoryId { get; set; }
        public string? CategoryName { get; set; }
        public string Visibility { get; set; } = "Draft";
        public int ViewCount { get; set; }
        public int HelpfulCount { get; set; }
        public int NotHelpfulCount { get; set; }
        public int Version { get; set; }
        public DateTime? PublishedAt { get; set; }
        public DateTime CreationDate { get; set; }
    }

    private class KbArticleFormModel
    {
        public string Title { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string Body { get; set; } = string.Empty;
        public int CategoryId { get; set; } = 1;
        public string TagsJson { get; set; } = "[]";
        public string Visibility { get; set; } = "0"; // bound to select as string
    }
}
