@page "/admin/events/promos/{PromoId}/commissions"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Promo Commissions — Admin</PageTitle>

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Admin Dashboard", "/admin"), new("Corporate Promos", "/admin/events/promos"), new("Promo Commissions") })" />

@if (_alertMsg is not null)
{
    <div class="alert @(_alertIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
        @_alertMsg <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
    </div>
}

<div class="d-flex mb-3 gap-2">
    <a href="/admin/events/promos/@PromoId/members" class="btn btn-outline-secondary btn-sm"><i class="ri-team-line me-1"></i>Members</a>
    <a href="/admin/events/promos/@PromoId/dashboard" class="btn btn-outline-secondary btn-sm"><i class="ri-dashboard-line me-1"></i>Dashboard</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header py-3 d-flex align-items-center gap-2">
        <h6 class="card-title mb-0 fw-semibold flex-grow-1">
            <i class="ri-percent-line me-2 text-primary"></i>Product Commission Overrides for Promo
        </h6>
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync"><i class="ri-refresh-line"></i></button>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreate">
            <i class="ri-add-line me-1"></i>New Rule
        </button>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else
        {
            <SfGrid TValue="PromoCommissionDto" DataSource="@_items"
                    AllowPaging="true" AllowFiltering="true" AllowSorting="true" AllowResizing="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="50" PageSizes="@(new int[]{50,100,250,500,1000})" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>
                    <GridColumn Field="@nameof(PromoCommissionDto.Id)" HeaderText="ID" Width="70" TextAlign="TextAlign.Center" />
                    <GridColumn Field="@nameof(PromoCommissionDto.ProductName)" HeaderText="Product" Width="200" />
                    <GridColumn HeaderText="Sponsor" Width="90" TextAlign="TextAlign.Center">
                        <Template><span class="badge @FlagBadge(((PromoCommissionDto)context).TriggerSponsorBonus)">@YesNo(((PromoCommissionDto)context).TriggerSponsorBonus)</span></Template>
                    </GridColumn>
                    <GridColumn HeaderText="Builder" Width="90" TextAlign="TextAlign.Center">
                        <Template><span class="badge @FlagBadge(((PromoCommissionDto)context).TriggerBuilderBonus)">@YesNo(((PromoCommissionDto)context).TriggerBuilderBonus)</span></Template>
                    </GridColumn>
                    <GridColumn HeaderText="FSBonus" Width="90" TextAlign="TextAlign.Center">
                        <Template><span class="badge @FlagBadge(((PromoCommissionDto)context).TriggerFastStartBonus)">@YesNo(((PromoCommissionDto)context).TriggerFastStartBonus)</span></Template>
                    </GridColumn>
                    <GridColumn HeaderText="Residual" Width="90" TextAlign="TextAlign.Center">
                        <Template><span class="badge @FlagBadge(((PromoCommissionDto)context).EligibleMembershipResidual)">@YesNo(((PromoCommissionDto)context).EligibleMembershipResidual)</span></Template>
                    </GridColumn>
                    <GridColumn HeaderText="Actions" Width="100" TextAlign="TextAlign.Center">
                        <Template>
                            <button class="btn btn-sm btn-outline-primary py-0 me-1" @onclick="() => OpenEdit((PromoCommissionDto)context)"><i class="ri-edit-line"></i></button>
                            <button class="btn btn-sm btn-outline-danger py-0" @onclick="() => ConfirmDelete((PromoCommissionDto)context)"><i class="ri-delete-bin-line"></i></button>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">@(_editId is null ? "New Commission Rule" : "Edit Rule")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">Configure which commission types fire for the selected product during this promo.</p>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Product <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="_form.ProductId" disabled="@(_editId is not null)">
                                <option value="">— Select a product —</option>
                                @foreach (var p in _eligibleProducts)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                            <div class="form-text">Only products with commission rules configured are shown.</div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded-3 p-3">
                                <p class="fw-semibold text-primary mb-3"><i class="ri-team-line me-2"></i>Sponsor &amp; Builder</p>
                                <div class="d-flex flex-column gap-2">
                                    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pSB" @bind="_form.TriggerSponsorBonus"><label class="form-check-label" for="pSB">Sponsor Bonus</label></div>
                                    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pSBT" @bind="_form.TriggerSponsorBonusTurbo"><label class="form-check-label" for="pSBT">Sponsor Bonus Turbo</label></div>
                                    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pBB" @bind="_form.TriggerBuilderBonus"><label class="form-check-label" for="pBB">Builder Bonus</label></div>
                                    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pBBT" @bind="_form.TriggerBuilderBonusTurbo"><label class="form-check-label" for="pBBT">Builder Bonus Turbo</label></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded-3 p-3">
                                <p class="fw-semibold text-primary mb-3"><i class="ri-rocket-line me-2"></i>Performance</p>
                                <div class="d-flex flex-column gap-2">
                                    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pFS" @bind="_form.TriggerFastStartBonus"><label class="form-check-label" for="pFS">Fast Start Bonus</label></div>
                                    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pBo" @bind="_form.TriggerBoostBonus"><label class="form-check-label" for="pBo">Boost Bonus</label></div>
                                    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pCar" @bind="_form.CarBonusEligible"><label class="form-check-label" for="pCar">Car Bonus</label></div>
                                    <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pPres" @bind="_form.PresidentialBonusEligible"><label class="form-check-label" for="pPres">Presidential Bonus</label></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="border rounded-3 p-3">
                                <p class="fw-semibold text-primary mb-3"><i class="ri-repeat-line me-2"></i>Residuals</p>
                                <div class="row g-2">
                                    <div class="col-md-6"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pMR" @bind="_form.EligibleMembershipResidual"><label class="form-check-label" for="pMR">Membership Residual</label></div></div>
                                    <div class="col-md-6"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="pDR" @bind="_form.EligibleDailyResidual"><label class="form-check-label" for="pDR">Daily Residual</label></div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editId is null ? "Create" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header"><h5 class="modal-title fw-bold text-danger">Delete Rule</h5><button type="button" class="btn-close" @onclick="() => { _showDeleteConfirm = false; _deleteItem = null; }"></button></div>
                <div class="modal-body">Delete this commission rule for product <strong>@_deleteItem?.ProductName</strong>? This cannot be undone.</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { _showDeleteConfirm = false; _deleteItem = null; }">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteItem" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string PromoId { get; set; } = string.Empty;

    private List<PromoCommissionDto> _items = new();
    private List<ProductItem> _eligibleProducts = new();
    private bool _loading = true;
    private bool _saving;
    private string? _alertMsg;
    private bool _alertIsError;
    private bool _showForm;
    private bool _showDeleteConfirm;
    private int? _editId;
    private PromoCommissionFormModel _form = new();
    private PromoCommissionDto? _deleteItem;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadEligibleProducts(), LoadAsync());
    }

    private async Task LoadEligibleProducts()
    {
        try
        {
            // Load all product commissions and unique products from them
            var pcResp = await Http.GetFromJsonAsync<ApiResp<Paged<PcItem>>>("api/v1/admin/product-commissions?page=1&pageSize=500");
            var prodResp = await Http.GetFromJsonAsync<ApiResp<Paged<ProductItem>>>("api/v1/admin/products?page=1&pageSize=500");
            if (pcResp?.Success == true && pcResp.Data is not null && prodResp?.Success == true && prodResp.Data is not null)
            {
                var configuredIds = pcResp.Data.Items.Select(x => x.ProductId).Distinct().ToHashSet();
                _eligibleProducts = prodResp.Data.Items
                    .Where(p => configuredIds.Contains(p.Id))
                    .OrderBy(p => p.Name)
                    .ToList();
            }
        }
        catch { /* non-critical */ }
    }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<Paged<PromoCommissionDto>>>($"api/v1/admin/corporate-promos/{PromoId}/product-commissions?page=1&pageSize=100");
            if (resp?.Success == true && resp.Data is not null)
                _items = resp.Data.Items.ToList();
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _loading = false; }
    }

    private void OpenCreate()
    {
        _editId = null;
        _form = new() { TriggerSponsorBonus = true, TriggerBuilderBonus = true, TriggerFastStartBonus = true,
            TriggerBoostBonus = true, CarBonusEligible = true, PresidentialBonusEligible = true,
            EligibleMembershipResidual = true, EligibleDailyResidual = true };
        _showForm = true;
    }

    private void OpenEdit(PromoCommissionDto p)
    {
        _editId = p.Id;
        _form = new PromoCommissionFormModel
        {
            ProductId = p.ProductId,
            TriggerSponsorBonus = p.TriggerSponsorBonus, TriggerSponsorBonusTurbo = p.TriggerSponsorBonusTurbo,
            TriggerBuilderBonus = p.TriggerBuilderBonus, TriggerBuilderBonusTurbo = p.TriggerBuilderBonusTurbo,
            TriggerFastStartBonus = p.TriggerFastStartBonus, TriggerBoostBonus = p.TriggerBoostBonus,
            CarBonusEligible = p.CarBonusEligible, PresidentialBonusEligible = p.PresidentialBonusEligible,
            EligibleMembershipResidual = p.EligibleMembershipResidual, EligibleDailyResidual = p.EligibleDailyResidual
        };
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; _editId = null; }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.ProductId)) { _alertMsg = "Product is required."; _alertIsError = true; return; }

        // Prevent duplicate product entries
        if (_editId is null && _items.Any(x => x.ProductId == _form.ProductId))
        {
            var productName = _eligibleProducts.FirstOrDefault(p => p.Id == _form.ProductId)?.Name ?? _form.ProductId;
            _alertMsg = $"A commission rule for '{productName}' already exists in this promo. Edit the existing rule instead.";
            _alertIsError = true;
            return;
        }

        _saving = true;
        try
        {
            var response = _editId is null
                ? await Http.PostAsJsonAsync($"api/v1/admin/corporate-promos/{PromoId}/product-commissions", _form)
                : await Http.PutAsJsonAsync($"api/v1/admin/corporate-promos/{PromoId}/product-commissions/{_editId}", _form);
            if (response.IsSuccessStatusCode) { _alertMsg = _editId is null ? "Created." : "Updated."; _alertIsError = false; CloseForm(); await LoadAsync(); }
            else { _alertMsg = $"Save failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(PromoCommissionDto p) { _deleteItem = p; _showDeleteConfirm = true; }

    private async Task DeleteItem()
    {
        if (_deleteItem is null) return;
        _saving = true;
        try
        {
            var response = await Http.DeleteAsync($"api/v1/admin/corporate-promos/{PromoId}/product-commissions/{_deleteItem.Id}");
            if (response.IsSuccessStatusCode) { _alertMsg = "Deleted."; _alertIsError = false; _showDeleteConfirm = false; _deleteItem = null; await LoadAsync(); }
            else { _alertMsg = $"Failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private static string FlagBadge(bool val) => val ? "bg-success" : "bg-light text-dark border";
    private static string YesNo(bool val) => val ? "Yes" : "No";

    private record PromoCommissionDto(int Id, string ProductId, string ProductName,
        bool TriggerSponsorBonus, bool TriggerSponsorBonusTurbo,
        bool TriggerBuilderBonus, bool TriggerBuilderBonusTurbo,
        bool TriggerFastStartBonus, bool TriggerBoostBonus,
        bool CarBonusEligible, bool PresidentialBonusEligible,
        bool EligibleMembershipResidual, bool EligibleDailyResidual);

    private record PcItem(int Id, string ProductId);
    private record ProductItem(string Id, string Name);

    private class PromoCommissionFormModel
    {
        public string ProductId { get; set; } = string.Empty;
        public bool TriggerSponsorBonus { get; set; }
        public bool TriggerSponsorBonusTurbo { get; set; }
        public bool TriggerBuilderBonus { get; set; }
        public bool TriggerBuilderBonusTurbo { get; set; }
        public bool TriggerFastStartBonus { get; set; }
        public bool TriggerBoostBonus { get; set; }
        public bool CarBonusEligible { get; set; }
        public bool PresidentialBonusEligible { get; set; }
        public bool EligibleMembershipResidual { get; set; }
        public bool EligibleDailyResidual { get; set; }
    }

    private record ApiResp<T>(bool Success, T? Data, IEnumerable<string>? Errors);
    private record Paged<T>(IEnumerable<T> Items, int TotalCount, int Page, int PageSize, int TotalPages);
}
