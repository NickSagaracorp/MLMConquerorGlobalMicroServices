@page "/admin/config/products/{ProductId}/loyalty-points"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Product Loyalty Points — Admin</PageTitle>

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Admin Dashboard", "/admin"), new("Products", "/admin/config/products"), new("Loyalty Points") })" />

@if (_alertMsg is not null)
{
    <div class="alert @(_alertIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
        @_alertMsg <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header py-3 d-flex align-items-center gap-2">
        <h6 class="card-title mb-0 fw-semibold flex-grow-1">
            <i class="ri-star-line me-2 text-primary"></i>Loyalty Points Settings
            @if (!string.IsNullOrWhiteSpace(_productName))
            {
                <span class="text-muted fw-normal ms-1">— @_productName</span>
            }
        </h6>
        <a href="/admin/config/products" class="btn btn-outline-secondary btn-sm"><i class="ri-arrow-left-line me-1"></i>Back</a>
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync"><i class="ri-refresh-line"></i></button>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreate"><i class="ri-add-line me-1"></i>New Setting</button>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else if (_items.Count == 0)
        {
            <div class="text-center py-5 text-muted">
                <i class="ri-star-line fs-2 d-block mb-2"></i>
                No loyalty points setting configured.<br />
                <button class="btn btn-primary btn-sm mt-3" @onclick="OpenCreate"><i class="ri-add-line me-1"></i>Create Setting</button>
            </div>
        }
        else
        {
            <SfGrid TValue="LoyaltyDto" DataSource="@_items"
                    AllowPaging="true" AllowSorting="true" AllowResizing="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="20" />
                <GridColumns>
                    <GridColumn Field="@nameof(LoyaltyDto.Id)" HeaderText="ID" Width="70" TextAlign="TextAlign.Center" />
                    <GridColumn HeaderText="Points / Unit" Width="130" TextAlign="TextAlign.Right">
                        <Template>@(((LoyaltyDto)context).PointsPerUnit.ToString("F2"))</Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(LoyaltyDto.RequiredSuccessfulPayments)" HeaderText="Req. Payments to Unlock" Width="200" TextAlign="TextAlign.Center" />
                    <GridColumn HeaderText="Status" Width="100">
                        <Template>
                            <span class="badge @(((LoyaltyDto)context).IsActive ? "bg-success" : "bg-secondary")">
                                @(((LoyaltyDto)context).IsActive ? "Active" : "Inactive")
                            </span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Actions" Width="90" TextAlign="TextAlign.Center">
                        <Template>
                            <button class="btn btn-sm btn-outline-primary py-0 me-1" @onclick="() => OpenEdit((LoyaltyDto)context)"><i class="ri-edit-line"></i></button>
                            <button class="btn btn-sm btn-outline-danger py-0" @onclick="() => ConfirmDelete((LoyaltyDto)context)"><i class="ri-delete-bin-line"></i></button>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">@(_editId is null ? "New Loyalty Points Setting" : "Edit Setting")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Points Per Unit <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" class="form-control" @bind="_form.PointsPerUnit" placeholder="e.g. 10.00" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Required Successful Payments to Unlock</label>
                            <input type="number" class="form-control" @bind="_form.RequiredSuccessfulPayments" />
                            <div class="form-text">Number of consecutive successful payments before loyalty points unlock.</div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="lpActive" @bind="_form.IsActive" />
                                <label class="form-check-label" for="lpActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editId is null ? "Create" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header"><h5 class="modal-title fw-bold text-danger">Delete Setting</h5><button type="button" class="btn-close" @onclick="() => { _showDeleteConfirm = false; _deleteItem = null; }"></button></div>
                <div class="modal-body">Delete loyalty points setting #<strong>@_deleteItem?.Id</strong>?</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { _showDeleteConfirm = false; _deleteItem = null; }">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteItem" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string ProductId { get; set; } = string.Empty;

    private List<LoyaltyDto> _items = new();
    private bool _loading = true;
    private bool _saving;
    private string? _alertMsg;
    private bool _alertIsError;
    private bool _showForm;
    private bool _showDeleteConfirm;
    private int? _editId;
    private LoyaltyFormModel _form = new();
    private LoyaltyDto? _deleteItem;
    private string? _productName;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductName();
        await LoadAsync();
    }

    private async Task LoadProductName()
    {
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<Paged<ProductItem>>>($"api/v1/admin/products?page=1&pageSize=500");
            if (resp?.Success == true && resp.Data is not null)
                _productName = resp.Data.Items.FirstOrDefault(x => x.Id == ProductId)?.Name;
        }
        catch { /* non-critical */ }
    }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<IEnumerable<LoyaltyDto>>>($"api/v1/admin/products/{ProductId}/loyalty-points");
            if (resp?.Success == true && resp.Data is not null)
                _items = resp.Data.ToList();
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _loading = false; }
    }

    private void OpenCreate() { _editId = null; _form = new LoyaltyFormModel { IsActive = true }; _showForm = true; }

    private void OpenEdit(LoyaltyDto item)
    {
        _editId = item.Id;
        _form = new LoyaltyFormModel
        {
            PointsPerUnit = item.PointsPerUnit,
            RequiredSuccessfulPayments = item.RequiredSuccessfulPayments,
            IsActive = item.IsActive
        };
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; _editId = null; }

    private async Task Save()
    {
        _saving = true;
        try
        {
            var response = _editId is null
                ? await Http.PostAsJsonAsync($"api/v1/admin/products/{ProductId}/loyalty-points", _form)
                : await Http.PutAsJsonAsync($"api/v1/admin/products/{ProductId}/loyalty-points/{_editId}", _form);
            if (response.IsSuccessStatusCode) { _alertMsg = _editId is null ? "Created." : "Updated."; _alertIsError = false; CloseForm(); await LoadAsync(); }
            else { _alertMsg = $"Save failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(LoyaltyDto item) { _deleteItem = item; _showDeleteConfirm = true; }

    private async Task DeleteItem()
    {
        if (_deleteItem is null) return;
        _saving = true;
        try
        {
            var response = await Http.DeleteAsync($"api/v1/admin/products/{ProductId}/loyalty-points/{_deleteItem.Id}");
            if (response.IsSuccessStatusCode) { _alertMsg = "Deleted."; _alertIsError = false; _showDeleteConfirm = false; _deleteItem = null; await LoadAsync(); }
            else { _alertMsg = $"Failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private record LoyaltyDto(int Id, string ProductId, decimal PointsPerUnit, int RequiredSuccessfulPayments, bool IsActive);
    private record ProductItem(string Id, string Name);

    private class LoyaltyFormModel
    {
        public decimal PointsPerUnit { get; set; }
        public int RequiredSuccessfulPayments { get; set; }
        public bool IsActive { get; set; } = true;
    }

    private record ApiResp<T>(bool Success, T? Data, IEnumerable<string>? Errors);
    private record Paged<T>(IEnumerable<T> Items, int TotalCount, int Page, int PageSize, int TotalPages);
}
