@page "/admin/config/products"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Nav
@using Syncfusion.Blazor.RichTextEditor

<PageTitle>Products — Admin</PageTitle>

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Admin Dashboard", "/admin"), new("Products") })" />

@if (_alertMsg is not null)
{
    <div class="alert @(_alertIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
        @_alertMsg <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header py-3 d-flex align-items-center gap-2">
        <h6 class="card-title mb-0 fw-semibold flex-grow-1">
            <i class="ri-shopping-bag-line me-2 text-primary"></i>Products
        </h6>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreate">
            <i class="ri-add-line me-1"></i>New Product
        </button>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else
        {
            <SfGrid TValue="ProductDto" DataSource="@_products"
                    AllowPaging="true" AllowFiltering="true" AllowSorting="true" AllowResizing="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="50" PageSizes="@(new int[]{50,100,250,500,1000})" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>
                    <GridColumn HeaderText="Name" Width="220">
                        <Template>
                            @{
                                var p = (ProductDto)context;
                                <span class="fw-semibold">@p.Name</span>
                                @if (!string.IsNullOrWhiteSpace(p.ThemeClass))
                                {
                                    <span class="badge ms-1 product-theme-badge @p.ThemeClass">@p.ThemeClass</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.Description))
                                {
                                    <div class="text-muted small product-desc-preview mt-1">
                                        @((MarkupString)TruncateHtml(p.Description, 80))
                                    </div>
                                }
                            }
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Monthly" Width="110" TextAlign="TextAlign.Right">
                        <Template>$@(((ProductDto)context).MonthlyFee.ToString("F2"))</Template>
                    </GridColumn>
                    <GridColumn HeaderText="Setup" Width="100" TextAlign="TextAlign.Right">
                        <Template>$@(((ProductDto)context).SetupFee.ToString("F2"))</Template>
                    </GridColumn>
                    <GridColumn HeaderText="Annual" Width="100" TextAlign="TextAlign.Right">
                        <Template>$@(((ProductDto)context).AnnualPrice.ToString("F2"))</Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(ProductDto.QualificationPoins)" HeaderText="BV Pts" Width="90" TextAlign="TextAlign.Center" />
                    <GridColumn HeaderText="Status" Width="100">
                        <Template>
                            <span class="badge @ActiveBadge(((ProductDto)context).IsActive)">
                                @(((ProductDto)context).IsActive ? "Active" : "Inactive")
                            </span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Actions" Width="160" TextAlign="TextAlign.Center">
                        <Template>
                            <button class="btn btn-sm btn-outline-info py-0 me-1" @onclick='() => Nav.NavigateTo($"/admin/config/products/{((ProductDto)context).Id}/commissions")'><i class="ri-percent-line"></i></button>
                            <button class="btn btn-sm btn-outline-warning py-0 me-1" @onclick='() => Nav.NavigateTo($"/admin/config/products/{((ProductDto)context).Id}/loyalty-points")'><i class="ri-star-line"></i></button>
                            <button class="btn btn-sm btn-outline-primary py-0 me-1" @onclick="() => OpenEdit((ProductDto)context)"><i class="ri-edit-line"></i></button>
                            <button class="btn btn-sm btn-outline-danger py-0" @onclick="() => ConfirmDelete((ProductDto)context)"><i class="ri-delete-bin-line"></i></button>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">@(_editId is null ? "New Product" : "Edit Product")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">

                        @* Name + Theme *@
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_form.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Product Theme</label>
                            <select class="form-select" @bind="_form.ThemeClass">
                                <option value="">— None —</option>
                                @foreach (var t in _themeOptions)
                                {
                                    <option value="@t.Value">@t.Label</option>
                                }
                            </select>
                            @if (!string.IsNullOrWhiteSpace(_form.ThemeClass))
                            {
                                <div class="mt-2 p-2 rounded product-theme-preview @_form.ThemeClass">
                                    <small class="fw-semibold">Theme preview — @_form.ThemeClass</small>
                                </div>
                            }
                        </div>

                        @* Product image *@
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Product Image</label>
                            <div class="d-flex align-items-center gap-2">
                                <InputFile OnChange="@(e => UploadImageAsync(e, false))" class="form-control form-control-sm" accept="image/*" />
                                @if (_uploadingImage) { <span class="spinner-border spinner-border-sm text-primary"></span> }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_form.ImageUrl))
                            {
                                <div class="mt-1">
                                    <small class="text-muted text-truncate d-block" style="max-width:260px" title="@_form.ImageUrl">
                                        <i class="ri-image-line me-1"></i>@_form.ImageUrl
                                    </small>
                                </div>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Membership Level</label>
                            <select class="form-select" @bind="_form.MembershipLevelId">
                                <option value="">— None —</option>
                                @foreach (var lvl in _membershipLevels)
                                {
                                    <option value="@lvl.Id">@lvl.Name</option>
                                }
                            </select>
                        </div>

                        @* Description (richtext) *@
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <SfRichTextEditor @bind-Value="_form.Description"
                                             Height="220"
                                             Placeholder="Enter product description…">
                                <RichTextEditorToolbarSettings Items="@_rteToolbar" />
                            </SfRichTextEditor>
                        </div>

                        @* Pricing *@
                        <div class="col-md-4"><label class="form-label fw-semibold">Monthly Fee ($)</label><input type="number" step="0.01" class="form-control" @bind="_form.MonthlyFee" /></div>
                        <div class="col-md-4"><label class="form-label fw-semibold">Setup Fee ($)</label><input type="number" step="0.01" class="form-control" @bind="_form.SetupFee" /></div>
                        <div class="col-md-4"><label class="form-label fw-semibold">Annual Price ($)</label><input type="number" step="0.01" class="form-control" @bind="_form.AnnualPrice" /></div>
                        <div class="col-md-4"><label class="form-label fw-semibold">90-Day Price ($)</label><input type="number" step="0.01" class="form-control" @bind="_form.Price90Days" /></div>
                        <div class="col-md-4"><label class="form-label fw-semibold">180-Day Price ($)</label><input type="number" step="0.01" class="form-control" @bind="_form.Price180Days" /></div>
                        <div class="col-md-4"><label class="form-label fw-semibold">BV Points</label><input type="number" class="form-control" @bind="_form.QualificationPoins" /></div>

                        @* Promo section *@
                        <div class="col-12"><hr class="my-1" /><small class="text-muted fw-semibold text-uppercase">Promotional Offer</small></div>

                        <div class="col-md-4"><label class="form-label fw-semibold">Monthly Promo ($)</label><input type="number" step="0.01" class="form-control" @bind="_form.MonthlyFeePromo" /></div>
                        <div class="col-md-4"><label class="form-label fw-semibold">Setup Promo ($)</label><input type="number" step="0.01" class="form-control" @bind="_form.SetupFeePromo" /></div>
                        <div class="col-md-4"><label class="form-label fw-semibold">Promo BV Pts</label><input type="number" class="form-control" @bind="_form.QualificationPoinsPromo" /></div>

                        @* Promo description (richtext) *@
                        <div class="col-md-7">
                            <label class="form-label fw-semibold">Promo Description</label>
                            <SfRichTextEditor @bind-Value="_form.DescriptionPromo"
                                             Height="200"
                                             Placeholder="Enter promotional description…">
                                <RichTextEditorToolbarSettings Items="@_rteToolbar" />
                            </SfRichTextEditor>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Promo Image</label>
                            <div class="d-flex align-items-center gap-2">
                                <InputFile OnChange="@(e => UploadImageAsync(e, true))" class="form-control form-control-sm" accept="image/*" />
                                @if (_uploadingImagePromo) { <span class="spinner-border spinner-border-sm text-primary"></span> }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_form.ImageUrlPromo))
                            {
                                <div class="mt-1">
                                    <small class="text-muted text-truncate d-block" style="max-width:260px" title="@_form.ImageUrlPromo">
                                        <i class="ri-image-line me-1"></i>@_form.ImageUrlPromo
                                    </small>
                                </div>
                            }
                        </div>

                        <div class="col-12"><hr class="my-1" /></div>
                        <div class="col-md-6"><label class="form-label fw-semibold">Old System ID</label><input type="number" class="form-control" @bind="_form.OldSystemProductId" /></div>
                        @if (_editId is not null)
                        {
                            <div class="col-12">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="productIsActive" @bind="_form.IsActive" />
                                    <label class="form-check-label fw-semibold" for="productIsActive">
                                        @(_form.IsActive ? "Active" : "Inactive")
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveProduct" disabled="@_saving">
                        @if (_saving){<span class="spinner-border spinner-border-sm me-1"></span>}
                        @(_editId is null ? "Create" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header"><h5 class="modal-title fw-bold text-danger">Delete Product</h5><button type="button" class="btn-close" @onclick="() => { _showDeleteConfirm = false; _deleteProduct = null; }"></button></div>
                <div class="modal-body">Delete <strong>@_deleteProduct?.Name</strong>? This cannot be undone.</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { _showDeleteConfirm = false; _deleteProduct = null; }">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteProduct" disabled="@_saving">
                        @if (_saving){<span class="spinner-border spinner-border-sm me-1"></span>}Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductDto> _products = new();
    private bool _loading = true;
    private bool _saving;
    private string? _alertMsg;
    private bool _alertIsError;
    private bool _showForm;
    private bool _showDeleteConfirm;
    private string? _editId;
    private ProductFormModel _form = new();
    private ProductDto? _deleteProduct;
    private List<MembershipLevelItem> _membershipLevels = new();
    private bool _uploadingImage;
    private bool _uploadingImagePromo;

    private static readonly (string Value, string Label)[] _themeOptions =
    {
        ("theme-product-guest",  "Guest Member (Blue-Grey)"),
        ("theme-product-vip",    "VIP (Gold)"),
        ("theme-product-elite",  "Elite (Purple)"),
        ("theme-product-turbo",  "Turbo (Red-Orange)")
    };

    private static readonly List<ToolbarItemModel> _rteToolbar = new()
    {
        new() { Command = ToolbarCommand.Bold },
        new() { Command = ToolbarCommand.Italic },
        new() { Command = ToolbarCommand.Underline },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.Formats },
        new() { Command = ToolbarCommand.Alignments },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.OrderedList },
        new() { Command = ToolbarCommand.UnorderedList },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.CreateLink },
        new() { Command = ToolbarCommand.Image },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.Undo },
        new() { Command = ToolbarCommand.Redo },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.SourceCode }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        await LoadMembershipLevels();
    }

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<Paged<ProductDto>>>("api/v1/admin/products?page=1&pageSize=100");
            if (resp?.Success == true && resp.Data is not null) _products = resp.Data.Items.ToList();
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _loading = false; }
    }

    private async Task LoadMembershipLevels()
    {
        try
        {
            // The membership-levels endpoint returns a flat IEnumerable (not paged) — match that shape exactly
            var resp = await Http.GetFromJsonAsync<ApiResp<IEnumerable<MembershipLevelItem>>>("api/v1/admin/membership-levels");
            if (resp?.Success == true && resp.Data is not null)
                _membershipLevels = resp.Data.ToList();
        }
        catch { /* non-critical — dropdown will be empty */ }
    }

    private async Task UploadImageAsync(InputFileChangeEventArgs e, bool isPromo)
    {
        var file = e.File;
        if (file is null) return;
        if (isPromo) _uploadingImagePromo = true; else _uploadingImage = true;
        StateHasChanged();
        try
        {
            using var content = new MultipartFormDataContent();
            var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", file.Name);
            var response = await Http.PostAsync("api/v1/admin/upload", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResp<UploadResult>>();
                var url = result?.Data?.Url ?? string.Empty;
                if (isPromo) _form.ImageUrlPromo = url; else _form.ImageUrl = url;
            }
            else { _alertMsg = $"Image upload failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Upload error: {ex.Message}"; _alertIsError = true; }
        finally
        {
            if (isPromo) _uploadingImagePromo = false; else _uploadingImage = false;
        }
    }

    private void OpenCreate() { _editId = null; _form = new(); _showForm = true; }
    private void OpenEdit(ProductDto p)
    {
        _editId = p.Id;
        _form = new ProductFormModel
        {
            Name                  = p.Name,
            Description           = p.Description,
            ImageUrl              = p.ImageUrl,
            MonthlyFee            = p.MonthlyFee,
            SetupFee              = p.SetupFee,
            Price90Days           = p.Price90Days,
            Price180Days          = p.Price180Days,
            AnnualPrice           = p.AnnualPrice,
            DescriptionPromo      = p.DescriptionPromo,
            MonthlyFeePromo       = p.MonthlyFeePromo,
            SetupFeePromo         = p.SetupFeePromo,
            ImageUrlPromo         = p.ImageUrlPromo,
            QualificationPoins    = p.QualificationPoins,
            QualificationPoinsPromo = p.QualificationPoinsPromo,
            MembershipLevelId     = p.MembershipLevelId,
            OldSystemProductId    = p.OldSystemProductId,
            ThemeClass            = p.ThemeClass,
            IsActive              = p.IsActive
        };
        _showForm = true;
    }
    private void CloseForm() { _showForm = false; _editId = null; }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) { _alertMsg = "Name is required."; _alertIsError = true; return; }
        _saving = true;
        try
        {
            var response = _editId is null
                ? await Http.PostAsJsonAsync("api/v1/admin/products", _form)
                : await Http.PutAsJsonAsync($"api/v1/admin/products/{_editId}", _form);
            if (response.IsSuccessStatusCode)
            {
                _alertMsg = _editId is null ? "Product created." : "Product updated.";
                _alertIsError = false;
                CloseForm();
                await LoadAsync();
            }
            else { _alertMsg = $"Save failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(ProductDto p) { _deleteProduct = p; _showDeleteConfirm = true; }
    private async Task DeleteProduct()
    {
        if (_deleteProduct is null) return;
        _saving = true;
        try
        {
            var response = await Http.DeleteAsync($"api/v1/admin/products/{_deleteProduct.Id}");
            if (response.IsSuccessStatusCode)
            {
                _alertMsg = "Product deleted."; _alertIsError = false;
                _showDeleteConfirm = false; _deleteProduct = null;
                await LoadAsync();
            }
            else { _alertMsg = $"Delete failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    /// <summary>Strips HTML tags to produce a plain-text preview of up to <paramref name="maxLength"/> characters.</summary>
    private static string TruncateHtml(string html, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(html)) return string.Empty;
        // Strip tags with a simple regex-free approach: keep only text nodes
        var sb = new System.Text.StringBuilder();
        bool inTag = false;
        foreach (var c in html)
        {
            if (c == '<') { inTag = true; continue; }
            if (c == '>') { inTag = false; continue; }
            if (!inTag) sb.Append(c);
            if (sb.Length >= maxLength) break;
        }
        var text = sb.ToString().Trim();
        return text.Length > maxLength ? text[..maxLength] + "…" : text;
    }

    private class ProductFormModel
    {
        public string  Name                   { get; set; } = string.Empty;
        public string  Description            { get; set; } = string.Empty;
        public string  ImageUrl               { get; set; } = string.Empty;
        public decimal MonthlyFee             { get; set; }
        public decimal SetupFee               { get; set; }
        public decimal Price90Days            { get; set; }
        public decimal Price180Days           { get; set; }
        public decimal AnnualPrice            { get; set; }
        public string? DescriptionPromo       { get; set; }
        public decimal MonthlyFeePromo        { get; set; }
        public decimal SetupFeePromo          { get; set; }
        public string? ImageUrlPromo          { get; set; }
        public int     QualificationPoins     { get; set; }
        public int     QualificationPoinsPromo { get; set; }
        public int?    MembershipLevelId      { get; set; }
        public int     OldSystemProductId     { get; set; }
        public string? ThemeClass             { get; set; }
        public bool    IsActive               { get; set; } = true;
    }

    private static string ActiveBadge(bool isActive) => isActive ? "bg-success" : "bg-secondary";

    private record MembershipLevelItem(int Id, string Name);
    private record UploadResult(string Url);
    private record ProductDto(string Id, string Name, string Description, string ImageUrl,
        decimal MonthlyFee, decimal SetupFee, decimal Price90Days, decimal Price180Days,
        decimal AnnualPrice, string? DescriptionPromo, decimal MonthlyFeePromo, decimal SetupFeePromo,
        string? ImageUrlPromo, int QualificationPoins, int QualificationPoinsPromo,
        bool IsActive, int? MembershipLevelId, int OldSystemProductId, string? ThemeClass);
    private record ApiResp<T>(bool Success, T? Data, IEnumerable<string>? Errors);
    private record Paged<T>(IEnumerable<T> Items, int TotalCount, int Page, int PageSize, int TotalPages);
}
