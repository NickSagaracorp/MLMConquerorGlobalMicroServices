@page "/admin/config/ranks"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager Nav
@using Syncfusion.Blazor.RichTextEditor

<PageTitle>Rank Definitions — Admin</PageTitle>

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Admin Dashboard", "/admin"), new("Rank Definitions") })" />

@if (_alertMsg is not null)
{
    <div class="alert @(_alertIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
        @_alertMsg <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header py-3 d-flex align-items-center gap-2">
        <h6 class="card-title mb-0 fw-semibold flex-grow-1">
            <i class="ri-medal-line me-2 text-primary"></i>Rank Definitions
        </h6>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreate">
            <i class="ri-add-line me-1"></i>New Rank
        </button>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else
        {
            <SfGrid TValue="RankDto" DataSource="@_items"
                    AllowPaging="true" AllowFiltering="true" AllowSorting="true" AllowResizing="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="50" PageSizes="@(new int[]{50,100,250,500,1000})" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>
                    <GridColumn Field="@nameof(RankDto.Id)" HeaderText="ID" Width="70" TextAlign="TextAlign.Center" />
                    <GridColumn Field="@nameof(RankDto.Name)" HeaderText="Name" Width="160" />
                    <GridColumn HeaderText="Description" Width="220">
                        <Template><span class="text-muted small">@(((RankDto)context).Description ?? "—")</span></Template>
                    </GridColumn>
                    <GridColumn HeaderText="Order" Width="90" TextAlign="TextAlign.Center">
                        <Template><span class="badge bg-primary">@(((RankDto)context).SortOrder)</span></Template>
                    </GridColumn>
                    <GridColumn HeaderText="Status" Width="100">
                        <Template>
                            <span class="badge @RankStatusBadge(((RankDto)context).Status)">@(((RankDto)context).Status)</span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Actions" Width="210" TextAlign="TextAlign.Center">
                        <Template>
                            <button class="btn btn-sm btn-outline-secondary py-0 me-1" @onclick='() => Nav.NavigateTo($"/admin/config/ranks/{((RankDto)context).Id}/requirements")'><i class="ri-list-check me-1"></i>Req.</button>
                            <button class="btn btn-sm btn-outline-primary py-0 me-1" @onclick="() => OpenEdit((RankDto)context)"><i class="ri-edit-line"></i></button>
                            <button class="btn btn-sm btn-outline-danger py-0" @onclick="() => ConfirmDelete((RankDto)context)"><i class="ri-delete-bin-line"></i></button>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    </div>
</div>


@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header"><h5 class="modal-title fw-bold">@(_editId is null ? "New Rank" : "Edit Rank")</h5><button type="button" class="btn-close" @onclick="CloseForm"></button></div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label fw-semibold">Name <span class="text-danger">*</span></label><input class="form-control" @bind="_form.Name"/></div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <SfRichTextEditor @bind-Value="_form.Description" Height="220">
                            <RichTextEditorToolbarSettings Items="@_rteToolbar" />
                        </SfRichTextEditor>
                    </div>
                    <div class="mb-3"><label class="form-label fw-semibold">Sort Order</label><input type="number" class="form-control" @bind="_form.SortOrder"/></div>
                    <div class="mb-3"><label class="form-label fw-semibold">Certificate Template URL</label><input class="form-control" @bind="_form.CertificateTemplateUrl" placeholder="https://..."/></div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving){<span class="spinner-border spinner-border-sm me-1"></span>}
                        @(_editId is null ? "Create" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header"><h5 class="modal-title fw-bold text-danger">Deactivate Rank</h5><button type="button" class="btn-close" @onclick="() => { _showDeleteConfirm = false; _deleteItem = null; }"></button></div>
                <div class="modal-body">Deactivate rank <strong>@_deleteItem?.Name</strong>?</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { _showDeleteConfirm = false; _deleteItem = null; }">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteItem" disabled="@_saving">
                        @if (_saving){<span class="spinner-border spinner-border-sm me-1"></span>}Deactivate
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<RankDto> _items = new();
    private bool _loading = true;
    private bool _saving;
    private string? _alertMsg;
    private bool _alertIsError;
    private bool _showForm;
    private bool _showDeleteConfirm;
    private int? _editId;
    private string _editStatus = "Active"; // preserved from the loaded entity during edit
    private RankFormModel _form = new();
    private RankDto? _deleteItem;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<IEnumerable<RankDto>>>("api/v1/admin/rank-definitions");
            if (resp?.Success == true && resp.Data is not null) _items = resp.Data.ToList();
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _loading = false; }
    }

    private void OpenCreate() { _editId = null; _editStatus = "Active"; _form = new(); _showForm = true; }
    private void OpenEdit(RankDto r) { _editId = r.Id; _editStatus = r.Status; _form = new RankFormModel { Name = r.Name, Description = r.Description, SortOrder = r.SortOrder, CertificateTemplateUrl = r.CertificateTemplateUrl }; _showForm = true; }
    private void CloseForm() { _showForm = false; _editId = null; }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) { _alertMsg = "Name is required."; _alertIsError = true; return; }
        _saving = true;
        try
        {
            HttpResponseMessage response;
            if (_editId is null)
            {
                // POST: CreateRankDefinitionDto — no Status field
                response = await Http.PostAsJsonAsync("api/v1/admin/rank-definitions", new
                {
                    _form.Name,
                    _form.Description,
                    _form.SortOrder,
                    _form.CertificateTemplateUrl
                });
            }
            else
            {
                // PUT: UpdateRankDefinitionDto — must include Status to prevent mapper zeroing it out
                response = await Http.PutAsJsonAsync($"api/v1/admin/rank-definitions/{_editId}", new
                {
                    _form.Name,
                    _form.Description,
                    _form.SortOrder,
                    _form.CertificateTemplateUrl,
                    Status = _editStatus
                });
            }
            if (response.IsSuccessStatusCode) { _alertMsg = _editId is null ? "Rank created." : "Rank updated."; _alertIsError = false; CloseForm(); await LoadAsync(); }
            else { _alertMsg = $"Save failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(RankDto r) { _deleteItem = r; _showDeleteConfirm = true; }
    private async Task DeleteItem()
    {
        if (_deleteItem is null) return;
        _saving = true;
        try
        {
            var response = await Http.DeleteAsync($"api/v1/admin/rank-definitions/{_deleteItem.Id}");
            if (response.IsSuccessStatusCode) { _alertMsg = "Rank deactivated."; _alertIsError = false; _showDeleteConfirm = false; _deleteItem = null; await LoadAsync(); }
            else { _alertMsg = $"Failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private static readonly List<ToolbarItemModel> _rteToolbar =
    [
        new() { Command = ToolbarCommand.Bold },
        new() { Command = ToolbarCommand.Italic },
        new() { Command = ToolbarCommand.Underline },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.OrderedList },
        new() { Command = ToolbarCommand.UnorderedList },
        new() { Command = ToolbarCommand.Separator },
        new() { Command = ToolbarCommand.CreateLink },
        new() { Command = ToolbarCommand.ClearFormat },
    ];

    private class RankFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int SortOrder { get; set; }
        public string? CertificateTemplateUrl { get; set; }
    }

    private static string RankStatusBadge(string s) => s == "Active" ? "bg-success" : "bg-secondary";

    private record RankDto(int Id, string Name, string? Description, int SortOrder, string Status, string? CertificateTemplateUrl);
    private record ApiResp<T>(bool Success, T? Data, IEnumerable<string>? Errors);
}
