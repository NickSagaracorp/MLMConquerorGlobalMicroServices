@page "/admin/document-types"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http

<PageTitle>Document Types — Admin</PageTitle>

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Admin Dashboard", "/admin"), new("Document Types") })" />

@if (_alertMsg is not null)
{
    <div class="alert @(_alertIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
        @_alertMsg <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header py-3 d-flex align-items-center gap-2">
        <h6 class="card-title mb-0 fw-semibold flex-grow-1">
            <i class="ri-folder-3-line me-2 text-primary"></i>Document Types
        </h6>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreate">
            <i class="ri-add-line me-1"></i>New Document Type
        </button>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else
        {
            <SfGrid TValue="DocumentTypeDto" DataSource="@_items"
                    AllowPaging="true" AllowFiltering="true" AllowSorting="true" AllowResizing="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="50" PageSizes="@(new int[] { 50, 100, 250 })" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>
                    <GridColumn Field="@nameof(DocumentTypeDto.Id)" HeaderText="ID" Width="70" TextAlign="TextAlign.Center" />
                    <GridColumn HeaderText="Name" Width="220">
                        <Template>
                            <span class="fw-semibold">@(((DocumentTypeDto)context).Name)</span>
                            @if (!string.IsNullOrWhiteSpace(((DocumentTypeDto)context).Description))
                            {
                                <text><br /><small class="text-muted">@(((DocumentTypeDto)context).Description)</small></text>
                            }
                        </Template>
                    </GridColumn>
                    <GridColumn Field="@nameof(DocumentTypeDto.SortOrder)" HeaderText="Order" Width="90" TextAlign="TextAlign.Center" />
                    <GridColumn HeaderText="Status" Width="110" TextAlign="TextAlign.Center">
                        <Template>
                            <span class="badge @BoolBadge(((DocumentTypeDto)context).IsActive)">
                                @(((DocumentTypeDto)context).IsActive ? "Active" : "Inactive")
                            </span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Actions" Width="110" TextAlign="TextAlign.Center">
                        <Template>
                            <button class="btn btn-sm btn-outline-primary py-0 me-1"
                                    @onclick="() => OpenEdit((DocumentTypeDto)context)">
                                <i class="ri-edit-line"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger py-0"
                                    @onclick="() => ConfirmDelete((DocumentTypeDto)context)">
                                <i class="ri-delete-bin-line"></i>
                            </button>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

@* ── Create / Edit modal ── *@
@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">@(_editId is null ? "New Document Type" : "Edit Document Type")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_form.Name" placeholder="e.g. Brochures" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" rows="3" @bind="_form.Description"
                                      placeholder="Optional description visible to members"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Sort Order</label>
                            <input type="number" class="form-control" @bind="_form.SortOrder" />
                        </div>
                        @if (_editId is not null)
                        {
                            <div class="col-md-6 d-flex align-items-end pb-1">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="dtActive" @bind="_form.IsActive" />
                                    <label class="form-check-label fw-semibold" for="dtActive">Active</label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editId is null ? "Create" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete confirmation modal ── *@
@if (_showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold text-danger">Delete Document Type</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    @if (_deleteBlockedMsg is not null)
                    {
                        <div class="alert alert-warning mb-2">
                            <i class="ri-error-warning-line me-1"></i>@_deleteBlockedMsg
                        </div>
                    }
                    else
                    {
                        <p>Delete document type <strong>@_deleteItem?.Name</strong>? This action cannot be undone.</p>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    @if (_deleteBlockedMsg is null)
                    {
                        <button class="btn btn-danger" @onclick="DeleteItem" disabled="@_saving">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Delete
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<DocumentTypeDto> _items = new();
    private bool _loading = true;
    private bool _saving;
    private string? _alertMsg;
    private bool _alertIsError;

    private bool _showForm;
    private int? _editId;
    private DocumentTypeFormModel _form = new();

    private bool _showDeleteConfirm;
    private DocumentTypeDto? _deleteItem;
    private string? _deleteBlockedMsg;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<List<DocumentTypeDto>>>("api/v1/admin/document-types");
            if (resp?.Success == true && resp.Data is not null)
                _items = resp.Data;
        }
        catch (Exception ex) { _alertMsg = $"Error loading document types: {ex.Message}"; _alertIsError = true; }
        finally { _loading = false; }
    }

    private void OpenCreate()
    {
        _editId = null;
        _form = new();
        _showForm = true;
    }

    private void OpenEdit(DocumentTypeDto dt)
    {
        _editId = dt.Id;
        _form = new DocumentTypeFormModel
        {
            Name = dt.Name,
            Description = dt.Description,
            SortOrder = dt.SortOrder,
            IsActive = dt.IsActive
        };
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; _editId = null; }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _alertMsg = "Name is required."; _alertIsError = true; return;
        }
        _saving = true;
        try
        {
            HttpResponseMessage response;
            if (_editId is null)
            {
                response = await Http.PostAsJsonAsync("api/v1/admin/document-types", new
                {
                    _form.Name,
                    _form.Description,
                    _form.SortOrder
                });
            }
            else
            {
                response = await Http.PutAsJsonAsync($"api/v1/admin/document-types/{_editId}", new
                {
                    _form.Name,
                    _form.Description,
                    _form.SortOrder,
                    _form.IsActive
                });
            }

            if (response.IsSuccessStatusCode)
            {
                _alertMsg = _editId is null ? "Document type created." : "Document type updated.";
                _alertIsError = false;
                CloseForm();
                await LoadAsync();
            }
            else
            {
                _alertMsg = $"Save failed ({(int)response.StatusCode}).";
                _alertIsError = true;
            }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(DocumentTypeDto dt)
    {
        _deleteItem = dt;
        _deleteBlockedMsg = null;
        _showDeleteConfirm = true;
    }

    private void CancelDelete() { _showDeleteConfirm = false; _deleteItem = null; _deleteBlockedMsg = null; }

    private async Task DeleteItem()
    {
        if (_deleteItem is null) return;
        _saving = true;
        _deleteBlockedMsg = null;
        try
        {
            var response = await Http.DeleteAsync($"api/v1/admin/document-types/{_deleteItem.Id}");
            if (response.IsSuccessStatusCode)
            {
                _alertMsg = $"'{_deleteItem.Name}' deleted.";
                _alertIsError = false;
                _showDeleteConfirm = false;
                _deleteItem = null;
                await LoadAsync();
            }
            else if ((int)response.StatusCode == 400)
            {
                // API returns 400 with HAS_DOCUMENTS error code when type has associated documents
                var body = await response.Content.ReadFromJsonAsync<ApiResp<object>>();
                var code = body?.ErrorCode;
                _deleteBlockedMsg = code == "HAS_DOCUMENTS"
                    ? "This document type has associated marketing documents and cannot be deleted. Deactivate it instead, or reassign its documents first."
                    : $"Cannot delete this document type ({(int)response.StatusCode}).";
            }
            else
            {
                _alertMsg = $"Delete failed ({(int)response.StatusCode}).";
                _alertIsError = true;
                _showDeleteConfirm = false;
            }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private static string BoolBadge(bool val) => val ? "bg-success" : "bg-secondary";

    // ── Local models ──────────────────────────────────────────────
    private class DocumentTypeFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int SortOrder { get; set; }
        public bool IsActive { get; set; } = true;
    }

    private record DocumentTypeDto(int Id, string Name, string? Description, int SortOrder, bool IsActive);
    private record ApiResp<T>(bool Success, T? Data, string? ErrorCode, IEnumerable<string>? Errors);
}
