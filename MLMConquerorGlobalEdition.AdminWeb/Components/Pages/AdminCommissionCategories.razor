@page "/admin/config/commission-categories"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http

<PageTitle>Commission Categories — Admin</PageTitle>

<BreadcrumbNav Items="@(new List<BreadcrumbNav.BreadcrumbItem> { new("Admin Dashboard", "/admin"), new("Commission Categories") })" />

@if (_alertMsg is not null)
{
    <div class="alert @(_alertIsError ? "alert-danger" : "alert-success") alert-dismissible mb-3">
        @_alertMsg <button type="button" class="btn-close" @onclick="() => _alertMsg = null"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header py-3 d-flex align-items-center gap-2">
        <h6 class="card-title mb-0 fw-semibold flex-grow-1">
            <i class="ri-folder-line me-2 text-primary"></i>Commission Categories
        </h6>
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync"><i class="ri-refresh-line"></i></button>
        <button class="btn btn-primary btn-sm" @onclick="OpenCreate">
            <i class="ri-add-line me-1"></i>New Category
        </button>
    </div>
    <div class="card-body p-0">
        @if (_loading)
        {
            <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
        }
        else
        {
            <SfGrid TValue="CommissionCategoryDto" DataSource="@_items"
                    AllowPaging="true" AllowFiltering="true" AllowSorting="true" AllowResizing="true" GridLines="GridLine.Horizontal">
                <GridPageSettings PageSize="50" PageSizes="@(new int[]{50,100,250,500,1000})" />
                <GridFilterSettings Type="Syncfusion.Blazor.Grids.FilterType.Excel" />
                <GridColumns>
                    <GridColumn Field="@nameof(CommissionCategoryDto.Id)" HeaderText="ID" Width="70" TextAlign="TextAlign.Center" />
                    <GridColumn HeaderText="Name" Width="220">
                        <Template>
                            <span class="fw-semibold">@(((CommissionCategoryDto)context).Name)</span>
                            @if (!string.IsNullOrWhiteSpace(((CommissionCategoryDto)context).Description))
                            {<text><br/><small class="text-muted">@(((CommissionCategoryDto)context).Description)</small></text>}
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Status" Width="110">
                        <Template>
                            <span class="badge @BoolBadge(((CommissionCategoryDto)context).IsActive)">
                                @(((CommissionCategoryDto)context).IsActive ? "Active" : "Inactive")
                            </span>
                        </Template>
                    </GridColumn>
                    <GridColumn HeaderText="Created" Width="130">
                        <Template><span class="small text-muted">@(((CommissionCategoryDto)context).CreationDate.ToString("yyyy-MM-dd"))</span></Template>
                    </GridColumn>
                    <GridColumn HeaderText="Actions" Width="100" TextAlign="TextAlign.Center">
                        <Template>
                            <button class="btn btn-sm btn-outline-primary py-0 me-1" @onclick="() => OpenEdit((CommissionCategoryDto)context)"><i class="ri-edit-line"></i></button>
                            <button class="btn btn-sm btn-outline-danger py-0" @onclick="() => ConfirmDelete((CommissionCategoryDto)context)"><i class="ri-delete-bin-line"></i></button>
                        </Template>
                    </GridColumn>
                </GridColumns>
            </SfGrid>
        }
    </div>
</div>

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">@(_editId is null ? "New Category" : "Edit Category")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_form.Name" placeholder="Category name" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" rows="3" @bind="_form.Description"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="catIsActive" @bind="_form.IsActive" />
                                <label class="form-check-label" for="catIsActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editId is null ? "Create" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content border-0 rounded-3 shadow">
                <div class="modal-header"><h5 class="modal-title fw-bold text-danger">Delete Category</h5><button type="button" class="btn-close" @onclick="() => { _showDeleteConfirm = false; _deleteItem = null; }"></button></div>
                <div class="modal-body">Delete category <strong>@_deleteItem?.Name</strong>? This cannot be undone.</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => { _showDeleteConfirm = false; _deleteItem = null; }">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteItem" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<CommissionCategoryDto> _items = new();
    private bool _loading = true;
    private bool _saving;
    private string? _alertMsg;
    private bool _alertIsError;
    private bool _showForm;
    private bool _showDeleteConfirm;
    private int? _editId;
    private CategoryFormModel _form = new();
    private CommissionCategoryDto? _deleteItem;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResp<IEnumerable<CommissionCategoryDto>>>("api/v1/admin/commission-categories");
            if (resp?.Success == true && resp.Data is not null)
                _items = resp.Data.ToList();
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _loading = false; }
    }

    private void OpenCreate() { _editId = null; _form = new() { IsActive = true }; _showForm = true; }

    private void OpenEdit(CommissionCategoryDto c)
    {
        _editId = c.Id;
        _form = new CategoryFormModel { Name = c.Name, Description = c.Description, IsActive = c.IsActive };
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; _editId = null; }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_form.Name)) { _alertMsg = "Name is required."; _alertIsError = true; return; }
        _saving = true;
        try
        {
            var response = _editId is null
                ? await Http.PostAsJsonAsync("api/v1/admin/commission-categories", _form)
                : await Http.PutAsJsonAsync($"api/v1/admin/commission-categories/{_editId}", _form);
            if (response.IsSuccessStatusCode) { _alertMsg = _editId is null ? "Created." : "Updated."; _alertIsError = false; CloseForm(); await LoadAsync(); }
            else { _alertMsg = $"Save failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private void ConfirmDelete(CommissionCategoryDto c) { _deleteItem = c; _showDeleteConfirm = true; }

    private async Task DeleteItem()
    {
        if (_deleteItem is null) return;
        _saving = true;
        try
        {
            var response = await Http.DeleteAsync($"api/v1/admin/commission-categories/{_deleteItem.Id}");
            if (response.IsSuccessStatusCode) { _alertMsg = "Deleted."; _alertIsError = false; _showDeleteConfirm = false; _deleteItem = null; await LoadAsync(); }
            else { _alertMsg = $"Failed ({response.StatusCode})."; _alertIsError = true; }
        }
        catch (Exception ex) { _alertMsg = $"Error: {ex.Message}"; _alertIsError = true; }
        finally { _saving = false; }
    }

    private static string BoolBadge(bool val) => val ? "bg-success" : "bg-secondary";

    private record CommissionCategoryDto(int Id, string Name, string? Description, bool IsActive, DateTime CreationDate);

    private class CategoryFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
    }

    private record ApiResp<T>(bool Success, T? Data, IEnumerable<string>? Errors);
}
