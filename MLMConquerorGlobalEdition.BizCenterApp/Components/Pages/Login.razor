@page "/login"
@layout MLMConquerorGlobalEdition.SharedComponents.Components.Layout.BlankLayout
@inject JwtAuthStateProvider AuthProvider
@inject BizCenterApiClient Api
@inject NavigationManager Navigation
@inject ViewContextInitializer ViewContextInitializer

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-logo">
            <h2>MLM Conqueror</h2>
            <p class="text-muted">Ambassador &amp; Member Portal</p>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="_model.Email" type="email" placeholder="your@email.com" />
                <ValidationMessage For="() => _model.Email" />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <InputText class="form-control" @bind-Value="_model.Password" type="password" placeholder="••••••••" />
                <ValidationMessage For="() => _model.Password" />
            </div>
            <button type="submit" class="btn btn-primary w-100" disabled="@_busy">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                Sign In
            </button>
        </EditForm>

        <div class="mt-3 text-center">
            <a href="/forgot-password">Forgot your password?</a>
        </div>
        <div class="mt-2 text-center">
            <span class="text-muted small">Don't have an account?</span>
            <a href="/signup" class="ms-1 small">Sign up</a>
        </div>
    </div>
</div>

<style>
    .login-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background: #f0f2f5;
    }
    .login-card {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,.08);
        width: 100%;
        max-width: 420px;
    }
    .login-logo { text-align: center; margin-bottom: 1.5rem; }
</style>

@code {
    private LoginModel _model = new();
    private bool _busy;
    private string _error = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Already logged in? Skip login page
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
            Navigation.NavigateTo("/");
    }

    private async Task HandleLogin()
    {
        _busy  = true;
        _error = string.Empty;
        try
        {
            var response = await Api.PostAsync<AuthResponse>(
                "api/v1/auth/login",
                new { _model.Email, _model.Password });

            if (response?.Success == true && response.Data != null)
            {
                await AuthProvider.NotifyLoginAsync(response.Data.AccessToken, response.Data.RefreshToken);
                await ViewContextInitializer.InitializeAsync();
                Navigation.NavigateTo("/");
            }
            else
            {
                _error = response?.Message ?? response?.Errors?.FirstOrDefault() ?? "Login failed. Please check your credentials.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Unable to connect to the server: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = string.Empty;
    }

    private record AuthResponse(string AccessToken, string RefreshToken, DateTime TokenExpiry);
}
