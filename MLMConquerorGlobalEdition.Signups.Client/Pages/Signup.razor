@* ── Country Picker Modal ─────────────────────────────────────────────────── *@
@if (_showCountryModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.6); z-index:2000;">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <div class="w-100 text-center">
                        <h5 class="modal-title fw-bold mb-1">
                            <i class="ri-earth-line me-2 text-primary"></i>Select Your Country
                        </h5>
                        <p class="text-muted small mb-0">Choose the country where you will be enrolling.</p>
                    </div>
                    @if (!string.IsNullOrEmpty(_country))
                    {
                        <button type="button" class="btn-close position-absolute top-0 end-0 mt-3 me-3"
                                @onclick="() => _showCountryModal = false"></button>
                    }
                </div>
                <div class="modal-body pt-3">
                    <div class="mb-3">
                        <input class="form-control" placeholder="🔍 Search country…"
                               @bind="_countrySearch" @bind:event="oninput" />
                    </div>
                    @{
                        var filtered = _countryData
                            .Where(c => string.IsNullOrEmpty(_countrySearch) ||
                                        c.NameEn.Contains(_countrySearch, StringComparison.OrdinalIgnoreCase))
                            .ToList();
                    }
                    @if (!filtered.Any())
                    {
                        <p class="text-center text-muted py-4">No countries found matching "@_countrySearch".</p>
                    }
                    else
                    {
                        <div class="country-grid">
                            @foreach (var ct in filtered)
                            {
                                <button type="button"
                                        class="country-item @(_country == ct.NameEn ? "is-selected" : "")"
                                        @onclick="() => OnCountryModalSelect(ct)">
                                    <img class="country-flag"
                                         src="https://flagcdn.com/w40/@(ct.Iso2.ToLower()).png"
                                         alt="@ct.NameEn"
                                         onerror="this.style.display='none'" />
                                    <span class="country-item-name">@ct.NameEn</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

