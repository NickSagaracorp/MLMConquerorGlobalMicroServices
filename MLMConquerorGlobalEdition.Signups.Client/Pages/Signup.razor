@page "/ambassador-join"
@page "/ambassador-join/{SponsorSlug}"
@rendermode InteractiveAuto
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="theme-ambassador">

<!-- ── HEADER ─────────────────────────────────────────────────────────────── -->
<header class="enroll-header py-2 px-3">
    <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2">
        <span class="brand-name">MLM Conqueror</span>
        <div class="d-flex align-items-center gap-2">
            @if (!string.IsNullOrEmpty(_country))
            {
                <button type="button" class="btn btn-sm btn-outline-light d-flex align-items-center gap-1"
                        @onclick="() => { _showCountryModal = true; _countrySearch = string.Empty; }"
                        style="font-size:0.8rem;">
                    <span>@(_countryData.FirstOrDefault(x => x.NameEn == _country)?.FlagEmoji ?? "🌐")</span>
                    <span>@_country</span>
                    <i class="ri-arrow-down-s-line"></i>
                </button>
            }
            <div class="d-flex align-items-center gap-1 secure-badge">
                <span>Secure Enrollment</span>
                <i class="ri-lock-2-line fs-5"></i>
            </div>
        </div>
    </div>
</header>

<!-- ── SPONSOR CARD ────────────────────────────────────────────────────────── -->
@if (_sponsor is not null || !string.IsNullOrEmpty(SponsorSlug))
{
    <div class="sponsor-card px-3">
        <div class="sponsor-avatar">
            @if (!string.IsNullOrEmpty(_sponsor?.PhotoUrl))
            {
                <img src="@_sponsor.PhotoUrl" alt="@_sponsor.DisplayName" />
            }
            else
            {
                @SponsorInitials
            }
        </div>
        <div class="sponsor-info">
            <p class="sponsor-label">Your Sponsor</p>
            <p class="sponsor-name">@(_sponsor?.DisplayName ?? SponsorSlug)</p>
            @if (!string.IsNullOrEmpty(_sponsor?.ReplicateSiteSlug))
            {
                <p class="sponsor-slug">mlmconqueror.com/@_sponsor.ReplicateSiteSlug</p>
            }
        </div>
        <span class="sponsor-badge"><i class="ri-shield-check-line"></i> Verified</span>
    </div>
}

<!-- ── MAIN LAYOUT ─────────────────────────────────────────────────────────── -->
<div class="signup-layout">

    <!-- LEFT: form sections -->
    <div class="signup-form-col">

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger mb-4">@_error</div>
        }

        @if (_success)
        {
            <div class="section-card">
                <div class="section-body text-center py-5">
                    <i class="ri-checkbox-circle-fill success-check"></i>
                    <h3 class="mt-3 mb-2">Welcome, @_completedEmail!</h3>
                    <p class="text-muted mb-4">Your account is active. Access your BizCenter to get started.</p>
                    <a href="/login" class="btn btn-enroll px-5">Go to BizCenter</a>
                </div>
            </div>
        }
        else
        {
        @if (_productsLoading)
        {
            <div class="section-card">
                <div class="section-body text-center py-5">
                    <div class="spinner-border text-primary mb-3"></div>
                    <p class="text-muted">Loading available plans for @_country…</p>
                </div>
            </div>
        }
        else if (_productsLoaded)
        {

        <!-- ── ENROLLMENT ─────────────────────────────────────────────────── -->
        @if (_enrollmentProduct is not null)
        {
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-award-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Enrollment</h5>
                    <small class="text-muted">You are enrolling as a Lifestyle Ambassador.</small>
                </div>
            </div>
            <div class="section-body">
                <label class="plan-card is-checked">
                    <input type="checkbox" class="plan-card__radio" checked disabled />
                    <div class="plan-card__body @(_enrollmentProduct.ThemeClass)">
                        <div class="plan-card__header">
                            <div class="flex-1">
                                <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                    <p class="plan-card__title mb-0">@_enrollmentProduct.Name</p>
                                    <span class="plan-selected-chip"><i class="ri-check-fill"></i> Included</span>
                                </div>
                                <p class="plan-card__subtitle">One-time enrollment fee</p>
                            </div>
                            @if (!string.IsNullOrEmpty(_enrollmentProduct.ImageUrl))
                            {
                                <img src="@_enrollmentProduct.ImageUrl" alt="@_enrollmentProduct.Name"
                                     class="plan-card__img" onerror="this.style.display='none'" />
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_enrollmentProduct.Description))
                        {
                            <div class="plan-card__desc">@((MarkupString)_enrollmentProduct.Description)</div>
                        }
                        <span class="price-chip">@_enrollmentProduct.Price.ToString("C")</span>
                    </div>
                </label>
            </div>
        </div>
        }

        <!-- ── SELECT MEMBERSHIP ──────────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-vip-crown-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Select your membership</h5>
                    <small class="text-muted">Choose the plan that unlocks your full benefits.</small>
                </div>
            </div>
            <div class="section-body">
                @if (_membershipProducts.Count == 0)
                {
                    <p class="text-muted small py-2">Loading options…</p>
                }
                @foreach (var p in _membershipProducts)
                {
                    <label class="plan-card @(_selectedMembershipProductId == p.Id ? "is-checked" : "")"
                           @onclick="() => SelectMembership(p.Id)">
                        <input type="radio" class="plan-card__radio" name="membership"
                               checked="@(_selectedMembershipProductId == p.Id)"
                               @onchange="() => SelectMembership(p.Id)" />
                        <div class="plan-card__body @(p.ThemeClass)">
                            <div class="plan-card__header">
                                <div class="flex-1">
                                    <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                        <p class="plan-card__title mb-0">@p.Name</p>
                                        <span class="plan-selected-chip"><i class="ri-check-fill"></i> Selected</span>
                                    </div>
                                    <p class="plan-card__subtitle">@p.Price.ToString("C") / month</p>
                                </div>
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.Name"
                                         class="plan-card__img" onerror="this.style.display='none'" />
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div class="plan-card__desc">@((MarkupString)p.Description)</div>
                            }
                            <span class="price-chip">@p.Price.ToString("C")</span>
                        </div>
                    </label>
                }
                <!-- No-membership option -->
                <div class="text-center mt-3">
                    <button type="button" class="btn btn-link btn-sm text-muted"
                            @onclick="() => _showNoMemberModal = true">
                        Continue without a membership plan
                    </button>
                </div>
            </div>
        </div>

        <!-- ── PERSONAL / BUSINESS INFO ───────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-user-3-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Personal / Business Info</h5>
                    <small class="text-muted">Your details stay private and secure.</small>
                </div>
            </div>
            <div class="section-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="First Name"
                                   value="@_firstName" @oninput="e => _firstName = e.Value?.ToString() ?? string.Empty" />
                            <label>First Name *</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="Last Name"
                                   value="@_lastName" @oninput="e => _lastName = e.Value?.ToString() ?? string.Empty" />
                            <label>Last Name *</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="date" class="form-control" @bind="_dateOfBirth" max="@_maxDob" />
                            <label>Date of Birth *</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="SSN (optional)" @bind="_ssn" />
                            <label>SSN</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div>
                        <p class="mb-0 fw-semibold">Enrolling as a business?</p>
                        <small class="text-muted">Toggle to add company details.</small>
                    </div>
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input" type="checkbox" @bind="_showBusiness" />
                        <label class="form-check-label">Yes</label>
                    </div>
                </div>

                @if (_showBusiness)
                {
                    <div class="row g-3 mt-2">
                        <div class="col-md-8">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Business Name" @bind="_businessName" />
                                <label>Business Name</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="EIN" @bind="_ein" />
                                <label>EIN</label>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ── CONTACT INFO ───────────────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-contacts-book-2-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Contact Info</h5>
                    <small class="text-muted">Use a valid email and phone number.</small>
                </div>
            </div>
            <div class="section-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">WhatsApp</label>
                        <div class="input-group country-line">
                            <div class="phone-picker">
                                @{ var waCt = _countryData.FirstOrDefault(x => x.PhoneCode == _waCountryCode); }
                                <button type="button" class="phone-picker-btn"
                                        @onclick="() => { _showWaPicker = !_showWaPicker; _waPickerSearch = string.Empty; _showCellPicker = false; }">
                                    <img class="phone-picker-flag"
                                         src="https://flagcdn.com/w40/@((waCt?.Iso2 ?? "us").ToLower()).png"
                                         alt="@(waCt?.Iso2 ?? "")"
                                         onerror="this.style.display='none'" />
                                    <span>@_waCountryCode</span>
                                    <i class="ri-arrow-down-s-line"></i>
                                </button>
                                @if (_showWaPicker)
                                {
                                    <div class="phone-picker-dropdown">
                                        <input class="phone-picker-search" placeholder="🔍 Search…"
                                               @bind="_waPickerSearch" @bind:event="oninput" />
                                        <div class="phone-picker-list">
                                            @foreach (var c in _countryData.Where(x => x.PhoneCode != null &&
                                                (string.IsNullOrEmpty(_waPickerSearch) ||
                                                 x.NameEn.Contains(_waPickerSearch, StringComparison.OrdinalIgnoreCase) ||
                                                 x.PhoneCode!.Contains(_waPickerSearch))))
                                            {
                                                <button type="button"
                                                        class="phone-picker-option @(_waCountryCode == c.PhoneCode ? "is-selected" : "")"
                                                        @onclick="() => { _waCountryCode = c.PhoneCode!; _showWaPicker = false; }">
                                                    <img class="phone-picker-option-flag"
                                                         src="https://flagcdn.com/w40/@(c.Iso2.ToLower()).png"
                                                         alt="@c.Iso2"
                                                         onerror="this.style.display='none'" />
                                                    <span>@c.NameEn</span>
                                                    <span class="phone-picker-code">@c.PhoneCode</span>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            <input type="tel" class="form-control" placeholder="9XXXXXXXX" @bind="_whatsApp" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Cell Phone</label>
                        <div class="input-group country-line">
                            <div class="phone-picker">
                                @{ var cellCt = _countryData.FirstOrDefault(x => x.PhoneCode == _cellCountryCode); }
                                <button type="button" class="phone-picker-btn"
                                        @onclick="() => { _showCellPicker = !_showCellPicker; _cellPickerSearch = string.Empty; _showWaPicker = false; }">
                                    <img class="phone-picker-flag"
                                         src="https://flagcdn.com/w40/@((cellCt?.Iso2 ?? "us").ToLower()).png"
                                         alt="@(cellCt?.Iso2 ?? "")"
                                         onerror="this.style.display='none'" />
                                    <span>@_cellCountryCode</span>
                                    <i class="ri-arrow-down-s-line"></i>
                                </button>
                                @if (_showCellPicker)
                                {
                                    <div class="phone-picker-dropdown">
                                        <input class="phone-picker-search" placeholder="🔍 Search…"
                                               @bind="_cellPickerSearch" @bind:event="oninput" />
                                        <div class="phone-picker-list">
                                            @foreach (var c in _countryData.Where(x => x.PhoneCode != null &&
                                                (string.IsNullOrEmpty(_cellPickerSearch) ||
                                                 x.NameEn.Contains(_cellPickerSearch, StringComparison.OrdinalIgnoreCase) ||
                                                 x.PhoneCode!.Contains(_cellPickerSearch))))
                                            {
                                                <button type="button"
                                                        class="phone-picker-option @(_cellCountryCode == c.PhoneCode ? "is-selected" : "")"
                                                        @onclick="() => { _cellCountryCode = c.PhoneCode!; _showCellPicker = false; }">
                                                    <img class="phone-picker-option-flag"
                                                         src="https://flagcdn.com/w40/@(c.Iso2.ToLower()).png"
                                                         alt="@c.Iso2"
                                                         onerror="this.style.display='none'" />
                                                    <span>@c.NameEn</span>
                                                    <span class="phone-picker-code">@c.PhoneCode</span>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                            <input type="tel" class="form-control" placeholder="9XXXXXXXX" @bind="_cellPhone" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="email" class="form-control @(_emailMismatch ? "is-invalid" : "")"
                                   placeholder="name@example.com"
                                   value="@_email" @oninput="OnEmailInput" />
                            <label>Email *</label>
                            <div class="invalid-feedback">Emails do not match.</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="email" class="form-control @(_emailMismatch ? "is-invalid" : "")"
                                   placeholder="Repeat email"
                                   value="@_email2" @oninput="OnEmail2Input" />
                            <label>Confirm Email *</label>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="Address" @bind="_address" />
                            <label>Address</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="City" @bind="_city" />
                            <label>City</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="country-select-wrap">
                            <button type="button" class="country-select-btn"
                                    @onclick="() => { _showCountryModal = true; _countrySearch = string.Empty; }">
                                @if (!string.IsNullOrEmpty(_country))
                                {
                                    var selCt = _countryData.FirstOrDefault(x => x.NameEn == _country);
                                    <img class="country-select-flag"
                                         src="https://flagcdn.com/w40/@((selCt?.Iso2 ?? "").ToLower()).png"
                                         alt="@_country"
                                         onerror="this.style.display='none'" />
                                    <span>@_country</span>
                                }
                                else
                                {
                                    <span class="placeholder-text">— Select Country —</span>
                                }
                                <i class="ri-arrow-down-s-line country-select-chevron"></i>
                            </button>
                            <span class="country-select-label">Country *</span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="Postal Code" @bind="_postalCode" />
                            <label>Postal Code</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <select class="form-select" @bind="_province">
                                <option value="">— State —</option>
                                @foreach (var pr in GetProvinces(_countryIso2))
                                {
                                    <option value="@pr">@pr</option>
                                }
                            </select>
                            <label>State / Province</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />
                <div class="row g-3 align-items-center">
                    <div class="col-lg-7">
                        <p class="mb-0 fw-semibold">Same billing address?</p>
                    </div>
                    <div class="col-lg-5">
                        <div class="d-flex gap-4">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="billingSame"
                                       checked="@_billingSame" @onchange="() => _billingSame = true" />
                                <label class="form-check-label">Yes</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="billingSame"
                                       checked="@(!_billingSame)" @onchange="() => _billingSame = false" />
                                <label class="form-check-label">No</label>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!_billingSame)
                {
                    <div class="row g-3 mt-2">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CopyContactToBilling">
                                Copy from above
                            </button>
                        </div>
                        <div class="col-md-8">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Billing Address" @bind="_billAddress" />
                                <label>Billing Address</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="City" @bind="_billCity" />
                                <label>City</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="country-select-wrap">
                                <button type="button" class="country-select-btn"
                                        @onclick="() => { _showBillCountryModal = true; _billCountrySearch = string.Empty; }">
                                    @if (!string.IsNullOrEmpty(_billCountry))
                                    {
                                        var selBillCt = _countryData.FirstOrDefault(x => x.NameEn == _billCountry);
                                        <img class="country-select-flag"
                                             src="https://flagcdn.com/w40/@((selBillCt?.Iso2 ?? "").ToLower()).png"
                                             alt="@_billCountry"
                                             onerror="this.style.display='none'" />
                                        <span>@_billCountry</span>
                                    }
                                    else
                                    {
                                        <span class="placeholder-text">— Country —</span>
                                    }
                                    <i class="ri-arrow-down-s-line country-select-chevron"></i>
                                </button>
                                <span class="country-select-label">Country</span>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Postal Code" @bind="_billPostal" />
                                <label>Postal Code</label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating">
                                <select class="form-select" @bind="_billProvince">
                                    <option value="">— State —</option>
                                    @foreach (var pr in GetProvinces(_billCountryIso2))
                                    {
                                        <option value="@pr">@pr</option>
                                    }
                                </select>
                                <label>State</label>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ── WEBSITE NAME & PASSWORD ────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-global-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Your Website & Password</h5>
                    <small class="text-muted">Choose a unique website name and secure password.</small>
                </div>
            </div>
            <div class="section-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label text-secondary small">Website URL</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">mlmconqueror.com/</span>
                            <input type="text" class="form-control" placeholder="yourname"
                                   maxlength="30" autocomplete="off"
                                   value="@_siteHandle" @oninput="OnHandleInput" />
                        </div>
                        <div class="d-flex gap-3 mt-1 align-items-center">
                            <small class="text-muted">Letters and numbers only.</small>
                            <small class="fw-semibold @_slugStatusClass">@_slugStatusMsg</small>
                        </div>
                    </div>
                </div>
                <hr class="my-4" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Password *</label>
                        <div class="input-group">
                            <input type="@(_showPwd ? "text" : "password")" class="form-control"
                                   placeholder="Create a password"
                                   value="@_password" @oninput="OnPasswordInput" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => _showPwd = !_showPwd">
                                <i class="@(_showPwd ? "ri-eye-off-line" : "ri-eye-line")"></i>
                            </button>
                        </div>
                        <div class="mt-2">
                            <div class="progress" style="height:6px">
                                <div class="progress-bar @PwdStrengthClass" style="width:@(PwdStrengthPct)%"></div>
                            </div>
                            <small class="text-muted">Strength: @PwdStrengthLabel</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Confirm Password *</label>
                        <div class="input-group">
                            <input type="@(_showPwd2 ? "text" : "password")"
                                   class="form-control @(PasswordMismatch ? "is-invalid" : "")"
                                   placeholder="Repeat password"
                                   value="@_password2" @oninput="OnPassword2Input" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => _showPwd2 = !_showPwd2">
                                <i class="@(_showPwd2 ? "ri-eye-off-line" : "ri-eye-line")"></i>
                            </button>
                            <div class="invalid-feedback">Passwords do not match.</div>
                        </div>
                        <div class="d-flex gap-2 mt-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GeneratePassword">
                                Generate
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CopyPassword">
                                @_copyBtnText
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── PAYMENT INFO ───────────────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-bank-card-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Payment Info</h5>
                    <small class="text-muted">Choose how you'd like to pay.</small>
                </div>
            </div>
            <div class="section-body">

                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Coupon Code</label>
