    private async Task ReloadProductsAsync()
    {
        _productsLoading = true;
        _productsLoaded  = false;
        StateHasChanged();
        try
        {
            var api = HttpFactory.CreateClient("SignupsInternal");
            var url = string.IsNullOrEmpty(_countryIso2)
                ? "api/v1/signups/products"
                : $"api/v1/signups/products?countryIso2={_countryIso2}";
            var r = await api.GetFromJsonAsync<ApiWrapper<List<ProductModel>>>(url);
            if (r?.Success == true && r.Data is not null)
            {
                _enrollmentProduct  = r.Data.FirstOrDefault(p => p.CorporateFee);
                _membershipProducts = r.Data.Where(p => p.JoinPageMembership).ToList();
                if (_membershipProducts.Count > 0 && !_membershipProducts.Any(p => p.Id == _selectedMembershipProductId))
                    _selectedMembershipProductId = _membershipProducts[0].Id;
            }
        }
        catch { }
        finally
        {
            _productsLoading = false;
            _productsLoaded  = true;
        }
    }

