    private void OnHandleInput(ChangeEventArgs e)
    {
        var raw   = e.Value?.ToString() ?? string.Empty;
        var clean = System.Text.RegularExpressions.Regex.Replace(raw.ToLowerInvariant(), "[^a-z0-9]", "");
        _siteHandle = clean;
        _slugTimer?.Dispose();

        if (string.IsNullOrEmpty(clean)) { _slugStatusMsg = string.Empty; return; }

        _slugStatusMsg   = "Checking…";
        _slugStatusClass = string.Empty;

        _slugTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                try
                {
                    var api  = HttpFactory.CreateClient("SignupsInternal");
                    var resp = await api.PostAsJsonAsync("api/v1/signups/validate-replicate-site",
                        new { ReplicateSiteSlug = clean });
                    var b = await resp.Content.ReadFromJsonAsync<ApiWrapper<bool>>();
                    if (b?.Success == true)
                    { _slugStatusMsg = "✓ Available"; _slugStatusClass = "slug-ok"; }
                    else
                    { _slugStatusMsg = "Unavailable — try another"; _slugStatusClass = "slug-err"; }
                }
                catch { _slugStatusMsg = "Could not verify"; _slugStatusClass = "text-warning"; }
                StateHasChanged();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

