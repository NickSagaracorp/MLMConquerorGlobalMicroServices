@code {
    [Parameter] public string? SponsorSlug { get; set; }

    // ── Page state ────────────────────────────────────────────────────────────
    private bool    _busy;
    private string  _error         = string.Empty;
    private bool    _success;
    private string? _completedEmail;
    private string? _signupId;

    // ── API data ──────────────────────────────────────────────────────────────
    private SponsorModel?      _sponsor;
    private ProductModel?      _enrollmentProduct;
    private List<ProductModel> _membershipProducts           = new();
    private string?            _selectedMembershipProductId  = string.Empty;

    // ── Personal info ─────────────────────────────────────────────────────────
    private string   _firstName   = string.Empty;
    private string   _lastName    = string.Empty;
    private DateTime _dateOfBirth = DateTime.Today.AddYears(-25);
    private string   _ssn         = string.Empty;
    private bool     _showBusiness;
    private string   _businessName = string.Empty;
    private string   _ein          = string.Empty;
    private string   _maxDob       = DateTime.Today.AddYears(-18).ToString("yyyy-MM-dd");

    // ── Contact info ──────────────────────────────────────────────────────────
    private string _waCountryCode   = "+1";
    private string _whatsApp        = string.Empty;
    private string _cellCountryCode = "+1";
    private string _cellPhone       = string.Empty;
    private string _email           = string.Empty;
    private string _email2          = string.Empty;
    private bool   _emailMismatch;
    private string _address   = string.Empty;
    private string _city      = string.Empty;
    private string _country   = string.Empty;
    private string _postalCode = string.Empty;
    private string _province   = string.Empty;
    private bool   _billingSame   = true;
    private string _billAddress   = string.Empty;
    private string _billCity      = string.Empty;
    private string _billCountry   = string.Empty;
    private string _billPostal    = string.Empty;
    private string _billProvince  = string.Empty;

    // ── Website & password ────────────────────────────────────────────────────
    private string  _siteHandle      = string.Empty;
    private string  _slugStatusClass = string.Empty;
    private string  _slugStatusMsg   = string.Empty;
    private System.Threading.Timer? _slugTimer;
    private string  _password   = string.Empty;
    private string  _password2  = string.Empty;
    private bool    _showPwd;
    private bool    _showPwd2;
    private string  _copyBtnText = "Copy";

    // ── Payment ───────────────────────────────────────────────────────────────
    private string _paymentTab    = "card";
    private string _couponCode    = string.Empty;
    private string _couponMsg     = string.Empty;
    private string _couponMsgClass = string.Empty;
    private string _ccFirst   = string.Empty;
    private string _ccLast    = string.Empty;
    private string _ccNumber  = string.Empty;
    private string _ccCvv     = string.Empty;
    private int    _ccExpMonth;
    private int    _ccExpYear;
    private bool   _showCcNum;
    private bool   _showCcv;
    private string _payToken  = string.Empty;
    private bool   _agreedTerms;

    // ── Country data (loaded from API) ───────────────────────────────────────
    private List<CountryLookupDto> _countryData = new();
    private string _countryIso2     = string.Empty;
    private string _billCountryIso2 = string.Empty;

    // ── Phone pickers ────────────────────────────────────────────────────────
    private bool   _showWaPicker      = false;
    private string _waPickerSearch    = string.Empty;
    private bool   _showCellPicker    = false;
    private string _cellPickerSearch  = string.Empty;

    // ── Country modal ────────────────────────────────────────────────────────
    private bool   _showCountryModal  = true;  // shown immediately on load
    private string _countrySearch     = string.Empty;

    // ── Billing country modal ─────────────────────────────────────────────────
    private bool   _showBillCountryModal = false;
    private string _billCountrySearch    = string.Empty;
    private bool   _productsLoading   = false;
    private bool   _productsLoaded    = false;
    private bool   _showNoMemberModal = false;
    private bool   _skipMembershipValidation = false;

    // ── Computed ──────────────────────────────────────────────────────────────
    private string SponsorInitials
    {
        get
        {
            var name = _sponsor?.DisplayName ?? SponsorSlug ?? "?";
            var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 2)
                return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
            return name.Length >= 2 ? name[..2].ToUpperInvariant() : name.ToUpperInvariant();
        }
    }

    private bool PasswordMismatch =>
        !string.IsNullOrEmpty(_password2) && _password != _password2;

    private int PwdStrengthPct
    {
        get
        {
            if (string.IsNullOrEmpty(_password)) return 0;
            int s = 0;
            if (_password.Length >= 8)  s += 25;
            if (_password.Length >= 12) s += 10;
            if (System.Text.RegularExpressions.Regex.IsMatch(_password, "[a-z]")) s += 15;
            if (System.Text.RegularExpressions.Regex.IsMatch(_password, "[A-Z]")) s += 15;
            if (System.Text.RegularExpressions.Regex.IsMatch(_password, "[0-9]")) s += 15;
            if (System.Text.RegularExpressions.Regex.IsMatch(_password, "[^A-Za-z0-9]")) s += 15;
            return Math.Min(100, s);
        }
    }

    private string PwdStrengthClass => PwdStrengthPct < 30 ? "bg-danger"
                                     : PwdStrengthPct < 60 ? "bg-warning"
                                     : PwdStrengthPct < 80 ? "bg-info"
                                     :                        "bg-success";

    private string PwdStrengthLabel => PwdStrengthPct < 30 ? "Weak"
                                     : PwdStrengthPct < 60 ? "Fair"
                                     : PwdStrengthPct < 80 ? "Good"
                                     :                        "Strong";

    private decimal AmountToday
    {
        get
        {
            decimal total = _enrollmentProduct?.Price ?? 0m;
            var m = _membershipProducts.FirstOrDefault(p => p.Id == _selectedMembershipProductId);
            if (m is not null) total += m.Price;
            return total;
        }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var api = HttpFactory.CreateClient("SignupsInternal");

        // Load countries first (needed to populate dropdowns)
        try
        {
            var cr = await api.GetFromJsonAsync<ApiWrapper<List<CountryLookupDto>>>("api/v1/signups/countries");
            if (cr?.Success == true && cr.Data is not null)
            {
                _countryData = cr.Data;
                // Default phone code to US if available
                var us = _countryData.FirstOrDefault(x => x.Iso2 == "US");
                if (us?.PhoneCode is not null)
                {
                    _waCountryCode   = us.PhoneCode;
                    _cellCountryCode = us.PhoneCode;
                }
            }
        }
        catch { }

        if (!string.IsNullOrWhiteSpace(SponsorSlug))
        {
            try
            {
                var r = await api.PostAsJsonAsync("api/v1/signups/validate-sponsor",
                    new { SponsorMemberId = SponsorSlug });
                if (r.IsSuccessStatusCode)
                {
                    var b = await r.Content.ReadFromJsonAsync<ApiWrapper<SponsorModel>>();
                    if (b?.Success == true) _sponsor = b.Data;
                }
            }
            catch { }
        }
        // Products are NOT loaded here — they load after country selection via OnCountryModalSelect.
    }

    private void OnCountryChange(ChangeEventArgs e)
    {
        var nameEn = e.Value?.ToString() ?? string.Empty;
        _country  = nameEn;
        _province = string.Empty;
        var ct = _countryData.FirstOrDefault(x => x.NameEn == nameEn);
        _countryIso2 = ct?.Iso2 ?? string.Empty;
        // Phone codes are updated but products are not reloaded from the dropdown —
        // product reloading is triggered exclusively from the country modal.
        if (ct?.PhoneCode is not null)
        {
            _waCountryCode   = ct.PhoneCode;
            _cellCountryCode = ct.PhoneCode;
        }
    }

