        if (n.StartsWith("4"))          return "Visa";
        if (n.Length > 1 && (n[0] == '5' || n[0] == '2')) return "MC";
        if (n.StartsWith("34") || n.StartsWith("37")) return "Amex";
        if (n.StartsWith("6"))          return "Disc";
        return "•••";
    }

