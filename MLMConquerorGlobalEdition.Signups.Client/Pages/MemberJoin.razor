@page "/member-join"
@page "/member-join/{SponsorSlug}"
@rendermode InteractiveAuto
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="theme-member">

<!-- ── HEADER ─────────────────────────────────────────────────────────────── -->
<header class="enroll-header py-2 px-3">
    <div class="container d-flex align-items-center justify-content-between flex-wrap gap-2">
        <span class="brand-name">MLM Conqueror</span>
        <div class="d-flex align-items-center gap-1 secure-badge">
            <span>Secure Enrollment</span>
            <i class="ri-lock-2-line fs-5"></i>
        </div>
    </div>
</header>

<!-- ── SPONSOR CARD ────────────────────────────────────────────────────────── -->
@if (_sponsor is not null || !string.IsNullOrEmpty(SponsorSlug))
{
    <div class="sponsor-card px-3">
        <div class="sponsor-avatar">
            @if (!string.IsNullOrEmpty(_sponsor?.PhotoUrl))
            {
                <img src="@_sponsor.PhotoUrl" alt="@_sponsor.DisplayName" />
            }
            else
            {
                @SponsorInitials
            }
        </div>
        <div class="sponsor-info">
            <p class="sponsor-label">Invited by</p>
            <p class="sponsor-name">@(_sponsor?.DisplayName ?? SponsorSlug)</p>
            @if (!string.IsNullOrEmpty(_sponsor?.ReplicateSiteSlug))
            {
                <p class="sponsor-slug">mlmconqueror.com/@_sponsor.ReplicateSiteSlug</p>
            }
        </div>
        <span class="sponsor-badge"><i class="ri-shield-check-line"></i> Verified</span>
    </div>
}

<!-- ── MAIN LAYOUT ─────────────────────────────────────────────────────────── -->
<div class="signup-layout">

    <!-- LEFT: form sections -->
    <div class="signup-form-col">

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger mb-4">@_error</div>
        }

        @if (_success)
        {
            <div class="section-card">
                <div class="section-body text-center py-5">
                    <i class="ri-checkbox-circle-fill success-check"></i>
                    <h3 class="mt-3 mb-2">Welcome, @_completedEmail!</h3>
                    <p class="text-muted mb-4">Your membership is active. Enjoy your exclusive benefits.</p>
                    <a href="/login" class="btn btn-enroll px-5">Access My Account</a>
                </div>
            </div>
        }
        else
        {

        <!-- ── SELECT MEMBERSHIP ──────────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-vip-crown-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Select your membership</h5>
                    <small class="text-muted">Choose the plan that matches your travel lifestyle.</small>
                </div>
            </div>
            <div class="section-body">
                @if (_membershipProducts.Count == 0)
                {
                    <p class="text-muted small py-2">Loading options…</p>
                }
                @foreach (var p in _membershipProducts)
                {
                    <label class="plan-card @(_selectedMembershipProductId == p.Id ? "is-checked" : "")"
                           @onclick="() => SelectMembership(p.Id)">
                        <input type="radio" class="plan-card__radio" name="membership"
                               checked="@(_selectedMembershipProductId == p.Id)"
                               @onchange="() => SelectMembership(p.Id)" />
                        <div class="plan-card__body @(p.ThemeClass)">
                            <div class="plan-card__header">
                                <div class="flex-1">
                                    <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                        <p class="plan-card__title mb-0">@p.Name</p>
                                        <span class="plan-selected-chip"><i class="ri-check-fill"></i> Selected</span>
                                    </div>
                                    <p class="plan-card__subtitle">@p.Price.ToString("C") / month</p>
                                </div>
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.Name"
                                         class="plan-card__img" onerror="this.style.display='none'" />
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <div class="plan-card__desc">@((MarkupString)p.Description)</div>
                            }
                            <span class="price-chip">@p.Price.ToString("C")</span>
                        </div>
                    </label>
                }
            </div>
        </div>

        <!-- ── PERSONAL INFO ──────────────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-user-3-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Personal Information</h5>
                    <small class="text-muted">Your details stay private and secure.</small>
                </div>
            </div>
            <div class="section-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="First Name"
                                   value="@_firstName" @oninput="e => _firstName = e.Value?.ToString() ?? string.Empty" />
                            <label>First Name *</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="Last Name"
                                   value="@_lastName" @oninput="e => _lastName = e.Value?.ToString() ?? string.Empty" />
                            <label>Last Name *</label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── CONTACT INFO ───────────────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-contacts-book-2-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Contact Info</h5>
                    <small class="text-muted">Use a valid email and phone number.</small>
                </div>
            </div>
            <div class="section-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">WhatsApp</label>
                        <div class="input-group country-line">
                            <select class="form-select country-code" @bind="_waCountryCode">
                                @foreach (var c in _countryCodes)
                                {
                                    <option value="@c.Code">@c.Flag @c.Code</option>
                                }
                            </select>
                            <input type="tel" class="form-control" placeholder="9XXXXXXXX" @bind="_whatsApp" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Cell Phone</label>
                        <div class="input-group country-line">
                            <select class="form-select country-code" @bind="_cellCountryCode">
                                @foreach (var c in _countryCodes)
                                {
                                    <option value="@c.Code">@c.Flag @c.Code</option>
                                }
                            </select>
                            <input type="tel" class="form-control" placeholder="9XXXXXXXX" @bind="_cellPhone" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="email" class="form-control @(_emailMismatch ? "is-invalid" : "")"
                                   placeholder="name@example.com"
                                   value="@_email" @oninput="OnEmailInput" />
                            <label>Email *</label>
                            <div class="invalid-feedback">Emails do not match.</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input type="email" class="form-control @(_emailMismatch ? "is-invalid" : "")"
                                   placeholder="Repeat email"
                                   value="@_email2" @oninput="OnEmail2Input" />
                            <label>Confirm Email *</label>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="Address" @bind="_address" />
                            <label>Address</label>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="City" @bind="_city" />
                            <label>City</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <select class="form-select"
                                    value="@_country"
                                    @onchange="e => { _country = e.Value?.ToString() ?? string.Empty; _province = string.Empty; }">
                                <option value="">— Select Country —</option>
                                @foreach (var ct in _countryList)
                                {
                                    <option value="@ct.Code">@ct.Name</option>
                                }
                            </select>
                            <label>Country *</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <input type="text" class="form-control" placeholder="Postal Code" @bind="_postalCode" />
                            <label>Postal Code</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <select class="form-select" @bind="_province">
                                <option value="">— State —</option>
                                @foreach (var pr in GetProvinces(_country))
                                {
                                    <option value="@pr">@pr</option>
                                }
                            </select>
                            <label>State / Province</label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />
                <div class="row g-3 align-items-center">
                    <div class="col-lg-7">
                        <p class="mb-0 fw-semibold">Same billing address?</p>
                    </div>
                    <div class="col-lg-5">
                        <div class="d-flex gap-4">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="billingSame"
                                       checked="@_billingSame" @onchange="() => _billingSame = true" />
                                <label class="form-check-label">Yes</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="billingSame"
                                       checked="@(!_billingSame)" @onchange="() => _billingSame = false" />
                                <label class="form-check-label">No</label>
                            </div>
                        </div>
                    </div>
                </div>

                @if (!_billingSame)
                {
                    <div class="row g-3 mt-2">
                        <div class="col-12 text-end">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CopyContactToBilling">
                                Copy from above
                            </button>
                        </div>
                        <div class="col-md-8">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Billing Address" @bind="_billAddress" />
                                <label>Billing Address</label>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="City" @bind="_billCity" />
                                <label>City</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <select class="form-select" @bind="_billCountry">
                                    <option value="">— Country —</option>
                                    @foreach (var ct in _countryList)
                                    {
                                        <option value="@ct.Code">@ct.Name</option>
                                    }
                                </select>
                                <label>Country</label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Postal Code" @bind="_billPostal" />
                                <label>Postal Code</label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-floating">
                                <select class="form-select" @bind="_billProvince">
                                    <option value="">— State —</option>
                                    @foreach (var pr in GetProvinces(_billCountry))
                                    {
                                        <option value="@pr">@pr</option>
                                    }
                                </select>
                                <label>State</label>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- ── PASSWORD ───────────────────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-lock-password-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Create your Password</h5>
                    <small class="text-muted">Choose a strong, secure password.</small>
                </div>
            </div>
            <div class="section-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Password *</label>
                        <div class="input-group">
                            <input type="@(_showPwd ? "text" : "password")" class="form-control"
                                   placeholder="Create a password"
                                   value="@_password" @oninput="OnPasswordInput" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => _showPwd = !_showPwd">
                                <i class="@(_showPwd ? "ri-eye-off-line" : "ri-eye-line")"></i>
                            </button>
                        </div>
                        <div class="mt-2">
                            <div class="progress" style="height:6px">
                                <div class="progress-bar @PwdStrengthClass" style="width:@(PwdStrengthPct)%"></div>
                            </div>
                            <small class="text-muted">Strength: @PwdStrengthLabel</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Confirm Password *</label>
                        <div class="input-group">
                            <input type="@(_showPwd2 ? "text" : "password")"
                                   class="form-control @(PasswordMismatch ? "is-invalid" : "")"
                                   placeholder="Repeat password"
                                   value="@_password2" @oninput="OnPassword2Input" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="() => _showPwd2 = !_showPwd2">
                                <i class="@(_showPwd2 ? "ri-eye-off-line" : "ri-eye-line")"></i>
                            </button>
                            <div class="invalid-feedback">Passwords do not match.</div>
                        </div>
                        <div class="d-flex gap-2 mt-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="GeneratePassword">
                                Generate
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CopyPassword">
                                @_copyBtnText
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── PAYMENT INFO ───────────────────────────────────────────────── -->
        <div class="section-card">
            <div class="section-head">
                <div class="section-icon"><i class="ri-bank-card-line"></i></div>
                <div>
                    <h5 class="mb-0 fw-bold">Payment Info</h5>
                    <small class="text-muted">Choose how you'd like to pay.</small>
                </div>
            </div>
            <div class="section-body">

                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small">Coupon Code</label>
                        <input type="text" class="form-control" placeholder="Enter code" @bind="_couponCode" />
                    </div>
                    <div class="col-md-3">
                        <button type="button" class="btn btn-outline-secondary w-100" @onclick="ApplyCoupon">Apply</button>
                    </div>
                    <div class="col-md-3">
                        <small class="@_couponMsgClass">@_couponMsg</small>
                    </div>
                </div>

                <ul class="nav nav-pills pay-tabs mb-3">
                    <li class="nav-item">
                        <button class="nav-link @(_paymentTab == "card" ? "active" : "")" type="button"
                                @onclick='() => _paymentTab = "card"'>
                            <i class="ri-bank-card-2-line me-1"></i>Credit Card
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_paymentTab == "token" ? "active" : "")" type="button"
                                @onclick='() => _paymentTab = "token"'>
                            <i class="ri-key-line me-1"></i>Token
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(_paymentTab == "crypto" ? "active" : "")" type="button"
                                @onclick='() => _paymentTab = "crypto"'>
                            <i class="ri-bit-coin-line me-1"></i>Crypto
                        </button>
                    </li>
                </ul>

                @if (_paymentTab == "card")
                {
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="First Name" @bind="_ccFirst" />
                                <label>First Name on Card</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="Last Name" @bind="_ccLast" />
                                <label>Last Name on Card</label>
                            </div>
                        </div>
                        <div class="col-lg-8">
                            <label class="form-label text-secondary small">Card Number</label>
                            <div class="input-group">
                                <input type="@(_showCcNum ? "text" : "password")" class="form-control"
                                       inputmode="numeric" placeholder="1234 5678 9012 3456"
                                       value="@_ccNumber" @oninput="e => _ccNumber = e.Value?.ToString() ?? string.Empty" />
                                <span class="input-group-text bg-light">@DetectCardBrand()</span>
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => _showCcNum = !_showCcNum">
                                    <i class="@(_showCcNum ? "ri-eye-off-line" : "ri-eye-line")"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <label class="form-label text-secondary small">CVV</label>
                            <div class="input-group">
                                <input type="@(_showCcv ? "text" : "password")" class="form-control"
                                       inputmode="numeric" placeholder="123" @bind="_ccCvv" />
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => _showCcv = !_showCcv">
                                    <i class="@(_showCcv ? "ri-eye-off-line" : "ri-eye-line")"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-secondary small">Expiration</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <select class="form-select" @bind="_ccExpMonth">
                                        <option value="0">Month</option>
                                        @for (int m = 1; m <= 12; m++)
                                        {
                                            var mo = m;
                                            <option value="@mo">@mo.ToString("D2")</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <select class="form-select" @bind="_ccExpYear">
                                        <option value="0">Year</option>
                                        @for (int y = DateTime.Now.Year; y <= DateTime.Now.Year + 12; y++)
                                        {
                                            var yr = y;
                                            <option value="@yr">@yr</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (_paymentTab == "token")
                {
                    <p class="text-muted small mb-2">Enter the token provided by your ambassador. Tokens are non-refundable.</p>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" class="form-control" placeholder="TOKEN-XXXX" @bind="_payToken" />
                                <label>Token Code</label>
                            </div>
                        </div>
                    </div>
                }

                @if (_paymentTab == "crypto")
                {
                    <div class="text-center py-4 text-muted">
                        <i class="ri-bit-coin-line" style="font-size:3rem;opacity:.5"></i>
                        <p class="mt-2 mb-0 small">You'll be redirected to our crypto gateway after clicking Join Now.</p>
                    </div>
                }

                <hr class="my-4" />

                <div class="captcha-placeholder d-flex align-items-center gap-2 mb-3">
                    <i class="ri-shield-check-line"></i>
                    <span>reCAPTCHA verification (to be configured)</span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="agreeTermsMember" @bind="_agreedTerms" />
                    <label class="form-check-label small" for="agreeTermsMember">
                        I have read and agree to the
                        <a href="#" target="_blank" rel="noopener">Member Agreement</a>,
                        <a href="#" target="_blank" rel="noopener">Privacy Policy</a>, and
                        <a href="#" target="_blank" rel="noopener">Terms of Service</a>.
                    </label>
                </div>

                <div class="d-grid">
                    <button type="button" class="btn btn-enroll"
                            disabled="@(!_agreedTerms || _busy)"
                            @onclick="HandleJoinNow">
                        @if (_busy)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Join Now — @AmountToday.ToString("C")
                    </button>
                </div>

                <p class="text-center mt-3 mb-0">
                    <small class="text-muted"><i class="ri-lock-2-line me-1"></i>256-bit encrypted · Secure checkout</small>
                </p>
            </div>
        </div>

        } <!-- end !_success -->
    </div>

    <!-- RIGHT: sticky pricing sidebar -->
    <div class="signup-sidebar-col">
        <div class="pricing-sidebar">
            <div class="pricing-sidebar__head">
                <i class="ri-receipt-line"></i>
                Order Summary
            </div>
            <div class="pricing-sidebar__body">
                @{
                    var selectedProduct = _membershipProducts.FirstOrDefault(p => p.Id == _selectedMembershipProductId);
                }
                @if (selectedProduct is not null)
                {
                    <div class="pricing-sidebar__line">
                        <span class="label">@selectedProduct.Name</span>
                        <span class="amount">@selectedProduct.Price.ToString("C")</span>
                    </div>
                    <div class="pricing-sidebar__line">
                        <span class="label">Monthly recurring</span>
                        <span class="amount">@selectedProduct.Price.ToString("C")/mo</span>
                    </div>
                }
                else
                {
                    <div class="pricing-sidebar__line">
                        <span class="label text-muted">No membership selected</span>
                        <span class="amount">—</span>
                    </div>
                }

                <div class="pricing-sidebar__total">
                    <span>Due today</span>
                    <span class="total-amount">@AmountToday.ToString("C")</span>
                </div>
                <p class="pricing-sidebar__note">
                    Secure, encrypted checkout.<br />
                    Cancel anytime after initial period.
                </p>
            </div>
        </div>
    </div>

</div><!-- /.signup-layout -->

<!-- ── FOOTER ─────────────────────────────────────────────────────────────── -->
<footer class="join-footer">
    <div class="join-footer__grid">
        <div>
            <span class="d-block fw-bold text-white fs-5 mb-3">MLM Conqueror</span>
            <p style="font-size:.75rem;letter-spacing:.06em;color:var(--footer-dim);margin:0 0 8px">FOLLOW US</p>
            <div class="join-footer__social">
                <a href="#" aria-label="Facebook"><i class="ri-facebook-fill"></i></a>
                <a href="#" aria-label="Instagram"><i class="ri-instagram-line"></i></a>
                <a href="#" aria-label="YouTube"><i class="ri-youtube-fill"></i></a>
                <a href="#" aria-label="Twitter/X"><i class="ri-twitter-x-fill"></i></a>
                <a href="#" aria-label="LinkedIn"><i class="ri-linkedin-fill"></i></a>
            </div>
        </div>
        <div>
            <h6><i class="ri-map-pin-2-fill"></i> Hong Kong</h6>
            <address>Suite C, Level 7, World Trust Tower<br />50 Stanley Street, Central</address>
            <h6 class="mt-3"><i class="ri-map-pin-2-fill"></i> United States</h6>
            <address>300 SE 2nd Street, Suite 600<br />Fort Lauderdale, FL 33301</address>
        </div>
        <div>
            <h6><i class="ri-map-pin-2-fill"></i> Dubai</h6>
            <address>2001-36 Prime Tower, 20th Floor<br />Burj Khalifa Street, Business Bay</address>
            <h6 class="mt-3"><i class="ri-map-pin-2-fill"></i> United Kingdom</h6>
            <address>637 Oxford Road<br />Reading, Berkshire RG30 1HP</address>
        </div>
        <div>
            <h6><i class="ri-map-pin-2-fill"></i> France</h6>
            <address>46 bis Av. du Maine<br />Paris, 75015</address>
