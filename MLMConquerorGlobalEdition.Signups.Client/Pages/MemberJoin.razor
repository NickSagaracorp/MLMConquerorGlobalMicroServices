    private void GeneratePassword()
    {
        const string pool = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*_+";
        var rng   = new Random();
        var chars = new char[14];
        chars[0] = "abcdefghijklmnopqrstuvwxyz"[rng.Next(26)];
        chars[1] = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"[rng.Next(26)];
        chars[2] = "0123456789"[rng.Next(10)];
        chars[3] = "!@#$%^&*_+"[rng.Next(10)];
        for (int i = 4; i < 14; i++) chars[i] = pool[rng.Next(pool.Length)];
        var pwd   = new string(chars.OrderBy(_ => rng.Next()).ToArray());
        _password  = pwd;
        _password2 = pwd;
    }

