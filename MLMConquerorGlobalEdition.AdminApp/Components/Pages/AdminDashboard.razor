@page "/admin"
@attribute [Authorize(Roles = "SuperAdmin,Admin,CommissionManager,BillingManager,SupportManager,SupportLevel1,SupportLevel2,SupportLevel3,IT")]
@inject AdminApiClient Api
@inject IViewContextService ViewContext

<div class="container-fluid py-4">
    <h4 class="mb-4">Admin Dashboard</h4>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <StatCard Title="Total Members" Value="@_stats.TotalMembers.ToString()" Icon="ri-team-line" Color="primary" />
            </div>
            <div class="col-md-3">
                <StatCard Title="Active Ambassadors" Value="@_stats.ActiveAmbassadors.ToString()" Icon="ri-user-star-line" Color="success" />
            </div>
            <div class="col-md-3">
                <StatCard Title="Pending Commissions" Value="@_stats.PendingCommissions.ToString("C")" Icon="ri-money-dollar-circle-line" Color="warning" />
            </div>
            <div class="col-md-3">
                <StatCard Title="Open Tickets" Value="@_stats.OpenTickets.ToString()" Icon="ri-ticket-line" Color="danger" />
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">Recent Activity</div>
                    <div class="card-body">
                        <p class="text-muted">Activity feed will be wired to API.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">Quick Links</div>
                    <div class="card-body d-grid gap-2">
                        <a href="/admin/members" class="btn btn-outline-primary btn-sm">Browse Members</a>
                        <a href="/admin/commissions" class="btn btn-outline-warning btn-sm">Commission Management</a>
                        <a href="/admin/tickets" class="btn btn-outline-danger btn-sm">Support Tickets</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private AdminStats _stats = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(50); // placeholder for API call
        _stats = new AdminStats { TotalMembers = 142, ActiveAmbassadors = 87, PendingCommissions = 15340.50m, OpenTickets = 23 };
        _loading = false;
    }

    private record AdminStats
    {
        public int TotalMembers { get; init; }
        public int ActiveAmbassadors { get; init; }
        public decimal PendingCommissions { get; init; }
        public int OpenTickets { get; init; }
    }
}
