{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=MLMConquerorGlobalEditionDb;integrated security=true;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=True;",
    "HangFire": "Server=.;Database=MLMConquerorGlobalEditionDb;integrated security=true;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=True;",
    "Redis": "localhost:6379"
  },
  "Hangfire": {
    "WorkerCount": 5
  },
  "Firebase": {
    "CredentialsFilePath": "",
    "ProjectId": "REPLACE_WITH_FIREBASE_PROJECT_ID"
  },
  "RootAmbassador": {
    "Email": "REPLACE_WITH_ENV_VAR_ROOT_AMBASSADOR_EMAIL",
    "FirstName": "Corporate",
    "LastName": "Root",
    "Password": "REPLACE_WITH_ENV_VAR_ROOT_AMBASSADOR_PASSWORD"
  },
  "Jwt": {
    "PrivateKeyBase64": "REPLACE_WITH_ENV_VAR_RSA_PRIVATE_KEY",
    "PublicKeyBase64":  "REPLACE_WITH_ENV_VAR_RSA_PUBLIC_KEY",
    "Issuer": "MLMConquerorGlobalEdition",
    "Audience": "MLMConquerorGlobalEdition.Clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:7002", "https://localhost:7004" ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "POST:/api/v1/auth/login",          "Period": "1m", "Limit": 5  },
      { "Endpoint": "POST:/api/v1/auth/refresh-token",  "Period": "1m", "Limit": 10 },
      { "Endpoint": "POST:/api/v1/auth/forgot-password","Period": "1h", "Limit": 3  },
      { "Endpoint": "*:/api/v1/signups/ambassador",     "Period": "1m", "Limit": 5  },
      { "Endpoint": "*:/api/v1/signups/member",         "Period": "1m", "Limit": 5  },
      { "Endpoint": "*",                                "Period": "1m", "Limit": 60 }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost"
}
