{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=MLMConquerorGlobalEditionDb;integrated security=true;TrustServerCertificate=True;MultipleActiveResultSets=true;Encrypt=True;",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "PrivateKeyBase64": "REPLACE_WITH_ENV_VAR_RSA_PRIVATE_KEY",
    "PublicKeyBase64":  "REPLACE_WITH_ENV_VAR_RSA_PUBLIC_KEY",
    "Issuer": "MLMConquerorGlobalEdition",
    "Audience": "MLMConquerorGlobalEditionClients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:7001", "https://localhost:7003" ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "POST:/api/v1/auth/login",          "Period": "1m", "Limit": 5  },
      { "Endpoint": "POST:/api/v1/auth/refresh-token",  "Period": "1m", "Limit": 10 },
      { "Endpoint": "POST:/api/v1/auth/forgot-password","Period": "1h", "Limit": 3  },
      { "Endpoint": "*",                                 "Period": "1s", "Limit": 20 }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost",
  "Services": {
    "BizCenter":              "https://localhost:7102",
    "CommissionEngine":       "https://localhost:60560",
    "RankEngine":             "https://localhost:49184",
    "SignupAPI":              "https://localhost:7147",
    "TicketManagementSystem": "https://localhost:7046",
    "Billing":                "https://localhost:7049",
    "SharedAPICenter":        "https://localhost:7170"
  }
}
